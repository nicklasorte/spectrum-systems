{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/governance/repo-compliance.schema.json",
  "title": "Repository Compliance Checklist",
  "description": "Governance checklist for repositories to assert conformance with spectrum-systems standards.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repo_name",
    "repo_url",
    "schema_version",
    "status",
    "last_reviewed",
    "controls"
  ],
  "properties": {
    "repo_name": {
      "type": "string",
      "description": "Repository slug or descriptive name."
    },
    "repo_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the repository being evaluated."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the repo compliance schema."
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "in_progress"
      ],
      "description": "Current compliance status for this repository."
    },
    "last_reviewed": {
      "type": "string",
      "format": "date",
      "description": "Date when compliance was last reviewed."
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/control"
      },
      "description": "List of governance controls evaluated for this repository."
    }
  },
  "$defs": {
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable control identifier."
        },
        "description": {
          "type": "string",
          "description": "What the control verifies."
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not_applicable",
            "needs_review"
          ],
          "description": "Evaluation status for this control."
        },
        "evidence": {
          "type": "string",
          "description": "Reference to evidence, run manifest, or link documenting the control."
        }
      }
    }
  }
}
