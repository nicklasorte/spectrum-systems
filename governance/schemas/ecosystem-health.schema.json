{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ecosystem-health.schema.json",
  "title": "Ecosystem Health Report",
  "description": "Machine-readable ecosystem health report produced by generate_ecosystem_health_report.py.",
  "type": "object",
  "required": ["schema_version", "generated_at", "summary", "repos"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version for this report format."
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp when the report was generated."
    },
    "summary": {
      "type": "object",
      "required": [
        "overall_health",
        "total_repos",
        "governance_compliance",
        "contract_alignment",
        "schema_integrity",
        "ci_enforcement",
        "repos_missing_required_artifacts",
        "repos_not_yet_enforceable"
      ],
      "additionalProperties": false,
      "properties": {
        "overall_health": {
          "type": "string",
          "enum": ["healthy", "warning", "failing"]
        },
        "total_repos": {"type": "integer", "minimum": 0},
        "governance_compliance": {"type": "object", "additionalProperties": {"type": "integer"}},
        "contract_alignment": {"type": "object", "additionalProperties": {"type": "integer"}},
        "schema_integrity": {"type": "object", "additionalProperties": {"type": "integer"}},
        "ci_enforcement": {"type": "object", "additionalProperties": {"type": "integer"}},
        "repos_missing_required_artifacts": {
          "type": "array",
          "items": {"type": "string"}
        },
        "repos_not_yet_enforceable": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "repo_name",
          "repo_type",
          "architecture_layer",
          "governance_status",
          "contract_status",
          "schema_status",
          "ci_status",
          "maturity_score",
          "maturity_level"
        ],
        "additionalProperties": true,
        "properties": {
          "repo_name": {"type": "string"},
          "system_id": {"type": "string"},
          "repo_type": {"type": "string"},
          "architecture_layer": {"type": "string"},
          "status": {"type": "string"},
          "governance_status": {"type": "string"},
          "contract_status": {"type": "string"},
          "schema_status": {"type": "string"},
          "ci_status": {"type": "string"},
          "maturity_score": {
            "type": "object",
            "required": ["raw", "max", "categories"],
            "properties": {
              "raw": {"type": "integer", "minimum": 0},
              "max": {"type": "integer", "minimum": 0},
              "categories": {
                "type": "object",
                "additionalProperties": {
                  "type": "string",
                  "enum": ["compliant", "partial", "missing"]
                }
              }
            }
          },
          "maturity_level": {"type": "integer", "minimum": 1, "maximum": 10},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
