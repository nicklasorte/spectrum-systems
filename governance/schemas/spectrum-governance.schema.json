{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/governance/spectrum-governance.schema.json",
  "title": "Spectrum Governance Manifest",
  "description": "Required governance manifest (.spectrum-governance.json) for downstream repositories.",
  "type": "object",
  "additionalProperties": false,
  "required": ["system_id", "repo_name", "repo_type", "governance_repo", "governance_version", "contracts"],
  "properties": {
    "system_id": {
      "$ref": "#/$defs/system_slug"
    },
    "repo_name": {
      "$ref": "#/$defs/system_slug"
    },
    "repo_type": {
      "type": "string",
      "enum": ["governance", "factory", "operational_engine", "advisory", "pipeline"],
      "description": "Repository type aligned to the ecosystem registry."
    },
    "governance_repo": {
      "type": "string",
      "const": "spectrum-systems",
      "description": "Canonical governance authority for manifests."
    },
    "governance_version": {
      "$ref": "#/$defs/semver",
      "description": "Pinned governance release version (semver)."
    },
    "contracts": {
      "$ref": "#/$defs/contracts"
    },
    "upstream_systems": {
      "type": "array",
      "items": { "$ref": "#/$defs/system_slug" },
      "uniqueItems": true,
      "description": "Optional list of system_ids that provide inputs to this system."
    },
    "downstream_systems": {
      "type": "array",
      "items": { "$ref": "#/$defs/system_slug" },
      "uniqueItems": true,
      "description": "Optional list of system_ids that consume outputs from this system."
    }
  },
  "$defs": {
    "system_slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "description": "Registered system identifier matching ecosystem registry entries."
    },
    "semver": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][A-Za-z0-9.-]+)?$",
      "description": "Semantic version string."
    },
    "contracts": {
      "type": "object",
      "minProperties": 0,
      "patternProperties": {
        "^[A-Za-z0-9._-]+$": {
          "$ref": "#/$defs/semver"
        }
      },
      "additionalProperties": false,
      "description": "Map of contract names to pinned versions."
    }
  }
}
