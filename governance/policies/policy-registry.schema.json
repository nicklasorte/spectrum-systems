{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Policy Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["policies"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "policy_id",
          "title",
          "description",
          "severity",
          "enabled",
          "scope",
          "input_artifacts",
          "expected_check"
        ],
        "properties": {
          "policy_id": {
            "type": "string",
            "pattern": "^GOV-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["error", "warning"]
          },
          "enabled": {
            "type": "boolean"
          },
          "scope": {
            "type": "string",
            "enum": ["repo", "ecosystem", "contract"]
          },
          "input_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_check": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
