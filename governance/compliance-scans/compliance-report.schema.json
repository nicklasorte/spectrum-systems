{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/governance/compliance-scans/compliance-report.schema.json",
  "title": "Cross-Repository Governance Compliance Report",
  "description": "Machine-readable report emitted by the cross-repo governance compliance scanner.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scan_date",
    "repos"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the compliance report schema."
    },
    "scan_date": {
      "type": "string",
      "format": "date",
      "description": "Date the scan was executed."
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/repoResult"
      },
      "description": "Per-repository compliance results."
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Optional scan-level notes or warnings."
    }
  },
  "$defs": {
    "repoResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_name",
        "repo_path",
        "compliant",
        "missing_requirements",
        "failures",
        "warnings"
      ],
      "properties": {
        "repo_name": {
          "type": "string",
          "description": "Repository name from the scan config."
        },
        "repo_path": {
          "type": "string",
          "description": "Filesystem path inspected for this repository."
        },
        "expected_system_id": {
          "type": "string",
          "description": "Expected system identifier supplied in the scan config."
        },
        "expected_repo_type": {
          "type": "string",
          "description": "Expected repository type supplied in the scan config."
        },
        "compliant": {
          "type": "boolean",
          "description": "Overall compliance result; false if any required element is missing."
        },
        "missing_requirements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of required governance elements not found."
        },
        "failures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failure"
          },
          "description": "Blocking compliance failures with severity and type metadata."
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Non-blocking issues or informational notes."
        }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "type",
        "repo",
        "repo_path"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning"
          ],
          "description": "Severity of the compliance failure."
        },
        "type": {
          "type": "string",
          "description": "Machine-readable failure category."
        },
        "repo": {
          "type": "string",
          "description": "Repository name associated with the failure."
        },
        "repo_path": {
          "type": "string",
          "description": "Filesystem path to the repository being evaluated."
        },
        "detail": {
          "type": "string",
          "description": "Optional detail or error message."
        },
        "expected": {
          "type": "string",
          "description": "Expected value when applicable."
        },
        "actual": {
          "type": "string",
          "description": "Observed value when applicable."
        },
        "contract": {
          "type": "string",
          "description": "Contract identifier tied to the failure when relevant."
        }
      }
    }
  }
}
