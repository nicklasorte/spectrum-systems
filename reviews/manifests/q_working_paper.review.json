  "invariants": [
    "Generated working paper must include executive_summary, purpose_and_scope, technical_analysis, and key_findings sections.",
    "Every key finding must trace back to a source in structured_transcript, slide_signals, or gap_analysis.",
    "The appendix source_traceability array must not be empty when input contains claims.",
    "validate_working_paper must return True for any document produced by generate_working_paper.",
    "Open questions must be generated when action items or risks are present in the transcript."
  ],
  "known_edge_cases": [
    "Transcript with only decisions and no risks produces a paper with empty risks_and_uncertainties (valid).",
    "Slide signals with no claims produce a paper with no slide alignment summary entries.",
    "Empty transcript text with non-empty action items must still produce a structurally valid paper."
  ],
  "known_failure_modes": [
    "decorative_gap_analysis",
    "false_alignment",
    "schema_valid_but_semantically_empty",
    "overmerged_conflict",
    "missing_traceability",
    "brittle_frequency_extraction"
  ],
