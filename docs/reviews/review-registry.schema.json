{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems/review-registry.schema.json",
  "title": "Review Registry",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "review_id",
      "review_date",
      "review_type",
      "repo",
      "reviewer",
      "status",
      "artifact_path",
      "action_tracker_path",
      "follow_up_trigger"
    ],
    "properties": {
      "review_id": {
        "type": "string",
        "pattern": "^[A-Za-z0-9._-]+$"
      },
      "review_date": {
        "type": "string",
        "format": "date"
      },
      "review_type": {
        "type": "string",
        "minLength": 1
      },
      "repo": {
        "type": "string",
        "minLength": 1
      },
      "reviewer": {
        "type": "string",
        "minLength": 1
      },
      "status": {
        "type": "string",
        "enum": [
          "Open",
          "In Progress",
          "Blocked",
          "Closed"
        ]
      },
      "maturity_rating": {
        "type": "string"
      },
      "artifact_path": {
        "type": "string",
        "pattern": "^docs/reviews/.+\\.[A-Za-z0-9]+$"
      },
      "action_tracker_path": {
        "type": "string",
        "pattern": "^docs/review-actions/.+\\.[A-Za-z0-9]+$"
      },
      "follow_up_trigger": {
        "type": "string",
        "minLength": 1
      },
      "follow_up_due_date": {
        "type": "string",
        "format": "date"
      },
      "reconciles_prior_review_ids": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "uniqueItems": true
      },
      "carried_forward_finding_ids": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "uniqueItems": true
      },
      "scope": {
        "type": "string",
        "description": "Scope of the design or architecture review (e.g., full repo audit, pipeline review, governance review)."
      },
      "notes": {
        "type": "string"
      },
      "resolution_notes": {
        "type": "string",
        "description": "Summary of actions taken to resolve findings from this review, or explanation of why findings remain open."
      },
      "closure_verification_date": {
        "type": "string",
        "format": "date",
        "description": "ISO 8601 date when the formal closure verification was performed for this review."
      },
      "closure_report_path": {
        "type": "string",
        "description": "Repo-relative path to the closure verification report document.",
        "pattern": "^docs/reviews/.+\\.[A-Za-z0-9]+$"
      },
      "carried_forward_findings": {
        "type": "array",
        "description": "Structured tracking of individual findings carried forward from this or prior reviews, with per-finding resolution status.",
        "items": {
          "type": "object",
          "required": ["finding_id", "status"],
          "properties": {
            "finding_id": {
              "type": "string",
              "description": "Finding identifier (e.g., RC-1, GA-007, F-2)."
            },
            "source_review_id": {
              "type": "string",
              "description": "ID of the review that originally raised this finding."
            },
            "description": {
              "type": "string",
              "description": "Short summary of the finding."
            },
            "status": {
              "type": "string",
              "enum": ["Open", "Resolved", "Superseded", "Deferred"],
              "description": "Current resolution status of the finding."
            },
            "resolution_note": {
              "type": "string",
              "description": "Brief note on how the finding was resolved or why it remains open."
            }
          },
          "additionalProperties": false
        },
        "uniqueItems": false
      }
    },
    "additionalProperties": false
  }
}
