{
  "schema_version": "1.0.0",
  "policy_id": "APU-3LS-01",
  "policy_name": "agent_pr_update_policy",
  "authority_scope": "observation_only",
  "owners": {
    "policy_owner": "TPA",
    "evidence_runner": "APU",
    "consumers": [
      "AEX",
      "PQX",
      "EVL",
      "TPA",
      "CDE",
      "SEL",
      "LIN",
      "REP",
      "GOV",
      "CLP",
      "AGL",
      "PRL"
    ]
  },
  "governed_agent_types": [
    "codex",
    "claude",
    "other",
    "unknown"
  ],
  "repo_mutating_surfaces": [
    ".github/workflows/",
    "scripts/",
    "contracts/",
    "spectrum_systems/",
    "tests/",
    "docs/governance/",
    "docs/architecture/system_registry.md"
  ],
  "non_governed_docs_only_surfaces": [
    "README.md",
    "CHANGELOG.md",
    "docs/reviews/",
    "docs/review-actions/",
    "docs/roadmaps/"
  ],
  "required_clp_artifact_type": "core_loop_pre_pr_gate_result",
  "required_clp_artifact_path_default": "outputs/core_loop_pre_pr_gate/core_loop_pre_pr_gate_result.json",
  "required_agl_artifact_type": "agent_core_loop_run_record",
  "required_agl_artifact_path_default": "outputs/agent_core_loop/agent_core_loop_run_record.json",
  "required_agent_pr_ready_artifact_type": "agent_pr_ready_result",
  "required_agent_pr_ready_artifact_path_default": "outputs/core_loop_pre_pr_gate/agent_pr_ready_result.json",
  "required_evidence_legs": [
    "AEX",
    "PQX",
    "EVL",
    "TPA",
    "CDE",
    "SEL",
    "LIN",
    "REP",
    "CLP",
    "APU",
    "AGL"
  ],
  "required_clp_check_observations": [
    "authority_shape_preflight",
    "authority_leak_guard",
    "contract_enforcement",
    "tls_generated_artifact_freshness",
    "contract_preflight",
    "selected_tests"
  ],
  "allowed_warning_reason_codes": [],
  "out_of_scope_legs_default": [],
  "rules": {
    "repo_mutating_unknown_yields_not_ready": true,
    "repo_mutating_requires_clp_evidence": true,
    "repo_mutating_requires_agl_evidence": true,
    "missing_clp_evidence_blocks_pr_update_ready": true,
    "missing_agl_evidence_blocks_pr_update_ready": true,
    "clp_block_status_blocks_pr_update_ready": true,
    "clp_warn_requires_explicit_allow": true,
    "present_leg_without_artifact_refs_is_invalid": true,
    "non_present_leg_without_reason_codes_is_invalid": true,
    "unknown_leg_does_not_count_as_present": true,
    "pr_body_prose_is_not_artifact_evidence": true,
    "claimed_3ls_usage_without_artifact_refs_is_invalid": true,
    "missing_required_check_observation_blocks": true,
    "authority_scope_must_be_observation_only": true
  },
  "block_reason_codes": [
    "repo_mutating_unknown",
    "clp_evidence_missing",
    "agl_evidence_missing",
    "agl_record_invalid",
    "clp_status_block",
    "clp_status_unknown",
    "clp_warning_not_policy_allowed",
    "clp_warning_unallowed_reason_code",
    "leg_present_without_artifact_refs",
    "leg_non_present_without_reason_codes",
    "leg_unknown_counted_present",
    "pr_body_prose_used_as_evidence",
    "claimed_3ls_usage_without_artifact_refs",
    "agent_pr_ready_evidence_invalid",
    "agent_pr_ready_status_not_ready",
    "missing_required_check_observation",
    "policy_ref_invalid",
    "authority_scope_drift"
  ],
  "max_repair_attempts": 0,
  "must_not_do": [
    "claim_admission_authority",
    "claim_execution_authority",
    "claim_eval_authority",
    "claim_policy_authority",
    "claim_continuation_authority",
    "claim_final_gate_authority",
    "claim_lineage_authority",
    "claim_replay_authority",
    "auto_apply_repairs",
    "suppress_existing_gates",
    "treat_pr_body_as_evidence",
    "count_unknown_as_present",
    "downgrade_present_without_artifact_refs"
  ],
  "introduced_in": "APU-3LS-01",
  "last_updated_in": "APU-3LS-01",
  "notes": "APU-3LS-01 policy. APU is observation-only and emits PR-update readiness observations. Canonical authority remains with AEX (admission), PQX (execution closure), EVL (eval evidence), TPA (policy/scope), CDE (continuation/closure), SEL (final gate signal), LIN (lineage), REP (replay), and GOV per docs/architecture/system_registry.md. APU consumes core_loop_pre_pr_gate_result (CLP), agent_core_loop_run_record (AGL), and agent_pr_ready_result (CLP-02 guard) as readiness inputs and emits an agent_pr_update_ready_result evidence artifact. APU enforces the artifact-backed evidence invariant: 'no artifact = it did not happen'. Claimed 3LS usage without artifact refs is invalid. PR body prose, comments, and CI success cannot substitute for artifact_refs. AEX/PQX/CDE/SEL retain canonical signal authority and consume APU output as a readiness input only."
}
