{
  "artifact_type": "pytest_pr_selection_integrity_policy",
  "schema_version": "1.1.0",
  "policy_version": "1.1.0",
  "minimum_selection_threshold": 1,
  "allow_bounded_equivalence": false,
  "governed_surface_prefixes": [
    "contracts/",
    "scripts/",
    "spectrum_systems/",
    "tests/",
    ".github/workflows/",
    "docs/governance/",
    "docs/architecture/"
  ],
  "selection_fail_closed_on_empty_governed": true,
  "fallback_suite_ref": "docs/governance/pytest_pr_inventory_baseline.json",
  "selection_integrity_requirements": [
    "record_selected_targets",
    "validate_selected_targets_exist",
    "fallback_when_weak_or_uncertain",
    "reject_empty_governed_selection"
  ],
  "surface_rules": [
    {
      "path_prefix": "contracts/",
      "required_test_targets": [
        "tests/test_contracts.py"
      ]
    },
    {
      "path_prefix": "docs/architecture/system_registry.md",
      "required_test_targets": [
        "tests/test_system_registry.py"
      ]
    },
    {
      "path_prefix": "spectrum_systems/modules/runtime/control_",
      "required_test_targets": [
        "tests/test_control_signals.py",
        "tests/test_slo_control.py"
      ]
    },
    {
      "path_prefix": "spectrum_systems/modules/runtime/policy_",
      "required_test_targets": [
        "tests/test_policy_enforcement_integrity.py"
      ]
    },
    {
      "path_prefix": "spectrum_systems/modules/runtime/eval",
      "required_test_targets": [
        "tests/test_required_eval_coverage.py"
      ]
    },
    {
      "path_prefix": "spectrum_systems/modules/runtime/replay",
      "required_test_targets": [
        "tests/test_trace_and_provenance.py"
      ]
    },
    {
      "path_prefix": "spectrum_systems/modules/runtime/lineage",
      "required_test_targets": [
        "tests/test_trace_and_provenance.py"
      ]
    },
    {
      "path_prefix": "apps/dashboard",
      "required_test_targets": [
        "tests/test_dashboard_ui.py"
      ]
    },
    {
      "path_prefix": "apps/dashboard-3ls",
      "required_test_targets": [
        "tests/test_dashboard_ui.py"
      ]
    }
  ],
  "bounded_equivalence": [],
  "allowed_exceptions": []
}
