{
  "artifact_type": "ci_gate_ownership_manifest",
  "schema_version": "1.1.0",
  "owned_ci_scripts": [
    "scripts/run_pr_gate.py",
    "scripts/run_contract_gate.py",
    "scripts/run_test_selection_gate.py",
    "scripts/run_runtime_test_gate.py",
    "scripts/run_governance_gate.py",
    "scripts/run_readiness_evidence_gate.py"
  ],
  "required_checks": {
    "pr-gate": "pr_gate"
  },
  "gates": {
    "contract_gate": {
      "owner_surface": "contracts",
      "purpose": "schema and contract preflight validation surface",
      "inputs": ["base_ref", "head_ref", "contracts/*"],
      "outputs": ["outputs/contract_gate/contract_gate_result.json"],
      "protected_invariants": ["schema_authority", "contract_fail_closed"],
      "required_tests": ["tests/test_contracts.py"],
      "failure_modes": ["missing_preflight", "preflight_nonzero"],
      "escalation_path": "contracts + governance",
      "runtime_budget": "pr-fast"
    },
    "runtime_test_gate": {
      "owner_surface": "runtime",
      "purpose": "selected and fallback runtime tests",
      "inputs": ["changed_paths", "selection_policy", "baseline_suite"],
      "outputs": [
        "outputs/test_selection_gate/test_selection_gate_result.json",
        "outputs/runtime_test_gate/runtime_test_gate_result.json"
      ],
      "protected_invariants": ["selection_integrity", "required_eval_coverage", "signal_integrity"],
      "required_tests": ["tests/test_required_eval_coverage.py", "tests/test_control_signals.py"],
      "failure_modes": ["empty_governed_selection", "pytest_failure"],
      "escalation_path": "runtime",
      "runtime_budget": "pr-fast"
    },
    "governance_gate": {
      "owner_surface": "governance",
      "purpose": "registry and required-check signal validation",
      "inputs": ["system_registry", "required_pr_checks"],
      "outputs": ["outputs/governance_gate/governance_gate_result.json"],
      "protected_invariants": ["authority_boundaries", "required_check_integrity"],
      "required_tests": ["tests/test_required_check_alignment_audit.py", "tests/test_system_registry_guard.py"],
      "failure_modes": ["required_check_drift", "registry_guard_failure"],
      "escalation_path": "governance",
      "runtime_budget": "pr-fast"
    },
    "readiness_evidence_gate": {
      "owner_surface": "governance_inputs",
      "purpose": "collect readiness evidence for downstream GOV-10 handling",
      "inputs": ["upstream_gate_artifacts", "replay_lineage_inputs"],
      "outputs": ["outputs/readiness_evidence_gate/readiness_evidence_gate_result.json"],
      "protected_invariants": ["required_artifact_presence", "readiness_signal_completeness"],
      "required_tests": ["tests/test_trace_and_provenance.py", "tests/test_replay_governance.py"],
      "failure_modes": ["missing_artifact", "missing_readiness_input"],
      "escalation_path": "governance",
      "runtime_budget": "pr-fast/release"
    }
  }
}
