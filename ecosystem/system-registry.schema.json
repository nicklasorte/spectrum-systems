{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/ecosystem/system-registry.schema.json",
  "title": "System Registry",
  "description": "Authoritative control-plane registry of systems, repositories, and maturity alignment across the spectrum ecosystem.",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/system_record"
  },
  "$defs": {
    "system_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_id",
        "repo_name",
        "repo_type",
        "system_role",
        "status",
        "maturity_level",
        "primary_loop_alignment",
        "consumes_artifact_types",
        "emits_artifact_types",
        "contract_dependencies",
        "interface_standard_expected"
      ],
      "properties": {
        "system_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "description": "Canonical system identifier that stays stable even if repository names change."
        },
        "repo_name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "description": "Repository slug for the system implementation."
        },
        "repo_url": {
          "type": "string",
          "format": "uri",
          "description": "URL for the repository; may be a placeholder if the repo is not yet public."
        },
        "repo_type": {
          "type": "string",
          "enum": [
            "governance",
            "data_lake",
            "operational_engine",
            "orchestration",
            "advisory",
            "factory"
          ],
          "description": "Role of the repository within the ecosystem stack."
        },
        "system_role": {
          "type": "string",
          "minLength": 1,
          "description": "Concise statement of what the system does in the ecosystem."
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "active",
            "experimental",
            "deprecated"
          ],
          "description": "Lifecycle state for the system."
        },
        "maturity_level": {
          "type": "integer",
          "minimum": 0,
          "description": "Placement on the ecosystem maturity ladder (Level 0-20)."
        },
        "primary_loop_alignment": {
          "type": "string",
          "enum": [
            "coordination",
            "document_production",
            "cross_loop",
            "governance"
          ],
          "description": "Which loop the system primarily serves."
        },
        "consumes_artifact_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "description": "Artifact types the system ingests."
        },
        "emits_artifact_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "description": "Artifact types the system produces."
        },
        "contract_dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "description": "Contract names this system depends on."
        },
        "interface_standard_expected": {
          "type": "boolean",
          "description": "Whether the engine interface standard must be implemented."
        },
        "notes": {
          "type": "string",
          "description": "Optional freeform context."
        },
        "repo": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+/[a-z0-9._-]+$",
          "description": "Qualified repo identifier in owner/repo-name format."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Short human-readable description of the system."
        },
        "maturity": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?$",
          "description": "Current maturity score as a decimal string (e.g. '2.5')."
        },
        "target_maturity": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?$",
          "description": "Target maturity score as a decimal string (e.g. '4.0')."
        }
      }
    }
  }
}
