{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spectrum-systems://schemas/spectrum-systems.file-types.schema.json",
  "title": "Spectrum Systems Allowed File Types Schema",
  "description": "Defines governance boundary: which file types are allowed in spectrum-systems (governance-only repo). No production code.",
  "type": "object",
  "properties": {
    "allowed_file_types": {
      "type": "object",
      "description": "File types and patterns permitted in spectrum-systems",
      "properties": {
        "governance_artifacts": {
          "type": "array",
          "description": "Governance documentation, contracts, schemas",
          "items": {
            "type": "string"
          },
          "default": [
            "*.md",
            "*.json",
            "*.yaml",
            "*.yml",
            "*.toml",
            "*.txt",
            "*.rst"
          ]
        },
        "schema_files": {
          "type": "array",
          "description": "JSON Schema definition files",
          "items": {
            "type": "string"
          },
          "default": [
            "*.schema.json"
          ]
        },
        "contract_files": {
          "type": "array",
          "description": "Contract and standards definition files",
          "items": {
            "type": "string"
          },
          "default": [
            "*.contract.json",
            "*.contract.yaml"
          ]
        },
        "configuration_files": {
          "type": "array",
          "description": "Repository and CI configuration",
          "items": {
            "type": "string"
          },
          "default": [
            "*.ini",
            "*.cfg",
            "pytest.ini",
            "pyproject.toml",
            ".gitignore"
          ]
        },
        "ci_workflows": {
          "type": "array",
          "description": "CI/CD workflow definitions",
          "items": {
            "type": "string"
          },
          "default": [
            ".github/workflows/*.yml",
            ".github/workflows/*.yaml"
          ]
        },
        "governance_scripts": {
          "type": "array",
          "description": "Governance-only Python scripts (not production code)",
          "items": {
            "type": "string"
          },
          "default": [
            "scripts/check_protected_files.py",
            "scripts/validate-governance-boundary.py",
            "scripts/run_system_registry_guard.py"
          ]
        },
        "test_files": {
          "type": "array",
          "description": "Governance boundary enforcement tests only",
          "items": {
            "type": "string"
          },
          "default": [
            "tests/test_governance_*.py",
            "tests/test_contract_*.py",
            "tests/test_schema_*.py",
            "tests/test_compliance_*.py",
            "tests/test_boundary_*.py"
          ]
        },
        "examples": {
          "type": "array",
          "description": "Contract and schema examples",
          "items": {
            "type": "string"
          },
          "default": [
            "contracts/examples/**",
            "schemas/examples/**"
          ]
        }
      }
    },
    "forbidden_patterns": {
      "type": "array",
      "description": "File patterns that must never exist in a governance-only repo",
      "items": {
        "type": "string"
      },
      "default": [
        "spectrum_systems/**",
        "spectrum_systems/__init__.py",
        "src/mvp-integration/**",
        "src/observability/**",
        "src/governance/**",
        "src/replay/**",
        "src/trace/**",
        "src/signing/**",
        "src/judgment/**",
        "src/policy/**",
        "control_plane/**",
        "working_paper_generator/**",
        "systems/**/*.py",
        "modules/**/*.py"
      ]
    },
    "validation_rules": {
      "type": "object",
      "description": "Rules for validating spectrum-systems against this schema",
      "properties": {
        "fail_on_any_forbidden": {
          "type": "boolean",
          "description": "CI must fail if any forbidden pattern is found",
          "default": true
        },
        "enforce_in_ci": {
          "type": "boolean",
          "description": "Boundary check runs on every PR",
          "default": true
        },
        "allow_tests_for_governance_only": {
          "type": "boolean",
          "description": "Test files are allowed only if they test governance boundaries",
          "default": true
        },
        "require_migration_guide_on_removal": {
          "type": "boolean",
          "description": "Any removed module must have a migration guide",
          "default": true
        }
      }
    }
  },
  "required": [
    "allowed_file_types",
    "forbidden_patterns",
    "validation_rules"
  ]
}
