  "operational_considerations": [
    {
      "consideration_id": "OC-1",
      "title": "Maintenance Windows & Incident Coordination",
      "description": "Phases 16-17 involve removing code and restructuring repos; must happen during maintenance window with incident coordination plan and rollback procedures.",
      "severity": "HIGH",
      "mitigation": "Add scheduled maintenance windows; define rollback triggers and decision authority; communicate with stakeholders 2 weeks in advance"
    },
    {
      "consideration_id": "OC-2",
      "title": "Opt-In vs Mandatory Decision",
      "description": "Phase 20 requires organizational decision: is downstream repo governance adoption opt-in or mandatory? Ambiguity creates tension between teams.",
      "severity": "HIGH",
      "mitigation": "Board-level decision required before Phase 20 starts; document decision in governance policy"
    },
    {
      "consideration_id": "OC-3",
      "title": "Phase 19 Capacity Planning",
      "description": "Compliance scanner finds violations in 8 repos simultaneously; fix capacity will be overwhelmed if not planned.",
      "severity": "MEDIUM",
      "mitigation": "Phase 19 includes capacity assessment; staged rollout to identify and fix violations in 2-3 repo batches; allocate 2 engineers per batch"
    },
    {
      "consideration_id": "OC-4",
      "title": "Escape Hatch for Phase 16.5",
      "description": "If spectrum-systems fails its own compliance check, no auto-block; requires explicit governance team decision and escalation.",
      "severity": "MEDIUM",
      "mitigation": "Document escalation authority; define turnaround time (24-48 hrs); require board approval for any exemptions"
    },
    {
      "consideration_id": "OC-5",
      "title": "Waiver Accumulation Over Time",
      "description": "Without sunset dates, exception waivers become permanent governance debt.",
      "severity": "MEDIUM",
      "mitigation": "All waivers have 6-month auto-expiry; renewal requires re-approval and re-assessment"
    }
  ],
