{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/ecosystem/ecosystem-registry.schema.json",
  "title": "Ecosystem Registry",
  "description": "Authoritative ecosystem inventory and dependency-tracking source for the czar GitHub org.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "repositories"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the ecosystem registry schema."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this registry snapshot was generated."
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/repository"
      },
      "description": "List of repositories governed by spectrum-systems."
    }
  },
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_name",
        "repo_url",
        "repo_type",
        "status",
        "layer",
        "contracts"
      ],
      "properties": {
        "repo_name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$",
          "description": "Repository slug or descriptive name."
        },
        "repo_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/?$",
          "description": "URL to the repository home."
        },
        "repo_type": {
          "type": "string",
          "enum": [
            "governance",
            "operational_engine",
            "tooling",
            "template",
            "advisory"
          ],
          "description": "Role of the repository within the ecosystem."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "planned",
            "experimental",
            "archived"
          ],
          "description": "Lifecycle status of the repository."
        },
        "layer": {
          "type": "string",
          "enum": [
            "Layer 1",
            "Layer 2",
            "Layer 3",
            "Layer 4",
            "Layer 5"
          ],
          "description": "Layer within the governed ecosystem stack."
        },
        "system_id": {
          "type": "string",
          "pattern": "^SYS-[0-9]{3}$",
          "description": "System identifier when the repository implements a governed system."
        },
        "description": {
          "type": "string",
          "description": "Concise description of the repository purpose."
        },
        "contracts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "uniqueItems": true,
          "minItems": 0,
          "description": "Contracts produced or consumed by this repository."
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "repo_type"
            ],
            "properties": {
              "repo_type": {
                "const": "template"
              }
            }
          },
          "then": {
            "properties": {
              "contracts": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "repo_type",
              "status"
            ],
            "properties": {
              "repo_type": {
                "not": {
                  "const": "governance"
                }
              },
              "status": {
                "enum": [
                  "active",
                  "experimental"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "contracts": {
                "minItems": 1
              }
            }
          }
        }
      ]
    }
  }
}
