{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/ecosystem/ecosystem-registry.schema.json",
  "title": "Ecosystem Registry",
  "description": "Authoritative registry of repositories in the Spectrum Systems ecosystem.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "repositories"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the ecosystem registry schema."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this registry snapshot was generated."
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/repository"
      },
      "description": "List of repositories governed by spectrum-systems."
    }
  },
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo_name",
        "repo_url",
        "repo_type",
        "status"
      ],
      "properties": {
        "repo_name": {
          "type": "string",
          "description": "Repository slug or descriptive name."
        },
        "repo_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to the repository home."
        },
        "repo_type": {
          "type": "string",
          "enum": [
            "governance",
            "operational_engine",
            "tooling",
            "template",
            "advisory"
          ],
          "description": "Role of the repository within the ecosystem."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "planned",
            "experimental",
            "archived"
          ],
          "description": "Lifecycle status of the repository."
        },
        "system_id": {
          "type": "string",
          "description": "System identifier when the repository implements a governed system."
        },
        "description": {
          "type": "string",
          "description": "Concise description of the repository purpose."
        },
        "contracts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Contracts produced or consumed by this repository."
        }
      }
    }
  }
}
