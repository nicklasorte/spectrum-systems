{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/ecosystem/roadmap-tracker.schema.json",
  "title": "Roadmap Tracker",
  "description": "Machine-readable 100-step roadmap tracker for the spectrum ecosystem.",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/$defs/roadmap_step"
  },
  "$defs": {
    "status_enum": {
      "type": "string",
      "enum": ["planned", "active", "complete", "blocked", "deferred"]
    },
    "roadmap_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_number",
        "title",
        "repo",
        "status",
        "maturity_target",
        "dependencies",
        "primary_risk",
        "guardrail"
      ],
      "properties": {
        "step_number": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/status_enum"
        },
        "maturity_target": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "primary_risk": {
          "type": "string",
          "minLength": 1
        },
        "guardrail": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
