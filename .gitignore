# Node and build artifacts
node_modules/
dist/

# OS files
.DS_Store

# Python artifacts
__pycache__/
*.pyc

# Claude Code session directory
.claude/

# Study runner outputs
outputs/
logs/

# Runtime decision archives (generated at runtime, not committed)
data/run_output_evaluation_decisions/*.json
data/cross_run_intelligence_decisions/*.json
data/runtime_decisions/*.json
data/run_bundle_decisions/*.json
data/working_paper_synthesis_decisions/*.json
data/slo_evaluations/*.json
data/failure_enforcement_decisions/*.json

# Comparison output artifacts at repo root (generated by tests/CLI)
cross_run_comparison.json
cross_run_intelligence_decision.json

# Policy engine outputs
artifacts/policy-engine-report.json
artifacts/policy-engine-summary.md

# Operational artifacts are prohibited in GitHub (see docs/data-boundary-governance.md)
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx
*.rtf
*.msg
*.eml
*.zip
*.7z
*.tar
*.gz
*.bz2
*.rar
*.bin
*.sqlite
*.db

# Allow synthetic fixtures under clearly named example/test paths
!examples/**/*.pdf
!examples/**/*.docx
!tests/fixtures/**/*.pdf
!tests/fixtures/**/*.docx
!contracts/examples/**/*.pdf
!contracts/examples/**/*.docx

# Runtime decision archive files (transient operational artifacts)
data/run_bundle_decisions/*.json
data/run_output_evaluation_decisions/*.json

# Persisted traces (runtime data, not committed)
data/traces/*.json

# HOP trial run experience-store contents (regenerated per run; only the
# summary JSONs are committed as evidence).
artifacts/hop_trial_run/run_*/
