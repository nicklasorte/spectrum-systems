{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.local/schemas/aex/aex_admission_policy_observation.schema.json",
  "title": "AEX Admission Policy Observation (supplemental)",
  "description": "Supplemental structural schema mirroring contracts/schemas/admission_policy_observation.schema.json. Used for AEX trust-gap evidence and as a stable import surface for tests in tests/aex/. The canonical contract schema in contracts/schemas/ remains authoritative — this file does not redefine governance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "observation_id",
    "request_id",
    "trace_id",
    "run_id",
    "created_at",
    "produced_by",
    "producer_authority",
    "admission_outcome",
    "reason_codes",
    "input_refs",
    "output_refs",
    "downstream_refs",
    "evidence_refs",
    "replay_refs",
    "policy_refs",
    "non_authority_assertions"
  ],
  "properties": {
    "artifact_type": {
      "const": "admission_policy_observation"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "observation_id": {
      "type": "string",
      "pattern": "^apo-[0-9a-f]{16}$"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "produced_by": {
      "type": "string",
      "minLength": 1
    },
    "producer_authority": {
      "const": "AEX"
    },
    "admission_outcome": {
      "enum": [
        "admitted",
        "rejected",
        "indeterminate"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "input_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "output_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "downstream_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_systems",
        "handoff_refs"
      ],
      "properties": {
        "consumer_systems": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "SEL",
              "ENF",
              "POL",
              "PQX",
              "TPA",
              "CDE",
              "GOV",
              "OBS"
            ]
          },
          "contains": {"const": "SEL"},
          "minContains": 1
        },
        "handoff_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "replay_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_hash",
        "output_hash",
        "replay_command_ref"
      ],
      "properties": {
        "input_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "output_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "replay_command_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policy_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "non_authority_assertions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      },
      "allOf": [
        {"contains": {"const": "aex_emits_enforcement_input_only"}, "minContains": 1},
        {"contains": {"const": "aex_emits_promotion_input_only"}, "minContains": 1},
        {"contains": {"const": "aex_emits_certification_input_only"}, "minContains": 1},
        {"contains": {"const": "aex_emits_control_input_only"}, "minContains": 1},
        {"contains": {"const": "aex_emits_readiness_observation_only"}, "minContains": 1}
      ]
    }
  }
}
