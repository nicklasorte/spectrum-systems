{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/schemas/study-output-schema.json",
  "title": "Study Output Record",
  "description": "Schema for structured study artifacts (tables, figures, narratives) with provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_id",
    "artifact_type",
    "title",
    "source_scenarios",
    "metrics",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1.0",
      "description": "Version of the study output schema used to validate this record."
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^ART-[A-Z0-9._-]+$",
      "description": "Stable identifier for the artifact."
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "table",
        "figure",
        "narrative",
        "dataset"
      ],
      "description": "Type of artifact."
    },
    "title": {
      "type": "string",
      "description": "Human-readable title."
    },
    "description": {
      "type": "string",
      "description": "Short description of the artifact contents."
    },
    "source_scenarios": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Scenario names covered by this artifact."
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Metrics represented (e.g., interference_margin, throughput)."
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Assumption IDs associated with this artifact."
    },
    "render_ref": {
      "type": "string",
      "description": "Path or URI to the rendered artifact."
    },
    "report_section": {
      "type": "string",
      "description": "Report section anchor where this artifact is used."
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "approved"
      ],
      "description": "Lifecycle state of the artifact."
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Non-blocking warnings produced during generation/compilation."
    },
    "provenance": {
      "$ref": "provenance-schema.json",
      "description": "Provenance record capturing lineage, run manifest, and review status."
    }
  }
}
