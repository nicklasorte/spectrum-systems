{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spectrum.systems/schemas/system_evidence_attachment.schema.json",
  "title": "system_evidence_attachment",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "phase", "source_dependency_graph_phase", "systems"],
  "properties": {
    "schema_version": { "type": "string", "const": "tls-01.v1" },
    "phase": { "type": "string", "const": "TLS-01" },
    "source_dependency_graph_phase": { "type": ["string", "null"] },
    "systems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "system_id",
          "has_evidence",
          "missing_evidence_reason",
          "evidence_count",
          "evidence"
        ],
        "properties": {
          "system_id": { "type": "string", "pattern": "^[A-Z][A-Z0-9]{1,5}$" },
          "has_evidence": { "type": "boolean" },
          "missing_evidence_reason": { "type": ["string", "null"] },
          "evidence_count": { "type": "integer", "minimum": 0 },
          "evidence": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "modules",
              "tests",
              "schemas",
              "docs",
              "reviews",
              "review_actions",
              "scripts",
              "artifacts"
            ],
            "properties": {
              "modules": { "type": "array", "items": { "type": "string" } },
              "tests": { "type": "array", "items": { "type": "string" } },
              "schemas": { "type": "array", "items": { "type": "string" } },
              "docs": { "type": "array", "items": { "type": "string" } },
              "reviews": { "type": "array", "items": { "type": "string" } },
              "review_actions": { "type": "array", "items": { "type": "string" } },
              "scripts": { "type": "array", "items": { "type": "string" } },
              "artifacts": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
