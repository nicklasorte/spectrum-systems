{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spectrum.systems/schemas/system_trust_gap_report.schema.json",
  "title": "system_trust_gap_report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "phase", "signal_taxonomy", "systems"],
  "properties": {
    "schema_version": { "type": "string", "const": "tls-03.v1" },
    "phase": { "type": "string", "const": "TLS-03" },
    "signal_taxonomy": {
      "type": "array",
      "items": { "type": "string" }
    },
    "systems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "system_id",
          "classification",
          "gaps_evaluated",
          "gap_count",
          "failing_signals",
          "passing_signals",
          "trust_state"
        ],
        "properties": {
          "system_id": { "type": "string" },
          "classification": { "type": "string" },
          "gaps_evaluated": { "type": "integer", "minimum": 1 },
          "gap_count": { "type": "integer", "minimum": 0 },
          "failing_signals": { "type": "array", "items": { "type": "string" } },
          "passing_signals": { "type": "array", "items": { "type": "string" } },
          "trust_state": { "type": "string", "enum": ["ok", "warn", "freeze", "block", "unknown"] }
        }
      }
    }
  }
}
