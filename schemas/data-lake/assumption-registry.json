{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/schemas/data-lake/assumption-registry.json",
  "title": "Assumption Registry Record",
  "description": "Schema for assumptions persisted in the data lake with review and provenance metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "record_type",
    "assumption_id",
    "assumption_text",
    "source",
    "impact_level",
    "timestamp_created",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of this registry schema."
    },
    "record_id": {
      "type": "string",
      "pattern": "^PRV-ASM-[A-Z0-9._-]+$",
      "description": "Stable provenance identifier for the record."
    },
    "record_type": {
      "type": "string",
      "const": "assumption",
      "description": "Type of record."
    },
    "assumption_id": {
      "type": "string",
      "pattern": "^ASM-[A-Z0-9._-]+$",
      "description": "Stable assumption identifier."
    },
    "study_name": {
      "type": "string",
      "description": "Study this assumption supports."
    },
    "assumption_text": {
      "type": "string",
      "description": "Statement of the assumption."
    },
    "source": {
      "type": "string",
      "description": "Originating document or decision."
    },
    "impact_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "description": "Impact classification on downstream results."
    },
    "approved_by": {
      "type": "string",
      "description": "Reviewer or approver."
    },
    "date_approved": {
      "type": "string",
      "format": "date",
      "description": "Approval date."
    },
    "later_changes": {
      "type": "string",
      "description": "Notes on subsequent changes or reviews."
    },
    "source_document": {
      "type": "string",
      "description": "Source document name or identifier."
    },
    "source_document_id": {
      "type": "string",
      "description": "Canonical source document ID."
    },
    "source_location": {
      "type": "string",
      "description": "Section, page, or paragraph of the source."
    },
    "timestamp_created": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp."
    },
    "derived_from": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Parent entities this record derives from."
    },
    "version_number": {
      "type": "string",
      "description": "Record version number within its lineage."
    },
    "review_status": {
      "type": "string",
      "enum": [
        "pending_review",
        "approved",
        "rejected"
      ],
      "description": "Human review state."
    },
    "reviewed_by": {
      "type": "string",
      "description": "Reviewer identifier."
    },
    "review_date": {
      "type": "string",
      "format": "date-time",
      "description": "When review occurred."
    },
    "confidence_score": {
      "type": "string",
      "description": "Confidence assessment (structured string for compatibility)."
    },
    "quality_status": {
      "type": "string",
      "description": "Data quality state (e.g., raw, validated)."
    },
    "provenance": {
      "$ref": "../provenance-schema.json",
      "description": "Provenance record capturing lineage and validation details."
    }
  }
}
