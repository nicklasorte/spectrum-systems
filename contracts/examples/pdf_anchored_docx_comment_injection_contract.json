  "status_policy": {
    "eligible_statuses": ["pending_injection", "requires_insertion", "needs_injection_review"],
    "skip_statuses": ["complete", "no_action", "not_applicable", "rejected", "blocked"],
    "normalization_rules": {
      "map": {
        "Pending": "pending_injection",
        "pending": "pending_injection",
        "Needs insertion": "requires_insertion",
        "needs insertion": "requires_insertion",
        "Needs injection review": "needs_injection_review",
        "needs injection review": "needs_injection_review",
        "Done": "complete",
        "done": "complete",
        "Completed": "complete",
        "N/A": "not_applicable",
        "n/a": "not_applicable",
        "Not applicable": "not_applicable",
        "No action": "no_action",
        "no action": "no_action",
        "Rejected": "rejected",
        "Blocked": "blocked"
      }
    }
  },
  "insertion_behavior": {
    "anchor_strategy": "pdf_page_line_primary",
    "verification_steps": {
      "requires_excerpt_match": true,
      "requires_line_presence": true,
      "use_heading_hint": true
    },
    "docx_mapping": {
      "method": "map_pdf_excerpt_to_docx_text",
      "allow_approximate_mapping": false
    },
    "failure_behavior": [
      "fail_on_missing_pdf_anchor",
      "fail_on_missing_excerpt_verification",
      "fail_on_ambiguous_pdf_anchor",
      "fail_on_ambiguous_docx_mapping",
      "fail_on_missing_injection_text"
    ],
    "output_policy": {
      "preserve_source_docx": true,
      "commented_docx_role": "commented_output"
    }
  },
