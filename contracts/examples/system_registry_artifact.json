      "prohibited_behaviors": [
        "trust_policy_adjudication",
        "repair_plan_generation",
        "closure_decisioning"
      ],
      "upstream_dependencies": [
        "TLC",
        "TPA"
      ],
      "downstream_consumers": [
        "FRE",
        "SEL"
      ]
    },
    {
