        "build_admission_record",
        "normalized_execution_request",
        "admission_rejection_record"
      ],
      "prohibited_behaviors": [
        "work_execution",
        "workflow_orchestration",
        "trust_policy_adjudication",
        "output_evaluation",
        "closure_decisioning",
        "runtime_enforcement"
      ],
      "upstream_dependencies": [
        "PRG"
      ],
      "downstream_consumers": [
        "TLC"
      ]
    },
    {
      "acronym": "PQX",
