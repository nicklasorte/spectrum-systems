{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/comment-resolution-matrix.schema.json",
  "title": "Comment Resolution Matrix",
  "description": "Canonical exchange shape for the working-paper-review-engine and comment-resolution-engine.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "record_id",
    "run_id",
    "created_at",
    "created_by",
    "source_repo",
    "source_repo_version",
    "matrix_id",
    "entries"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "comment_resolution_matrix",
      "description": "Canonical artifact type identifier."
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[A-Z0-9._-]+$",
      "description": "Stable identifier for this matrix artifact."
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version of this matrix instance for diffing and rollback."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the comment-resolution-matrix schema."
    },
    "standards_version": {
      "type": "string",
      "const": "2026.03.0",
      "description": "Standards release version from contracts/standards-manifest.json."
    },
    "record_id": {
      "type": "string",
      "pattern": "^REC-[A-Z0-9._-]+$",
      "description": "Record identifier used for provenance and diffing."
    },
    "run_id": {
      "type": "string",
      "pattern": "^run-[A-Za-z0-9._-]+$",
      "description": "Deterministic run identifier for the workflow that produced this matrix."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this matrix was generated."
    },
    "created_by": {
      "$ref": "#/$defs/created_by"
    },
    "source_repo": {
      "type": "string",
      "description": "Repository slug that produced this matrix."
    },
    "source_repo_version": {
      "type": "string",
      "description": "Tag or commit hash of the source repository."
    },
    "matrix_id": {
      "type": "string",
      "pattern": "^CRM-[A-Z0-9._-]+$",
      "description": "Identifier for this comment resolution matrix."
    },
    "input_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_artifact"
      },
      "description": "Upstream artifacts (reviewer comments, prior matrices) used to populate this matrix."
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      },
      "description": "Resolution entries aligned to reviewer comments."
    }
  },
  "$defs": {
    "created_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "agent_type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "agent_type": {
          "type": "string",
          "enum": [
            "human",
            "ai_model",
            "workflow",
            "script"
          ]
        },
        "organization": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "input_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "artifact_version",
        "role"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^[A-Z0-9._-]+$"
        },
        "artifact_type": {
          "type": "string"
        },
        "artifact_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "role": {
          "type": "string"
        },
        "source_repo": {
          "type": "string"
        },
        "source_repo_version": {
          "type": "string"
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comment_id",
        "source_agency",
        "comment_text",
        "document_section",
        "line_number",
        "proposed_resolution",
        "status",
        "revision_reference"
      ],
      "properties": {
        "comment_id": {
          "type": "string",
          "pattern": "^CMT-[A-Z0-9._-]+$",
          "description": "Identifier for the reviewer comment."
        },
        "source_agency": {
          "type": "string",
          "description": "Agency submitting the comment."
        },
        "comment_text": {
          "type": "string",
          "description": "Original reviewer comment text."
        },
        "document_section": {
          "type": "string",
          "description": "Section or paragraph anchor referenced by the comment."
        },
        "line_number": {
          "type": "integer",
          "minimum": 1,
          "description": "Line number in the source document."
        },
        "proposed_resolution": {
          "type": "string",
          "description": "Proposed text or action to resolve the comment."
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "in_review",
            "needs_clarification",
            "resolved",
            "deferred",
            "rejected"
          ],
          "description": "Current resolution status."
        },
        "revision_reference": {
          "type": "string",
          "pattern": "^rev[0-9]+$",
          "description": "Document revision the resolution applies to."
        },
        "rationale": {
          "type": "string",
          "description": "Explanation for the disposition."
        },
        "disposition_owner": {
          "type": "string",
          "description": "Owner responsible for implementing the resolution."
        },
        "evidence_links": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "last_updated": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp for the last modification to this entry."
        },
        "provenance_id": {
          "type": "string",
          "pattern": "^PRV-[A-Z0-9._-]+$",
          "description": "Identifier linking to provenance records."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
