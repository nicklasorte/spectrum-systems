{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/interpretation_bundle.schema.json",
  "title": "interpretation_bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "bundle_id",
    "trace_id",
    "failure_packet_ref",
    "interpretation_record_ref",
    "interpretation_eval_result_ref",
    "interpretation_readiness_record_ref",
    "interpretation_conflict_record_ref",
    "lineage_complete",
    "non_authority_assertions"
  ],
  "properties": {
    "artifact_type": {
      "const": "interpretation_bundle"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "bundle_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "failure_packet_ref": {
      "type": "string",
      "pattern": "^failure_packet:.+"
    },
    "interpretation_record_ref": {
      "type": "string",
      "pattern": "^interpretation_record:.+"
    },
    "interpretation_eval_result_ref": {
      "type": "string",
      "pattern": "^interpretation_eval_result:.+"
    },
    "interpretation_readiness_record_ref": {
      "type": "string",
      "pattern": "^interpretation_readiness_record:.+"
    },
    "interpretation_conflict_record_ref": {
      "type": "string",
      "pattern": "^interpretation_conflict_record:.+"
    },
    "lineage_complete": {
      "type": "boolean"
    },
    "non_authority_assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
