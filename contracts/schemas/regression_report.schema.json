{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "regression_report.schema.json",
  "title": "RegressionReport",
  "description": "Governed regression report produced after comparing a candidate run against a named baseline.",
  "type": "object",
  "required": [
    "report_id",
    "timestamp",
    "baseline_id",
    "candidate_id",
    "policy_id",
    "summary",
    "dimension_results",
    "worst_regressions",
    "recommendations"
  ],
  "additionalProperties": false,
  "properties": {
    "report_id": {
      "type": "string",
      "description": "Unique identifier for this regression report."
    },
    "timestamp": {
      "type": "string",
      "description": "ISO-8601 timestamp when the report was generated."
    },
    "baseline_id": {
      "type": "string",
      "description": "Name/ID of the baseline used for comparison."
    },
    "candidate_id": {
      "type": "string",
      "description": "Name/ID of the candidate run being evaluated."
    },
    "policy_id": {
      "type": "string",
      "description": "Policy used to perform regression evaluation."
    },
    "summary": {
      "type": "object",
      "description": "High-level summary of the regression check outcome.",
      "required": [
        "overall_pass",
        "hard_failures",
        "warnings",
        "cases_compared",
        "passes_compared"
      ],
      "additionalProperties": false,
      "properties": {
        "overall_pass": {
          "type": "boolean",
          "description": "True if there are no hard failures."
        },
        "hard_failures": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of dimensions that triggered a hard failure."
        },
        "warnings": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of dimensions that triggered a warning."
        },
        "cases_compared": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of cases included in the comparison."
        },
        "passes_compared": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of pass-level records included in the comparison."
        }
      }
    },
    "dimension_results": {
      "type": "object",
      "description": "Per-dimension regression comparison results.",
      "required": [
        "structural_score",
        "semantic_score",
        "grounding_score",
        "latency",
        "human_disagreement"
      ],
      "additionalProperties": false,
      "properties": {
        "structural_score": { "$ref": "#/$defs/DimensionResult" },
        "semantic_score":   { "$ref": "#/$defs/DimensionResult" },
        "grounding_score":  { "$ref": "#/$defs/DimensionResult" },
        "latency":          { "$ref": "#/$defs/DimensionResult" },
        "human_disagreement": { "$ref": "#/$defs/DimensionResult" }
      }
    },
    "worst_regressions": {
      "type": "array",
      "description": "Individual worst regression entries, ordered by severity.",
      "items": {
        "type": "object",
        "required": [
          "dimension",
          "baseline_value",
          "candidate_value",
          "delta",
          "severity",
          "explanation"
        ],
        "additionalProperties": false,
        "properties": {
          "case_id": {
            "type": "string",
            "description": "Case identifier (optional)."
          },
          "artifact_id": {
            "type": "string",
            "description": "Artifact identifier (optional)."
          },
          "pass_id": {
            "type": "string",
            "description": "Pass identifier (optional)."
          },
          "pass_type": {
            "type": "string",
            "description": "Pass type (optional)."
          },
          "dimension": {
            "type": "string",
            "description": "Score dimension that regressed."
          },
          "baseline_value": {
            "type": "number",
            "description": "Baseline value for this dimension."
          },
          "candidate_value": {
            "type": "number",
            "description": "Candidate value for this dimension."
          },
          "delta": {
            "type": "number",
            "description": "Candidate minus baseline (negative = regression)."
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "hard_fail"],
            "description": "Severity classification for this regression entry."
          },
          "explanation": {
            "type": "string",
            "description": "Human-readable explanation of this regression."
          }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Actionable recommendations derived from the regression results."
    }
  },
  "$defs": {
    "DimensionResult": {
      "type": "object",
      "required": [
        "baseline_value",
        "candidate_value",
        "delta",
        "threshold",
        "passed",
        "severity"
      ],
      "additionalProperties": false,
      "properties": {
        "baseline_value": {
          "type": "number",
          "description": "Baseline aggregate value for this dimension."
        },
        "candidate_value": {
          "type": "number",
          "description": "Candidate aggregate value for this dimension."
        },
        "delta": {
          "type": "number",
          "description": "Candidate minus baseline."
        },
        "threshold": {
          "type": "number",
          "description": "Maximum allowed drop/increase per policy."
        },
        "passed": {
          "type": "boolean",
          "description": "True if the delta is within the allowed threshold."
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "hard_fail"],
          "description": "Severity classification for this dimension."
        },
        "insufficient_data": {
          "type": "boolean",
          "description": "True when there is not enough data to evaluate this dimension reliably."
        }
      }
    }
  }
}
