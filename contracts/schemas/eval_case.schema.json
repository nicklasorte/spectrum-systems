{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/eval_case.schema.json",
  "title": "Eval Case",
  "description": "Governed eval-case artifact auto-generated from deterministic runtime failures.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eval_case_id",
    "source_artifact_type",
    "source_artifact_id",
    "failure_mode",
    "input_snapshot",
    "expected_behavior",
    "observed_behavior",
    "generation_timestamp",
    "provenance",
    "reproducibility"
  ],
  "properties": {
    "eval_case_id": {
      "type": "string",
      "format": "uuid"
    },
    "source_artifact_type": {
      "type": "string",
      "minLength": 1
    },
    "source_artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "failure_mode": {
      "type": "string",
      "enum": [
        "schema_violation",
        "execution_failure",
        "indeterminate",
        "threshold_breach",
        "drift_detected"
      ]
    },
    "input_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "key_metrics",
        "decision_inputs"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "minLength": 1
        },
        "key_metrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pass_rate": { "type": "number" },
            "drift_rate": { "type": "number" },
            "reproducibility_score": { "type": "number" }
          }
        },
        "decision_inputs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pass_rate": { "type": "number" },
            "drift_rate": { "type": "number" },
            "reproducibility_score": { "type": "number" },
            "indeterminate_failure_count": { "type": "integer" },
            "indeterminate_count": { "type": "integer" },
            "decision": {
              "type": "string",
              "enum": ["allow", "deny", "indeterminate", "require_review"]
            }
          }
        }
      }
    },
    "expected_behavior": {
      "type": "string",
      "enum": ["allow", "deny", "require_review"]
    },
    "observed_behavior": {
      "type": "string",
      "enum": ["allow", "deny", "require_review", "indeterminate"]
    },
    "generation_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "run_id"],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reproducibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deterministic", "requires_seed", "seed_value"],
      "properties": {
        "deterministic": { "type": "boolean" },
        "requires_seed": { "type": "boolean" },
        "seed_value": {
          "type": ["number", "null"]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "reproducibility": {
            "properties": {
              "deterministic": { "const": true }
            },
            "required": ["deterministic"]
          }
        },
        "required": ["reproducibility"]
      },
      "then": {
        "properties": {
          "reproducibility": {
            "properties": {
              "seed_value": { "type": "null" }
            },
            "required": ["seed_value"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reproducibility": {
            "properties": {
              "requires_seed": { "const": true }
            },
            "required": ["requires_seed"]
          }
        },
        "required": ["reproducibility"]
      },
      "then": {
        "properties": {
          "reproducibility": {
            "properties": {
              "seed_value": { "type": "number" }
            },
            "required": ["seed_value"]
          }
        }
      }
    }
  ]
}
