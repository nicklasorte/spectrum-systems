{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/wpg_redteam_findings.schema.json",
  "title": "WPG Redteam Findings",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "schema_version", "suite_id", "overall_verdict", "findings", "signature"],
  "properties": {
    "artifact_type": {"type": "string", "const": "wpg_redteam_findings"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "suite_id": {"type": "string", "const": "RTX-05"},
    "overall_verdict": {"type": "string", "enum": ["PASS", "NEEDS_FIXES"]},
    "signature": {"type": "string", "minLength": 1},
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scenario_id", "severity", "decision", "passed", "stage_decisions"],
        "properties": {
          "scenario_id": {"type": "string", "minLength": 1},
          "severity": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH"]},
          "decision": {"type": "string", "enum": ["ALLOW", "WARN", "BLOCK", "FREEZE"]},
          "passed": {"type": "boolean"},
          "stage_decisions": {
            "type": "array",
            "items": {"type": "string", "enum": ["ALLOW", "WARN", "BLOCK", "FREEZE"]}
          }
        },
        "additionalProperties": false
      }
    }
  }
}
