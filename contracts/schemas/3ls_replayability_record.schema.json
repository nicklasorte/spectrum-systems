{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/3ls_replayability_record.schema.json",
  "title": "3LS Replayability Record",
  "description": "Measurement of whether a system's outputs are replayable and deterministic. Observation only. Fail-closed: replay_available=true requires replay_refs; replay_available=false requires replay_gap_reason.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "trace_id",
    "created_at",
    "provenance",
    "system",
    "replay_available",
    "replay_refs",
    "deterministic_output",
    "authority_scope"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "3ls_replayability_record"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "trace_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_system", "inputs"],
      "properties": {
        "source_system": {"type": "string", "pattern": "^[A-Z0-9]{2,8}$"},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "simulated": {"type": "boolean"}
      }
    },
    "record_id": {"type": "string"},
    "system": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,8}$"
    },
    "replay_available": {"type": "boolean"},
    "replay_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "replay_gap_reason": {"type": ["string", "null"]},
    "deterministic_output": {"type": "boolean"},
    "authority_scope": {"type": "string", "const": "observation_only"},
    "notes": {"type": "string"}
  },
  "allOf": [
    {
      "description": "If replay is available, replay_refs must be non-empty.",
      "if": {
        "properties": {"replay_available": {"const": true}},
        "required": ["replay_available"]
      },
      "then": {
        "properties": {
          "replay_refs": {"type": "array", "minItems": 1}
        }
      }
    },
    {
      "description": "If replay is unavailable, replay_gap_reason must be a non-empty string and replay_refs must be empty (a record cannot simultaneously declare replay unavailable and attach replay evidence).",
      "if": {
        "properties": {"replay_available": {"const": false}},
        "required": ["replay_available"]
      },
      "then": {
        "required": ["replay_gap_reason"],
        "properties": {
          "replay_gap_reason": {"type": "string", "minLength": 1},
          "replay_refs": {"type": "array", "maxItems": 0}
        }
      }
    }
  ]
}
