{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/working_paper_bundle.schema.json",
  "title": "Working Paper Bundle",
  "description": "Governed output bundle produced by the Working Paper Engine. Contains the structured report, FAQ, gap register, validation checklist, results readiness status, traceability requirements, validation results, and metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "source_artifact_ids",
    "report",
    "faq",
    "gap_register",
    "validation_checklist",
    "results_readiness",
    "traceability_requirements",
    "validation",
    "metadata"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^WPE-[A-F0-9]{12}$",
      "description": "Unique artifact identifier for this bundle."
    },
    "source_artifact_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of all source artifacts (documents, transcripts, study plans) used as inputs."
    },
    "report": {
      "$ref": "#/$defs/report",
      "description": "The structured working paper report."
    },
    "faq": {
      "type": "array",
      "items": { "$ref": "#/$defs/faq_item" },
      "description": "Extracted FAQ items with section references."
    },
    "gap_register": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap_item" },
      "description": "Gap register entries referencing report sections."
    },
    "validation_checklist": {
      "type": "array",
      "items": { "$ref": "#/$defs/validation_finding" },
      "description": "All validation findings (passes, warnings, and errors)."
    },
    "results_readiness": {
      "$ref": "#/$defs/results_readiness",
      "description": "Readiness status for quantitative results."
    },
    "traceability_requirements": {
      "$ref": "#/$defs/traceability_requirements",
      "description": "Required traceability artifacts, mappings, and reproducibility inputs."
    },
    "validation": {
      "$ref": "#/$defs/validation_result",
      "description": "Categorized validation outcomes."
    },
    "metadata": {
      "$ref": "#/$defs/bundle_metadata",
      "description": "Engine version, timestamp, input summary, and provenance mode."
    }
  },
  "$defs": {
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "sections"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Title of the working paper."
        },
        "sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/report_section" },
          "minItems": 7,
          "description": "Ordered list of the seven report sections."
        }
      }
    },
    "report_section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section_id", "title", "content"],
      "properties": {
        "section_id": {
          "type": "string",
          "enum": ["1", "2", "3", "4", "5", "6", "7"],
          "description": "Section identifier (1–7)."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Section title."
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "description": "Section content text."
        }
      }
    },
    "faq_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["faq_id", "section_ref", "question", "source_refs"],
      "properties": {
        "faq_id": {
          "type": "string",
          "pattern": "^FAQ-[0-9]{3}$",
          "description": "FAQ item identifier."
        },
        "section_ref": {
          "type": "string",
          "description": "ID of the report section this FAQ item relates to."
        },
        "question": {
          "type": "string",
          "minLength": 10,
          "description": "The FAQ question text."
        },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Source observed-item IDs that prompted this question."
        }
      }
    },
    "gap_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap_id",
        "description",
        "section_ref",
        "gap_type",
        "impact",
        "blocking",
        "suggested_resolution",
        "source_refs"
      ],
      "properties": {
        "gap_id": {
          "type": "string",
          "pattern": "^GAP-[0-9]{3}$",
          "description": "Gap register item identifier."
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "Description of the gap."
        },
        "section_ref": {
          "type": "string",
          "description": "ID of the report section this gap is most relevant to."
        },
        "gap_type": {
          "type": "string",
          "enum": ["Data", "Methodology", "Assumption", "Validation", "Coordination", "Modeling", "Other"],
          "description": "Classification of the gap type."
        },
        "impact": {
          "type": "string",
          "enum": ["High", "Medium", "Low"],
          "description": "Impact level of the gap."
        },
        "blocking": {
          "type": "boolean",
          "description": "Whether this gap blocks results from being reported."
        },
        "suggested_resolution": {
          "type": "string",
          "minLength": 1,
          "description": "Suggested path to resolving this gap."
        },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Source observed-item IDs that produced this gap."
        }
      }
    },
    "validation_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "text", "category", "severity"],
      "properties": {
        "check_id": {
          "type": "string",
          "description": "Unique check identifier (e.g., VAL-001)."
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "Short description of the check result."
        },
        "category": {
          "type": "string",
          "enum": ["traceability", "consistency", "completeness", "safety", "results_readiness"],
          "description": "Validation category."
        },
        "severity": {
          "type": "string",
          "enum": ["pass", "warning", "error"],
          "description": "Severity of the finding."
        },
        "detail": {
          "type": "string",
          "description": "Optional additional detail for warnings and errors."
        }
      }
    },
    "results_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "quantitative_results_available",
        "missing_elements",
        "readiness_notes"
      ],
      "properties": {
        "quantitative_results_available": {
          "type": "boolean",
          "description": "Whether quantitative results are available for reporting."
        },
        "missing_elements": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of elements that must be resolved before results are available."
        },
        "readiness_notes": {
          "type": "string",
          "description": "Human-readable notes on readiness status."
        }
      }
    },
    "traceability_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_artifacts",
        "required_mappings",
        "required_reproducibility_inputs"
      ],
      "properties": {
        "required_artifacts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Artifact IDs required for full traceability."
        },
        "required_mappings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Required claim-to-source mappings."
        },
        "required_reproducibility_inputs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Inputs required for reproducible output."
        }
      }
    },
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passes", "warnings", "errors"],
      "properties": {
        "passes": {
          "type": "array",
          "items": { "$ref": "#/$defs/validation_finding" },
          "description": "Checks that passed."
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/validation_finding" },
          "description": "Checks that produced warnings."
        },
        "errors": {
          "type": "array",
          "items": { "$ref": "#/$defs/validation_finding" },
          "description": "Checks that produced errors."
        }
      }
    },
    "bundle_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "engine_version",
        "created_at",
        "input_summary",
        "provenance_mode"
      ],
      "properties": {
        "engine_version": {
          "type": "string",
          "minLength": 1,
          "description": "Version of the Working Paper Engine that produced this bundle."
        },
        "created_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of bundle creation."
        },
        "input_summary": {
          "type": "object",
          "description": "Summary statistics for the inputs.",
          "additionalProperties": true
        },
        "provenance_mode": {
          "type": "string",
          "enum": ["best_effort", "full"],
          "description": "Provenance tracking mode used during this run."
        }
      }
    }
  }
}
