{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/evaluation_monitor_record.schema.json",
  "title": "Evaluation Monitor Record",
  "description": "Schema supporting both legacy regression monitor records and control-loop run-bundle monitor records.",
  "oneOf": [
    {
      "$ref": "#/$defs/legacy_monitor_record"
    },
    {
      "$ref": "#/$defs/control_loop_monitor_record"
    }
  ],
  "$defs": {
    "legacy_monitor_record": {
      "type": "object",
      "required": [
        "monitor_record_id",
        "source_run_id",
        "source_suite_id",
        "created_at",
        "total_traces",
        "passed_traces",
        "failed_traces",
        "pass_rate",
        "average_reproducibility_score",
        "drift_counts",
        "indeterminate_count",
        "overall_status",
        "sli_snapshot",
        "alert_recommendation",
        "metadata"
      ],
      "additionalProperties": false,
      "properties": {
        "monitor_record_id": {"type": "string", "minLength": 1},
        "source_run_id": {"type": "string", "minLength": 1},
        "source_suite_id": {"type": "string", "minLength": 1},
        "created_at": {"type": "string", "format": "date-time"},
        "total_traces": {"type": "integer", "minimum": 0},
        "passed_traces": {"type": "integer", "minimum": 0},
        "failed_traces": {"type": "integer", "minimum": 0},
        "pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "average_reproducibility_score": {"type": "number", "minimum": 0, "maximum": 1},
        "drift_counts": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "indeterminate_count": {"type": "integer", "minimum": 0},
        "overall_status": {"type": "string", "enum": ["pass", "fail"]},
        "sli_snapshot": {
          "type": "object",
          "required": ["regression_pass_rate", "drift_rate", "average_reproducibility_score"],
          "additionalProperties": false,
          "properties": {
            "regression_pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
            "drift_rate": {"type": "number", "minimum": 0, "maximum": 1},
            "average_reproducibility_score": {"type": "number", "minimum": 0, "maximum": 1},
            "replay_status": {"type": "string", "enum": ["consistent", "drifted", "indeterminate"]},
            "replay_consistency_sli": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "alert_recommendation": {
          "type": "object",
          "required": ["level", "reasons"],
          "additionalProperties": false,
          "properties": {
            "level": {"type": "string", "enum": ["none", "warning", "critical"]},
            "reasons": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            }
          }
        },
        "metadata": {
          "type": "object",
          "required": ["schema_version", "generator"],
          "additionalProperties": false,
          "properties": {
            "schema_version": {"type": "string", "minLength": 1},
            "generator": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "control_loop_monitor_record": {
      "type": "object",
      "required": [
        "record_id",
        "run_id",
        "trace_id",
        "source_decision_id",
        "timestamp",
        "status",
        "validation_status",
        "system_response",
        "slis",
        "reasons"
      ],
      "additionalProperties": false,
      "properties": {
        "record_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "trace_id": {"type": "string", "minLength": 1},
        "source_decision_id": {"type": "string", "minLength": 1},
        "timestamp": {"type": "string", "format": "date-time"},
        "status": {"type": "string", "enum": ["healthy", "failed", "indeterminate"]},
        "validation_status": {"type": "string", "enum": ["valid", "invalid"]},
        "system_response": {"type": "string", "enum": ["allow", "block", "require_rebuild"]},
        "slis": {
          "type": "object",
          "required": [
            "manifest_valid",
            "inputs_present",
            "expected_outputs_declared",
            "output_paths_valid",
            "provenance_required",
            "bundle_validation_success_rate"
          ],
          "additionalProperties": false,
          "properties": {
            "manifest_valid": {"type": "number", "enum": [0, 1]},
            "inputs_present": {"type": "number", "enum": [0, 1]},
            "expected_outputs_declared": {"type": "number", "enum": [0, 1]},
            "output_paths_valid": {"type": "number", "enum": [0, 1]},
            "provenance_required": {"type": "number", "enum": [0, 1]},
            "bundle_validation_success_rate": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "validation_status": {"const": "invalid"}
            },
            "required": ["validation_status"]
          },
          "then": {
            "not": {
              "properties": {
                "status": {"const": "healthy"},
                "system_response": {"const": "allow"}
              },
              "required": ["status", "system_response"]
            }
          }
        }
      ]
    }
  }
}
