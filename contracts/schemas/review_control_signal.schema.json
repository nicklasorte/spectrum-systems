{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/review_control_signal.schema.json",
  "title": "Review Control Signal",
  "description": "Deterministic review-derived control signal consumed by control, PQX, promotion, and roadmap gating seams.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "signal_id",
    "review_id",
    "review_type",
    "gate_assessment",
    "scale_recommendation",
    "critical_findings",
    "confidence",
    "trace_linkage"
  ],
  "properties": {
    "artifact_type": { "type": "string", "const": "review_control_signal" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "signal_id": { "type": "string", "pattern": "^rcs-[a-f0-9]{16}$" },
    "review_id": { "type": "string", "minLength": 1 },
    "review_type": { "type": "string", "minLength": 1 },
    "gate_assessment": { "type": "string", "enum": ["PASS", "FAIL", "CONDITIONAL"] },
    "scale_recommendation": { "type": "string", "enum": ["YES", "NO"] },
    "critical_findings": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "trace_linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_markdown_path", "source_digest_sha256"],
      "properties": {
        "review_markdown_path": { "type": "string", "minLength": 1 },
        "source_digest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}
