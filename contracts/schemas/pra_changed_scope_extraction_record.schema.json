{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pra_changed_scope_extraction_record.schema.json",
  "title": "pra_changed_scope_extraction_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "pr_number",
    "changed_files",
    "changed_systems",
    "changed_contract_families",
    "changed_runtime_seams"
  ],
  "properties": {
    "artifact_type": {
      "const": "pra_changed_scope_extraction_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "PRA"
    },
    "pr_number": {
      "type": "integer"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_systems": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_contract_families": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_runtime_seams": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
