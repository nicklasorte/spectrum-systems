{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/context_conflict_record.schema.json",
  "title": "Context Conflict Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "conflict_id",
    "source_a",
    "source_b",
    "field",
    "resolution_status"
  ],
  "properties": {
    "artifact_type": {
      "const": "context_conflict_record"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "conflict_id": {
      "type": "string",
      "pattern": "^ccr-[a-f0-9]{16}$"
    },
    "source_a": {
      "type": "string"
    },
    "source_b": {
      "type": "string"
    },
    "field": {
      "type": "string"
    },
    "resolution_status": {
      "type": "string",
      "enum": [
        "open",
        "resolved"
      ]
    }
  }
}
