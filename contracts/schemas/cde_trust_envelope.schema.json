{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/cde_trust_envelope.schema.json",
  "title": "cde_trust_envelope",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_type": { "type": "string", "const": "cde_trust_envelope" },
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_version": { "type": "string", "const": "1.0.0" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "standards_version": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "owner_system": { "type": "string", "pattern": "^[A-Z0-9]{2,8}$" },
    "envelope_id": { "type": "string", "minLength": 1 },
    "contents": { "type": "object" },
    "bundle_hash": { "type": "string", "minLength": 1 },
    "signature": { "type": "string", "minLength": 1 },
    "locked": { "type": "boolean" },
    "locked_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "artifact_type", "artifact_id", "artifact_version", "schema_version",
    "standards_version", "trace_id", "created_at", "owner_system",
    "envelope_id", "contents", "bundle_hash", "signature", "locked"
  ]
}
