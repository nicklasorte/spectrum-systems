{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/3ls_operator_debuggability_record.schema.json",
  "title": "3LS Operator Debuggability Record",
  "description": "Measurement of whether a failure can be understood by an operator without reading raw logs. Observation only; does not authorize remediation or modify SEL behavior. Fail-closed: single_artifact_debuggable=true requires at least one required_artifact_refs entry.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "trace_id",
    "created_at",
    "provenance",
    "failure_class",
    "root_cause_present",
    "next_action_present",
    "single_artifact_debuggable",
    "required_artifact_refs",
    "authority_scope"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "3ls_operator_debuggability_record"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "trace_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_system", "inputs"],
      "properties": {
        "source_system": {"type": "string", "pattern": "^[A-Z0-9]{2,8}$"},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "simulated": {"type": "boolean"}
      }
    },
    "record_id": {"type": "string"},
    "failure_class": {
      "type": "string",
      "enum": [
        "pytest_selection_missing",
        "schema_validation_failure",
        "contract_drift",
        "handoff_incomplete",
        "loop_incomplete",
        "eval_gate_missing",
        "policy_violation",
        "replay_mismatch",
        "ci_infrastructure",
        "lint_failure",
        "unknown"
      ]
    },
    "root_cause_present": {"type": "boolean"},
    "next_action_present": {"type": "boolean"},
    "single_artifact_debuggable": {"type": "boolean"},
    "required_artifact_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "authority_scope": {"type": "string", "const": "observation_only"},
    "notes": {"type": "string"}
  },
  "allOf": [
    {
      "description": "single_artifact_debuggable=true requires at least one required_artifact_refs entry.",
      "if": {
        "properties": {"single_artifact_debuggable": {"const": true}},
        "required": ["single_artifact_debuggable"]
      },
      "then": {
        "properties": {
          "required_artifact_refs": {"type": "array", "minItems": 1}
        }
      }
    }
  ]
}
