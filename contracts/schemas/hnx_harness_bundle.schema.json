{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hnx_harness_bundle.schema.json",
  "title": "Hnx Harness Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "bundle_id",
    "run_id",
    "trace_id",
    "input_fingerprint",
    "eval_ref",
    "continuity_refs",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "hnx_harness_bundle"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "input_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "eval_ref": {
      "type": "string",
      "pattern": "^hnx_harness_eval_result:.+"
    },
    "continuity_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
