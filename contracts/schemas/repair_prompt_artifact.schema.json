{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/repair_prompt_artifact.schema.json",
  "title": "Repair Prompt Artifact",
  "description": "Deterministic minimal Codex-ready repair prompt derived from a failure diagnosis artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "standards_version",
    "repair_prompt_id",
    "diagnosis_ref",
    "target_files_or_surfaces",
    "repair_intent",
    "smallest_safe_fix_description",
    "step_by_step_actions",
    "validation_commands",
    "constraints",
    "success_criteria",
    "repair_prompt_text",
    "emitted_at",
    "trace"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "repair_prompt_artifact"
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "repair_prompt_id": {
      "type": "string",
      "pattern": "^RPR-[a-f0-9]{20}$"
    },
    "diagnosis_ref": {
      "type": "string",
      "pattern": "^FDIAG-[a-f0-9]{20}$"
    },
    "target_files_or_surfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "repair_intent": {
      "type": "string",
      "minLength": 1
    },
    "smallest_safe_fix_description": {
      "type": "string",
      "minLength": 1
    },
    "step_by_step_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "repair_prompt_text": {
      "type": "string",
      "minLength": 1
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "trace_id",
        "policy_id",
        "governing_ref",
        "diagnosis_hash",
        "template_id"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "policy_id": {
          "type": "string",
          "const": "FRE-004.repair_prompt_generator.v1"
        },
        "governing_ref": {
          "type": "string",
          "const": "docs/roadmaps/system_roadmap.md#batch-fre-02"
        },
        "diagnosis_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "template_id": {
          "type": "string",
          "enum": [
            "missing_required_surface",
            "schema_example_drift",
            "producer_wiring_gap",
            "consumer_wiring_gap",
            "invariant_violation",
            "test_expectation_drift",
            "manifest_or_registry_mismatch",
            "control_surface_input_missing",
            "override_temporal_validation_gap",
            "corroboration_validation_gap"
          ]
        }
      }
    }
  }
}
