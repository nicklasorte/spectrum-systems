{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prompt_queue_step_decision.schema.json",
  "title": "Prompt Queue Step Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "step_id",
    "decision",
    "reason_codes",
    "blocking_reasons",
    "derived_from_artifacts",
    "timestamp",
    "generator_version",
    "validation_result_refs",
    "review_evidence_ref",
    "preflight_decision"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "step_id": {
      "type": "string",
      "pattern": "^step-[0-9]{3}$"
    },
    "queue_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "trace_linkage": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "warn",
        "block"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "clean_findings",
          "warnings_detected",
          "errors_detected",
          "ambiguity_detected",
          "invalid_report"
        ]
      }
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "execution_status",
          "error_summary",
          "output_reference",
          "artifact_reference",
          "validation",
          "fail_closed",
          "review"
        ]
      }
    },
    "derived_from_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "validation_result_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_evidence_ref": {
      "type": "string",
      "minLength": 1
    },
    "preflight_decision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "BLOCK"
      ]
    }
  },
  "anyOf": [
    {
      "required": [
        "queue_id"
      ]
    },
    {
      "required": [
        "trace_linkage"
      ]
    }
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "block"
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "blocking_reasons": {
            "minItems": 1
          }
        },
        "required": [
          "blocking_reasons"
        ]
      }
    }
  ]
}
