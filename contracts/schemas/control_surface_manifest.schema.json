{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/control_surface_manifest.schema.json",
  "title": "Control Surface Manifest",
  "description": "Deterministic governed inventory of active control surfaces with invariant and test coverage mapping.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "manifest_status",
    "deterministic_build_identity",
    "surfaces",
    "gap_signals",
    "summary"
  ],
  "properties": {
    "artifact_type": {"const": "control_surface_manifest"},
    "schema_version": {"const": "1.0.0"},
    "manifest_status": {"type": "string", "enum": ["complete", "gaps_detected"]},
    "deterministic_build_identity": {"type": "string", "pattern": "^csm-[a-f0-9]{16}$"},
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/surface"}
    },
    "gap_signals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uncovered_surfaces",
        "surfaces_missing_invariants",
        "surfaces_missing_required_refs",
        "surfaces_missing_targeted_tests",
        "contradictory_surface_metadata"
      ],
      "properties": {
        "uncovered_surfaces": {"$ref": "#/$defs/string_array"},
        "surfaces_missing_invariants": {"$ref": "#/$defs/string_array"},
        "surfaces_missing_required_refs": {"$ref": "#/$defs/string_array"},
        "surfaces_missing_targeted_tests": {"$ref": "#/$defs/string_array"},
        "contradictory_surface_metadata": {"$ref": "#/$defs/string_array"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_surfaces",
        "fully_covered_surfaces",
        "partially_covered_surfaces",
        "uncovered_surfaces_count",
        "blocking_gaps_present"
      ],
      "properties": {
        "total_surfaces": {"type": "integer", "minimum": 1},
        "fully_covered_surfaces": {"type": "integer", "minimum": 0},
        "partially_covered_surfaces": {"type": "integer", "minimum": 0},
        "uncovered_surfaces_count": {"type": "integer", "minimum": 0},
        "blocking_gaps_present": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "invariant_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invariants_applied",
        "invariant_source_module",
        "invariant_enforcement_mode",
        "invariant_blocking_effect"
      ],
      "properties": {
        "invariants_applied": {"$ref": "#/$defs/string_array"},
        "invariant_source_module": {"type": "string"},
        "invariant_enforcement_mode": {"type": "string", "enum": ["hard_block", "soft_signal", "none"]},
        "invariant_blocking_effect": {"type": "string", "minLength": 1}
      }
    },
    "test_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["covering_test_files", "critical_test_names", "coverage_status"],
      "properties": {
        "covering_test_files": {"$ref": "#/$defs/string_array"},
        "critical_test_names": {"$ref": "#/$defs/string_array"},
        "coverage_status": {"type": "string", "enum": ["covered", "partially_covered", "uncovered"]}
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "surface_name",
        "surface_category",
        "owning_module",
        "entrypoint_function",
        "decision_scope",
        "enforcement_scope",
        "artifact_types_consumed",
        "artifact_types_emitted",
        "required_refs",
        "optional_refs",
        "fail_closed",
        "promotion_blocking",
        "certification_blocking",
        "invariant_coverage",
        "test_coverage"
      ],
      "properties": {
        "surface_id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "surface_name": {"type": "string", "minLength": 1},
        "surface_category": {
          "type": "string",
          "enum": ["runtime_decision", "governance_validation", "promotion_certification"]
        },
        "owning_module": {"type": "string", "minLength": 1},
        "entrypoint_function": {"type": "string", "minLength": 1},
        "decision_scope": {"type": "string", "minLength": 1},
        "enforcement_scope": {"type": "string", "minLength": 1},
        "artifact_types_consumed": {"$ref": "#/$defs/string_array"},
        "artifact_types_emitted": {"$ref": "#/$defs/string_array"},
        "required_refs": {"$ref": "#/$defs/string_array"},
        "optional_refs": {"$ref": "#/$defs/string_array"},
        "fail_closed": {"type": "boolean"},
        "promotion_blocking": {"type": "boolean"},
        "certification_blocking": {"type": "boolean"},
        "invariant_coverage": {"$ref": "#/$defs/invariant_coverage"},
        "test_coverage": {"$ref": "#/$defs/test_coverage"}
      }
    }
  }
}
