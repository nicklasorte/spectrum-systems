{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/eval_requirement_profile.schema.json",
  "title": "eval_requirement_profile",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "artifact_type": {
      "const": "eval_requirement_profile"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace_id": {
      "type": "string"
    },
    "policy_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evaluation_refs": {
      "type": "object",
      "required": [
        "control_decision"
      ]
    }
  },
  "required": [
    "artifact_type",
    "schema_version",
    "trace_id",
    "policy_rules",
    "evaluation_refs"
  ]
}
