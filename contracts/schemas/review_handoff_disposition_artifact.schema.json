{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/review_handoff_disposition_artifact.schema.json",
  "title": "Review Handoff Disposition Artifact",
  "description": "Bounded control/scheduling disposition artifact classifying unresolved review operator handoff outcomes without triggering execution or recursion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "standards_version",
    "disposition_id",
    "source_handoff_ref",
    "source_review_fix_execution_result_ref",
    "source_review_result_ref",
    "source_review_id",
    "disposition",
    "permitted_follow_on",
    "required_human_action",
    "scheduling_eligible",
    "reason_code",
    "rationale",
    "provenance",
    "trace_linkage",
    "emitted_at"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "review_handoff_disposition_artifact"},
    "artifact_version": {"type": "string", "const": "1.0.0"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "standards_version": {"type": "string", "const": "1.0.0"},
    "disposition_id": {"type": "string", "pattern": "^rhda:.+"},
    "source_handoff_ref": {"type": "string", "pattern": "^review_operator_handoff_artifact:.+"},
    "source_review_fix_execution_result_ref": {
      "type": "string",
      "pattern": "^review_fix_execution_result_artifact:.+"
    },
    "source_review_result_ref": {"type": ["string", "null"], "pattern": "^review_result_artifact:.+"},
    "source_review_id": {"type": "string", "minLength": 1},
    "disposition": {
      "type": "string",
      "enum": [
        "manual_review_required",
        "schedule_follow_on_cycle",
        "hold_pending_input",
        "escalate_to_owner",
        "no_further_action",
        "request_checkpoint_decision"
      ]
    },
    "permitted_follow_on": {
      "type": "string",
      "enum": ["not_permitted", "permitted_with_explicit_operator_action", "checkpoint_decision_required"]
    },
    "required_human_action": {"type": "boolean"},
    "scheduling_eligible": {"type": "boolean"},
    "escalation_owner_ref": {"type": ["string", "null"], "minLength": 1},
    "reason_code": {
      "type": "string",
      "enum": [
        "unresolved_fix_required",
        "not_safe_to_merge",
        "execution_failed",
        "tpa_blocked",
        "checkpoint_missing",
        "policy_blocked",
        "missing_prerequisite",
        "high_risk_findings_present"
      ]
    },
    "rationale": {"type": "string", "minLength": 1},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classified_by_system",
        "execution_triggered",
        "rqx_cycle_reentry_triggered",
        "closure_authority_transferred"
      ],
      "properties": {
        "classified_by_system": {"type": "string", "const": "TLC"},
        "execution_triggered": {"type": "boolean", "const": false},
        "rqx_cycle_reentry_triggered": {"type": "boolean", "const": false},
        "closure_authority_transferred": {"type": "boolean", "const": false}
      }
    },
    "trace_linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["handoff_id", "request_ref", "fix_slice_ref", "tpa_artifact_ref", "pqx_execution_ref"],
      "properties": {
        "handoff_id": {"type": "string", "pattern": "^roha:.+"},
        "request_ref": {"type": "string", "pattern": "^review_fix_execution_request_artifact:.+"},
        "fix_slice_ref": {"type": "string", "pattern": "^review_fix_slice_artifact:.+"},
        "tpa_artifact_ref": {"type": "string", "pattern": "^tpa_slice_artifact:.+"},
        "pqx_execution_ref": {"type": ["string", "null"]}
      }
    },
    "emitted_at": {"type": "string", "format": "date-time"}
  }
}
