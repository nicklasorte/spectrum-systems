{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hnx_readiness_certification_record.schema.json",
  "title": "HNX Readiness Certification Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "certification_id",
    "run_id",
    "trace_id",
    "status",
    "checks",
    "fail_reasons",
    "non_authority_proof_refs",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "hnx_readiness_certification_record"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "certification_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "pass",
        "fail"
      ]
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "fail_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "non_authority_proof_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
