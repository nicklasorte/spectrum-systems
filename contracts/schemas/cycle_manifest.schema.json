{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/cycle_manifest.schema.json",
  "title": "Cycle Manifest",
  "description": "Deterministic fail-closed cycle-state artifact for autonomous control-loop progression.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cycle_id",
    "current_state",
    "roadmap_artifact_path",
    "source_authorities",
    "strategy_authority",
    "roadmap_review_artifact_paths",
    "execution_report_paths",
    "implementation_review_paths",
    "fix_roadmap_path",
    "fix_roadmap_markdown_path",
    "fix_group_refs",
    "fix_execution_report_paths",
    "certification_record_path",
    "blocking_issues",
    "next_action",
    "updated_at",
    "required_judgments",
    "judgment_scope",
    "judgment_environment",
    "judgment_policy_paths",
    "judgment_policy_lifecycle_paths",
    "judgment_policy_rollout_paths",
    "judgment_input_context",
    "judgment_evidence_refs",
    "judgment_precedent_record_paths",
    "judgment_record_path",
    "judgment_application_record_path",
    "judgment_eval_result_path",
    "drift_remediation_artifact_path",
    "fix_plan_artifact_path",
    "roadmap_eligibility_artifact_path",
    "next_step_decision_artifact_path",
    "selected_step_id",
    "selected_step_status",
    "decision_summary",
    "decision_blocked",
    "decision_block_reason",
    "eligibility_summary_snapshot",
    "eligible_step_ids_snapshot",
    "recommended_next_step_ids"
  ],
  "properties": {
    "cycle_id": {
      "type": "string",
      "pattern": "^cycle-[a-z0-9][a-z0-9-]*$"
    },
    "current_state": {
      "type": "string",
      "enum": [
        "draft_roadmap",
        "roadmap_under_review",
        "roadmap_approved",
        "execution_ready",
        "execution_in_progress",
        "execution_complete_unreviewed",
        "implementation_reviews_complete",
        "fix_roadmap_ready",
        "fixes_in_progress",
        "fixes_complete_unreviewed",
        "certification_pending",
        "certified_done",
        "blocked"
      ]
    },
    "roadmap_artifact_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "roadmap_review_artifact_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "execution_report_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_review_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fix_roadmap_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "fix_roadmap_markdown_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "fix_group_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fix_execution_report_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "certification_record_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "roadmap_approval_state": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "default": "pending"
    },
    "hard_gates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "roadmap_approved": {
          "type": "boolean"
        },
        "execution_contracts_pinned": {
          "type": "boolean"
        },
        "review_templates_present": {
          "type": "boolean"
        }
      }
    },
    "pqx_execution_request_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "done_certification_input_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "pqx_request_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "execution_started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "execution_completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "certification_status": {
      "type": "string",
      "enum": [
        "pending",
        "passed",
        "failed"
      ],
      "default": "pending"
    },
    "certification_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_step_decision_artifact_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "required_judgments": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "artifact_release_readiness"
        ]
      }
    },
    "judgment_scope": {
      "type": [
        "string",
        "null"
      ]
    },
    "judgment_environment": {
      "type": [
        "string",
        "null"
      ]
    },
    "judgment_policy_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "judgment_policy_lifecycle_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "judgment_policy_rollout_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "judgment_input_context": {
      "type": "object"
    },
    "judgment_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "judgment_precedent_record_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "judgment_record_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "judgment_application_record_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "judgment_eval_result_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "required_judgment_eval_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "evidence_coverage",
          "policy_alignment",
          "replay_consistency"
        ]
      },
      "uniqueItems": true
    },
    "judgment_replay_reference_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "strategy_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "version"
      ],
      "properties": {
        "path": {
          "type": "string",
          "const": "docs/architecture/system_strategy.md"
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_authorities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "path",
          "title"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^[A-Z0-9][A-Z0-9-]*$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "drift_remediation_artifact_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "fix_plan_artifact_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "roadmap_eligibility_artifact_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_step_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_step_status": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "authorized",
        null
      ]
    },
    "decision_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "decision_blocked": {
      "type": "boolean"
    },
    "decision_block_reason": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 500
    },
    "eligibility_summary_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_steps",
        "completed_steps",
        "eligible_steps",
        "blocked_steps"
      ],
      "properties": {
        "total_steps": {
          "type": "integer",
          "minimum": 0
        },
        "completed_steps": {
          "type": "integer",
          "minimum": 0
        },
        "eligible_steps": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_steps": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "eligible_step_ids_snapshot": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "recommended_next_step_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "next_step_decision_artifact_path": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "then": {
        "required": [
          "roadmap_eligibility_artifact_path",
          "selected_step_id",
          "selected_step_status"
        ],
        "properties": {
          "roadmap_eligibility_artifact_path": {
            "type": "string",
            "minLength": 1
          },
          "selected_step_id": {
            "type": "string",
            "minLength": 1
          },
          "selected_step_status": {
            "const": "authorized"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision_blocked": {
            "const": true
          }
        }
      },
      "then": {
        "properties": {
          "decision_block_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision_blocked": {
            "const": false
          }
        }
      },
      "then": {
        "properties": {
          "decision_block_reason": {
            "type": "null"
          }
        }
      }
    }
  ]
}
