{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/cycle_manifest.schema.json",
  "title": "Cycle Manifest",
  "description": "Deterministic fail-closed cycle-state artifact for autonomous control-loop progression.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cycle_id",
    "current_state",
    "roadmap_artifact_path",
    "roadmap_review_artifact_paths",
    "execution_report_paths",
    "implementation_review_paths",
    "fix_roadmap_path",
    "certification_record_path",
    "blocking_issues",
    "next_action",
    "updated_at"
  ],
  "properties": {
    "cycle_id": {"type": "string", "pattern": "^cycle-[a-z0-9][a-z0-9-]*$"},
    "current_state": {
      "type": "string",
      "enum": [
        "draft_roadmap",
        "roadmap_under_review",
        "roadmap_approved",
        "execution_ready",
        "execution_in_progress",
        "execution_complete_unreviewed",
        "implementation_reviews_complete",
        "fix_roadmap_ready",
        "fixes_in_progress",
        "fixes_complete_unreviewed",
        "certification_pending",
        "certified_done",
        "blocked"
      ]
    },
    "roadmap_artifact_path": {"type": ["string", "null"]},
    "roadmap_review_artifact_paths": {"type": "array", "items": {"type": "string"}},
    "execution_report_paths": {"type": "array", "items": {"type": "string"}},
    "implementation_review_paths": {"type": "array", "items": {"type": "string"}},
    "fix_roadmap_path": {"type": ["string", "null"]},
    "certification_record_path": {"type": ["string", "null"]},
    "blocking_issues": {"type": "array", "items": {"type": "string"}},
    "next_action": {"type": "string", "minLength": 1},
    "roadmap_approval_state": {
      "type": "string",
      "enum": ["pending", "approved", "rejected"],
      "default": "pending"
    },
    "hard_gates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "roadmap_approved": {"type": "boolean"},
        "execution_contracts_pinned": {"type": "boolean"},
        "review_templates_present": {"type": "boolean"}
      }
    },
    "pqx_execution_request_path": {"type": ["string", "null"]},
    "done_certification_input_refs": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
