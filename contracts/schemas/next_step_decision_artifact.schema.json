{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/next_step_decision_artifact.schema.json",
  "title": "Next Step Decision Artifact",
  "description": "Deterministic fail-closed non-authoritative next-step recommendation artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "cycle_id",
    "current_state",
    "recommendation_action",
    "recommendation_candidates",
    "blocking",
    "blocking_reasons",
    "required_inputs_missing",
    "drift_detected",
    "drift_reasons",
    "strategy_compliant",
    "source_grounded",
    "trust_score",
    "policy_id",
    "policy_version",
    "policy_hash",
    "eligibility_artifact_path",
    "eligible_step_ids_snapshot",
    "selected_step_id",
    "selection_basis",
    "decision_rationale",
    "decided_at",
    "remediation_required",
    "remediation_class",
    "blocking_reason_category",
    "drift_remediation_artifact_path",
    "fre_fix_plan_artifact_ref",
    "authority_level"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "cycle_id": {
      "type": "string",
      "pattern": "^cycle-[a-z0-9][a-z0-9-]*$"
    },
    "current_state": {
      "type": "string"
    },
    "recommendation_action": {
      "type": "string",
      "minLength": 1
    },
    "recommendation_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocking": {
      "type": "boolean"
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_inputs_missing": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "drift_detected": {
      "type": "boolean"
    },
    "drift_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "strategy_compliant": {
      "type": "boolean"
    },
    "source_grounded": {
      "type": "boolean"
    },
    "trust_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "decision_rationale": {
      "type": "string",
      "pattern": "^state=[a-z_]+;action=[a-z_]+;blocking=(true|false);reasons=[0-9]+;drift=(true|false);trust=[0-9]{1,3}$"
    },
    "decided_at": {
      "type": "string",
      "format": "date-time"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "policy_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "remediation_required": {
      "type": "boolean"
    },
    "remediation_class": {
      "type": [
        "string",
        "null"
      ]
    },
    "blocking_reason_category": {
      "type": [
        "string",
        "null"
      ]
    },
    "drift_remediation_artifact_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "fre_fix_plan_artifact_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "authority_level": {
      "type": "string",
      "const": "non_authoritative_recommendation"
    },
    "drift_remediation_artifact": {
      "type": [
        "object",
        "null"
      ]
    },
    "eligibility_artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "eligible_step_ids_snapshot": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "selected_step_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "selection_basis": {
      "type": "string",
      "const": "eligibility_constrained"
    }
  }
}
