{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/3ls_scope_risk_record.schema.json",
  "title": "3LS Scope Risk Record",
  "description": "Measurement of change scope and blast radius. Observation only; does not block, gate, or enforce. Fail-closed: changes that touch workflows AND schemas AND scripts must classify as 'high' or 'critical'.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "trace_id",
    "created_at",
    "provenance",
    "changed_systems",
    "changed_surfaces",
    "workflows_changed",
    "schemas_changed",
    "scripts_changed",
    "tests_changed",
    "scope_level",
    "authority_scope"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "3ls_scope_risk_record"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "trace_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_system", "inputs"],
      "properties": {
        "source_system": {"type": "string", "pattern": "^[A-Z0-9]{2,8}$"},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "simulated": {"type": "boolean"}
      }
    },
    "record_id": {"type": "string"},
    "changed_systems": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[A-Z0-9]{2,8}$"}
    },
    "changed_surfaces": {
      "type": "array",
      "items": {"type": "string"}
    },
    "workflows_changed": {"type": "boolean"},
    "schemas_changed": {"type": "boolean"},
    "scripts_changed": {"type": "boolean"},
    "tests_changed": {"type": "boolean"},
    "scope_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "authority_scope": {"type": "string", "const": "observation_only"},
    "notes": {"type": "string"}
  },
  "allOf": [
    {
      "description": "Changes touching workflows AND schemas AND scripts must classify as high or critical.",
      "if": {
        "properties": {
          "workflows_changed": {"const": true},
          "schemas_changed": {"const": true},
          "scripts_changed": {"const": true}
        },
        "required": ["workflows_changed", "schemas_changed", "scripts_changed"]
      },
      "then": {
        "properties": {
          "scope_level": {"enum": ["high", "critical"]}
        }
      }
    }
  ]
}
