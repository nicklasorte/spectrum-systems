{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/eval_registry_snapshot.schema.json",
  "title": "Eval Registry Snapshot",
  "description": "Governed immutable snapshot of dataset status and active eval admission policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "snapshot_id",
    "created_at",
    "provenance",
    "active_policy_id",
    "active_canonicalization_policy_id",
    "datasets"
  ],
  "properties": {
    "artifact_type": { "type": "string", "const": "eval_registry_snapshot" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "snapshot_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "run_id"],
      "properties": {
        "trace_id": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 }
      }
    },
    "active_policy_id": { "type": "string", "minLength": 1 },
    "active_canonicalization_policy_id": { "type": "string", "minLength": 1 },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "dataset_id",
          "dataset_version",
          "status",
          "intended_use",
          "canonicalization_policy_id",
          "approved_for_use"
        ],
        "properties": {
          "dataset_id": { "type": "string", "minLength": 1 },
          "dataset_version": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["draft", "candidate", "approved", "retired"]
          },
          "intended_use": {
            "type": "string",
            "enum": ["development", "pre_merge_gate", "runtime_gate", "replay", "audit"]
          },
          "canonicalization_policy_id": { "type": "string", "minLength": 1 },
          "approved_for_use": { "type": "boolean" }
        }
      }
    }
  }
}
