{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hnx_feedback_routing_record.schema.json",
  "title": "HNX Feedback Routing Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "routing_id",
    "feedback_id",
    "trace_id",
    "routes",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "hnx_feedback_routing_record"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "routing_id": {
      "type": "string",
      "minLength": 1
    },
    "feedback_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
