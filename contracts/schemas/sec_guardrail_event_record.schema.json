{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/sec_guardrail_event_record.schema.json",
  "title": "sec_guardrail_event_record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "sec_guardrail_event_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner_system": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,8}$"
    },
    "guardrail_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "allow",
        "block",
        "indeterminate"
      ]
    },
    "freeze_required": {
      "type": "boolean"
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "trace_id",
    "created_at",
    "owner_system",
    "guardrail_id",
    "event_type",
    "outcome",
    "freeze_required"
  ]
}
