{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/queue_governance_record.schema.json",
  "title": "queue_governance_record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "queue_governance_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner_system": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,8}$"
    },
    "queue_name": {
      "type": "string"
    },
    "depth": {
      "type": "integer",
      "minimum": 0
    },
    "capacity": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "type": "string",
      "enum": [
        "normal",
        "backpressure",
        "shed"
      ]
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "trace_id",
    "created_at",
    "owner_system",
    "queue_name",
    "depth",
    "capacity",
    "state"
  ]
}
