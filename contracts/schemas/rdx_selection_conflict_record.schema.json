{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/rdx_selection_conflict_record.schema.json",
  "title": "Rdx Selection Conflict Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "conflict_id",
    "trace_id",
    "created_at",
    "conflict_codes"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "rdx_selection_conflict_record"
    },
    "conflict_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "conflict_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
