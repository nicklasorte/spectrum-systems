{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/slo_budget_status_artifact.schema.json",
  "title": "slo_budget_status_artifact",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "slo_budget_status_artifact"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner_system": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,8}$"
    },
    "slo_name": {
      "type": "string"
    },
    "error_budget_remaining": {
      "type": "number"
    },
    "burn_rate": {
      "type": "number",
      "minimum": 0
    },
    "freeze_recommended": {
      "type": "boolean"
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "trace_id",
    "created_at",
    "owner_system",
    "slo_name",
    "error_budget_remaining",
    "burn_rate",
    "freeze_recommended"
  ]
}
