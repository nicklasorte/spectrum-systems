{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prl/prl_gate_result.schema.json",
  "title": "PRL Gate Result",
  "description": "PRL final gate decision artifact. Feeds CDE. control_decision authority remains with CDE; this record is PRL-emitted evidence only. Owned by PRL.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "id",
    "timestamp",
    "run_id",
    "trace_id",
    "trace_refs",
    "control_decision",
    "failure_count",
    "failure_classes",
    "failure_packet_refs",
    "repair_candidate_refs",
    "eval_candidate_refs",
    "blocking_reasons",
    "gate_passed"
  ],
  "properties": {
    "artifact_type": {
      "const": "prl_gate_result"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "pattern": "^prl-gate-[a-f0-9]{16}$"
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "related": { "type": "array", "items": { "type": "string" } }
      }
    },
    "control_decision": {
      "type": "string",
      "enum": ["block", "freeze", "warn", "allow"]
    },
    "failure_count": {
      "type": "integer",
      "minimum": 0
    },
    "failure_classes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "pytest_selection_missing",
          "authority_shape_violation",
          "system_registry_mismatch",
          "contract_schema_violation",
          "missing_required_artifact",
          "trace_missing",
          "replay_mismatch",
          "policy_mismatch",
          "timeout",
          "rate_limited",
          "unknown_failure"
        ]
      }
    },
    "failure_packet_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "repair_candidate_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "eval_candidate_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blocking_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gate_passed": {
      "type": "boolean"
    }
  }
}
