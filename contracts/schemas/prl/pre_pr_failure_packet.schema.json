{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prl/pre_pr_failure_packet.schema.json",
  "title": "Pre-PR Failure Packet",
  "description": "PRL-01: normalized, system-aware failure packet emitted after classification. Owned by PRL.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "id",
    "timestamp",
    "run_id",
    "trace_id",
    "trace_refs",
    "capture_record_ref",
    "failure_class",
    "owning_system",
    "control_signal",
    "normalized_message",
    "file_refs",
    "remediation_hint"
  ],
  "properties": {
    "artifact_type": {
      "const": "pre_pr_failure_packet"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "pattern": "^prl-pkt-[a-f0-9]{16}$"
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "related": { "type": "array", "items": { "type": "string" } }
      }
    },
    "capture_record_ref": {
      "type": "string",
      "pattern": "^pr_failure_capture_record:.+"
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "pytest_selection_missing",
        "authority_shape_violation",
        "system_registry_mismatch",
        "contract_schema_violation",
        "missing_required_artifact",
        "trace_missing",
        "replay_mismatch",
        "policy_mismatch",
        "timeout",
        "rate_limited",
        "unknown_failure"
      ]
    },
    "owning_system": {
      "type": "string",
      "minLength": 1
    },
    "control_signal": {
      "type": "string",
      "enum": ["failed_gate", "gate_hold", "gate_warn", "passed_gate"]
    },
    "normalized_message": {
      "type": "string",
      "minLength": 1
    },
    "file_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "remediation_hint": {
      "type": "string"
    }
  }
}
