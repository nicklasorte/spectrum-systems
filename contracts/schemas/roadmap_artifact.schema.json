{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/roadmap_artifact.schema.json",
  "title": "Roadmap Artifact",
  "description": "Deterministic governed roadmap artifact defining batch-level execution order, dependencies, and gate posture.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "roadmap_id",
    "schema_version",
    "title",
    "generated_at",
    "source_ref",
    "batches",
    "current_batch_id",
    "next_hard_gate"
  ],
  "properties": {
    "roadmap_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9_.-]*$"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "batches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "batch_id",
          "title",
          "step_ids",
          "depends_on",
          "required_signals",
          "hard_gate_after",
          "execution_mode",
          "trust_goal",
          "status"
        ],
        "properties": {
          "batch_id": {
            "type": "string",
            "pattern": "^BATCH-[A-Z]$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "step_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^BATCH-[A-Z]$"
            }
          },
          "required_signals": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "hard_gate_after": {
            "type": "boolean"
          },
          "execution_mode": {
            "type": "string",
            "enum": [
              "pqx_batch"
            ]
          },
          "trust_goal": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "not_started",
              "running",
              "completed",
              "blocked"
            ]
          }
        }
      }
    },
    "current_batch_id": {
      "type": "string",
      "pattern": "^BATCH-[A-Z]$"
    },
    "next_hard_gate": {
      "type": "string",
      "minLength": 1
    }
  }
}
