{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/contract_preflight_result_artifact.schema.json",
  "title": "Contract Preflight Result Artifact",
  "description": "Governed contract preflight status artifact consumed by PQX pre-execution control mapping.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "preflight_status",
    "changed_contracts",
    "impacted_producers",
    "impacted_fixtures",
    "impacted_consumers",
    "masking_detected",
    "recommended_repair_area",
    "report_paths",
    "generated_at",
    "control_surface_gap_status",
    "control_surface_gap_result_ref",
    "pqx_gap_work_items_ref",
    "control_surface_gap_blocking",
    "pytest_execution",
    "pqx_required_context_enforcement",
    "control_signal",
    "trace"
  ],
  "properties": {
    "artifact_type": {
      "const": "contract_preflight_result_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.2.0"
    },
    "preflight_status": {
      "type": "string",
      "enum": [
        "passed",
        "failed",
        "skipped"
      ]
    },
    "changed_contracts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "impacted_producers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "impacted_fixtures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "impacted_consumers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "masking_detected": {
      "type": "boolean"
    },
    "recommended_repair_area": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "report_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "json_report_path",
        "markdown_report_path"
      ],
      "properties": {
        "json_report_path": {
          "type": "string",
          "minLength": 1
        },
        "markdown_report_path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "control_surface_gap_status": {
      "type": "string",
      "enum": [
        "not_run",
        "ok",
        "gaps_detected",
        "conversion_failed"
      ]
    },
    "control_surface_gap_result_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "pqx_gap_work_items_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "control_surface_gap_blocking": {
      "type": "boolean"
    },
    "pytest_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_name",
        "pytest_execution_count",
        "pytest_commands",
        "selected_targets",
        "fallback_targets",
        "fallback_used",
        "targeted_selection_empty",
        "fallback_selection_empty"
      ],
      "properties": {
        "event_name": {"type": "string"},
        "pytest_execution_count": {"type": "integer", "minimum": 0},
        "pytest_commands": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "selected_targets": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "fallback_targets": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "fallback_used": {"type": "boolean"},
        "targeted_selection_empty": {"type": "boolean"},
        "fallback_selection_empty": {"type": "boolean"}
      }
    },
    "pqx_required_context_enforcement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification",
        "execution_context",
        "wrapper_present",
        "wrapper_context_valid",
        "authority_context_valid",
        "authority_state",
        "requires_pqx_execution",
        "enforcement_decision",
        "status",
        "blocking_reasons"
      ],
      "properties": {
        "classification": {
          "type": "string",
          "enum": [
            "governed_pqx_required",
            "exploration_only_or_non_governed"
          ]
        },
        "execution_context": {
          "type": "string",
          "minLength": 1
        },
        "wrapper_present": {
          "type": "boolean"
        },
        "wrapper_context_valid": {
          "type": "boolean"
        },
        "authority_context_valid": {
          "type": "boolean"
        },
        "authority_state": {
          "type": "string",
          "enum": [
            "authoritative_governed_pqx",
            "non_authoritative_direct_run",
            "unknown_pending_execution"
          ]
        },
        "requires_pqx_execution": {
          "type": "boolean"
        },
        "enforcement_decision": {
          "type": "string",
          "enum": [
            "allow",
            "block"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "allow",
            "block"
          ]
        },
        "blocking_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "control_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy_gate_decision",
        "rationale",
        "changed_path_detection_mode",
        "degraded_detection"
      ],
      "properties": {
        "strategy_gate_decision": {
          "type": "string",
          "enum": [
            "ALLOW",
            "WARN",
            "FREEZE",
            "BLOCK"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "changed_path_detection_mode": {
          "type": "string",
          "minLength": 1
        },
        "degraded_detection": {
          "type": "boolean"
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer",
        "policy_version",
        "refs_attempted",
        "fallback_used",
        "evaluation_mode",
        "skip_reason",
        "changed_paths_resolved",
        "evaluated_surfaces",
        "provenance_ref"
      ],
      "properties": {
        "producer": {
          "type": "string",
          "const": "scripts/run_contract_preflight.py"
        },
        "policy_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "refs_attempted": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "fallback_used": {
          "type": "boolean"
        },
        "evaluation_mode": {
          "type": "string",
          "enum": [
            "full",
            "partial",
            "no-op"
          ]
        },
        "skip_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "changed_paths_resolved": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "evaluated_surfaces": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "provenance_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
