{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum.systems/contracts/schemas/strategic_knowledge_validation_decision.schema.json",
  "title": "Strategic Knowledge Validation Decision",
  "description": "Governed admission decision for a strategic knowledge artifact candidate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "trace_id",
    "span_id",
    "artifact_id",
    "artifact_type",
    "schema_version",
    "evaluated_at",
    "validator_version",
    "provenance",
    "schema_valid",
    "source_refs_valid",
    "artifact_refs_valid",
    "evidence_anchor_coverage",
    "provenance_completeness",
    "trust_score",
    "issues",
    "system_response"
  ],
  "properties": {
    "decision_id": {
      "type": "string",
      "minLength": 1,
      "description": "Deterministic identifier for this validation decision artifact."
    },
    "trace_id": {
      "type": "string",
      "minLength": 1,
      "description": "Trace identifier linking this decision to the broader workflow trace."
    },
    "span_id": {
      "type": "string",
      "minLength": 1,
      "description": "Span identifier for the strategic knowledge validation decision operation."
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier of the strategic knowledge artifact that was evaluated."
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "book_intelligence_pack",
        "transcript_intelligence_pack",
        "story_bank_entry",
        "tactic_register",
        "viewpoint_pack",
        "evidence_map"
      ],
      "description": "Strategic knowledge artifact family for the candidate artifact."
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Schema version declared by the candidate artifact."
    },
    "evaluated_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp for when gate evaluation completed."
    },
    "validator_version": {
      "type": "string",
      "minLength": 1,
      "description": "Version of the Strategic Knowledge Validation Gate implementation."
    },
    "schema_valid": {
      "type": "boolean",
      "description": "Whether the candidate artifact conforms to its declared artifact contract schema."
    },
    "source_refs_valid": {
      "type": "boolean",
      "description": "Whether all declared source references resolve to registered source catalog entries with admissible status."
    },
    "artifact_refs_valid": {
      "type": "boolean",
      "description": "Whether declared artifact references resolve to known artifacts when references are present."
    },
    "evidence_anchor_coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Coverage ratio of structurally valid evidence anchors required for trust evaluation."
    },
    "provenance_completeness": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Completeness ratio for required provenance fields in the artifact payload."
    },
    "trust_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Deterministic trust score computed from governed sub-signals."
    },
    "issues": {
      "type": "array",
      "description": "Structured governance and validation findings collected during evaluation.",
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "system_response": {
      "type": "string",
      "enum": [
        "allow",
        "require_review",
        "require_rebuild",
        "block"
      ],
      "description": "Admission control outcome for the candidate artifact."
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "trace_id",
        "span_id",
        "parent_span_id",
        "source_artifacts",
        "generator",
        "timestamp",
        "artifact"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "span_id": {
          "type": "string",
          "minLength": 1
        },
        "parent_span_id": {
          "type": "string",
          "minLength": 1
        },
        "source_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact_type",
              "artifact_id"
            ],
            "properties": {
              "artifact_type": {
                "type": "string",
                "minLength": 1
              },
              "artifact_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "version"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifact_type",
            "artifact_id",
            "schema_version"
          ],
          "properties": {
            "artifact_type": {
              "type": "string",
              "minLength": 1
            },
            "artifact_id": {
              "type": "string",
              "minLength": 1
            },
            "schema_version": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "severity",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "description": "Stable machine-readable issue code."
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error"
          ],
          "description": "Issue severity classification."
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable issue description for operators/reviewers."
        }
      }
    }
  }
}
