{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems/contracts/schemas/test_inventory_integrity_result.schema.json",
  "title": "test_inventory_integrity_result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "owner_system",
    "policy_observation",
    "execution_system",
    "orchestration_system",
    "diagnosis_system",
    "registry_system",
    "configured_test_roots",
    "discovered_test_files",
    "collected_nodeids",
    "selected_nodeids",
    "collected_count",
    "selected_count",
    "baseline_expected_count",
    "baseline_expected_nodeids",
    "baseline_missing_nodeids",
    "baseline_unexpected_nodeids",
    "failure_class",
    "status",
    "blocking",
    "recommended_repair_route",
    "classification_detail",
    "execution_cwd",
    "repo_root"
  ],
  "properties": {
    "artifact_type": {"const": "test_inventory_integrity_result"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "owner_system": {"type": "string", "const": "PRG"},
    "policy_observation": {"type": "string", "const": "SEL"},
    "execution_system": {"type": "string", "const": "PQX"},
    "orchestration_system": {"type": "string", "const": "TLC"},
    "diagnosis_system": {"type": "string", "const": "FRE"},
    "registry_system": {"type": "string", "const": "SRG"},
    "configured_test_roots": {"type": "array", "items": {"type": "string"}},
    "discovered_test_files": {"type": "array", "items": {"type": "string"}},
    "collected_nodeids": {"type": "array", "items": {"type": "string"}},
    "selected_nodeids": {"type": "array", "items": {"type": "string"}},
    "collected_count": {"type": "integer", "minimum": 0},
    "selected_count": {"type": "integer", "minimum": 0},
    "baseline_expected_count": {"type": "integer", "minimum": 0},
    "baseline_expected_nodeids": {"type": "array", "items": {"type": "string"}},
    "baseline_missing_nodeids": {"type": "array", "items": {"type": "string"}},
    "baseline_unexpected_nodeids": {"type": "array", "items": {"type": "string"}},
    "failure_class": {
      "type": "string",
      "enum": [
        "pytest_config_missing",
        "pytest_config_mismatch",
        "testpaths_missing",
        "no_tests_discovered",
        "unexpected_test_inventory_regression",
        "import_resolution_failure",
        "collection_failure",
        "working_directory_mismatch",
        "accidental_filtering_detected",
        "success"
      ]
    },
    "status": {"type": "string", "enum": ["passed", "failed"]},
    "blocking": {"type": "boolean"},
    "recommended_repair_route": {"type": "string", "minLength": 1},
    "classification_detail": {"type": "string"},
    "execution_cwd": {"type": "string", "minLength": 1},
    "repo_root": {"type": "string", "minLength": 1},
    "pytest_config": {"type": "object", "additionalProperties": true},
    "selected_targets": {"type": "array", "items": {"type": "string"}},
    "collect_output_excerpt": {"type": "string"},
    "selected_output_excerpt": {"type": "string"},
    "baseline_status": {"type": "string"}
  }
}
