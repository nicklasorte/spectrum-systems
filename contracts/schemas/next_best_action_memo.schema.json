{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/next_best_action_memo.schema.json",
  "title": "Next Best Action Memo",
  "description": "Canonical memo recommending prioritized next actions with decision and risk linkages.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_class",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "record_id",
    "run_id",
    "created_at",
    "created_by",
    "source_repo",
    "source_repo_version",
    "program_id",
    "actions"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "next_best_action_memo",
      "description": "Canonical artifact type identifier."
    },
    "artifact_class": {
      "type": "string",
      "const": "coordination",
      "description": "Canonical artifact class identifier."
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^NBA-MEMO-[A-Z0-9._-]+$",
      "description": "Stable identifier for this memo instance."
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version of this artifact instance for diffing and rollback."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the next_best_action_memo schema."
    },
    "standards_version": {
      "type": "string",
      "const": "2026.03.0",
      "description": "Standards release version from contracts/standards-manifest.json."
    },
    "record_id": {
      "type": "string",
      "pattern": "^REC-[A-Z0-9._-]+$",
      "description": "Record identifier used for provenance and diffing."
    },
    "run_id": {
      "type": "string",
      "pattern": "^run-[A-Za-z0-9._-]+$",
      "description": "Deterministic run identifier for the workflow that produced this record."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this memo was generated."
    },
    "created_by": {
      "$ref": "#/$defs/created_by"
    },
    "source_repo": {
      "type": "string",
      "description": "Repository slug that published this contract instance."
    },
    "source_repo_version": {
      "type": "string",
      "description": "Tag or commit hash of the source repository."
    },
    "program_id": {
      "type": "string",
      "pattern": "^PRG-[A-Z0-9._-]+$",
      "description": "Program identifier this memo belongs to."
    },
    "summary": {
      "type": "string",
      "description": "High-level memo summary."
    },
    "source_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_artifact"
      },
      "description": "Traceable list of inputs used to assemble the memo."
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/action"
      },
      "description": "Prioritized actions with dependencies."
    }
  },
  "$defs": {
    "created_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "agent_type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "agent_type": {
          "type": "string",
          "enum": [
            "human",
            "ai_model",
            "workflow",
            "script",
            "automated_system",
            "ai_assistant"
          ]
        },
        "organization": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "source_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_type",
        "ref_id"
      ],
      "properties": {
        "ref_type": {
          "type": "string",
          "enum": [
            "artifact",
            "decision",
            "risk",
            "assumption",
            "milestone",
            "issue",
            "minutes_entry",
            "evidence"
          ]
        },
        "ref_id": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "provenance_id": {
          "type": "string"
        }
      }
    },
    "source_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "artifact_id",
        "role"
      ],
      "properties": {
        "artifact_type": {
          "type": "string"
        },
        "artifact_id": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "checksum_sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "title",
        "priority",
        "status"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "pattern": "^NBA-[A-Z0-9._-]+$"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "due_at": {
          "type": "string",
          "format": "date-time"
        },
        "priority": {
          "type": "string",
          "enum": [
            "urgent",
            "high",
            "medium",
            "low"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "in_progress",
            "blocked",
            "complete",
            "deferred"
          ]
        },
        "decision_dependency": {
          "type": "string",
          "pattern": "^DEC-[A-Z0-9][A-Z0-9._-]*$"
        },
        "related_risks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^RISK-[A-Z0-9._-]+$"
          }
        },
        "related_assumptions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ASM-[A-Z0-9._-]+$"
          }
        },
        "related_milestones": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^MS-[A-Z0-9._-]+$"
          }
        },
        "expected_outcome": {
          "type": "string"
        },
        "impact": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_reference"
          }
        }
      }
    }
  }
}
