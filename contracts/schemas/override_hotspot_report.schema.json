{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/override_hotspot_report.schema.json",
  "title": "override_hotspot_report",
  "description": "Deterministic report of high override concentration artifact families.",
  "type": "object",
  "additionalProperties": false,
  "required": ["report_id", "schema_version", "hotspots", "created_at", "trace_id"],
  "properties": {
    "report_id": {"type": "string", "pattern": "^OVH-[A-F0-9]{12}$"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "hotspots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_family", "override_rate"],
        "properties": {
          "artifact_family": {"type": "string", "minLength": 1},
          "override_rate": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "trace_id": {"type": "string", "pattern": "^trace-[A-Za-z0-9._:-]+$"}
  }
}
