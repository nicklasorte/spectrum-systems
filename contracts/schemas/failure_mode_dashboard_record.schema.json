{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems/contracts/failure_mode_dashboard_record.schema.json",
  "title": "failure_mode_dashboard_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "failure_modes"
  ],
  "properties": {
    "artifact_type": {
      "const": "failure_mode_dashboard_record"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "failure_modes": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mode",
          "affected_systems",
          "severity",
          "trend",
          "detection_mechanism",
          "control_response",
          "fix_status"
        ],
        "properties": {
          "mode": {
            "type": "string"
          },
          "affected_systems": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Z0-9]{3}$"
            }
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "trend": {
            "type": "string",
            "enum": [
              "up",
              "flat",
              "down"
            ]
          },
          "detection_mechanism": {
            "type": "string"
          },
          "control_response": {
            "type": "string"
          },
          "fix_status": {
            "type": "string",
            "enum": [
              "open",
              "in_progress",
              "closed"
            ]
          }
        }
      }
    }
  }
}
