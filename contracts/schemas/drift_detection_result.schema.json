{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/drift_detection_result.schema.json",
  "title": "Drift Detection Result",
  "description": "Deterministic drift comparison artifact between a governed current artifact and an approved baseline artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "timestamp",
    "trace_refs",
    "run_id",
    "policy_id",
    "baseline_id",
    "baseline_source",
    "comparison_target_id",
    "comparison_target_type",
    "drift_status",
    "compared_dimensions",
    "metrics",
    "triggered_thresholds",
    "reasons",
    "generated_by_version"
  ],
  "properties": {
    "artifact_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "artifact_type": { "type": "string", "const": "drift_detection_result" },
    "schema_version": { "type": "string", "const": "1.1.0" },
    "timestamp": { "type": "string", "format": "date-time" },
    "trace_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id"],
      "properties": {
        "trace_id": { "type": "string", "minLength": 1 }
      }
    },
    "run_id": { "type": "string", "minLength": 1 },
    "policy_id": { "type": "string", "minLength": 1 },
    "baseline_id": { "type": "string", "minLength": 1 },
    "baseline_source": {
      "type": "string",
      "enum": ["approved_replay_baseline", "approved_release_baseline"]
    },
    "comparison_target_id": { "type": "string", "minLength": 1 },
    "comparison_target_type": { "type": "string", "enum": ["replay_result"] },
    "drift_status": {
      "type": "string",
      "enum": ["no_drift", "within_threshold", "exceeds_threshold", "invalid_comparison"]
    },
    "compared_dimensions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "final_status_delta",
          "enforcement_action_delta",
          "consistency_mismatch_delta",
          "drift_detected_delta",
          "failure_reason_present_delta"
        ]
      },
      "uniqueItems": true
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "final_status_delta",
        "enforcement_action_delta",
        "consistency_mismatch_delta",
        "drift_detected_delta",
        "failure_reason_present_delta"
      ],
      "properties": {
        "final_status_delta": { "type": "number", "minimum": 0 },
        "enforcement_action_delta": { "type": "number", "minimum": 0 },
        "consistency_mismatch_delta": { "type": "number", "minimum": 0 },
        "drift_detected_delta": { "type": "number", "minimum": 0 },
        "failure_reason_present_delta": { "type": "number", "minimum": 0 }
      }
    },
    "triggered_thresholds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dimension", "severity", "value", "threshold"],
        "properties": {
          "dimension": {
            "type": "string",
            "enum": [
              "final_status_delta",
              "enforcement_action_delta",
              "consistency_mismatch_delta",
              "drift_detected_delta",
              "failure_reason_present_delta"
            ]
          },
          "severity": { "type": "string", "enum": ["warn", "block"] },
          "value": { "type": "number", "minimum": 0 },
          "threshold": { "type": "number", "minimum": 0 }
        }
      }
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "generated_by_version": { "type": "string", "minLength": 1 }
  }
}
