{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/roadmap_adjustment_record.schema.json",
  "title": "roadmap_adjustment_record",
  "description": "Deterministic governed roadmap adjustment artifact describing auditable mutations derived from bounded system signals.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "adjustment_id",
    "roadmap_id",
    "source_batch_id",
    "source_exception_ref",
    "adjustment_type",
    "target_batch_id",
    "new_position",
    "reason_codes",
    "supporting_signals",
    "affected_dependencies",
    "safety_classification",
    "requires_human_review",
    "created_at",
    "trace_id"
  ],
  "properties": {
    "adjustment_id": {"type": "string", "pattern": "^RADJ-[A-F0-9]{12}$"},
    "roadmap_id": {"type": "string", "minLength": 1},
    "source_batch_id": {"type": "string", "minLength": 1},
    "source_exception_ref": {"type": "string", "minLength": 3},
    "adjustment_type": {
      "type": "string",
      "enum": ["insert", "reorder", "defer", "block", "annotate"]
    },
    "target_batch_id": {"type": "string", "minLength": 1},
    "new_position": {"type": ["integer", "null"], "minimum": 1},
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "missing_eval_coverage",
          "replay_mismatch",
          "drift_detected",
          "unresolved_critical_risk",
          "review_required",
          "repeated_failure"
        ]
      },
      "uniqueItems": true
    },
    "supporting_signals": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "affected_dependencies": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "safety_classification": {
      "type": "string",
      "enum": ["governed_change", "hard_gate_block", "review_required", "defer_only"]
    },
    "requires_human_review": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "trace_id": {"type": "string", "pattern": "^trace-[A-Za-z0-9._:-]+$"}
  }
}
