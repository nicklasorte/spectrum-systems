{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/red_team_findings_record.schema.json",
  "title": "red_team_findings_record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_type": { "type": "string", "const": "red_team_findings_record" },
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_version": { "type": "string", "const": "1.0.0" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "standards_version": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "owner_system": { "type": "string", "pattern": "^[A-Z0-9]{2,8}$" },
    "round": { "type": "integer", "minimum": 1 },
    "campaign_count": { "type": "integer", "minimum": 0 },
    "timestamp": { "type": "string", "format": "date-time" },
    "results": { "type": "object" }
  },
  "required": [
    "artifact_type", "artifact_id", "artifact_version", "schema_version",
    "standards_version", "trace_id", "created_at", "owner_system",
    "round", "campaign_count", "timestamp", "results"
  ]
}
