{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum.systems/contracts/schemas/trace_span.schema.json",
  "title": "Trace Span",
  "description": "Deterministic trace span shape for governed validation outputs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "span_id",
    "trace_id",
    "parent_span_id",
    "name",
    "status",
    "start_time",
    "end_time",
    "events"
  ],
  "properties": {
    "span_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_span_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error",
        "blocked"
      ]
    },
    "start_time": {
      "type": "string",
      "format": "date-time"
    },
    "end_time": {
      "type": "string",
      "format": "date-time"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/trace_event"
      }
    }
  },
  "$defs": {
    "trace_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_type",
        "timestamp",
        "attributes"
      ],
      "properties": {
        "event_type": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "attributes": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "null"
            ]
          }
        }
      }
    }
  }
}
