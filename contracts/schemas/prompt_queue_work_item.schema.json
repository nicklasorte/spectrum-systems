{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prompt_queue_work_item.schema.json",
  "title": "Prompt Queue Work Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "work_item_id",
    "prompt_id",
    "title",
    "status",
    "priority",
    "risk_level",
    "repo",
    "branch",
    "scope_paths",
    "review_provider_primary",
    "review_provider_actual",
    "review_attempt_count",
    "review_fallback_used",
    "review_fallback_reason",
    "findings_artifact_path",
    "created_at",
    "updated_at",
    "repair_prompt_artifact_path",
    "gating_decision_artifact_path",
    "spawned_from_repair_prompt_artifact_path",
    "spawned_from_findings_artifact_path",
    "spawned_from_review_artifact_path",
    "generation_count",
    "repair_loop_generation",
    "child_work_item_ids",
    "loop_control_decision_artifact_path",
    "execution_result_artifact_path",
    "post_execution_decision_artifact_path",
    "next_step_action_artifact_path",
    "review_trigger_artifact_path",
    "review_invocation_result_artifact_path",
    "review_parsing_handoff_artifact_path",
    "findings_reentry_artifact_path",
    "spawned_from_execution_result_artifact_path",
    "spawned_from_post_execution_decision_artifact_path",
    "spawned_from_loop_control_decision_artifact_path"
  ],
  "properties": {
    "work_item_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_work_item_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "prompt_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "review_queued",
        "review_running",
        "review_provider_failed",
        "review_fallback_running",
        "review_complete",
        "findings_parsed",
        "repair_prompt_generated",
        "repair_child_created",
        "execution_gated",
        "runnable",
        "approval_required",
        "blocked",
        "executing",
        "executed_success",
        "executed_failure",
        "complete",
        "review_triggered",
        "review_invoking",
        "review_invocation_succeeded",
        "review_invocation_failed",
        "review_required",
        "reentry_blocked",
        "reentry_eligible"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "scope_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_provider_primary": {
      "type": "string",
      "const": "codex"
    },
    "review_provider_actual": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "claude",
        "codex",
        null
      ]
    },
    "review_attempt_count": {
      "type": "integer",
      "minimum": 0
    },
    "review_fallback_used": {
      "type": "boolean"
    },
    "review_fallback_reason": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "usage_limit",
        "rate_limited",
        "auth_failure",
        "timeout",
        "provider_unavailable",
        null
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "findings_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "repair_prompt_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "spawned_from_repair_prompt_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "spawned_from_findings_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "spawned_from_review_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "repair_loop_generation": {
      "type": "integer",
      "minimum": 0
    },
    "child_work_item_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "gating_decision_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "execution_result_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "post_execution_decision_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "next_step_action_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "generation_count": {
      "type": "integer",
      "minimum": 0
    },
    "loop_control_decision_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "review_trigger_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "spawned_from_execution_result_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "spawned_from_post_execution_decision_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "spawned_from_loop_control_decision_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "review_invocation_result_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "review_parsing_handoff_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "findings_reentry_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  }
}
