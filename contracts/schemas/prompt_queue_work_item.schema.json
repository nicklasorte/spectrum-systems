{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prompt_queue_work_item.schema.json",
  "title": "Prompt Queue Work Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "work_item_id",
    "prompt_id",
    "title",
    "status",
    "priority",
    "risk_level",
    "repo",
    "branch",
    "scope_paths",
    "review_provider_primary",
    "review_provider_actual",
    "review_attempt_count",
    "review_fallback_used",
    "review_fallback_reason",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "work_item_id": {"type": "string", "minLength": 1},
    "parent_work_item_id": {"type": ["string", "null"], "minLength": 1},
    "prompt_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "review_queued",
        "review_running",
        "review_provider_failed",
        "review_fallback_running",
        "review_complete",
        "blocked"
      ]
    },
    "priority": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
    "repo": {"type": "string", "minLength": 1},
    "branch": {"type": "string", "minLength": 1},
    "scope_paths": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "review_provider_primary": {"type": "string", "const": "claude"},
    "review_provider_actual": {"type": ["string", "null"], "enum": ["claude", "codex", null]},
    "review_attempt_count": {"type": "integer", "minimum": 0},
    "review_fallback_used": {"type": "boolean"},
    "review_fallback_reason": {
      "type": ["string", "null"],
      "enum": ["usage_limit", "rate_limited", "auth_failure", "timeout", "provider_unavailable", null]
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
