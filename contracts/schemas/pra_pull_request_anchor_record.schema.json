{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pra_pull_request_anchor_record.schema.json",
  "title": "pra_pull_request_anchor_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "repo_name",
    "pr_number",
    "pr_url",
    "base_sha",
    "head_sha",
    "changed_files",
    "ci_status",
    "failed_checks",
    "review_findings",
    "summary_of_changes",
    "exposed_gaps",
    "selected_pr_reason",
    "selection_mode"
  ],
  "properties": {
    "artifact_type": {
      "const": "pra_pull_request_anchor_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "PRA"
    },
    "repo_name": {
      "type": "string"
    },
    "pr_number": {
      "type": "integer"
    },
    "pr_url": {
      "type": "string"
    },
    "base_sha": {
      "type": "string"
    },
    "head_sha": {
      "type": "string"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ci_status": {
      "type": "string"
    },
    "failed_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary_of_changes": {
      "type": "string"
    },
    "exposed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "selected_pr_reason": {
      "type": "string"
    },
    "selection_mode": {
      "type": "string"
    }
  }
}
