{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/rge_amendment_record.schema.json",
  "title": "rge_amendment_record",
  "description": "Emitted by the RGE Self-Amender. Judgment-based amendments to a candidate roadmap.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "record_id",
    "run_id",
    "trace_id",
    "created_at",
    "roadmap_record_id",
    "redteam_record_id",
    "decision",
    "amendments",
    "touched_phase_ids",
    "rollout",
    "oscillation_count",
    "oscillation_ceiling",
    "dag_ok",
    "escalated"
  ],
  "properties": {
    "artifact_type": { "type": "string", "const": "rge_amendment_record" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "record_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "roadmap_record_id": { "type": "string" },
    "redteam_record_id": { "type": "string" },
    "decision": { "type": "string", "enum": ["apply", "block", "escalate", "no_amendment"] },
    "amendments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["amendment_type", "phase_id", "reason"],
        "properties": {
          "amendment_type": { "type": "string" },
          "phase_id": { "type": "string" },
          "reason": { "type": "string" },
          "owner": { "type": ["string", "null"] }
        }
      }
    },
    "touched_phase_ids": { "type": "array", "items": { "type": "string" } },
    "rollout": { "type": "string" },
    "oscillation_count": { "type": "integer", "minimum": 0 },
    "oscillation_ceiling": { "type": "integer", "minimum": 1 },
    "dag_ok": { "type": "boolean" },
    "escalated": { "type": "boolean" }
  }
}
