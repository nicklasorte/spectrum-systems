{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/required_eval_registry.schema.json",
  "title": "required_eval_registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "registry_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "policy_reference",
    "mappings",
    "created_at"
  ],
  "properties": {
    "artifact_type": {"const": "required_eval_registry"},
    "registry_id": {"type": "string", "pattern": "^RER-[A-Z0-9-]+$"},
    "artifact_version": {"type": "string", "pattern": "^1\\.0\\.0$"},
    "schema_version": {"type": "string", "pattern": "^1\\.0\\.0$"},
    "standards_version": {"type": "string", "minLength": 1},
    "policy_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_id", "policy_version"],
      "properties": {
        "policy_id": {"type": "string", "minLength": 1},
        "policy_version": {"type": "string", "minLength": 1}
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_family", "required_evals"],
        "properties": {
          "artifact_family": {"type": "string", "minLength": 1},
          "notes": {"type": "string", "minLength": 1},
          "required_evals": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["eval_id", "mandatory_for_progression"],
              "properties": {
                "eval_id": {"type": "string", "minLength": 1},
                "eval_family": {"type": "string", "minLength": 1},
                "mandatory_for_progression": {"type": "boolean"}
              }
            }
          }
        }
      }
    },
    "created_at": {"type": "string", "format": "date-time"}
  }
}
