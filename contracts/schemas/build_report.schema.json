{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/build_report.schema.json",
  "title": "Build Report",
  "description": "Governed build report artifact consumed by context selection.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "build_report_id",
    "target_scope",
    "status",
    "created_at",
    "source_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "build_report"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "build_report_id": {
      "type": "string",
      "pattern": "^br-[A-Za-z0-9-]{6,64}$"
    },
    "target_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_type", "scope_id"],
      "properties": {
        "scope_type": {
          "type": "string",
          "enum": ["slice_id", "batch_id", "program_id"]
        },
        "scope_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 256
      }
    }
  }
}
