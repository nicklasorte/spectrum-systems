{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spectrum-systems.org/contracts/issue_registry_artifact.json",
  "title": "Issue Registry Artifact",
  "description": "Registry of extracted issues with assignees, status, and transcript lineage.",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "artifact_type", "issues", "trace"],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^IRG-[0-9a-f]{8}$"},
    "artifact_type": {"type": "string", "const": "issue_registry_artifact"},
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_id", "title", "source_transcript_ref"],
        "additionalProperties": true,
        "properties": {
          "issue_id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "assignee": {"type": "string"},
          "status": {"type": "string", "enum": ["open", "in_progress", "resolved", "deferred"]},
          "source_transcript_ref": {"type": "string", "minLength": 1},
          "dependencies": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "trace": {
      "type": "object",
      "required": ["trace_id"],
      "properties": {
        "trace_id": {"type": "string", "minLength": 1},
        "upstream_artifact_id": {"type": "string"},
        "created_at": {"type": "string"}
      }
    }
  }
}
