{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hnx_contract_tightening_record.schema.json",
  "title": "HNX Contract Tightening Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "tightening_id",
    "feedback_id",
    "trace_id",
    "required_contract_fields",
    "failure_type",
    "tightening_action",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "hnx_contract_tightening_record"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "tightening_id": {
      "type": "string",
      "minLength": 1
    },
    "feedback_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "required_contract_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "failure_type": {
      "type": "string",
      "minLength": 1
    },
    "tightening_action": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
