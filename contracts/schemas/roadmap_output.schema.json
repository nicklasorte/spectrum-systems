{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems/contracts/schemas/roadmap_output.schema.json",
  "title": "roadmap_output",
  "description": "Fail-closed roadmap output contract requiring explicit strategy alignment and trust gain per step.",
  "type": "object",
  "required": [
    "steps"
  ],
  "properties": {
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "ID",
          "Prompt",
          "Status",
          "What It Does",
          "Why It Matters",
          "Strategy Alignment",
          "Primary Trust Gain"
        ],
        "properties": {
          "ID": {
            "type": "string",
            "minLength": 1
          },
          "Prompt": {
            "type": "string",
            "minLength": 1
          },
          "Status": {
            "type": "string",
            "minLength": 1
          },
          "What It Does": {
            "type": "string",
            "minLength": 1
          },
          "Why It Matters": {
            "type": "string",
            "minLength": 1
          },
          "Strategy Alignment": {
            "type": "string",
            "minLength": 1
          },
          "Primary Trust Gain": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
