{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/next_step_recommendation.schema.json",
  "title": "next_step_recommendation",
  "description": "Deterministic operator artifact recommending the next bounded roadmap step based on execution and integration validation outcomes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recommendation_id",
    "schema_version",
    "next_batch_id",
    "next_batch_candidate",
    "stop_reason",
    "continuation_decision",
    "why",
    "blockers",
    "required_reviews",
    "risk_summary",
    "next_step",
    "remediation_plan_ref",
    "remediation_steps",
    "remediation_plan",
    "candidate_evaluation",
    "artifact_refs",
    "trace_navigation",
    "replay_entry_points",
    "quick_links",
    "trace_id",
    "created_at",
    "source_refs"
  ],
  "properties": {
    "recommendation_id": {
      "type": "string",
      "pattern": "^NSR-[A-F0-9]{12}$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.5.0"
    },
    "next_batch_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^BATCH-[A-Z]$"
    },
    "why": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "required_reviews": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "risk_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "signals"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "signals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        }
      }
    },
    "next_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "why_now",
        "blocked_by",
        "watchouts",
        "required_artifacts"
      ],
      "properties": {
        "action": {
          "type": "string",
          "minLength": 3
        },
        "why_now": {
          "type": "string",
          "minLength": 3
        },
        "blocked_by": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "watchouts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        }
      }
    },
    "candidate_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ranking_policy",
        "candidates"
      ],
      "properties": {
        "ranking_policy": {
          "type": "string",
          "minLength": 3
        },
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "candidate_id",
              "action",
              "required_artifacts",
              "blockers",
              "risk_profile",
              "alignment_with_program",
              "score",
              "ranking_factors"
            ],
            "properties": {
              "candidate_id": {
                "type": "string",
                "minLength": 3
              },
              "action": {
                "type": "string",
                "minLength": 3
              },
              "required_artifacts": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 3
                },
                "uniqueItems": true
              },
              "blockers": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 3
                },
                "uniqueItems": true
              },
              "risk_profile": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "level",
                  "signals"
                ],
                "properties": {
                  "level": {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high"
                    ]
                  },
                  "signals": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 3
                    },
                    "uniqueItems": true
                  }
                }
              },
              "alignment_with_program": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "priority",
                  "justification"
                ],
                "properties": {
                  "priority": {
                    "type": "string",
                    "minLength": 3
                  },
                  "justification": {
                    "type": "string",
                    "minLength": 3
                  }
                }
              },
              "score": {
                "type": "integer",
                "minimum": 0
              },
              "ranking_factors": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "program_alignment",
                  "unblock_potential",
                  "risk_reduction",
                  "dependency_readiness",
                  "review_readiness"
                ],
                "properties": {
                  "program_alignment": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "unblock_potential": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "risk_reduction": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "dependency_readiness": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "review_readiness": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            }
          }
        },
        "why_not_selected": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "candidate_id",
              "reason",
              "score"
            ],
            "properties": {
              "candidate_id": {
                "type": "string",
                "minLength": 3
              },
              "reason": {
                "type": "string",
                "enum": [
                  "lower_priority",
                  "missing_dependency",
                  "program_constraint",
                  "tie_broken_by_candidate_id"
                ]
              },
              "score": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "artifact_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roadmap_multi_batch_run_result",
        "core_system_integration_validation",
        "trace_id",
        "replay_refs",
        "upstream_refs",
        "downstream_refs",
        "related_artifacts"
      ],
      "properties": {
        "roadmap_multi_batch_run_result": {
          "type": "string",
          "minLength": 3
        },
        "core_system_integration_validation": {
          "type": "string",
          "minLength": 3
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trace-[A-Za-z0-9._:-]+$"
        },
        "replay_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "upstream_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "downstream_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "related_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        }
      }
    },
    "trace_navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "execution_path",
        "decision_points",
        "influencing_artifacts",
        "layer_transitions",
        "replay_entry_points",
        "replay_ready"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "execution_path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "decision_points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "influencing_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "layer_transitions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Z]+->[A-Z]+$"
          },
          "uniqueItems": true
        },
        "replay_entry_points": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "replay_from_context",
            "replay_from_plan",
            "replay_from_execution",
            "replay_from_failure"
          ],
          "properties": {
            "replay_from_context": {
              "$ref": "#/$defs/replay_entry_point"
            },
            "replay_from_plan": {
              "$ref": "#/$defs/replay_entry_point"
            },
            "replay_from_execution": {
              "$ref": "#/$defs/replay_entry_point"
            },
            "replay_from_failure": {
              "$ref": "#/$defs/replay_entry_point"
            }
          }
        },
        "replay_ready": {
          "type": "boolean"
        }
      }
    },
    "replay_entry_points": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replay_from_context",
        "replay_from_plan",
        "replay_from_execution",
        "replay_from_failure"
      ],
      "properties": {
        "replay_from_context": {
          "$ref": "#/$defs/replay_entry_point"
        },
        "replay_from_plan": {
          "$ref": "#/$defs/replay_entry_point"
        },
        "replay_from_execution": {
          "$ref": "#/$defs/replay_entry_point"
        },
        "replay_from_failure": {
          "$ref": "#/$defs/replay_entry_point"
        }
      }
    },
    "quick_links": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace-[A-Za-z0-9._:-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "remediation_plan_ref": {
      "type": "string",
      "pattern": "^remediation_plan:RMP-[A-F0-9]{12}$"
    },
    "remediation_steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/remediation_step"
      }
    },
    "remediation_plan": {
      "$ref": "#/$defs/remediation_plan"
    },
    "continuation_decision": {
      "type": "string",
      "enum": [
        "continue",
        "stop",
        "escalate"
      ]
    },
    "stop_reason": {
      "type": "string",
      "minLength": 3
    },
    "next_batch_candidate": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^BATCH-[A-Z]$"
    }
  },
  "$defs": {
    "replay_entry_point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_artifacts",
        "trace_refs"
      ],
      "properties": {
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "trace_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        }
      }
    },
    "remediation_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "action",
        "why",
        "required_artifacts",
        "trace_refs"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "pattern": "^RMS-[0-9]{2}$"
        },
        "action": {
          "type": "string",
          "minLength": 3
        },
        "why": {
          "type": "string",
          "minLength": 3
        },
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "trace_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        }
      }
    },
    "remediation_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_id",
        "root_cause",
        "remediation_steps",
        "required_artifacts",
        "expected_outcome",
        "risk_level",
        "created_at",
        "trace_id"
      ],
      "properties": {
        "plan_id": {
          "type": "string",
          "pattern": "^RMP-[A-F0-9]{12}$"
        },
        "root_cause": {
          "type": "string",
          "minLength": 3
        },
        "remediation_steps": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/remediation_step"
          }
        },
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "expected_outcome": {
          "type": "string",
          "minLength": 3
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trace-[A-Za-z0-9._:-]+$"
        }
      }
    }
  }
}
