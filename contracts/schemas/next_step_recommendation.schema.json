{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/next_step_recommendation.schema.json",
  "title": "next_step_recommendation",
  "description": "Deterministic operator artifact recommending the next bounded roadmap step based on execution and integration validation outcomes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recommendation_id",
    "schema_version",
    "next_batch_id",
    "why",
    "blockers",
    "required_reviews",
    "risk_summary",
    "next_step",
    "candidate_evaluation",
    "artifact_refs",
    "trace_id",
    "created_at",
    "source_refs"
  ],
  "properties": {
    "recommendation_id": {"type": "string", "pattern": "^NSR-[A-F0-9]{12}$"},
    "schema_version": {"type": "string", "const": "1.2.0"},
    "next_batch_id": {"type": ["string", "null"], "pattern": "^BATCH-[A-Z]$"},
    "why": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 3},
      "uniqueItems": true
    },
    "blockers": {
      "type": "array",
      "items": {"type": "string", "minLength": 3},
      "uniqueItems": true
    },
    "required_reviews": {
      "type": "array",
      "items": {"type": "string", "minLength": 3},
      "uniqueItems": true
    },
    "risk_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "signals"],
      "properties": {
        "level": {"type": "string", "enum": ["low", "medium", "high"]},
        "signals": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        }
      }
    },
    "next_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "why_now", "blocked_by", "watchouts", "required_artifacts"],
      "properties": {
        "action": {"type": "string", "minLength": 3},
        "why_now": {"type": "string", "minLength": 3},
        "blocked_by": {
          "type": "array",
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        },
        "watchouts": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        },
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        }
      }
    },
    "candidate_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ranking_policy", "candidates"],
      "properties": {
        "ranking_policy": {"type": "string", "minLength": 3},
        "candidates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "candidate_id",
              "action",
              "required_artifacts",
              "blockers",
              "risk_profile",
              "alignment_with_program",
              "score",
              "ranking_factors"
            ],
            "properties": {
              "candidate_id": {"type": "string", "minLength": 3},
              "action": {"type": "string", "minLength": 3},
              "required_artifacts": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 3},
                "uniqueItems": true
              },
              "blockers": {
                "type": "array",
                "items": {"type": "string", "minLength": 3},
                "uniqueItems": true
              },
              "risk_profile": {
                "type": "object",
                "additionalProperties": false,
                "required": ["level", "signals"],
                "properties": {
                  "level": {"type": "string", "enum": ["low", "medium", "high"]},
                  "signals": {
                    "type": "array",
                    "minItems": 1,
                    "items": {"type": "string", "minLength": 3},
                    "uniqueItems": true
                  }
                }
              },
              "alignment_with_program": {
                "type": "object",
                "additionalProperties": false,
                "required": ["priority", "justification"],
                "properties": {
                  "priority": {"type": "string", "minLength": 3},
                  "justification": {"type": "string", "minLength": 3}
                }
              },
              "score": {"type": "integer", "minimum": 0},
              "ranking_factors": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "program_alignment",
                  "unblock_potential",
                  "risk_reduction",
                  "dependency_readiness",
                  "review_readiness"
                ],
                "properties": {
                  "program_alignment": {"type": "integer", "minimum": 0},
                  "unblock_potential": {"type": "integer", "minimum": 0},
                  "risk_reduction": {"type": "integer", "minimum": 0},
                  "dependency_readiness": {"type": "integer", "minimum": 0},
                  "review_readiness": {"type": "integer", "minimum": 0}
                }
              }
            }
          }
        },
        "why_not_selected": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["candidate_id", "reason", "score"],
            "properties": {
              "candidate_id": {"type": "string", "minLength": 3},
              "reason": {"type": "string", "enum": ["lower_priority", "missing_dependency", "program_constraint", "tie_broken_by_candidate_id"]},
              "score": {"type": "integer", "minimum": 0}
            }
          }
        }
      }
    },
    "artifact_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roadmap_multi_batch_run_result",
        "core_system_integration_validation",
        "trace_id",
        "replay_refs"
      ],
      "properties": {
        "roadmap_multi_batch_run_result": {"type": "string", "minLength": 3},
        "core_system_integration_validation": {"type": "string", "minLength": 3},
        "trace_id": {"type": "string", "pattern": "^trace-[A-Za-z0-9._:-]+$"},
        "replay_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        }
      }
    },
    "trace_id": {"type": "string", "pattern": "^trace-[A-Za-z0-9._:-]+$"},
    "created_at": {"type": "string", "format": "date-time"},
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
