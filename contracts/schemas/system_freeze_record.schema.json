{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.local/contracts/schemas/system_freeze_record.schema.json",
  "title": "System Freeze Record",
  "description": "Immutable record of a system being frozen (no further execution allowed).",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "record_id": {
      "type": "string",
      "description": "Unique record identifier"
    },
    "system_id": {
      "type": "string",
      "description": "ID of the system being frozen"
    },
    "prior_state": {
      "type": "string",
      "enum": ["active"],
      "description": "State prior to freeze (must be active)"
    },
    "current_state": {
      "type": "string",
      "enum": ["frozen"],
      "description": "State after freeze"
    },
    "reason": {
      "type": "string",
      "description": "Human-readable justification for freeze"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp of the transition"
    },
    "record_type": {
      "type": "string",
      "const": "system_freeze_record"
    }
  },
  "required": ["record_id", "system_id", "prior_state", "current_state", "reason", "timestamp"],
  "additionalProperties": true
}
