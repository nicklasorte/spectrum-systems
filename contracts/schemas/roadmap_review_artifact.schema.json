{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/roadmap_review_artifact.schema.json",
  "title": "Roadmap Review Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "cycle_id",
    "roadmap_path",
    "reviewer",
    "approval_state",
    "findings",
    "governance_provenance",
    "reviewed_at"
  ],
  "properties": {
    "artifact_id": {
      "type": "string"
    },
    "artifact_type": {
      "const": "roadmap_review_artifact"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "cycle_id": {
      "type": "string"
    },
    "roadmap_path": {
      "type": "string"
    },
    "reviewer": {
      "type": "string",
      "enum": [
        "claude",
        "codex",
        "human"
      ]
    },
    "approval_state": {
      "type": "string",
      "enum": [
        "approved",
        "changes_requested",
        "rejected"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "severity",
          "summary"
        ],
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "blocker",
              "required_fix",
              "optional_improvement"
            ]
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "governance_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy_authority",
        "source_authorities",
        "invariant_checks",
        "drift_findings"
      ],
      "properties": {
        "strategy_authority": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path",
            "version"
          ],
          "properties": {
            "path": {
              "type": "string",
              "const": "docs/architecture/system_strategy.md"
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "source_authorities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_id",
              "path"
            ],
            "properties": {
              "source_id": {
                "type": "string",
                "pattern": "^[A-Z0-9][A-Z0-9-]*$"
              },
              "path": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "invariant_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "invariant_id",
              "status"
            ],
            "properties": {
              "invariant_id": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "pass",
                  "fail"
                ]
              },
              "detail": {
                "type": "string"
              }
            }
          }
        },
        "drift_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "finding_id",
              "severity",
              "summary"
            ],
            "properties": {
              "finding_id": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "enum": [
                  "info",
                  "warn",
                  "block"
                ]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
