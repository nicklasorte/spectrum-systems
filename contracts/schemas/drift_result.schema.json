{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/drift_result.schema.json",
  "title": "Drift Result",
  "description": "Deterministic fail-closed replay drift classification artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "drift_result_id",
    "source_run_id",
    "replay_run_id",
    "drift_detected",
    "drift_type",
    "comparison_fields",
    "original_values",
    "replay_values",
    "drift_severity",
    "detection_timestamp",
    "provenance"
  ],
  "properties": {
    "drift_result_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "source_run_id": {
      "type": "string",
      "minLength": 1
    },
    "replay_run_id": {
      "type": "string",
      "minLength": 1
    },
    "drift_detected": {
      "type": "boolean"
    },
    "drift_type": {
      "type": "string",
      "enum": [
        "none",
        "status_mismatch",
        "action_mismatch",
        "missing_original",
        "missing_replay",
        "indeterminate"
      ]
    },
    "comparison_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "final_status",
          "enforcement_action"
        ]
      },
      "minItems": 2,
      "maxItems": 2
    },
    "original_values": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "final_status",
        "enforcement_action"
      ],
      "properties": {
        "final_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "enforcement_action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "replay_values": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "final_status",
        "enforcement_action"
      ],
      "properties": {
        "final_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "enforcement_action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "drift_severity": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "detection_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "trace_id",
        "span_id",
        "parent_span_id",
        "source_artifacts",
        "generator",
        "timestamp",
        "artifact"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "span_id": {
          "type": "string",
          "minLength": 1
        },
        "parent_span_id": {
          "type": "string",
          "minLength": 1
        },
        "source_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifact_type",
              "artifact_id"
            ],
            "properties": {
              "artifact_type": {
                "type": "string",
                "minLength": 1
              },
              "artifact_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "version"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "artifact": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifact_type",
            "artifact_id",
            "schema_version"
          ],
          "properties": {
            "artifact_type": {
              "type": "string",
              "minLength": 1
            },
            "artifact_id": {
              "type": "string",
              "minLength": 1
            },
            "schema_version": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
