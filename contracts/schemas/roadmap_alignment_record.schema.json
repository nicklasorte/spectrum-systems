{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/roadmap_alignment_record.schema.json",
  "title": "roadmap_alignment_record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_type": { "type": "string", "const": "roadmap_alignment_record" },
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_version": { "type": "string", "const": "1.0.0" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "standards_version": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "owner_system": { "type": "string", "pattern": "^[A-Z0-9]{2,8}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "roadmap_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "step_id": { "type": "string" },
          "title": { "type": "string" },
          "owner": { "type": "string" },
          "slis_improved": { "type": "array", "items": { "type": "string" } },
          "control_loops_strengthened": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  },
  "required": [
    "artifact_type", "artifact_id", "artifact_version", "schema_version",
    "standards_version", "trace_id", "created_at", "owner_system",
    "timestamp", "roadmap_items"
  ]
}
