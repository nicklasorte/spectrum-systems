{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/service_level_objective.schema.json",
  "title": "Service Level Objective",
  "description": "Governed deterministic SLO definition for runtime/replay observability metrics.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slo_id",
    "artifact_type",
    "schema_version",
    "timestamp",
    "service_name",
    "service_scope",
    "objective_window",
    "objectives",
    "policy_id",
    "generated_by_version"
  ],
  "properties": {
    "slo_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "artifact_type": {"type": "string", "const": "service_level_objective"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "timestamp": {"type": "string", "format": "date-time"},
    "service_name": {"type": "string", "minLength": 1},
    "service_scope": {
      "type": "string",
      "enum": ["runtime_control_surface", "replay_control_surface", "runtime_replay_control_surface"]
    },
    "objective_window": {
      "type": "string",
      "enum": ["per_run", "rolling_24h", "rolling_7d", "rolling_30d"]
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "metric_name",
          "target_operator",
          "target_value",
          "unit",
          "severity_on_breach",
          "description"
        ],
        "properties": {
          "metric_name": {
            "type": "string",
            "enum": [
              "replay_success_rate",
              "grounding_block_rate",
              "unsupported_claim_rate",
              "invalid_evidence_ref_rate",
              "drift_exceed_threshold_rate",
              "baseline_gate_block_rate",
              "regression_failure_rate"
            ]
          },
          "target_operator": {"type": "string", "enum": ["gte", "lte", "eq"]},
          "target_value": {"type": "number", "minimum": 0, "maximum": 1},
          "unit": {"type": "string", "enum": ["ratio"]},
          "severity_on_breach": {"type": "string", "enum": ["warn", "block"]},
          "description": {"type": "string", "minLength": 1}
        }
      },
      "uniqueItems": true
    },
    "policy_id": {"type": "string", "minLength": 1},
    "generated_by_version": {"type": "string", "minLength": 1}
  }
}
