{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/judgment_remediation_readiness_status.schema.json",
  "title": "Judgment Remediation Readiness Status",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "remediation_id",
    "current_lifecycle_state",
    "required_evidence_refs",
    "evidence_present_refs",
    "evidence_missing_refs",
    "required_thresholds",
    "thresholds_satisfied",
    "thresholds_not_satisfied",
    "closure_eligible",
    "blocking_reasons",
    "trace"
  ],
  "properties": {
    "artifact_type": {"const": "judgment_remediation_readiness_status"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "remediation_id": {"type": "string", "minLength": 1},
    "current_lifecycle_state": {"type": "string", "minLength": 1},
    "required_evidence_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "evidence_present_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "evidence_missing_refs": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "required_thresholds": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "thresholds_satisfied": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "thresholds_not_satisfied": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "closure_eligible": {"type": "boolean"},
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "missing_required_evidence",
          "missing_eval_result",
          "threshold_not_met",
          "missing_closure_artifact",
          "missing_reinstatement_artifact",
          "invalid_artifact_contract",
          "remediation_not_in_closure_state",
          "remediation_not_closed"
        ]
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "remediation_record_id",
        "closure_record_id",
        "reinstatement_record_id"
      ],
      "properties": {
        "trace_id": {"type": "string"},
        "remediation_record_id": {"type": "string"},
        "closure_record_id": {"type": "string"},
        "reinstatement_record_id": {"type": "string"}
      }
    }
  }
}
