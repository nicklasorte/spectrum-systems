{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/canary_analysis_record.schema.json",
  "title": "canary_analysis_record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "canary_analysis_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner_system": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,8}$"
    },
    "canary_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "delta_summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "metric": {
          "type": "string"
        },
        "candidate": {
          "type": "number"
        },
        "baseline": {
          "type": "number"
        }
      },
      "required": [
        "metric",
        "candidate",
        "baseline"
      ]
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "trace_id",
    "created_at",
    "owner_system",
    "canary_id",
    "status",
    "delta_summary"
  ]
}
