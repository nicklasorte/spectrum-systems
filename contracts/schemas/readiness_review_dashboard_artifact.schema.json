{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/readiness_review_dashboard_artifact.schema.json",
  "title": "Readiness Review Dashboard Artifact",
  "description": "RIL-005 deterministic read-only readiness/dashboard aggregate derived only from readiness_review_projection_artifact. Non-authoritative intake surface only; not an enforcement or policy-mutation decision artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_class",
    "schema_version",
    "readiness_review_dashboard_id",
    "source_readiness_projection_ref",
    "source_review_projection_bundle_ref",
    "source_review_path",
    "review_date",
    "system_scope",
    "dashboard_items",
    "blocker_present",
    "escalation_present",
    "counts_by_severity",
    "counts_by_type",
    "item_count",
    "emitted_at",
    "non_authoritative_notice",
    "provenance"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "readiness_review_dashboard_artifact"},
    "artifact_class": {"type": "string", "const": "coordination"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "readiness_review_dashboard_id": {"type": "string", "pattern": "^rda-[a-f0-9]{16}$"},
    "source_readiness_projection_ref": {"type": "string", "pattern": "^rdp-[a-f0-9]{16}$"},
    "source_review_projection_bundle_ref": {"type": "string", "pattern": "^rpb-[a-f0-9]{16}$"},
    "source_review_path": {"type": "string", "minLength": 1},
    "review_date": {"type": "string", "pattern": "^20\\d{2}-\\d{2}-\\d{2}$"},
    "system_scope": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
    "dashboard_items": {
      "type": "array",
      "items": {"$ref": "#/$defs/dashboardItem"}
    },
    "blocker_present": {"type": "boolean"},
    "escalation_present": {"type": "boolean"},
    "counts_by_severity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical", "high", "medium"],
      "properties": {
        "critical": {"type": "integer", "minimum": 0},
        "high": {"type": "integer", "minimum": 0},
        "medium": {"type": "integer", "minimum": 0}
      }
    },
    "counts_by_type": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "blocker_intake": {"type": "integer", "minimum": 0},
        "escalation_intake": {"type": "integer", "minimum": 0},
        "roadmap_priority_intake": {"type": "integer", "minimum": 0},
        "drift_watch_intake": {"type": "integer", "minimum": 0},
        "recovery_followup_intake": {"type": "integer", "minimum": 0},
        "governance_attention_intake": {"type": "integer", "minimum": 0}
      }
    },
    "item_count": {"type": "integer", "minimum": 0},
    "emitted_at": {"type": "string", "format": "date-time"},
    "non_authoritative_notice": {
      "type": "string",
      "const": "Read-only consumer intake/view artifact only; signals such as enforcement_block or control_escalation are non-authoritative and require independent governed decisions."
    },
    "provenance": {"$ref": "#/$defs/provenance"}
  },
  "$defs": {
    "traceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_path", "line_number", "source_excerpt"],
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "line_number": {"type": "integer", "minimum": 1},
        "source_excerpt": {"type": "string", "minLength": 1}
      }
    },
    "dashboardItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dashboard_item_id",
        "source_readiness_item_id",
        "input_type",
        "priority",
        "severity",
        "affected_systems",
        "rationale",
        "trace_refs"
      ],
      "properties": {
        "dashboard_item_id": {"type": "string", "pattern": "^rdb-[a-f0-9]{16}$"},
        "source_readiness_item_id": {"type": "string", "pattern": "^rdi-[a-f0-9]{16}$"},
        "input_type": {
          "type": "string",
          "enum": [
            "blocker_intake",
            "escalation_intake",
            "roadmap_priority_intake",
            "drift_watch_intake",
            "recovery_followup_intake",
            "governance_attention_intake"
          ]
        },
        "priority": {"type": "string", "enum": ["P0", "P1", "P2", "monitor"]},
        "severity": {"type": "string", "enum": ["critical", "high", "medium"]},
        "affected_systems": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z0-9_-]+$"}
        },
        "rationale": {"type": "string", "minLength": 1},
        "trace_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/traceRef"}
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter",
        "consumer_surface",
        "consumption_mode",
        "source_review_projection_bundle_ref",
        "source_readiness_projection_ref"
      ],
      "properties": {
        "adapter": {"type": "string", "const": "review_consumer_wiring"},
        "consumer_surface": {"type": "string", "const": "readiness_dashboard"},
        "consumption_mode": {"type": "string", "const": "projection_only_read_only"},
        "source_review_projection_bundle_ref": {"type": "string", "pattern": "^rpb-[a-f0-9]{16}$"},
        "source_readiness_projection_ref": {"type": "string", "pattern": "^rdp-[a-f0-9]{16}$"}
      }
    }
  }
}
