{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/schemas/transcript_pipeline/paper_draft_artifact.schema.json",
  "title": "Paper Draft Artifact",
  "description": "Initial working paper draft produced from a structured_issue_set. Subject to review and revision before promotion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "content_hash",
    "trace",
    "provenance",
    "created_at",
    "source_artifact_id",
    "title",
    "sections",
    "draft_version"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^PDA-[A-Z0-9_-]+$"
    },
    "artifact_type": {
      "type": "string",
      "const": "paper_draft_artifact"
    },
    "schema_ref": {
      "type": "string",
      "const": "transcript_pipeline/paper_draft_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "trace": {
      "$ref": "#/$defs/trace_context"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_artifact_id": {
      "type": "string",
      "description": "ID of the structured_issue_set this was derived from."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "abstract": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/paper_section"
      }
    },
    "draft_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "Draft version number (e.g., '1.0', '1.1')."
    },
    "word_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "trace_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "span_id"],
      "properties": {
        "trace_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
        "span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"},
        "parent_span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by", "input_artifact_ids"],
      "properties": {
        "produced_by": {"type": "string"},
        "input_artifact_ids": {"type": "array", "items": {"type": "string"}},
        "run_id": {"type": "string"}
      }
    },
    "paper_section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section_id", "title", "content"],
      "properties": {
        "section_id": {"type": "string"},
        "title": {"type": "string", "minLength": 1},
        "content": {"type": "string", "minLength": 1},
        "issue_cluster_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "order": {"type": "integer", "minimum": 1}
      }
    }
  }
}
