{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/schemas/transcript_pipeline/meeting_minutes_artifact.schema.json",
  "title": "Meeting Minutes Artifact",
  "description": "Structured meeting minutes extracted from a normalized transcript. Includes agenda items, decisions, and action items.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "content_hash",
    "trace",
    "provenance",
    "created_at",
    "source_artifact_id",
    "summary",
    "decisions",
    "action_items"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^MMA-[A-Z0-9_-]+$"
    },
    "artifact_type": {
      "type": "string",
      "const": "meeting_minutes_artifact"
    },
    "schema_ref": {
      "type": "string",
      "const": "transcript_pipeline/meeting_minutes_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "trace": {
      "$ref": "#/$defs/trace_context"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_artifact_id": {
      "type": "string",
      "description": "ID of the normalized_transcript this was derived from."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "High-level summary of the meeting."
    },
    "agenda_items": {
      "type": "array",
      "items": {"type": "string"}
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision_record"
      }
    },
    "action_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action_item"
      }
    },
    "attendees": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "trace_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "span_id"],
      "properties": {
        "trace_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
        "span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"},
        "parent_span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by", "input_artifact_ids"],
      "properties": {
        "produced_by": {"type": "string"},
        "input_artifact_ids": {"type": "array", "items": {"type": "string"}},
        "run_id": {"type": "string"}
      }
    },
    "decision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "description"],
      "properties": {
        "decision_id": {"type": "string"},
        "description": {"type": "string", "minLength": 1},
        "made_by": {"type": "string"},
        "rationale": {"type": "string", "minLength": 1},
        "source_reference": {
          "type": "string",
          "minLength": 1,
          "description": "Traceable origin: transcript segment ID, agenda item ID, or external reference."
        }
      },
      "anyOf": [
        {"required": ["source_reference"]},
        {"required": ["rationale"]}
      ]
    },
    "action_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "description"],
      "properties": {
        "action_id": {"type": "string"},
        "description": {"type": "string", "minLength": 1},
        "assignee": {"type": "string"},
        "due_date": {"type": "string", "format": "date"}
      }
    }
  }
}
