{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/schemas/transcript_pipeline/meeting_minutes_artifact.schema.json",
  "title": "Meeting Minutes Artifact",
  "description": "Structured meeting minutes extracted from transcript inputs with strict source grounding.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "content_hash",
    "trace",
    "provenance",
    "created_at",
    "source_context_bundle_id",
    "summary",
    "agenda_items",
    "meeting_outcomes",
    "action_items",
    "attendees",
    "source_coverage"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^MMA-[A-Z0-9_-]+$"
    },
    "artifact_type": {
      "type": "string",
      "const": "meeting_minutes_artifact"
    },
    "schema_ref": {
      "type": "string",
      "const": "transcript_pipeline/meeting_minutes_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "trace": {
      "$ref": "#/$defs/trace_context"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_context_bundle_id": {
      "type": "string",
      "pattern": "^CTX-[A-Z0-9_-]+$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "agenda_items": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "meeting_outcomes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/meeting_outcome"
      }
    },
    "action_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action_item"
      }
    },
    "attendees": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_coverage": {
      "$ref": "#/$defs/source_coverage"
    }
  },
  "$defs": {
    "trace_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "span_id"],
      "properties": {
        "trace_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
        "span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"},
        "parent_span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by", "input_artifact_ids"],
      "properties": {
        "produced_by": {"type": "string"},
        "input_artifact_ids": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "run_id": {"type": "string"}
      }
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_turn_id", "source_segment_id", "line_index"],
      "properties": {
        "source_turn_id": {"type": "string", "pattern": "^T-[0-9]{4,}$"},
        "source_segment_id": {"type": "string", "pattern": "^SEG-[0-9]{4,}$"},
        "line_index": {"type": "integer", "minimum": 0}
      }
    },
    "meeting_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome_id", "description"],
      "properties": {
        "outcome_id": {"type": "string", "pattern": "^OUT-[0-9]{3,}$"},
        "description": {"type": "string", "minLength": 1},
        "source_refs": {
          "type": "array",
          "items": {"$ref": "#/$defs/source_ref"},
          "minItems": 1
        },
        "rationale": {"type": "string", "minLength": 1}
      },
      "anyOf": [
        {"required": ["source_refs"]},
        {"required": ["rationale"]}
      ]
    },
    "action_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "description"],
      "properties": {
        "action_id": {"type": "string", "pattern": "^ACT-[0-9]{3,}$"},
        "description": {"type": "string", "minLength": 1},
        "assignee": {"type": "string", "minLength": 1},
        "assignee_status": {"type": "string", "enum": ["unknown"]},
        "due_date": {"type": "string", "format": "date"},
        "due_date_status": {"type": "string", "enum": ["unknown"]},
        "source_refs": {
          "type": "array",
          "items": {"$ref": "#/$defs/source_ref"},
          "minItems": 1
        }
      },
      "allOf": [
        {
          "anyOf": [
            {"required": ["assignee"]},
            {"required": ["assignee_status"]}
          ]
        },
        {
          "anyOf": [
            {"required": ["due_date"]},
            {"required": ["due_date_status"]}
          ]
        }
      ]
    },
    "source_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "covered_turn_ids",
        "covered_segment_ids",
        "total_transcript_turns",
        "covered_transcript_turns"
      ],
      "properties": {
        "covered_turn_ids": {
          "type": "array",
          "items": {"type": "string", "pattern": "^T-[0-9]{4,}$"}
        },
        "covered_segment_ids": {
          "type": "array",
          "items": {"type": "string", "pattern": "^SEG-[0-9]{4,}$"}
        },
        "total_transcript_turns": {"type": "integer", "minimum": 0},
        "covered_transcript_turns": {"type": "integer", "minimum": 0}
      }
    }
  }
}
