{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/schemas/transcript_pipeline/formatted_paper_artifact.schema.json",
  "title": "Formatted Paper Artifact",
  "description": "Final formatted output of a revised draft, ready for certification and release. Produced by the formatting step.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "content_hash",
    "trace",
    "provenance",
    "created_at",
    "source_artifact_id",
    "title",
    "formatted_content",
    "output_format",
    "formatting_version"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^FPA-[A-Z0-9_-]+$"
    },
    "artifact_type": {
      "type": "string",
      "const": "formatted_paper_artifact"
    },
    "schema_ref": {
      "type": "string",
      "const": "transcript_pipeline/formatted_paper_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "trace": {
      "$ref": "#/$defs/trace_context"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_artifact_id": {
      "type": "string",
      "description": "ID of the revised_draft_artifact or paper_draft_artifact that was formatted."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "formatted_content": {
      "type": "string",
      "minLength": 1,
      "description": "Final formatted paper content."
    },
    "output_format": {
      "type": "string",
      "enum": ["markdown", "html", "latex", "pdf_manifest"],
      "description": "Output format of the formatted paper."
    },
    "formatting_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "word_count": {
      "type": "integer",
      "minimum": 0
    },
    "table_of_contents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "anchor"],
        "properties": {
          "title": {"type": "string"},
          "anchor": {"type": "string"},
          "level": {"type": "integer", "minimum": 1, "maximum": 6}
        }
      }
    }
  },
  "$defs": {
    "trace_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "span_id"],
      "properties": {
        "trace_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
        "span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"},
        "parent_span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by", "input_artifact_ids"],
      "properties": {
        "produced_by": {"type": "string"},
        "input_artifact_ids": {"type": "array", "items": {"type": "string"}},
        "run_id": {"type": "string"}
      }
    }
  }
}
