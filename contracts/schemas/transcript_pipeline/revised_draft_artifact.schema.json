{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/schemas/transcript_pipeline/revised_draft_artifact.schema.json",
  "title": "Revised Draft Artifact",
  "description": "Revised working paper produced after incorporating review findings. Must reference both the original draft and the review artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "content_hash",
    "trace",
    "provenance",
    "created_at",
    "source_draft_artifact_id",
    "review_artifact_id",
    "title",
    "sections",
    "revision_version",
    "changes_applied"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^RDA-[A-Z0-9_-]+$"
    },
    "artifact_type": {
      "type": "string",
      "const": "revised_draft_artifact"
    },
    "schema_ref": {
      "type": "string",
      "const": "transcript_pipeline/revised_draft_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "trace": {
      "$ref": "#/$defs/trace_context"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_draft_artifact_id": {
      "type": "string",
      "description": "ID of the paper_draft_artifact that was revised."
    },
    "review_artifact_id": {
      "type": "string",
      "description": "ID of the review_artifact whose findings were addressed."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/paper_section"
      }
    },
    "revision_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "changes_applied": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/change_record"
      }
    }
  },
  "$defs": {
    "trace_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "span_id"],
      "properties": {
        "trace_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
        "span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"},
        "parent_span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by", "input_artifact_ids"],
      "properties": {
        "produced_by": {"type": "string"},
        "input_artifact_ids": {"type": "array", "items": {"type": "string"}},
        "run_id": {"type": "string"}
      }
    },
    "paper_section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section_id", "title", "content"],
      "properties": {
        "section_id": {"type": "string"},
        "title": {"type": "string", "minLength": 1},
        "content": {"type": "string", "minLength": 1},
        "order": {"type": "integer", "minimum": 1}
      }
    },
    "change_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "change_type", "description"],
      "properties": {
        "finding_id": {"type": "string"},
        "change_type": {
          "type": "string",
          "enum": ["added", "modified", "removed", "restructured"]
        },
        "description": {"type": "string", "minLength": 1},
        "section_id": {"type": "string"}
      }
    }
  }
}
