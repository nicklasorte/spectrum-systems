{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/schemas/transcript_pipeline/context_bundle.schema.json",
  "title": "Context Bundle",
  "description": "CPL-02 Context Bundle: deterministic, replayable artifact assembled from a transcript_artifact. Every segment is traceable to a transcript turn (source_turn_id, line_index). manifest_hash is a deterministic hash of the ordered segments and pins replay equivalence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "content_hash",
    "trace",
    "provenance",
    "created_at",
    "source_artifact_id",
    "segments",
    "manifest_hash"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^CTX-[A-Z0-9_-]+$"
    },
    "artifact_type": {
      "type": "string",
      "const": "context_bundle"
    },
    "schema_ref": {
      "type": "string",
      "const": "transcript_pipeline/context_bundle"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "trace": {
      "$ref": "#/$defs/trace_context"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_artifact_id": {
      "type": "string",
      "pattern": "^TXA-[A-Z0-9_-]+$",
      "description": "ID of the transcript_artifact this bundle was assembled from."
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/segment"
      },
      "description": "Ordered, traceable segments derived 1:1 from transcript speaker_turns."
    },
    "manifest_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Deterministic SHA-256 over the ordered segment manifest. Independent from content_hash; pins replay equivalence."
    },
    "assembly_strategy": {
      "type": "string",
      "enum": ["full"],
      "description": "Strategy used to assemble context from the transcript. CPL-02 only supports 'full' (no summarization, no LLM)."
    }
  },
  "$defs": {
    "trace_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "span_id"],
      "properties": {
        "trace_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
        "span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"},
        "parent_span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by", "input_artifact_ids"],
      "properties": {
        "produced_by": {"type": "string"},
        "input_artifact_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "run_id": {"type": "string"}
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["segment_id", "speaker", "text", "source_turn_id", "line_index"],
      "properties": {
        "segment_id": {
          "type": "string",
          "pattern": "^SEG-[0-9]{4,}$",
          "description": "Deterministic per-bundle segment id (SEG-0001 ...)."
        },
        "speaker": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "source_turn_id": {
          "type": "string",
          "pattern": "^T-[0-9]{4,}$",
          "description": "ID of the transcript_artifact speaker_turn this segment derives from."
        },
        "line_index": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based source line index inherited from the transcript turn."
        }
      }
    }
  }
}
