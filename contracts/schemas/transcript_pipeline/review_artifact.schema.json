{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/schemas/transcript_pipeline/review_artifact.schema.json",
  "title": "Review Artifact",
  "description": "Structured review record for a paper_draft_artifact. Contains findings, severity assessments, and a review decision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "content_hash",
    "trace",
    "provenance",
    "created_at",
    "reviewed_artifact_id",
    "reviewed_artifact_type",
    "findings",
    "review_decision",
    "reviewer_id"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^RVA-[A-Z0-9_-]+$"
    },
    "artifact_type": {
      "type": "string",
      "const": "review_artifact"
    },
    "schema_ref": {
      "type": "string",
      "const": "transcript_pipeline/review_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "trace": {
      "$ref": "#/$defs/trace_context"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewed_artifact_id": {
      "type": "string",
      "description": "ID of the artifact under review."
    },
    "reviewed_artifact_type": {
      "type": "string",
      "description": "Type of the artifact under review."
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/review_finding"
      }
    },
    "review_decision": {
      "type": "string",
      "enum": ["approve", "revise", "block"],
      "description": "Outcome of the review."
    },
    "reviewer_id": {
      "type": "string",
      "description": "Identifier of the reviewing agent or human."
    },
    "summary": {
      "type": "string"
    }
  },
  "$defs": {
    "trace_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "span_id"],
      "properties": {
        "trace_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
        "span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"},
        "parent_span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by", "input_artifact_ids"],
      "properties": {
        "produced_by": {"type": "string"},
        "input_artifact_ids": {"type": "array", "items": {"type": "string"}},
        "run_id": {"type": "string"}
      }
    },
    "review_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "severity", "description"],
      "properties": {
        "finding_id": {"type": "string"},
        "severity": {
          "type": "string",
          "enum": ["S0", "S1", "S2", "S3", "S4"],
          "description": "SBGE severity: S0=critical blocker, S4=informational."
        },
        "description": {"type": "string", "minLength": 1},
        "section_ref": {"type": "string"},
        "recommendation": {"type": "string"},
        "blocking": {"type": "boolean"}
      }
    }
  }
}
