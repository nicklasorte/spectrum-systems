{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/schemas/transcript_pipeline/release_artifact.schema.json",
  "title": "Release Artifact",
  "description": "Terminal artifact certifying a formatted paper is ready for external release. Requires a passed done_certification_record reference.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "content_hash",
    "trace",
    "provenance",
    "created_at",
    "source_artifact_id",
    "certification_record_id",
    "release_version",
    "release_status",
    "pipeline_trace_ids"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^REL-[A-Z0-9_-]+$"
    },
    "artifact_type": {
      "type": "string",
      "const": "release_artifact"
    },
    "schema_ref": {
      "type": "string",
      "const": "transcript_pipeline/release_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "trace": {
      "$ref": "#/$defs/trace_context"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_artifact_id": {
      "type": "string",
      "description": "ID of the formatted_paper_artifact being released."
    },
    "certification_record_id": {
      "type": "string",
      "description": "ID of the done_certification_record authorizing this release."
    },
    "release_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semver release version."
    },
    "release_status": {
      "type": "string",
      "enum": ["draft", "candidate", "released", "retracted"]
    },
    "pipeline_trace_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"},
      "description": "All trace_ids from the pipeline run that produced this release."
    },
    "changelog": {
      "type": "string"
    },
    "release_notes": {
      "type": "string"
    }
  },
  "$defs": {
    "trace_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "span_id"],
      "properties": {
        "trace_id": {"type": "string", "pattern": "^[a-f0-9]{32}$"},
        "span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"},
        "parent_span_id": {"type": "string", "pattern": "^[a-f0-9]{16}$"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["produced_by", "input_artifact_ids"],
      "properties": {
        "produced_by": {"type": "string"},
        "input_artifact_ids": {"type": "array", "items": {"type": "string"}},
        "run_id": {"type": "string"}
      }
    }
  }
}
