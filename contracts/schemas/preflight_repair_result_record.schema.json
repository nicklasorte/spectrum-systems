{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "preflight_repair_result_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "result_id",
    "attempt_id",
    "rerun_preflight_exit_code",
    "rerun_strategy_gate_decision",
    "success",
    "rerun_allowed",
    "rerun_requires",
    "escalation_required",
    "next_invocation_surface"
  ],
  "properties": {
    "artifact_type": {
      "const": "preflight_repair_result_record"
    },
    "artifact_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "result_id": {
      "type": "string"
    },
    "attempt_id": {
      "type": "string"
    },
    "rerun_preflight_exit_code": {
      "type": "integer"
    },
    "rerun_strategy_gate_decision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "WARN",
        "FREEZE",
        "BLOCK"
      ]
    },
    "success": {
      "type": "boolean"
    },
    "rerun_allowed": {
      "type": "boolean"
    },
    "rerun_requires": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "escalation_required": {
      "type": "boolean"
    },
    "next_invocation_surface": {
      "type": "string",
      "minLength": 1
    }
  }
}
