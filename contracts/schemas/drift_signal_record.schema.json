{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "drift_signal_record",
  "type": "object",
  "properties": {
    "artifact_type": {
      "type": "string"
    },
    "artifact_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "signal": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "threshold": {
            "type": "number"
          }
        },
        "required": [
          "signal",
          "value",
          "threshold"
        ],
        "additionalProperties": false
      }
    },
    "drift_detected": {
      "type": "boolean"
    }
  },
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "signals",
    "drift_detected"
  ],
  "additionalProperties": false
}
