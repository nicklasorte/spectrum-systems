{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/tpa_scope_policy.schema.json",
  "title": "TPA Scope Policy",
  "description": "Governed policy artifact defining where TPA is required versus optional.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "policy_id",
    "required_paths",
    "required_artifact_types",
    "required_pqx_steps",
    "optional_paths",
    "lightweight_mode_allowed"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "tpa_scope_policy"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "policy_id": {"type": "string", "minLength": 1},
    "required_paths": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "required_artifact_types": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "required_pqx_steps": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "optional_paths": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "lightweight_mode_allowed": {"type": "boolean"}
  }
}
