{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/repair_policy_candidate.schema.json",
  "title": "Repair Policy Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "schema_version", "policy_candidate_id", "template_refs", "candidate_policy_primitives", "compilation_state", "non_authority_assertions"],
  "properties": {
    "artifact_type": {"const": "repair_policy_candidate"},
    "schema_version": {"const": "1.0.0"},
    "policy_candidate_id": {"type": "string", "pattern": "^fre-pol-[a-f0-9]{16}$"},
    "template_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^repair_template_candidate:.+"}, "uniqueItems": true},
    "candidate_policy_primitives": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "compilation_state": {"type": "string", "enum": ["candidate_only"]},
    "non_authority_assertions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
