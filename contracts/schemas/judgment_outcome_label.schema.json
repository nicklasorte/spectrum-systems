{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/judgment_outcome_label.schema.json",
  "title": "Judgment Outcome Label",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "judgment_id",
    "decision_id",
    "policy_id",
    "trace_id",
    "outcome_status",
    "observation_time",
    "observed_outcome",
    "expected_outcome",
    "correctness",
    "source",
    "timestamp",
    "notes"
  ],
  "properties": {
    "artifact_type": {"const": "judgment_outcome_label"},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "schema_version": {"type": "string", "const": "1.1.0"},
    "standards_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "judgment_id": {"type": "string", "minLength": 1},
    "decision_id": {"type": "string", "minLength": 1},
    "policy_id": {"type": "string", "minLength": 1},
    "trace_id": {"type": "string", "minLength": 1},
    "outcome_status": {"type": "string", "enum": ["observed", "confirmed", "rejected"]},
    "observation_time": {"type": "string", "format": "date-time"},
    "observed_outcome": {"type": "string", "minLength": 1},
    "expected_outcome": {"type": "string", "minLength": 1},
    "correctness": {"type": "boolean"},
    "source": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
