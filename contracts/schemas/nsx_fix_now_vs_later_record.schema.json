{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/nsx_fix_now_vs_later_record.schema.json",
  "title": "nsx_fix_now_vs_later_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "classifier_basis",
    "fix_now",
    "later"
  ],
  "properties": {
    "artifact_type": {
      "const": "nsx_fix_now_vs_later_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "NSX"
    },
    "classifier_basis": {
      "type": "string"
    },
    "fix_now": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "later": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
