{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/fix_roadmap_artifact.schema.json",
  "title": "Fix Roadmap Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "cycle_id",
    "generated_at",
    "source_review_paths",
    "summary",
    "bundles"
  ],
  "properties": {
    "artifact_id": {"type": "string"},
    "artifact_type": {"const": "fix_roadmap_artifact"},
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "cycle_id": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"},
    "source_review_paths": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker", "required_fix", "optional_improvement", "total_unique_findings"],
      "properties": {
        "blocker": {"type": "integer", "minimum": 0},
        "required_fix": {"type": "integer", "minimum": 0},
        "optional_improvement": {"type": "integer", "minimum": 0},
        "total_unique_findings": {"type": "integer", "minimum": 0}
      }
    },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["bundle_id", "classification", "rationale", "target_seams", "findings"],
        "properties": {
          "bundle_id": {"type": "string"},
          "classification": {"type": "string", "enum": ["blocker", "required_fix", "optional_improvement"]},
          "rationale": {"type": "string"},
          "target_seams": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "findings": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["finding_id", "title", "severity", "category", "affected_paths", "source_reviewers"],
              "properties": {
                "finding_id": {"type": "string"},
                "title": {"type": "string"},
                "severity": {"type": "string"},
                "category": {"type": "string"},
                "affected_paths": {"type": "array", "items": {"type": "string"}},
                "source_reviewers": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        }
      }
    }
  }
}
