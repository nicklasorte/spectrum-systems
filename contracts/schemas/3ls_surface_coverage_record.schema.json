{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/3ls_surface_coverage_record.schema.json",
  "title": "3LS Surface Coverage Record",
  "description": "Measurement of changed-surface to test-target mapping coverage. Detects pytest_selection_missing class failures early. Observation only; does not grant authority. Fail-closed: when governed_surfaces are present but mapped_test_targets is empty, the record is invalid.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "trace_id",
    "created_at",
    "provenance",
    "changed_surfaces",
    "governed_surfaces",
    "mapped_test_targets",
    "unmapped_surfaces",
    "coverage_ratio",
    "fallback_used",
    "authority_scope"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "3ls_surface_coverage_record"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "trace_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_system", "inputs"],
      "properties": {
        "source_system": {"type": "string", "pattern": "^[A-Z0-9]{2,8}$"},
        "inputs": {"type": "array", "items": {"type": "string"}},
        "simulated": {"type": "boolean"}
      }
    },
    "record_id": {"type": "string"},
    "changed_surfaces": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "governed_surfaces": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "mapped_test_targets": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "unmapped_surfaces": {
      "type": "array",
      "items": {"type": "string"}
    },
    "coverage_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "fallback_used": {"type": "boolean"},
    "authority_scope": {"type": "string", "const": "observation_only"},
    "notes": {"type": "string"}
  },
  "allOf": [
    {
      "description": "When governed_surfaces are present, mapped_test_targets must be non-empty (fail-closed).",
      "if": {
        "properties": {"governed_surfaces": {"type": "array", "minItems": 1}},
        "required": ["governed_surfaces"]
      },
      "then": {
        "properties": {
          "mapped_test_targets": {"type": "array", "minItems": 1}
        }
      }
    }
  ]
}
