{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/meeting_minutes/gaps_output.schema.json",
  "title": "Gaps Output",
  "description": "Structured output of the gap_detection pass. Identifies missing information, unresolved questions, and incomplete decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meeting_id", "gaps"],
  "properties": {
    "meeting_id": {
      "type": "string"
    },
    "gaps": {
      "type": "array",
      "description": "Gaps identified in the meeting output.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gap_id", "description", "gap_type", "related_refs"],
        "properties": {
          "gap_id":       {"type": "string"},
          "description":  {"type": "string", "minLength": 1},
          "gap_type":     {
            "type": "string",
            "enum": ["missing_information", "unresolved_question", "incomplete_decision", "missing_owner", "missing_deadline"],
            "description": "Category of gap."
          },
          "related_refs": {
            "type": "array",
            "items": {"type": "string"},
            "description": "References to decisions or action items affected by this gap."
          }
        }
      }
    }
  }
}
