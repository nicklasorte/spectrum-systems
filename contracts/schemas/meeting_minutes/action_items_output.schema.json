{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/meeting_minutes/action_items_output.schema.json",
  "title": "Action Items Output",
  "description": "Structured output of the action_item_extraction pass.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meeting_id", "action_items"],
  "properties": {
    "meeting_id": {
      "type": "string"
    },
    "action_items": {
      "type": "array",
      "description": "Action items extracted from the meeting.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action_id", "description", "owner", "due_date"],
        "properties": {
          "action_id":   {"type": "string"},
          "description": {"type": "string", "minLength": 1},
          "owner":       {"type": ["string", "null"], "description": "Person or role responsible."},
          "due_date":    {"type": ["string", "null"], "description": "Due date as stated in the meeting, or null."},
          "references":  {
            "type": "array",
            "items": {"type": "string"},
            "description": "Identifiers of transcript facts or decisions that originated this action."
          }
        }
      }
    }
  }
}
