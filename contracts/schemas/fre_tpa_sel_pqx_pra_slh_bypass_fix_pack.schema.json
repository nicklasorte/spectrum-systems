{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/fre_tpa_sel_pqx_pra_slh_bypass_fix_pack.schema.json",
  "title": "fre_tpa_sel_pqx_pra_slh_bypass_fix_pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "status",
    "fixes_applied",
    "targeted_regressions_added",
    "targeted_reruns_executed"
  ],
  "properties": {
    "artifact_type": {
      "const": "fre_tpa_sel_pqx_pra_slh_bypass_fix_pack"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "FRE"
    },
    "status": {
      "type": "string"
    },
    "fixes_applied": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targeted_regressions_added": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "targeted_reruns_executed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
