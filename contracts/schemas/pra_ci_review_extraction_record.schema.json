{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pra_ci_review_extraction_record.schema.json",
  "title": "pra_ci_review_extraction_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "pr_number",
    "ci_status",
    "failed_checks",
    "key_review_findings",
    "residual_weaknesses",
    "review_summary"
  ],
  "properties": {
    "artifact_type": {
      "const": "pra_ci_review_extraction_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "PRA"
    },
    "pr_number": {
      "type": "integer"
    },
    "ci_status": {
      "type": "string"
    },
    "failed_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "key_review_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "residual_weaknesses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_summary": {
      "type": "string"
    }
  }
}
