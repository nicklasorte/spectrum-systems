{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "route_efficiency_report",
  "type": "object",
  "required": [
    "artifact_type",
    "schema_version",
    "trace_id",
    "outputs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "route_efficiency_report"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string"
    },
    "outputs": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
