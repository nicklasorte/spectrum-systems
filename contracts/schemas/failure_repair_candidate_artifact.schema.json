{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/failure_repair_candidate_artifact.schema.json",
  "title": "Failure Repair Candidate Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "failure_id",
    "source_run_ref",
    "source_test_refs",
    "failure_class",
    "safe_to_repair",
    "bounded_scope",
    "proposed_repair_ref",
    "trace_refs"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "failure_repair_candidate_artifact"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "failure_id": {"type": "string", "minLength": 1},
    "source_run_ref": {"type": "string", "minLength": 1},
    "source_test_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "failure_class": {"type": "string", "minLength": 1},
    "safe_to_repair": {"type": "boolean"},
    "bounded_scope": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "proposed_repair_ref": {"type": "string", "minLength": 1},
    "trace_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
