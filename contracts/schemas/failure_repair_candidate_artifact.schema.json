{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/failure_repair_candidate_artifact.schema.json",
  "title": "Failure Repair Candidate Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "failure_id",
    "source_run_ref",
    "source_test_refs",
    "failure_class",
    "safe_to_repair",
    "bounded_scope",
    "proposed_repair_ref",
    "trace_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "failure_repair_candidate_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "failure_id": {
      "type": "string",
      "minLength": 1
    },
    "source_run_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_test_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "schema_mismatch",
        "contract_registration_missing",
        "branch_policy_violation",
        "dependency_graph_violation",
        "test_expectation_drift",
        "unknown_failure",
        "missing_required_artifact",
        "contract_mismatch",
        "schema_violation",
        "lineage_missing",
        "authority_evidence_missing",
        "invalid_wrapper",
        "pytest_config_missing",
        "pytest_config_mismatch",
        "testpaths_missing",
        "no_tests_discovered",
        "unexpected_test_inventory_regression",
        "import_resolution_failure",
        "collection_failure",
        "working_directory_mismatch",
        "accidental_filtering_detected",
        "non_repairable_policy_violation",
        "internal_preflight_error",
        "test_inventory_regression",
        "control_surface_gap",
        "downstream_test_failure"
      ]
    },
    "safe_to_repair": {
      "type": "boolean"
    },
    "bounded_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "proposed_repair_ref": {
      "type": "string",
      "minLength": 1
    },
    "trace_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "reason_codes": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "retry_budget": {
      "type": "integer",
      "minimum": 0
    },
    "rerun_prerequisites": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    }
  }
}
