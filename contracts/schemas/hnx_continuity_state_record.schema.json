{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hnx_continuity_state_record.schema.json",
  "title": "Hnx Continuity State Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "state_id",
    "workflow_id",
    "continuity_refs",
    "max_checkpoint_age_minutes",
    "created_at",
    "trace_id"
  ],
  "properties": {
    "artifact_type": {
      "const": "hnx_continuity_state_record"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "state_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "continuity_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "max_checkpoint_age_minutes": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    }
  }
}
