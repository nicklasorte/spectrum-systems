{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "context_bundle",
  "type": "object",
  "properties": {
    "artifact_type": {
      "type": "string"
    },
    "artifact_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "recipe_id": {
      "type": "string"
    },
    "artifact_family": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_id": {
            "type": "string"
          },
          "trace_ref": {
            "type": "string"
          },
          "content_hash": {
            "type": "string"
          },
          "priority": {
            "type": "integer"
          },
          "fresh": {
            "type": "boolean"
          }
        },
        "required": [
          "source_id",
          "trace_ref",
          "content_hash",
          "priority",
          "fresh"
        ],
        "additionalProperties": false
      }
    },
    "manifest_hash": {
      "type": "string"
    }
  },
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "bundle_id",
    "run_id",
    "trace_id",
    "recipe_id",
    "artifact_family",
    "entries",
    "manifest_hash"
  ],
  "additionalProperties": false
}
