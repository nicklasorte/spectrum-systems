{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/fix_plan_artifact.schema.json",
  "title": "Fix Plan Artifact",
  "description": "Deterministic governed fix plan prescribed from a drift remediation artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fix_plan_id",
    "cycle_id",
    "remediation_id",
    "decision_id",
    "current_state",
    "blocking",
    "remediation_class",
    "objective",
    "required_actions",
    "required_artifacts",
    "validation_requirements",
    "completion_criteria",
    "blocking_conditions",
    "allowed_next_state_when_satisfied",
    "prohibited_progression_until_complete",
    "evidence_refs",
    "policy_id",
    "policy_version",
    "policy_hash",
    "generated_at"
  ],
  "properties": {
    "fix_plan_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "cycle_id": {"type": "string", "pattern": "^cycle-[a-z0-9][a-z0-9-]*$"},
    "remediation_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "decision_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "current_state": {"type": "string", "minLength": 1},
    "blocking": {"type": "boolean"},
    "remediation_class": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "required_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action_type", "target", "required"],
        "properties": {
          "action_type": {
            "type": "string",
            "enum": [
              "create_artifact",
              "repair_artifact",
              "update_manifest",
              "regenerate_review",
              "rerun_validation",
              "restore_provenance",
              "attach_missing_evidence",
              "reroute_for_review"
            ]
          },
          "target": {"type": "string", "minLength": 1},
          "required": {"type": "boolean"}
        }
      }
    },
    "required_artifacts": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "validation_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "completion_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "blocking_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "allowed_next_state_when_satisfied": {"type": "string", "minLength": 1},
    "prohibited_progression_until_complete": {"type": "boolean"},
    "evidence_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "policy_id": {"type": "string", "minLength": 1},
    "policy_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "policy_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "generated_at": {"type": "string", "format": "date-time"}
  }
}
