{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pqx_review_result.schema.json",
  "title": "PQX Review Result",
  "description": "Deterministic governed review artifact for bundle/step review checkpoints and structured findings ingestion.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "checkpoint_id",
    "review_type",
    "bundle_id",
    "bundle_run_id",
    "roadmap_authority_ref",
    "execution_plan_ref",
    "scope",
    "findings",
    "overall_disposition",
    "created_at",
    "provenance_refs"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "review_id": {"type": "string", "minLength": 1},
    "checkpoint_id": {"type": "string", "minLength": 1},
    "review_type": {"type": "string", "enum": ["pre_bundle_review", "post_bundle_review", "checkpoint_review"]},
    "bundle_id": {"type": "string", "minLength": 1},
    "bundle_run_id": {"type": "string", "minLength": 1},
    "roadmap_authority_ref": {"type": "string", "minLength": 1},
    "execution_plan_ref": {"type": "string", "minLength": 1},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_type", "step_id"],
      "properties": {
        "scope_type": {"type": "string", "enum": ["bundle", "step", "run"]},
        "step_id": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "severity",
          "category",
          "title",
          "description",
          "affected_step_ids",
          "recommended_action",
          "blocking",
          "source_refs"
        ],
        "properties": {
          "finding_id": {"type": "string", "minLength": 1},
          "severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
          "category": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "affected_step_ids": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1, "uniqueItems": true},
          "recommended_action": {"type": "string", "minLength": 1},
          "blocking": {"type": "boolean"},
          "source_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
        }
      }
    },
    "overall_disposition": {"type": "string", "enum": ["approved", "approved_with_findings", "rejected"]},
    "created_at": {"type": "string", "format": "date-time"},
    "provenance_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
