{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prompt_queue_state.schema.json",
  "title": "Prompt Queue State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "queue_id",
    "queue_status",
    "work_items",
    "active_work_item_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "queue_id": {
      "type": "string",
      "minLength": 1
    },
    "queue_status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "blocked",
        "complete"
      ]
    },
    "work_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/work_item"
      }
    },
    "active_work_item_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "work_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_item_id",
        "prompt_id",
        "title",
        "status",
        "priority",
        "risk_level",
        "repo",
        "branch",
        "scope_paths",
        "review_provider_primary",
        "review_provider_actual",
        "review_attempt_count",
        "review_fallback_used",
        "review_fallback_reason",
        "findings_artifact_path",
        "created_at",
        "updated_at",
        "repair_prompt_artifact_path"
      ],
      "properties": {
        "work_item_id": {
          "type": "string",
          "minLength": 1
        },
        "parent_work_item_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "prompt_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "queued",
            "review_queued",
            "review_running",
            "review_provider_failed",
            "review_fallback_running",
            "review_complete",
            "findings_parsed",
            "repair_prompt_generated",
            "blocked"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "scope_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "review_provider_primary": {
          "type": "string",
          "const": "claude"
        },
        "review_provider_actual": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "claude",
            "codex",
            null
          ]
        },
        "review_attempt_count": {
          "type": "integer",
          "minimum": 0
        },
        "review_fallback_used": {
          "type": "boolean"
        },
        "review_fallback_reason": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "usage_limit",
            "rate_limited",
            "auth_failure",
            "timeout",
            "provider_unavailable",
            null
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "findings_artifact_path": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "repair_prompt_artifact_path": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    }
  }
}
