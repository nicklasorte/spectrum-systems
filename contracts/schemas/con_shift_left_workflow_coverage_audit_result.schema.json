{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/con_shift_left_workflow_coverage_audit_result.schema.json",
  "title": "con_shift_left_workflow_coverage_audit_result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "status",
    "required_front_door",
    "workflows_checked",
    "uncovered_workflows"
  ],
  "properties": {
    "artifact_type": {
      "const": "con_shift_left_workflow_coverage_audit_result"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "CON"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "required_front_door": {
      "type": "string"
    },
    "workflows_checked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncovered_workflows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
