{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prompt_queue_observability_snapshot.schema.json",
  "title": "Prompt Queue Observability Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "snapshot_id",
    "timestamp",
    "total_items",
    "items_by_status",
    "retry_counts_summary",
    "blocked_items_count",
    "exhausted_retry_count",
    "active_run_ids",
    "invariant_violations",
    "trace_linkage",
    "queue_health_state",
    "health_reason_codes",
    "health_metrics"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "total_items": {
      "type": "integer",
      "minimum": 0
    },
    "items_by_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queued",
        "running",
        "completed",
        "failed",
        "blocked"
      ],
      "properties": {
        "queued": { "type": "integer", "minimum": 0 },
        "running": { "type": "integer", "minimum": 0 },
        "completed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 }
      }
    },
    "retry_counts_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_retry_count",
        "max_retry_count",
        "items_with_retries"
      ],
      "properties": {
        "total_retry_count": { "type": "integer", "minimum": 0 },
        "max_retry_count": { "type": "integer", "minimum": 0 },
        "items_with_retries": { "type": "integer", "minimum": 0 }
      }
    },
    "blocked_items_count": {
      "type": "integer",
      "minimum": 0
    },
    "exhausted_retry_count": {
      "type": "integer",
      "minimum": 0
    },
    "active_run_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "invariant_violations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "trace_linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["linkage_type", "linkage_id"],
      "properties": {
        "linkage_type": {
          "type": "string",
          "enum": ["run_id", "result_ref"]
        },
        "linkage_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "queue_health_state": {
      "type": "string",
      "enum": ["stable", "degraded", "unstable"]
    },
    "health_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "health_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_id",
        "current_step_index",
        "total_steps",
        "queue_status",
        "last_transition_action",
        "blocked_count",
        "retry_count",
        "remediation_count",
        "ambiguous_signal_count",
        "recovery_count",
        "completion_progress"
      ],
      "properties": {
        "queue_id": { "type": "string", "minLength": 1 },
        "current_step_index": { "type": "integer", "minimum": 0 },
        "total_steps": { "type": "integer", "minimum": 1 },
        "queue_status": { "type": "string", "enum": ["pending", "running", "blocked", "completed"] },
        "last_transition_action": { "type": "string", "enum": ["none", "continue", "block", "unknown"] },
        "blocked_count": { "type": "integer", "minimum": 0 },
        "retry_count": { "type": "integer", "minimum": 0 },
        "remediation_count": { "type": "integer", "minimum": 0 },
        "ambiguous_signal_count": { "type": "integer", "minimum": 0 },
        "recovery_count": { "type": "integer", "minimum": 0 },
        "completion_progress": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
