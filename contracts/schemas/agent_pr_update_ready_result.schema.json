{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/apu/agent_pr_update_ready_result.schema.json",
  "title": "Agent PR Update Ready Result",
  "description": "APU-3LS-01 PR-update readiness evidence artifact emitted by scripts/check_agent_pr_update_ready.py. The guard observes a core_loop_pre_pr_gate_result (CLP), an agent_core_loop_run_record (AGL), and the upstream agent_pr_ready_result (CLP-02 guard) against docs/governance/agent_pr_update_policy.json. APU then records whether a repo-mutating Codex/Claude slice has the artifact-backed 3LS evidence required to be safely handed off as PR-update ready. APU is observation-only: it surfaces PR-update readiness inputs and compliance observations only. Canonical authority remains with AEX (admission), PQX (execution closure), EVL (eval evidence), TPA (policy/scope), CDE (continuation/closure), SEL (final gate signal), LIN (lineage), REP (replay), and GOV per docs/architecture/system_registry.md. APU emits no admission, execution, eval, policy, control, or final-gate signal of its own.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "guard_id",
    "work_item_id",
    "agent_type",
    "repo_mutating",
    "policy_ref",
    "readiness_status",
    "reason_codes",
    "evidence",
    "clp_status",
    "allowed_warning_reason_codes",
    "blocked_warning_reason_codes",
    "source_artifact_refs",
    "evidence_hash",
    "trace_refs",
    "replay_refs",
    "authority_scope",
    "human_review_required",
    "pr_evidence_section_markdown",
    "generated_at",
    "prl_evidence_status",
    "prl_failure_classes",
    "prl_failure_packet_refs",
    "prl_repair_candidate_refs",
    "prl_eval_candidate_refs",
    "shard_first_status",
    "shard_first_evidence_status",
    "shard_first_reason_codes",
    "shard_first_fallback_used",
    "shard_first_full_suite_detected",
    "shard_first_fallback_reason_codes",
    "shard_first_required_for_repo_mutating"
  ],
  "properties": {
    "artifact_type": {
      "const": "agent_pr_update_ready_result"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "guard_id": {
      "type": "string",
      "minLength": 1
    },
    "work_item_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_type": {
      "enum": ["codex", "claude", "other", "unknown"]
    },
    "repo_mutating": {
      "type": ["boolean", "null"]
    },
    "policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "clp_result_ref": {
      "type": ["string", "null"]
    },
    "agl_record_ref": {
      "type": ["string", "null"]
    },
    "agent_pr_ready_result_ref": {
      "type": ["string", "null"]
    },
    "prl_result_ref": {
      "type": ["string", "null"]
    },
    "prl_artifact_index_ref": {
      "type": ["string", "null"]
    },
    "prl_artifact_index_status": {
      "enum": ["present", "missing"]
    },
    "prl_evidence_status": {
      "enum": ["present", "partial", "missing", "unknown"]
    },
    "prl_gate_recommendation": {
      "type": ["string", "null"],
      "enum": ["passed_gate", "gate_warn", "gate_hold", "failed_gate", null]
    },
    "prl_failure_classes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "prl_failure_packet_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "prl_repair_candidate_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "prl_eval_candidate_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "shard_first_readiness_ref": {
      "type": ["string", "null"]
    },
    "shard_first_status": {
      "enum": [
        "shard_first",
        "fallback_justified",
        "missing",
        "partial",
        "unknown"
      ]
    },
    "shard_first_evidence_status": {
      "enum": ["present", "partial", "missing", "unknown"]
    },
    "shard_first_reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "shard_first_fallback_used": {
      "type": "boolean"
    },
    "shard_first_full_suite_detected": {
      "type": "boolean"
    },
    "shard_first_fallback_reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "shard_first_required_for_repo_mutating": {
      "type": "boolean"
    },
    "prl_auto_invocation": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "status",
        "reason",
        "auto_run_enabled",
        "authority_scope"
      ],
      "properties": {
        "status": {
          "enum": ["ran", "skipped", "error"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": ["string", "null"]
        },
        "exit_code": {
          "type": ["integer", "null"]
        },
        "prl_gate_result_path": {
          "type": ["string", "null"]
        },
        "prl_artifact_index_path": {
          "type": ["string", "null"]
        },
        "log_excerpt": {
          "type": ["string", "null"]
        },
        "reason_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "invoked_at": {
          "type": "string",
          "minLength": 1
        },
        "auto_run_enabled": {
          "type": "boolean"
        },
        "authority_scope": {
          "const": "observation_only"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "error" } }
          },
          "then": {
            "properties": {
              "reason_codes": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "readiness_status": {
      "enum": ["ready", "not_ready", "human_review_required"]
    },
    "clp_status": {
      "enum": ["pass", "warn", "block", "missing", "unknown", null]
    },
    "reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "AEX",
        "PQX",
        "EVL",
        "TPA",
        "CDE",
        "SEL",
        "LIN",
        "REP",
        "CLP",
        "APU",
        "AGL"
      ],
      "properties": {
        "AEX": { "$ref": "#/$defs/leg_evidence" },
        "PQX": { "$ref": "#/$defs/leg_evidence" },
        "EVL": { "$ref": "#/$defs/leg_evidence" },
        "TPA": { "$ref": "#/$defs/leg_evidence" },
        "CDE": { "$ref": "#/$defs/leg_evidence" },
        "SEL": { "$ref": "#/$defs/leg_evidence" },
        "LIN": { "$ref": "#/$defs/leg_evidence" },
        "REP": { "$ref": "#/$defs/leg_evidence" },
        "CLP": { "$ref": "#/$defs/clp_evidence" },
        "APU": { "$ref": "#/$defs/apu_evidence" },
        "AGL": { "$ref": "#/$defs/leg_evidence" }
      }
    },
    "allowed_warning_reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "blocked_warning_reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source_artifact_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_hash": {
      "type": "string",
      "minLength": 1
    },
    "trace_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "replay_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "authority_scope": {
      "const": "observation_only"
    },
    "human_review_required": {
      "type": "boolean"
    },
    "pr_evidence_section_markdown": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "required_follow_up": {
      "type": "array",
      "items": { "$ref": "#/$defs/follow_up" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "readiness_status": { "const": "ready" }
        }
      },
      "then": {
        "properties": {
          "human_review_required": { "const": false },
          "reason_codes": { "maxItems": 0 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prl_evidence_status": { "const": "present" }
        },
        "required": ["prl_evidence_status"]
      },
      "then": {
        "properties": {
          "prl_result_ref": { "type": "string", "minLength": 1 }
        },
        "required": ["prl_result_ref"]
      }
    },
    {
      "description": "EVL-RT-05 — shard_first_evidence_status=present requires a shard_first_readiness_ref so a present claim always carries an artifact ref.",
      "if": {
        "properties": {
          "shard_first_evidence_status": { "const": "present" }
        },
        "required": ["shard_first_evidence_status"]
      },
      "then": {
        "properties": {
          "shard_first_readiness_ref": { "type": "string", "minLength": 1 }
        },
        "required": ["shard_first_readiness_ref"]
      }
    },
    {
      "description": "EVL-RT-05 — shard_first_evidence_status=partial must carry at least one shard_first_reason_codes entry so partial readiness is never silent.",
      "if": {
        "properties": {
          "shard_first_evidence_status": { "const": "partial" }
        },
        "required": ["shard_first_evidence_status"]
      },
      "then": {
        "properties": {
          "shard_first_reason_codes": { "type": "array", "minItems": 1 }
        }
      }
    },
    {
      "description": "EVL-RT-05 — shard_first_evidence_status=missing must carry at least one shard_first_reason_codes entry so missing is never silently treated as present.",
      "if": {
        "properties": {
          "shard_first_evidence_status": { "const": "missing" }
        },
        "required": ["shard_first_evidence_status"]
      },
      "then": {
        "properties": {
          "shard_first_reason_codes": { "type": "array", "minItems": 1 }
        }
      }
    },
    {
      "description": "EVL-RT-05 — shard_first_evidence_status=unknown must carry at least one shard_first_reason_codes entry so unknown is never silently treated as present.",
      "if": {
        "properties": {
          "shard_first_evidence_status": { "const": "unknown" }
        },
        "required": ["shard_first_evidence_status"]
      },
      "then": {
        "properties": {
          "shard_first_reason_codes": { "type": "array", "minItems": 1 }
        }
      }
    },
    {
      "description": "EVL-RT-05 — shard_first_fallback_used=true must carry at least one shard_first_fallback_reason_codes entry so fallback usage is never silent.",
      "if": {
        "properties": {
          "shard_first_fallback_used": { "const": true }
        },
        "required": ["shard_first_fallback_used"]
      },
      "then": {
        "properties": {
          "shard_first_fallback_reason_codes": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    },
    {
      "description": "EVL-RT-05 — shard_first_full_suite_detected=true must carry at least one shard_first_fallback_reason_codes entry so full-suite usage is never silent.",
      "if": {
        "properties": {
          "shard_first_full_suite_detected": { "const": true }
        },
        "required": ["shard_first_full_suite_detected"]
      },
      "then": {
        "properties": {
          "shard_first_fallback_reason_codes": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "leg_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "artifact_refs", "reason_codes"],
      "properties": {
        "status": {
          "enum": ["present", "partial", "missing", "unknown", "not_required"]
        },
        "artifact_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reason_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "present" } }
          },
          "then": {
            "properties": {
              "artifact_refs": { "minItems": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "enum": ["partial", "missing", "unknown"]
              }
            }
          },
          "then": {
            "properties": {
              "reason_codes": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "clp_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "artifact_refs", "reason_codes"],
      "properties": {
        "status": {
          "enum": ["pass", "warn", "block", "missing", "unknown"]
        },
        "artifact_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reason_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "pass" } }
          },
          "then": {
            "properties": {
              "artifact_refs": { "minItems": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "enum": ["warn", "block", "missing", "unknown"]
              }
            }
          },
          "then": {
            "properties": {
              "reason_codes": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "apu_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "artifact_refs", "reason_codes"],
      "properties": {
        "status": {
          "enum": ["ready", "not_ready", "missing", "unknown"]
        },
        "artifact_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "reason_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "ready" } }
          },
          "then": {
            "properties": {
              "artifact_refs": { "minItems": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "enum": ["not_ready", "missing", "unknown"]
              }
            }
          },
          "then": {
            "properties": {
              "reason_codes": { "minItems": 1 }
            }
          }
        }
      ]
    },
    "follow_up": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner_system", "action_type", "reason_code", "source_failure_ref"],
      "properties": {
        "owner_system": {
          "enum": [
            "AEX",
            "PQX",
            "EVL",
            "TPA",
            "CDE",
            "SEL",
            "LIN",
            "REP",
            "OBS",
            "SLO",
            "PRL",
            "RIL",
            "FRE",
            "AGL",
            "CLP",
            "APU",
            "GOV"
          ]
        },
        "action_type": { "type": "string", "minLength": 1 },
        "reason_code": { "type": "string", "minLength": 1 },
        "source_failure_ref": { "type": "string", "minLength": 1 }
      }
    }
  }
}
