{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/evaluation_budget_decision.schema.json",
  "title": "Evaluation Budget Decision",
  "description": "Schema supporting both legacy evaluation budget decisions and control-loop enforcement-ready decisions.",
  "oneOf": [
    {"$ref": "#/$defs/legacy_budget_decision"},
    {"$ref": "#/$defs/control_loop_budget_decision"}
  ],
  "$defs": {
    "legacy_budget_decision": {
      "type": "object",
      "required": [
        "decision_dialect",
        "decision_id",
        "summary_id",
        "status",
        "system_response",
        "reasons",
        "triggered_thresholds",
        "required_actions",
        "created_at"
      ],
      "additionalProperties": false,
      "properties": {
        "decision_dialect": {"const": "legacy"},
        "decision_id": {"type": "string", "minLength": 1},
        "summary_id": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["healthy", "warning", "exhausted", "blocked"]},
        "system_response": {
          "type": "string",
          "enum": ["allow", "allow_with_warning", "freeze_changes", "block_release", "require_review"]
        },
        "reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "triggered_thresholds": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "required_actions": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "created_at": {"type": "string", "format": "date-time"}
      }
    },
    "control_loop_budget_decision": {
      "type": "object",
      "required": [
        "decision_dialect",
        "decision_id",
        "summary_id",
        "trace_id",
        "timestamp",
        "status",
        "system_response",
        "triggered_thresholds",
        "reasons"
      ],
      "additionalProperties": false,
      "properties": {
        "decision_dialect": {"const": "control_loop"},
        "decision_id": {"type": "string", "minLength": 1},
        "summary_id": {"type": "string", "minLength": 1},
        "trace_id": {"type": "string", "minLength": 1},
        "timestamp": {"type": "string", "format": "date-time"},
        "status": {"type": "string", "enum": ["healthy", "warning", "exhausted", "blocked"]},
        "system_response": {"type": "string", "enum": ["allow", "warn", "freeze", "block"]},
        "triggered_thresholds": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "reasons": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {"enum": ["warning", "exhausted", "blocked"]}
            }
          },
          "then": {
            "properties": {
              "triggered_thresholds": {"minItems": 1},
              "reasons": {"minItems": 1}
            }
          }
        }
      ]
    }
  }
}
