{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/tpa_observability_consumer_record.schema.json",
  "title": "TPA Observability Consumer Record",
  "description": "Contract-backed record proving downstream consumption of tpa_observability_summary by control-loop learning surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "record_id",
    "run_id",
    "trace_id",
    "step_id",
    "generated_at",
    "consumer_surface",
    "source_observability_ref",
    "consumed_metrics",
    "derived_signals"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "tpa_observability_consumer_record"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "record_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "trace_id": {"type": "string", "minLength": 1},
    "step_id": {"type": "string", "pattern": "^AI-[0-9]+$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "consumer_surface": {"type": "string", "const": "control_loop_learning"},
    "source_observability_ref": {"type": "string", "minLength": 1},
    "consumed_metrics": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "pass2_promotion_rate",
          "pass1_retained_rate",
          "simplify_win_rate",
          "simplify_loss_rate",
          "complexity_regression_rate",
          "cleanup_deletion_rate",
          "bypass_attempt_count"
        ]
      }
    },
    "derived_signals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["priority_score", "recommended_control_decision"],
      "properties": {
        "priority_score": {"type": "integer", "minimum": 0, "maximum": 100},
        "recommended_control_decision": {"type": "string", "enum": ["allow", "warn", "freeze", "block"]}
      }
    }
  }
}
