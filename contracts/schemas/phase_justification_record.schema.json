{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/phase_justification_record.schema.json",
  "title": "phase_justification_record",
  "description": "Emitted by the RGE Phase Justification Gate for every proposed roadmap phase.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "record_id",
    "run_id",
    "trace_id",
    "created_at",
    "phase_id",
    "phase_name",
    "decision",
    "failure_prevented",
    "signal_improved",
    "loop_leg",
    "errors",
    "principle"
  ],
  "properties": {
    "artifact_type": { "type": "string", "const": "phase_justification_record" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "record_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "phase_id": { "type": "string" },
    "phase_name": { "type": "string" },
    "decision": { "type": "string", "enum": ["allow", "block"] },
    "failure_prevented": { "type": "string" },
    "signal_improved": { "type": "string" },
    "loop_leg": { "type": "string" },
    "errors": { "type": "array", "items": { "type": "string" } },
    "principle": { "type": "string", "const": "kill_complexity_early" }
  }
}
