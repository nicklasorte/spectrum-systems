{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/judgment_drift_signal.schema.json",
  "title": "Judgment Drift Signal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "group_signals",
    "created_at"
  ],
  "properties": {
    "artifact_type": {"const": "judgment_drift_signal"},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "standards_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "group_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "judgment_type",
          "policy_version",
          "environment",
          "baseline_ref",
          "current_ref",
          "deltas",
          "thresholds",
          "triggered_signals",
          "drift_detected"
        ],
        "properties": {
          "judgment_type": {"type": "string", "minLength": 1},
          "policy_version": {"type": "string", "minLength": 1},
          "environment": {"type": "string", "minLength": 1},
          "baseline_ref": {"type": "string", "minLength": 1},
          "current_ref": {"type": "string", "minLength": 1},
          "deltas": {
            "type": "object",
            "additionalProperties": false,
            "required": ["approval_rate_delta", "block_rate_delta", "error_rate_delta", "calibration_ece_delta"],
            "properties": {
              "approval_rate_delta": {"type": "number", "minimum": -1, "maximum": 1},
              "block_rate_delta": {"type": "number", "minimum": -1, "maximum": 1},
              "error_rate_delta": {"type": "number", "minimum": -1, "maximum": 1},
              "calibration_ece_delta": {"type": "number", "minimum": -1, "maximum": 1}
            }
          },
          "thresholds": {
            "type": "object",
            "additionalProperties": false,
            "required": ["approval_rate_delta", "block_rate_delta", "error_rate_delta", "calibration_ece_delta"],
            "properties": {
              "approval_rate_delta": {"type": "number", "minimum": 0, "maximum": 1},
              "block_rate_delta": {"type": "number", "minimum": 0, "maximum": 1},
              "error_rate_delta": {"type": "number", "minimum": 0, "maximum": 1},
              "calibration_ece_delta": {"type": "number", "minimum": 0, "maximum": 1}
            }
          },
          "triggered_signals": {
            "type": "object",
            "additionalProperties": false,
            "required": ["approval_rate_shift", "block_rate_shift", "error_rate_increase", "calibration_degradation"],
            "properties": {
              "approval_rate_shift": {"type": "boolean"},
              "block_rate_shift": {"type": "boolean"},
              "error_rate_increase": {"type": "boolean"},
              "calibration_degradation": {"type": "boolean"}
            }
          },
          "drift_detected": {"type": "boolean"}
        }
      }
    },
    "created_at": {"type": "string", "format": "date-time"}
  }
}
