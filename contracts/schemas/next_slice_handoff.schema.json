{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/next_slice_handoff.schema.json",
  "title": "Next Slice Handoff",
  "description": "Governed handoff artifact consumed by context selection.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "handoff_id",
    "from_scope",
    "to_scope",
    "created_at",
    "source_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "next_slice_handoff"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "handoff_id": {
      "type": "string",
      "pattern": "^handoff-[A-Za-z0-9-]{6,64}$"
    },
    "from_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_type", "scope_id"],
      "properties": {
        "scope_type": {
          "type": "string",
          "enum": ["slice_id", "batch_id", "program_id"]
        },
        "scope_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "to_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope_type", "scope_id"],
      "properties": {
        "scope_type": {
          "type": "string",
          "enum": ["slice_id", "batch_id", "program_id"]
        },
        "scope_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 256
      }
    }
  }
}
