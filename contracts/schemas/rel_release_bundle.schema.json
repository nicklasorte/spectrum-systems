{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/rel_release_bundle.schema.json",
  "title": "rel_release_bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "release_record_ref",
    "canary_metrics_ref",
    "change_freeze_ref"
  ],
  "properties": {
    "artifact_type": {
      "const": "rel_release_bundle"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "release_record_ref": {
      "type": "string"
    },
    "canary_metrics_ref": {
      "type": "string"
    },
    "change_freeze_ref": {
      "type": "string"
    }
  }
}
