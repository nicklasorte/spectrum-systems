{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/judgment_policy.schema.json",
  "title": "Judgment Policy",
  "description": "Versioned deterministic judgment policy artifact consumed by the autonomous control loop.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "judgment_type",
    "status",
    "scope",
    "environments",
    "required_inputs",
    "precedent_retrieval",
    "decision_rules"
  ],
  "properties": {
    "artifact_type": {"const": "judgment_policy"},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "standards_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "judgment_type": {"type": "string", "enum": ["artifact_release_readiness"]},
    "status": {"type": "string", "enum": ["draft", "canary", "active", "deprecated"]},
    "scope": {"type": "string", "minLength": 1},
    "environments": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "required_inputs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "precedent_retrieval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "method_id", "method_version", "query_fields", "threshold", "top_k", "similarity_basis"],
      "properties": {
        "required": {"type": "boolean"},
        "method_id": {"type": "string", "minLength": 1},
        "method_version": {"type": "string", "minLength": 1},
        "query_fields": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
        "threshold": {"type": "number", "minimum": 0, "maximum": 1},
        "top_k": {"type": "integer", "minimum": 1, "maximum": 20},
        "similarity_basis": {"type": "string", "minLength": 1}
      }
    },
    "decision_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "outcome", "priority", "all_conditions", "rationale_template"],
        "properties": {
          "rule_id": {"type": "string", "minLength": 1},
          "outcome": {"type": "string", "enum": ["approve", "revise", "block", "escalate", "needs_more_evidence"]},
          "priority": {"type": "integer", "minimum": 1},
          "all_conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["field", "operator", "value"],
              "properties": {
                "field": {"type": "string", "minLength": 1},
                "operator": {"type": "string", "enum": ["eq", "gte", "lte", "in"]},
                "value": {}
              }
            }
          },
          "rationale_template": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
