{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/nsx_safe_next_slice_recommendation_record.schema.json",
  "title": "nsx_safe_next_slice_recommendation_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "pr_number",
    "recommended_slice",
    "bounded_scope_systems",
    "stays_within_changed_scope"
  ],
  "properties": {
    "artifact_type": {
      "const": "nsx_safe_next_slice_recommendation_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "NSX"
    },
    "pr_number": {
      "type": "integer"
    },
    "recommended_slice": {
      "type": "string"
    },
    "bounded_scope_systems": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stays_within_changed_scope": {
      "type": "boolean"
    }
  }
}
