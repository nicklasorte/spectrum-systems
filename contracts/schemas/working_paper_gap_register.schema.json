{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/working_paper_gap_register.schema.json",
  "title": "Working Paper Gap Register",
  "description": "A standalone gap register artifact produced by the Working Paper Engine. Each entry describes a data, methodology, assumption, validation, coordination, or modeling gap identified during the study.",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "source_bundle_id", "gaps", "metadata"],
  "properties": {
    "artifact_id": {
      "type": "string",
      "description": "Unique identifier for this gap register artifact."
    },
    "source_bundle_id": {
      "type": "string",
      "description": "ID of the WorkingPaperBundle from which this register was extracted."
    },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap_item" },
      "description": "Ordered list of gap items."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_at", "total_gaps", "blocking_gaps"],
      "properties": {
        "created_at": {
          "type": "string",
          "description": "ISO 8601 timestamp."
        },
        "total_gaps": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of gap items in this register."
        },
        "blocking_gaps": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of blocking gap items."
        }
      }
    }
  },
  "$defs": {
    "gap_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap_id",
        "description",
        "section_ref",
        "gap_type",
        "impact",
        "blocking",
        "suggested_resolution",
        "source_refs"
      ],
      "properties": {
        "gap_id": {
          "type": "string",
          "pattern": "^GAP-[0-9]{3}$",
          "description": "Gap register item identifier."
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "Description of the gap."
        },
        "section_ref": {
          "type": "string",
          "description": "Working paper section this gap is most relevant to."
        },
        "gap_type": {
          "type": "string",
          "enum": ["Data", "Methodology", "Assumption", "Validation", "Coordination", "Modeling", "Other"],
          "description": "Classification of the gap type."
        },
        "impact": {
          "type": "string",
          "enum": ["High", "Medium", "Low"],
          "description": "Impact level of the gap."
        },
        "blocking": {
          "type": "boolean",
          "description": "Whether this gap blocks quantitative results from being reported."
        },
        "suggested_resolution": {
          "type": "string",
          "minLength": 1,
          "description": "Suggested resolution path."
        },
        "source_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Observed-item IDs that produced this gap."
        }
      }
    }
  }
}
