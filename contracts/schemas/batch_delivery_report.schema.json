{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/batch_delivery_report.schema.json",
  "title": "batch_delivery_report",
  "description": "Deterministic governed completion report emitted for each bounded roadmap batch cycle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "schema_version",
    "batch_id",
    "roadmap_id",
    "intent",
    "status",
    "files_changed",
    "contracts_added_or_updated",
    "tests_run",
    "results_summary",
    "remaining_risks",
    "open_followups",
    "recommended_next_batch",
    "blocking_issues",
    "evidence_refs",
    "source_refs",
    "trace_id",
    "created_at"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "pattern": "^BDR-[A-F0-9]{12}$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "batch_id": {
      "type": "string",
      "pattern": "^BATCH-[A-Z0-9-]+$"
    },
    "roadmap_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9_.-]*$"
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "completed_with_risk",
        "blocked",
        "failed"
      ]
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "contracts_added_or_updated": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "tests_run": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "results_summary": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "remaining_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "open_followups": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "recommended_next_batch": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^BATCH-[A-Z0-9-]+$"
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace-[A-Za-z0-9._:-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
