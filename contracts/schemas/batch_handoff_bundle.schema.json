{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/batch_handoff_bundle.schema.json",
  "title": "batch_handoff_bundle",
  "description": "Deterministic governed unresolved-state handoff used to carry forward prior-batch context into the next governed batch.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "schema_version",
    "source_batch_id",
    "roadmap_id",
    "recommended_next_batch",
    "must_carry_forward_risks",
    "must_carry_forward_artifacts",
    "must_preserve_invariants",
    "required_validations_next",
    "autonomy_blockers",
    "autonomy_decision_ref",
    "open_contract_work",
    "open_review_findings",
    "program_constraints",
    "human_decision_required",
    "source_delivery_report_ref",
    "trace_id",
    "created_at",
    "latest_exception_class",
    "latest_exception_resolution_action",
    "latest_exception_action_type",
    "latest_exception_requires_human_review",
    "latest_exception_requires_freeze",
    "required_next_actions",
    "capability_readiness_state",
    "capability_readiness_ref",
    "decision_proof_ref",
    "allow_decision_proof_ref",
    "unknown_state_signal_refs",
    "unknown_state_blockers",
    "failure_taxonomy_ref",
    "correction_pattern_ref",
    "rollback_plan_ref",
    "promotion_consistency_ref",
    "decision_quality_budget_ref",
    "calibration_assessment_ref",
    "judgment_promotion_gate_ref",
    "system_budget_status_ref",
    "canary_rollout_ref",
    "continuous_eval_run_refs",
    "trust_posture_snapshot_ref",
    "judgment_lifecycle_refs",
    "precedent_selection_refs",
    "precedent_conflict_refs",
    "override_governance_refs",
    "override_escalation_indicators",
    "expiring_override_refs",
    "required_lifecycle_followups",
    "required_governance_followups",
    "policy_candidate_refs",
    "policy_activation_ref",
    "policy_conflict_refs",
    "active_policy_refs"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "pattern": "^BHB-[A-F0-9]{12}$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.9.0"
    },
    "source_batch_id": {
      "type": "string",
      "pattern": "^BATCH-[A-Z0-9-]+$"
    },
    "roadmap_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9_.-]*$"
    },
    "recommended_next_batch": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^BATCH-[A-Z0-9-]+$"
    },
    "must_carry_forward_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "must_carry_forward_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "must_preserve_invariants": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "required_validations_next": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "autonomy_blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "autonomy_decision_ref": {
      "type": "string",
      "pattern": "^autonomy_decision_record:ADR-[A-F0-9]{12}$"
    },
    "open_contract_work": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "open_review_findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "program_constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "human_decision_required": {
      "type": "boolean"
    },
    "source_delivery_report_ref": {
      "type": "string",
      "pattern": "^batch_delivery_report:BDR-[A-F0-9]{12}$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace-[A-Za-z0-9._:-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "latest_exception_class": {
      "type": "string",
      "enum": [
        "missing_eval_coverage",
        "missing_required_eval_result",
        "indeterminate_required_eval",
        "replay_mismatch",
        "review_required",
        "autonomy_blocked",
        "program_misalignment",
        "drift_detected",
        "unresolved_critical_risk",
        "policy_violation",
        "execution_failure",
        "unknown_blocker"
      ]
    },
    "latest_exception_resolution_action": {
      "type": "string",
      "enum": [
        "create_eval_coverage_work",
        "re_run_or_remediate_eval_path",
        "freeze_and_investigate",
        "freeze_and_replay_investigation",
        "queue_review",
        "require_human_review",
        "roadmap_adjustment",
        "remediation_batch",
        "escalate"
      ]
    },
    "latest_exception_action_type": {
      "type": "string",
      "enum": [
        "create_remediation_batch",
        "create_eval_batch",
        "queue_review",
        "freeze_and_investigate",
        "escalate",
        "adjust_roadmap",
        "stop_without_auto_action"
      ]
    },
    "latest_exception_requires_human_review": {
      "type": "boolean"
    },
    "latest_exception_requires_freeze": {
      "type": "boolean"
    },
    "required_next_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "capability_readiness_state": {
      "type": "string",
      "enum": [
        "unsafe",
        "constrained",
        "supervised",
        "autonomous"
      ]
    },
    "capability_readiness_ref": {
      "type": "string",
      "pattern": "^capability_readiness_record:CRD-[A-F0-9]{12}$"
    },
    "decision_proof_ref": {
      "type": "string",
      "pattern": "^decision_proof_record:DPR-[A-F0-9]{12}$"
    },
    "allow_decision_proof_ref": {
      "type": "string",
      "pattern": "^allow_decision_proof:ADP-[A-F0-9]{12}$"
    },
    "unknown_state_signal_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^unknown_state_signal:USS-[A-F0-9]{12}$"
      },
      "uniqueItems": true
    },
    "unknown_state_blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "failure_taxonomy_ref": {
      "type": "string",
      "pattern": "^failure_taxonomy_record:FTX-[A-F0-9]{12}$"
    },
    "correction_pattern_ref": {
      "type": "string",
      "pattern": "^correction_pattern_record:CPR-[A-F0-9]{12}$"
    },
    "rollback_plan_ref": {
      "type": "string",
      "pattern": "^rollback_plan_record:RBP-[A-F0-9]{12}$"
    },
    "promotion_consistency_ref": {
      "type": "string",
      "pattern": "^promotion_consistency_record:PCR-[A-F0-9]{12}$"
    },
    "system_budget_status_ref": {
      "type": "string",
      "pattern": "^system_budget_status:SBS-[A-F0-9]{12}$"
    },
    "canary_rollout_ref": {
      "type": "string",
      "pattern": "^canary_rollout_record:CNR-[A-F0-9]{12}$"
    },
    "continuous_eval_run_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^continuous_eval_run_record:CER-[A-F0-9]{12}$"
      },
      "minItems": 4,
      "uniqueItems": true
    },
    "trust_posture_snapshot_ref": {
      "type": "string",
      "pattern": "^trust_posture_snapshot:TPS-[A-F0-9]{12}$"
    },
    "judgment_lifecycle_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^judgment_lifecycle_record:JLC-[A-F0-9]{12}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "precedent_selection_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^precedent_selection_record:PSL-[A-F0-9]{12}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "precedent_conflict_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^precedent_conflict_record:PCF-[A-F0-9]{12}$"
      },
      "uniqueItems": true
    },
    "override_governance_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^override_governance_record:OVG-[A-F0-9]{12}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "override_escalation_indicators": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "expiring_override_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^override_governance_record:[A-Z0-9-]+$"
      },
      "uniqueItems": true
    },
    "required_lifecycle_followups": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "required_governance_followups": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "decision_quality_budget_ref": {
      "type": "string",
      "pattern": "^decision_quality_budget_status:DQB-[A-F0-9]{12}$"
    },
    "calibration_assessment_ref": {
      "type": "string",
      "pattern": "^calibration_assessment_record:CAL-[A-F0-9]{12}$"
    },
    "judgment_promotion_gate_ref": {
      "type": "string",
      "pattern": "^judgment_promotion_gate_record:JPG-[A-F0-9]{12}$"
    },
    "policy_candidate_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^policy_candidate_record:PCD-[A-F0-9]{12}$"
      },
      "minItems": 0,
      "uniqueItems": true
    },
    "policy_activation_ref": {
      "type": "string",
      "pattern": "^policy_activation_record:PAC-[A-F0-9]{12}$"
    },
    "policy_conflict_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^policy_conflict_record:PCF-[A-F0-9]{12}$"
      },
      "minItems": 0,
      "uniqueItems": true
    },
    "active_policy_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^policy_candidate_record:PCD-[A-F0-9]{12}$"
      },
      "minItems": 0,
      "uniqueItems": true
    }
  }
}
