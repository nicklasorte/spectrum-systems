{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prompt_queue_review_trigger.schema.json",
  "title": "Prompt Queue Review Trigger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_trigger_artifact_id",
    "work_item_id",
    "parent_work_item_id",
    "post_execution_decision_artifact_path",
    "loop_control_decision_artifact_path",
    "execution_result_artifact_path",
    "trigger_status",
    "trigger_reason_code",
    "generated_at",
    "generator_version",
    "review_request"
  ],
  "properties": {
    "review_trigger_artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "work_item_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_work_item_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "post_execution_decision_artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "loop_control_decision_artifact_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "execution_result_artifact_path": {
      "type": "string",
      "minLength": 1
    },
    "trigger_status": {
      "type": "string",
      "enum": [
        "review_triggered",
        "no_review_needed",
        "blocked_no_trigger"
      ]
    },
    "trigger_reason_code": {
      "type": "string",
      "enum": [
        "review_triggered_post_execution_review_required",
        "review_triggered_failure_reentry_blocked",
        "review_triggered_failure_loop_block_reentry",
        "no_review_needed_post_execution_complete",
        "blocked_post_execution_reentry_blocked",
        "blocked_loop_control_block_reentry",
        "blocked_invalid_artifact",
        "blocked_invalid_lineage",
        "blocked_policy_ineligible"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "spawned_review_work_item_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "source_queue_state_path": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocking_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_request": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/review_request"
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "trigger_status": {
            "const": "review_triggered"
          }
        },
        "required": [
          "trigger_status"
        ]
      },
      "then": {
        "properties": {
          "review_request": {
            "$ref": "#/$defs/review_request"
          }
        }
      }
    }
  ],
  "$defs": {
    "review_request": {
      "title": "Review Request",
      "description": "Typed governed request describing required Claude review execution at deterministic checkpoints.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_id",
        "review_type",
        "scope_refs",
        "triggering_event",
        "required",
        "blocking",
        "related_batch_id",
        "slice_id",
        "program_id",
        "created_at",
        "trace_id",
        "source_refs"
      ],
      "properties": {
        "review_id": {
          "type": "string",
          "minLength": 1
        },
        "review_type": {
          "type": "string",
          "enum": [
            "surgical",
            "failure",
            "batch_architecture",
            "hard_gate",
            "strategic"
          ]
        },
        "scope_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "triggering_event": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "blocking": {
          "type": "boolean"
        },
        "related_batch_id": {
          "type": "string",
          "minLength": 1
        },
        "slice_id": {
          "type": "string",
          "minLength": 1
        },
        "program_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
