{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/tlc_handoff_record.schema.json",
  "title": "TLC Handoff Record",
  "description": "Formal AEX->TLC handoff artifact for admitted repo-mutating execution routed toward TPA/PQX.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "handoff_id",
    "request_id",
    "trace_id",
    "created_at",
    "produced_by",
    "build_admission_record_ref",
    "normalized_execution_request_ref",
    "handoff_status",
    "target_subsystems",
    "execution_type",
    "repo_mutation_requested",
    "reason_codes",
    "tlc_run_context",
    "lineage",
    "authenticity"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "tlc_handoff_record"
    },
    "handoff_id": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "produced_by": {
      "type": "string",
      "minLength": 1
    },
    "build_admission_record_ref": {
      "type": "string",
      "minLength": 1
    },
    "normalized_execution_request_ref": {
      "type": "string",
      "minLength": 1
    },
    "handoff_status": {
      "type": "string",
      "enum": [
        "accepted",
        "rejected",
        "blocked"
      ]
    },
    "target_subsystems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "TPA",
          "PQX",
          "FRE",
          "RIL",
          "CDE",
          "PRG",
          "SEL"
        ]
      },
      "uniqueItems": true
    },
    "execution_type": {
      "type": "string",
      "enum": [
        "repo_write",
        "read_only",
        "analysis_only",
        "unknown"
      ]
    },
    "repo_mutation_requested": {
      "type": "boolean"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tlc_run_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "branch_ref",
        "objective",
        "entry_boundary"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "branch_ref": {
          "type": "string",
          "minLength": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "entry_boundary": {
          "type": "string",
          "enum": [
            "aex_to_tlc"
          ]
        }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "upstream_refs",
        "intended_path"
      ],
      "properties": {
        "upstream_refs": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "intended_path": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "enum": [
              "TLC",
              "TPA",
              "PQX"
            ]
          }
        }
      }
    },
    "authenticity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issuer",
        "key_id",
        "payload_digest",
        "attestation"
      ],
      "properties": {
        "issuer": {
          "type": "string",
          "enum": [
            "AEX",
            "TLC"
          ]
        },
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "payload_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "attestation": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
