{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/judgment_remediation_closure_record.schema.json",
  "title": "Judgment Remediation Closure Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "closure_id",
    "remediation_id",
    "source_escalation_record_id",
    "source_action_id",
    "source_outcome_id",
    "closure_decision",
    "evidence_artifact_refs_reviewed",
    "replay_safe_checks",
    "approval_status",
    "approval_actor_ref",
    "resulting_system_effect",
    "rationale",
    "trace",
    "policy_version",
    "created_at"
  ],
  "properties": {
    "artifact_type": {"const": "judgment_remediation_closure_record"},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "const": "1.0.0"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "standards_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "closure_id": {"type": "string", "minLength": 1},
    "remediation_id": {"type": "string", "minLength": 1},
    "source_escalation_record_id": {"type": "string", "minLength": 1},
    "source_action_id": {"type": "string", "minLength": 1},
    "source_outcome_id": {"type": "string", "minLength": 1},
    "closure_decision": {"type": "string", "enum": ["approved", "rejected"]},
    "evidence_artifact_refs_reviewed": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "replay_safe_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_name", "passed", "details"],
        "properties": {
          "check_name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "details": {"type": "string", "minLength": 1}
        }
      }
    },
    "approval_status": {"type": "string", "enum": ["approved", "rejected", "pending", "not_required"]},
    "approval_actor_ref": {"type": "string"},
    "resulting_system_effect": {
      "type": "string",
      "enum": ["remain_blocked", "remain_frozen", "resume_with_warning", "resume_allowed"]
    },
    "rationale": {"type": "string", "minLength": 1},
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "run_id",
        "source_escalation_record_id",
        "action_id",
        "outcome_id",
        "remediation_id"
      ],
      "properties": {
        "trace_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "source_escalation_record_id": {"type": "string", "minLength": 1},
        "action_id": {"type": "string", "minLength": 1},
        "outcome_id": {"type": "string", "minLength": 1},
        "remediation_id": {"type": "string", "minLength": 1}
      }
    },
    "policy_version": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
