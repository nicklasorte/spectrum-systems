{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pqx_bundle_state.schema.json",
  "title": "PQX Bundle State",
  "description": "Deterministic persisted state artifact for governed PQX bundle advancement, blocking, review/fix attachment, and resume continuity.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "roadmap_authority_ref",
    "execution_plan_ref",
    "run_id",
    "sequence_run_id",
    "active_bundle_id",
    "completed_bundle_ids",
    "completed_step_ids",
    "blocked_step_ids",
    "pending_fix_ids",
    "review_artifact_refs",
    "artifact_index",
    "resume_position",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "roadmap_authority_ref": {
      "type": "string",
      "enum": [
        "docs/roadmaps/system_roadmap.md"
      ]
    },
    "execution_plan_ref": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "sequence_run_id": {
      "type": "string",
      "minLength": 1
    },
    "active_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "completed_bundle_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty"
      },
      "uniqueItems": true
    },
    "completed_step_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty"
      },
      "uniqueItems": true
    },
    "blocked_step_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty"
      },
      "uniqueItems": true
    },
    "pending_fix_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pending_fix"
      },
      "uniqueItems": true
    },
    "review_artifact_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/review_ref"
      },
      "uniqueItems": true
    },
    "artifact_index": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[A-Za-z0-9._:-]+$": {
          "$ref": "#/$defs/artifact_ref_list"
        }
      }
    },
    "resume_position": {
      "$ref": "#/$defs/resume_position"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "artifact_ref_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "review_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_id",
        "bundle_id",
        "step_id",
        "artifact_ref"
      ],
      "properties": {
        "review_id": {
          "$ref": "#/$defs/non_empty"
        },
        "bundle_id": {
          "$ref": "#/$defs/non_empty"
        },
        "step_id": {
          "$ref": "#/$defs/non_empty"
        },
        "artifact_ref": {
          "$ref": "#/$defs/non_empty"
        }
      }
    },
    "pending_fix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fix_id",
        "finding_id",
        "target_bundle_id",
        "target_step_id",
        "status"
      ],
      "properties": {
        "fix_id": {
          "$ref": "#/$defs/non_empty"
        },
        "finding_id": {
          "$ref": "#/$defs/non_empty"
        },
        "target_bundle_id": {
          "$ref": "#/$defs/non_empty"
        },
        "target_step_id": {
          "$ref": "#/$defs/non_empty"
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "in_progress",
            "complete",
            "deferred"
          ]
        }
      }
    },
    "resume_position": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bundle_id",
        "next_step_id",
        "resume_token"
      ],
      "properties": {
        "bundle_id": {
          "$ref": "#/$defs/non_empty"
        },
        "next_step_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "resume_token": {
          "type": "string",
          "pattern": "^resume:[A-Za-z0-9._:-]+:[A-Za-z0-9._:-]+:[0-9]+$"
        }
      }
    }
  }
}
