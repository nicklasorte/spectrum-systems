{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spectrum-systems.org/contracts/normalized_transcript.json",
  "title": "Normalized Transcript",
  "description": "Parsed and normalized meeting transcript with speaker registry and indexed segments.",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "artifact_type", "speakers", "segments", "manifest"],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^NTX-[0-9a-f]{8}$",
      "description": "Unique artifact identifier"
    },
    "artifact_type": {"type": "string", "const": "normalized_transcript"},
    "speakers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["speaker_id", "speaker_name"],
        "additionalProperties": false,
        "properties": {
          "speaker_id": {"type": "string", "pattern": "^SPK-[0-9a-f]{4}$"},
          "speaker_name": {"type": "string", "minLength": 1}
        }
      }
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["segment_id", "timestamp", "speaker_id", "text"],
        "additionalProperties": false,
        "properties": {
          "segment_id": {"type": "string", "pattern": "^SEG-[0-9a-f]{4}$"},
          "timestamp": {"type": "number", "minimum": 0},
          "speaker_id": {"type": "string", "pattern": "^SPK-[0-9a-f]{4}$"},
          "text": {"type": "string", "minLength": 1}
        }
      }
    },
    "manifest": {
      "type": "object",
      "required": ["total_segments", "speaker_count", "reproducible"],
      "additionalProperties": false,
      "properties": {
        "total_segments": {"type": "integer", "minimum": 1},
        "speaker_count": {"type": "integer", "minimum": 1},
        "reproducible": {"type": "boolean"},
        "duration_seconds": {"type": "number", "minimum": 0},
        "meeting_date": {"type": "string"}
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "trace_id": {"type": "string"},
        "upstream_artifact_id": {"type": "string"},
        "created_by": {"type": "string"},
        "created_at": {"type": "string"}
      }
    }
  }
}
