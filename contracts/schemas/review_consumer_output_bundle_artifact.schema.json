{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/review_consumer_output_bundle_artifact.schema.json",
  "title": "Review Consumer Output Bundle Artifact",
  "description": "RIL-005 deterministic top-level governed bundle tying read-only consumer outputs and projection-boundary validation. Non-authoritative intake/view bundle only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_class",
    "schema_version",
    "review_consumer_output_bundle_id",
    "source_review_projection_bundle_ref",
    "source_review_path",
    "review_date",
    "system_scope",
    "roadmap_review_view_ref",
    "control_loop_review_queue_record_ref",
    "readiness_review_dashboard_ref",
    "review_consumption_validation_ref",
    "blocker_present",
    "escalation_present",
    "emitted_at",
    "non_authoritative_notice",
    "provenance",
    "roadmap_review_view_artifact",
    "control_loop_review_queue_record_artifact",
    "readiness_review_dashboard_artifact",
    "review_consumption_validation_artifact"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "review_consumer_output_bundle_artifact"
    },
    "artifact_class": {
      "type": "string",
      "const": "coordination"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "review_consumer_output_bundle_id": {
      "type": "string",
      "pattern": "^rco-[a-f0-9]{16}$"
    },
    "source_review_projection_bundle_ref": {
      "type": "string",
      "pattern": "^rpb-[a-f0-9]{16}$"
    },
    "source_review_path": {
      "type": "string",
      "minLength": 1
    },
    "review_date": {
      "type": "string",
      "pattern": "^20\\d{2}-\\d{2}-\\d{2}$"
    },
    "system_scope": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "roadmap_review_view_ref": {
      "type": "string",
      "pattern": "^rrv-[a-f0-9]{16}$"
    },
    "control_loop_review_queue_record_ref": {
      "type": "string",
      "pattern": "^clr-[a-f0-9]{16}$"
    },
    "readiness_review_dashboard_ref": {
      "type": "string",
      "pattern": "^rda-[a-f0-9]{16}$"
    },
    "review_consumption_validation_ref": {
      "type": "string",
      "pattern": "^rcv-[a-f0-9]{16}$"
    },
    "blocker_present": {
      "type": "boolean"
    },
    "escalation_present": {
      "type": "boolean"
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "non_authoritative_notice": {
      "type": "string",
      "const": "Read-only consumer intake/view artifact only; signals such as enforcement_block or control_escalation are non-authoritative and require independent governed decisions."
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "roadmap_review_view_artifact": {
      "$ref": "#/$defs/roadmapViewArtifact"
    },
    "control_loop_review_queue_record_artifact": {
      "$ref": "#/$defs/controlQueueArtifact"
    },
    "readiness_review_dashboard_artifact": {
      "$ref": "#/$defs/readinessDashboardArtifact"
    },
    "review_consumption_validation_artifact": {
      "$ref": "#/$defs/consumptionValidationArtifact"
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter",
        "consumer_surface",
        "consumption_mode",
        "source_review_projection_bundle_ref",
        "source_consumer_output_ids"
      ],
      "properties": {
        "adapter": {
          "type": "string",
          "const": "review_consumer_wiring"
        },
        "consumer_surface": {
          "type": "string",
          "const": "consumer_output_bundle"
        },
        "consumption_mode": {
          "type": "string",
          "const": "projection_only_read_only"
        },
        "source_review_projection_bundle_ref": {
          "type": "string",
          "pattern": "^rpb-[a-f0-9]{16}$"
        },
        "source_consumer_output_ids": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "roadmap_review_view_id",
            "control_loop_review_queue_record_id",
            "readiness_review_dashboard_id",
            "review_consumption_validation_id"
          ],
          "properties": {
            "roadmap_review_view_id": {
              "type": "string",
              "pattern": "^rrv-[a-f0-9]{16}$"
            },
            "control_loop_review_queue_record_id": {
              "type": "string",
              "pattern": "^clr-[a-f0-9]{16}$"
            },
            "readiness_review_dashboard_id": {
              "type": "string",
              "pattern": "^rda-[a-f0-9]{16}$"
            },
            "review_consumption_validation_id": {
              "type": "string",
              "pattern": "^rcv-[a-f0-9]{16}$"
            }
          }
        }
      }
    },
    "roadmapViewArtifact": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "artifact_type",
        "roadmap_review_view_id"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "const": "roadmap_review_view_artifact"
        },
        "roadmap_review_view_id": {
          "type": "string",
          "pattern": "^rrv-[a-f0-9]{16}$"
        }
      }
    },
    "controlQueueArtifact": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "artifact_type",
        "control_loop_review_queue_record_id"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "const": "control_loop_review_queue_record_artifact"
        },
        "control_loop_review_queue_record_id": {
          "type": "string",
          "pattern": "^clr-[a-f0-9]{16}$"
        }
      }
    },
    "readinessDashboardArtifact": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "artifact_type",
        "readiness_review_dashboard_id"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "const": "readiness_review_dashboard_artifact"
        },
        "readiness_review_dashboard_id": {
          "type": "string",
          "pattern": "^rda-[a-f0-9]{16}$"
        }
      }
    },
    "consumptionValidationArtifact": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "artifact_type",
        "review_consumption_validation_id"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "const": "review_consumption_validation_artifact"
        },
        "review_consumption_validation_id": {
          "type": "string",
          "pattern": "^rcv-[a-f0-9]{16}$"
        }
      }
    }
  }
}
