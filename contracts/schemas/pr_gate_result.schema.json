{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pr_gate_result",
  "description": "Schema for the PR Gate shard aggregator result artifact.",
  "type": "object",
  "required": [
    "artifact_type",
    "schema_version",
    "status",
    "produced_at",
    "authority_scope",
    "required_shards",
    "shard_statuses",
    "blocking_reasons",
    "parity_status",
    "trace_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "pr_gate_result"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "block"]
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    },
    "authority_scope": {
      "type": "string"
    },
    "required_shards": {
      "type": "array",
      "items": { "type": "string" }
    },
    "shard_statuses": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "blocking_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "parity_status": {
      "type": "string"
    },
    "trace_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
