{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/canary_record.schema.json",
  "title": "canary_record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_type": { "type": "string", "const": "canary_record" },
    "artifact_id": { "type": "string", "minLength": 1 },
    "artifact_version": { "type": "string", "const": "1.0.0" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "standards_version": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "owner_system": { "type": "string", "pattern": "^[A-Z0-9]{2,8}$" },
    "source_artifact": { "type": "string", "minLength": 1 },
    "canary_scope": { "type": "string", "minLength": 1 },
    "started_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["running", "passed", "failed", "aborted"] }
  },
  "required": [
    "artifact_type", "artifact_id", "artifact_version", "schema_version",
    "standards_version", "trace_id", "created_at", "owner_system",
    "source_artifact", "canary_scope", "started_at", "status"
  ]
}
