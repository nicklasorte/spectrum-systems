{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/comment_resolution_matrix.schema.json",
  "title": "Comment Resolution Matrix",
  "description": "Authoritative mapping from reviewer comments to dispositions, actions, and validation status.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_class",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "record_id",
    "run_id",
    "created_at",
    "created_by",
    "source_repo",
    "source_repo_version",
    "matrix_id",
    "comment_set_id",
    "working_paper_id",
    "working_paper_revision",
    "entries"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "comment_resolution_matrix",
      "description": "Canonical artifact type identifier."
    },
    "artifact_class": {
      "type": "string",
      "const": "review",
      "description": "Canonical artifact class identifier."
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[A-Z0-9._-]+$",
      "description": "Stable identifier for this resolution matrix artifact."
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version of this artifact instance for diffing and rollback."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the comment_resolution_matrix schema."
    },
    "standards_version": {
      "type": "string",
      "const": "2026.03.0",
      "description": "Standards release version from contracts/standards-manifest.json."
    },
    "record_id": {
      "type": "string",
      "pattern": "^REC-[A-Z0-9._-]+$",
      "description": "Record identifier used for provenance and diffing."
    },
    "run_id": {
      "type": "string",
      "pattern": "^run-[A-Za-z0-9._-]+$",
      "description": "Deterministic run identifier for the workflow that produced this record."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this matrix was generated."
    },
    "created_by": {
      "$ref": "#/$defs/created_by"
    },
    "source_repo": {
      "type": "string",
      "description": "Repository slug that produced this matrix."
    },
    "source_repo_version": {
      "type": "string",
      "description": "Tag or commit hash of the source repository."
    },
    "matrix_id": {
      "type": "string",
      "pattern": "^CRM-[A-Z0-9._-]+$",
      "description": "Identifier for this comment resolution matrix."
    },
    "comment_set_id": {
      "type": "string",
      "pattern": "^CSET-[A-Z0-9._-]+$",
      "description": "Identifier of the comment set being resolved."
    },
    "working_paper_id": {
      "type": "string",
      "pattern": "^WKP-[A-Z0-9._-]+$",
      "description": "Identifier of the working paper being resolved."
    },
    "working_paper_revision": {
      "type": "string",
      "pattern": "^rev[0-9]+$",
      "description": "Revision marker for the working paper the resolutions target."
    },
    "input_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_artifact"
      },
      "description": "Upstream artifacts used to build this matrix (e.g., reviewer_comment_set, prior matrices)."
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      },
      "description": "Resolution entries aligned to reviewer comments."
    },
    "evaluation_refs": {
      "type": "object",
      "description": "Optional deterministic evaluation and control decision bundle for fail-closed orchestration integration."
    }
  },
  "$defs": {
    "created_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "agent_type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "agent_type": {
          "type": "string",
          "enum": [
            "human",
            "ai_model",
            "workflow",
            "script"
          ]
        },
        "organization": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "input_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "artifact_version",
        "role"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^[A-Z0-9._-]+$"
        },
        "artifact_type": {
          "type": "string"
        },
        "artifact_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "role": {
          "type": "string"
        },
        "source_repo": {
          "type": "string"
        },
        "source_repo_version": {
          "type": "string"
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "comment_id",
        "resolution_status",
        "response_text",
        "action_items",
        "validated_by",
        "applies_to_revision"
      ],
      "properties": {
        "entry_id": {
          "type": "string",
          "pattern": "^ENT-[A-Z0-9._-]+$"
        },
        "comment_id": {
          "type": "string",
          "pattern": "^CMT-[A-Z0-9._-]+$"
        },
        "resolution_status": {
          "type": "string",
          "enum": [
            "resolved",
            "partially_resolved",
            "deferred",
            "out_of_scope",
            "needs_input"
          ]
        },
        "response_text": {
          "type": "string"
        },
        "action_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/action_item"
          }
        },
        "evidence_links": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "validation_notes": {
          "type": "string"
        },
        "validated_by": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "role",
            "timestamp"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "role": {
              "type": "string"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "review_status": {
              "type": "string",
              "enum": [
                "pending_review",
                "in_review",
                "approved",
                "rejected"
              ]
            }
          }
        },
        "applies_to_revision": {
          "type": "string",
          "pattern": "^rev[0-9]+$"
        },
        "provenance_id": {
          "type": "string",
          "pattern": "^PRV-[A-Z0-9._-]+$"
        }
      }
    },
    "action_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "description",
        "owner",
        "status"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "pattern": "^ACT-[A-Z0-9._-]+$"
        },
        "description": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "due_date": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "in_progress",
            "complete",
            "blocked"
          ]
        }
      }
    }
  }
}
