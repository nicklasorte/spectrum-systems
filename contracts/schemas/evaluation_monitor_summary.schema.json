{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/evaluation_monitor_summary.schema.json",
  "title": "Evaluation Monitor Summary",
  "description": "Schema supporting both legacy regression monitor summaries and control-loop run-bundle summaries.",
  "oneOf": [
    {"$ref": "#/$defs/legacy_monitor_summary"},
    {"$ref": "#/$defs/control_loop_monitor_summary"}
  ],
  "$defs": {
    "legacy_monitor_summary": {
      "type": "object",
      "required": [
        "summary_id",
        "created_at",
        "window",
        "aggregates",
        "trend_analysis",
        "burn_rate_assessment",
        "recommended_action",
        "source_run_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "summary_id": {"type": "string", "minLength": 1},
        "created_at": {"type": "string", "format": "date-time"},
        "window": {
          "type": "object",
          "required": ["start_at", "end_at", "total_runs"],
          "additionalProperties": false,
          "properties": {
            "start_at": {"type": "string", "format": "date-time"},
            "end_at": {"type": "string", "format": "date-time"},
            "total_runs": {"type": "integer", "minimum": 0}
          }
        },
        "aggregates": {
          "type": "object",
          "required": [
            "average_pass_rate",
            "average_drift_rate",
            "average_reproducibility_score",
            "total_failed_runs",
            "total_critical_alerts"
          ],
          "additionalProperties": false,
          "properties": {
            "average_pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
            "average_drift_rate": {"type": "number", "minimum": 0, "maximum": 1},
            "average_reproducibility_score": {"type": "number", "minimum": 0, "maximum": 1},
            "total_failed_runs": {"type": "integer", "minimum": 0},
            "total_critical_alerts": {"type": "integer", "minimum": 0},
            "average_replay_consistency_sli": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "trend_analysis": {
          "type": "object",
          "required": ["pass_rate_trend", "drift_rate_trend", "reproducibility_trend"],
          "additionalProperties": false,
          "properties": {
            "pass_rate_trend": {"type": "string", "enum": ["improving", "stable", "degrading"]},
            "drift_rate_trend": {"type": "string", "enum": ["improving", "stable", "degrading"]},
            "reproducibility_trend": {"type": "string", "enum": ["improving", "stable", "degrading"]},
            "replay_consistency_trend": {"type": "string", "enum": ["improving", "stable", "degrading"]}
          }
        },
        "burn_rate_assessment": {
          "type": "object",
          "required": ["status", "reasons"],
          "additionalProperties": false,
          "properties": {
            "status": {"type": "string", "enum": ["normal", "elevated", "exhausting"]},
            "reasons": {
              "type": "array",
              "items": {"type": "string", "minLength": 1}
            }
          }
        },
        "recommended_action": {"type": "string", "enum": ["none", "watch", "freeze_changes", "rollback_candidate"]},
        "source_run_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "control_loop_monitor_summary": {
      "type": "object",
      "required": [
        "summary_id",
        "trace_id",
        "source_record_ids",
        "source_trace_ids",
        "generated_at",
        "window",
        "aggregated_slis",
        "overall_status",
        "reasons"
      ],
      "additionalProperties": false,
      "properties": {
        "summary_id": {"type": "string", "minLength": 1},
        "trace_id": {"type": "string", "minLength": 1},
        "source_record_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "source_trace_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "generated_at": {"type": "string", "format": "date-time"},
        "window": {
          "type": "object",
          "required": ["record_count"],
          "additionalProperties": false,
          "properties": {
            "record_count": {"type": "integer", "minimum": 1}
          }
        },
        "aggregated_slis": {
          "type": "object",
          "required": [
            "manifest_valid_rate",
            "inputs_present_rate",
            "expected_outputs_declared_rate",
            "output_paths_valid_rate",
            "provenance_required_rate",
            "bundle_validation_success_rate"
          ],
          "additionalProperties": false,
          "properties": {
            "manifest_valid_rate": {"type": "number", "minimum": 0, "maximum": 1},
            "inputs_present_rate": {"type": "number", "minimum": 0, "maximum": 1},
            "expected_outputs_declared_rate": {"type": "number", "minimum": 0, "maximum": 1},
            "output_paths_valid_rate": {"type": "number", "minimum": 0, "maximum": 1},
            "provenance_required_rate": {"type": "number", "minimum": 0, "maximum": 1},
            "bundle_validation_success_rate": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "overall_status": {"type": "string", "enum": ["healthy", "warning", "exhausted", "blocked", "indeterminate"]},
        "reasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
