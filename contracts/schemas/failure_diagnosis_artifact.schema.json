{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/failure_diagnosis_artifact.schema.json",
  "title": "Failure Diagnosis Artifact",
  "description": "Canonical deterministic diagnosis artifact for FRE failure intake and root-cause classification.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "standards_version",
    "diagnosis_id",
    "failure_source_type",
    "source_artifact_refs",
    "observed_failure_summary",
    "evidence",
    "primary_root_cause",
    "secondary_contributors",
    "smallest_safe_fix_class",
    "recommended_repair_area",
    "blocking_severity",
    "deterministic_reasoning_trace",
    "affected_surfaces",
    "expected_validation_commands",
    "related_contract_refs",
    "emitted_at",
    "trace"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "failure_diagnosis_artifact"
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "diagnosis_id": {
      "type": "string",
      "pattern": "^FDIAG-[a-f0-9]{20}$"
    },
    "failure_source_type": {
      "type": "string",
      "enum": [
        "contract_preflight",
        "pytest_summary",
        "contract_enforcement",
        "readiness_failure",
        "certification_failure",
        "control_surface_enforcement"
      ]
    },
    "source_artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "observed_failure_summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "source_surface",
          "evidence_type",
          "message",
          "artifact_ref",
          "details"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "pattern": "^E-[a-f0-9]{16}$"
          },
          "source_surface": {
            "type": "string",
            "minLength": 1
          },
          "evidence_type": {
            "type": "string",
            "enum": [
              "missing_required_surface",
              "schema_example_drift",
              "producer_wiring_gap",
              "consumer_wiring_gap",
              "fixture_gap",
              "invariant_violation",
              "test_expectation_drift",
              "manifest_or_registry_mismatch",
              "control_surface_input_missing",
              "certification_surface_gap",
              "source_authority_anchor_gap",
              "policy_composition_gap",
              "corroboration_validation_gap",
              "override_temporal_validation_gap",
              "unknown_failure_class"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "artifact_ref": {
            "type": "string",
            "minLength": 1
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "primary_root_cause": {
      "type": "string",
      "enum": [
        "missing_required_surface",
        "schema_example_drift",
        "producer_wiring_gap",
        "consumer_wiring_gap",
        "fixture_gap",
        "invariant_violation",
        "test_expectation_drift",
        "manifest_or_registry_mismatch",
        "control_surface_input_missing",
        "certification_surface_gap",
        "source_authority_anchor_gap",
        "policy_composition_gap",
        "corroboration_validation_gap",
        "override_temporal_validation_gap",
        "unknown_failure_class"
      ]
    },
    "secondary_contributors": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "missing_required_surface",
          "schema_example_drift",
          "producer_wiring_gap",
          "consumer_wiring_gap",
          "fixture_gap",
          "invariant_violation",
          "test_expectation_drift",
          "manifest_or_registry_mismatch",
          "control_surface_input_missing",
          "certification_surface_gap",
          "source_authority_anchor_gap",
          "policy_composition_gap",
          "corroboration_validation_gap",
          "override_temporal_validation_gap",
          "unknown_failure_class"
        ]
      },
      "uniqueItems": true
    },
    "smallest_safe_fix_class": {
      "type": "string",
      "minLength": 1
    },
    "recommended_repair_area": {
      "type": "string",
      "minLength": 1
    },
    "blocking_severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "blocker"
      ]
    },
    "deterministic_reasoning_trace": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "matched",
          "classification_candidate",
          "matched_evidence_ids",
          "reason"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1
          },
          "matched": {
            "type": "boolean"
          },
          "classification_candidate": {
            "type": "string",
            "enum": [
              "missing_required_surface",
              "schema_example_drift",
              "producer_wiring_gap",
              "consumer_wiring_gap",
              "fixture_gap",
              "invariant_violation",
              "test_expectation_drift",
              "manifest_or_registry_mismatch",
              "control_surface_input_missing",
              "certification_surface_gap",
              "source_authority_anchor_gap",
              "policy_composition_gap",
              "corroboration_validation_gap",
              "override_temporal_validation_gap",
              "unknown_failure_class"
            ]
          },
          "matched_evidence_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^E-[a-f0-9]{16}$"
            },
            "uniqueItems": true
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "affected_surfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "expected_validation_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "related_contract_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "trace_id",
        "policy_id",
        "governing_ref",
        "intake_hash"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "governing_ref": {
          "type": "string",
          "minLength": 1
        },
        "intake_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
