{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/roadmap_multi_batch_run_result.schema.json",
  "title": "Roadmap Multi-Batch Run Result",
  "description": "Deterministic governed bounded roadmap run artifact covering sequential authorized batch attempts under fixed per-run execution policy.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "schema_version",
    "roadmap_id",
    "attempted_batch_ids",
    "completed_batch_ids",
    "blocked_batch_id",
    "frozen_batch_id",
    "stop_reason",
    "stop_reason_codes",
    "max_batches_per_run",
    "resolved_max_batches_per_run",
    "batches_executed_count",
    "final_roadmap_status_ref",
    "loop_validation_refs",
    "progress_update_refs",
    "authorization_refs",
    "continuation_decision_sequence",
    "execution_efficiency_report",
    "executed_at",
    "input_hash",
    "trace_id",
    "source_refs"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^RMB-[A-F0-9]{12}$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.2.0"
    },
    "roadmap_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9_.-]*$"
    },
    "attempted_batch_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^BATCH-[A-Z]$"
      }
    },
    "completed_batch_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^BATCH-[A-Z]$"
      }
    },
    "blocked_batch_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^BATCH-[A-Z]$"
    },
    "frozen_batch_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^BATCH-[A-Z]$"
    },
    "stop_reason": {
      "type": "string",
      "enum": [
        "max_batches_reached",
        "hard_gate_stop",
        "authorization_block",
        "authorization_freeze",
        "missing_required_signal",
        "execution_blocked",
        "execution_failed",
        "loop_validation_failed",
        "replay_not_ready",
        "invalid_roadmap_state",
        "invalid_progress_state",
        "contract_precondition_failed",
        "no_eligible_batch",
        "diminishing_returns_detected",
        "repeated_failure_pattern",
        "unresolved_blocker_persists",
        "risk_accumulation_threshold_exceeded"
      ]
    },
    "stop_reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "max_batches_reached",
          "hard_gate_stop",
          "authorization_block",
          "authorization_freeze",
          "missing_required_signal",
          "execution_blocked",
          "execution_failed",
          "loop_validation_failed",
          "replay_not_ready",
          "invalid_roadmap_state",
          "invalid_progress_state",
          "contract_precondition_failed",
          "no_eligible_batch",
          "diminishing_returns_detected",
          "repeated_failure_pattern",
          "unresolved_blocker_persists",
          "risk_accumulation_threshold_exceeded"
        ]
      },
      "uniqueItems": true
    },
    "max_batches_per_run": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "resolved_max_batches_per_run": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "batches_executed_count": {
      "type": "integer",
      "minimum": 0
    },
    "final_roadmap_status_ref": {
      "type": "string",
      "minLength": 1
    },
    "loop_validation_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^RLV-[A-F0-9]{12}$"
      }
    },
    "progress_update_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^RPU-[A-F0-9]{12}$"
      }
    },
    "authorization_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^REA-[A-F0-9]{12}$"
      }
    },
    "continuation_decision_sequence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step",
          "decision",
          "reason_code"
        ],
        "properties": {
          "step": {
            "type": "integer",
            "minimum": 1
          },
          "decision": {
            "type": "string",
            "enum": [
              "continue",
              "stop"
            ]
          },
          "reason_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "execution_efficiency_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "batches_executed_per_run",
        "useful_batches",
        "early_stops",
        "average_progress_per_run",
        "chain_context_refs",
        "adaptive_factors"
      ],
      "properties": {
        "batches_executed_per_run": {
          "type": "integer",
          "minimum": 0
        },
        "useful_batches": {
          "type": "integer",
          "minimum": 0
        },
        "early_stops": {
          "type": "integer",
          "minimum": 0
        },
        "average_progress_per_run": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "chain_context_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "adaptive_factors": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "executed_at": {
      "type": "string",
      "format": "date-time"
    },
    "input_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace-[A-Za-z0-9._:-]+$"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
