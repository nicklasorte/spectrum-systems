{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/nsx_next_step_ranking_record.schema.json",
  "title": "nsx_next_step_ranking_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "pr_number",
    "deterministic_basis",
    "ranked_slices"
  ],
  "properties": {
    "artifact_type": {
      "const": "nsx_next_step_ranking_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "NSX"
    },
    "pr_number": {
      "type": "integer"
    },
    "deterministic_basis": {
      "type": "string"
    },
    "ranked_slices": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slice_id",
          "score",
          "reason"
        ],
        "properties": {
          "slice_id": {
            "type": "string"
          },
          "score": {
            "type": "integer"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    }
  }
}
