{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_rollback_signal.schema.json",
  "title": "Harness Rollback Signal",
  "description": "Advisory rollback signal produced by the harness feedback surface. The signal records evidence and a recommended_action for the canonical release owner (REL) to act on. It is informational only and confers no execution authority on the harness module.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "trace",
    "content_hash",
    "signal_id",
    "subject_candidate_id",
    "previous_promoted_candidate_id",
    "recommended_action",
    "reason",
    "evidence",
    "advisory_only",
    "delegates_to",
    "recorded_at"
  ],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^hop_rb_signal_[a-z0-9_-]+$"},
    "artifact_type": {"const": "hop_harness_rollback_signal"},
    "schema_ref": {"const": "hop/harness_rollback_signal.schema.json"},
    "schema_version": {"const": "1.0.0"},
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "trace": {"$ref": "#/$defs/trace"},
    "signal_id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
    "subject_candidate_id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
    "previous_promoted_candidate_id": {
      "type": ["string", "null"],
      "pattern": "^[a-z0-9_-]+$"
    },
    "recommended_action": {"type": "string", "enum": ["revert", "quarantine"]},
    "reason": {
      "type": "string",
      "enum": [
        "regression_detected",
        "blocking_failure_detected",
        "trace_incomplete",
        "control_plane_directive",
        "operator_request",
        "promotion_gate_block"
      ]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "detail"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "score_artifact_id",
              "failure_artifact_id",
              "release_readiness_signal_artifact_id",
              "trace_artifact_id",
              "snippet"
            ]
          },
          "detail": {"type": "string", "minLength": 1, "maxLength": 1024}
        }
      }
    },
    "advisory_only": {"const": true},
    "delegates_to": {"const": "REL"},
    "recorded_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {"type": "string", "minLength": 1},
        "related": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
