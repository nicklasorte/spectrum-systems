{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_release_readiness_signal.schema.json",
  "title": "Harness Release-Readiness Signal",
  "description": "Advisory release-readiness signal produced by the harness feedback surface. The signal records evidence that REL/CDE/control owners may consult; it confers no execution authority on the harness module. Fail-closed: any required check missing produces readiness_signal=risk_signal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "trace",
    "content_hash",
    "signal_id",
    "candidate_id",
    "search_score_artifact_id",
    "heldout_score_artifact_id",
    "search_score",
    "heldout_score",
    "search_eval_set_id",
    "heldout_eval_set_id",
    "trace_completeness",
    "risk_failure_count",
    "readiness_signal",
    "rationale",
    "advisory_only",
    "delegates_to",
    "evaluated_at"
  ],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^hop_rs_signal_[a-z0-9_-]+$"},
    "artifact_type": {"const": "hop_harness_release_readiness_signal"},
    "schema_ref": {"const": "hop/harness_release_readiness_signal.schema.json"},
    "schema_version": {"const": "1.0.0"},
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "trace": {"$ref": "#/$defs/trace"},
    "signal_id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
    "candidate_id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
    "search_score_artifact_id": {"type": "string", "minLength": 1},
    "heldout_score_artifact_id": {"type": "string", "minLength": 1},
    "search_score": {"type": "number", "minimum": 0, "maximum": 1},
    "heldout_score": {"type": "number", "minimum": 0, "maximum": 1},
    "search_eval_set_id": {"type": "string", "minLength": 1},
    "heldout_eval_set_id": {"type": "string", "minLength": 1},
    "trace_completeness": {"type": "number", "minimum": 0, "maximum": 1},
    "risk_failure_count": {"type": "integer", "minimum": 0},
    "readiness_signal": {"type": "string", "enum": ["ready_signal", "warn_signal", "risk_signal"]},
    "rationale": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check", "passed", "detail"],
        "properties": {
          "check": {
            "type": "string",
            "enum": [
              "search_score_threshold",
              "heldout_score_threshold",
              "trace_completeness",
              "no_risk_failures",
              "candidate_admitted",
              "search_set_disjoint_from_heldout",
              "candidate_not_withheld",
              "scores_admitted"
            ]
          },
          "passed": {"type": "boolean"},
          "detail": {"type": "string", "minLength": 1, "maxLength": 1024}
        }
      }
    },
    "advisory_only": {"const": true},
    "delegates_to": {"const": "REL"},
    "evaluated_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {"properties": {"readiness_signal": {"const": "ready_signal"}}},
      "then": {
        "properties": {
          "rationale": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "passed": {"const": true}
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {"type": "string", "minLength": 1},
        "related": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
