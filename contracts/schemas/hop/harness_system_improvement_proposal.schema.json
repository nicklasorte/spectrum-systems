{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_system_improvement_proposal.schema.json",
  "title": "HOP System Improvement Proposal",
  "description": "Advisory-only artifact that proposes a bounded improvement to a target 3-letter system based on a diagnosed AI failure pattern. HOP proposes only. CDE/GOV must authorize before any mutation. PQX executes authorized implementation slices. EVL validates. SEL acts on signals.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "trace",
    "content_hash",
    "proposal_id",
    "source_failure_pattern_id",
    "target_systems",
    "proposed_change_type",
    "proposed_guardrail",
    "expected_prevention",
    "required_eval",
    "required_tests",
    "authority_boundary",
    "advisory_only",
    "status",
    "generated_at"
  ],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^hop_proposal_[a-z0-9_-]+$"},
    "artifact_type": {"const": "hop_harness_system_improvement_proposal"},
    "schema_ref": {"const": "hop/harness_system_improvement_proposal.schema.json"},
    "schema_version": {"const": "1.0.0"},
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "trace": {"$ref": "#/$defs/trace"},
    "proposal_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "minLength": 1
    },
    "source_failure_pattern_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "minLength": 1
    },
    "target_systems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["AEX", "PQX", "HNX", "EVL", "CDE", "SEL", "OBS", "RDX", "PRL", "FRE", "TLC", "REP", "LIN"]
      }
    },
    "proposed_change_type": {
      "type": "string",
      "enum": [
        "admission_rule",
        "execution_budget",
        "checkpoint_requirement",
        "eval_case",
        "continuation_policy",
        "enforcement_signal",
        "observability_signal",
        "prl_prevention_rule"
      ]
    },
    "proposed_guardrail": {
      "type": "string",
      "minLength": 1
    },
    "expected_prevention": {
      "type": "string",
      "minLength": 1
    },
    "required_eval": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["eval_case_id", "description", "expected_outcome"],
        "properties": {
          "eval_case_id": {"type": "string", "pattern": "^[a-z0-9_-]+$", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "expected_outcome": {"type": "string", "minLength": 1}
        }
      }
    },
    "required_tests": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "authority_boundary": {"$ref": "#/$defs/authority_boundary"},
    "advisory_only": {"const": true},
    "status": {
      "type": "string",
      "enum": ["proposed", "under_review", "review_accepted", "rejected", "superseded"]
    },
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "$defs": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {"type": "string", "minLength": 1},
        "related": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hop_role",
        "review_owners",
        "execution_owner",
        "validation_owner",
        "enforcement_signal_owner"
      ],
      "properties": {
        "hop_role": {"const": "proposes_only"},
        "review_owners": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "enum": ["CDE", "GOV"]}
        },
        "execution_owner": {"const": "PQX"},
        "validation_owner": {"const": "EVL"},
        "enforcement_signal_owner": {"const": "SEL"}
      }
    }
  }
}
