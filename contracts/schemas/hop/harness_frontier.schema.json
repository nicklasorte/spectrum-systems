{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_frontier.schema.json",
  "title": "HOP Harness Frontier",
  "description": "Pareto frontier across (score, cost, latency, trace_completeness, eval_coverage). Recomputed on demand; all members refer to existing harness_score artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "trace",
    "content_hash",
    "frontier_id",
    "generated_at",
    "objectives",
    "members",
    "dominated_count",
    "considered_count"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^hop_frontier_[a-z0-9_-]+$"
    },
    "artifact_type": {
      "const": "hop_harness_frontier"
    },
    "schema_ref": {
      "const": "hop/harness_frontier.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace": {
      "$ref": "#/$defs/trace"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "frontier_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "direction"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["score", "cost", "latency_ms", "trace_completeness", "eval_coverage"]
          },
          "direction": {
            "type": "string",
            "enum": ["maximize", "minimize"]
          }
        }
      }
    },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "run_id",
          "score_artifact_id",
          "score",
          "cost",
          "latency_ms",
          "trace_completeness",
          "eval_coverage"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$"
          },
          "run_id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]+$"
          },
          "score_artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "cost": {
            "type": "number",
            "minimum": 0
          },
          "latency_ms": {
            "type": "number",
            "minimum": 0
          },
          "trace_completeness": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "eval_coverage": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "dominated_count": {
      "type": "integer",
      "minimum": 0
    },
    "considered_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "related": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
