{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_frontier.schema.json",
  "title": "harness_frontier",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "schema_ref",
    "trace",
    "content_hash",
    "created_at",
    "frontier_id",
    "objective_keys",
    "entries"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_ref": {
      "type": "string",
      "pattern": "^hop/[a-z_]+\\.schema\\.json@1\\.0\\.0$"
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "timestamp",
        "steps"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "status"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "start",
                  "pass",
                  "fail",
                  "block"
                ]
              },
              "detail": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifact_type": {
      "const": "harness_frontier"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "frontier_id": {
      "type": "string",
      "minLength": 1
    },
    "objective_keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "score",
          "cost",
          "latency",
          "trace_completeness",
          "eval_coverage"
        ]
      },
      "uniqueItems": true
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "score",
          "cost",
          "latency",
          "trace_completeness",
          "eval_coverage"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "score": {
            "type": "number"
          },
          "cost": {
            "type": "number"
          },
          "latency": {
            "type": "number"
          },
          "trace_completeness": {
            "type": "number"
          },
          "eval_coverage": {
            "type": "number"
          }
        }
      }
    }
  }
}
