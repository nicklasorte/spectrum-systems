{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_run.schema.json",
  "title": "harness_run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "schema_ref",
    "trace",
    "content_hash",
    "created_at",
    "run_id",
    "candidate_id",
    "eval_case_id",
    "status",
    "output_artifact"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_ref": {
      "type": "string",
      "pattern": "^hop/[a-z_]+\\.schema\\.json@1\\.0\\.0$"
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "timestamp",
        "steps"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "status"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "start",
                  "pass",
                  "fail",
                  "block"
                ]
              },
              "detail": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifact_type": {
      "const": "harness_run"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_id": {
      "type": "string",
      "minLength": 1
    },
    "eval_case_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "block"
      ]
    },
    "output_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "payload"
      ],
      "properties": {
        "artifact_type": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object"
        }
      }
    },
    "error": {
      "type": "string"
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0
    }
  }
}
