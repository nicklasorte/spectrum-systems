{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_failure_hypothesis.schema.json",
  "title": "HOP Harness Failure Hypothesis",
  "description": "Structured failure record emitted by the validator, evaluator, or safety_checks layer. No free-form output is consumed downstream; all classification is enum-bound.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "trace",
    "content_hash",
    "hypothesis_id",
    "candidate_id",
    "stage",
    "failure_class",
    "severity",
    "evidence",
    "detected_at",
    "blocks_promotion"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^hop_failure_[a-z0-9_-]+$"
    },
    "artifact_type": {
      "const": "hop_harness_failure_hypothesis"
    },
    "schema_ref": {
      "const": "hop/harness_failure_hypothesis.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace": {
      "$ref": "#/$defs/trace"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "hypothesis_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "run_id": {
      "type": ["string", "null"],
      "pattern": "^[a-z0-9_-]+$"
    },
    "stage": {
      "type": "string",
      "enum": ["validation", "safety_check", "evaluation", "store_admission"]
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "schema_violation",
        "import_error",
        "missing_method",
        "runtime_error",
        "malformed_artifact",
        "missing_trace",
        "incomplete_trace",
        "hardcoded_answer",
        "eval_dataset_leakage",
        "schema_weakening",
        "eval_bypass_attempt",
        "duplicate_artifact",
        "unknown_eval_case"
      ]
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warn", "reject"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "detail"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "schema_path",
              "code_path",
              "trace_id",
              "eval_case_id",
              "snippet",
              "exception",
              "comparison"
            ]
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "detected_at": {
      "type": "string",
      "format": "date-time"
    },
    "blocks_promotion": {
      "type": "boolean"
    }
  },
  "$defs": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "related": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
