{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_failure_hypothesis.schema.json",
  "title": "HOP Harness Failure Hypothesis",
  "description": "Structured failure record emitted by the validator, evaluator, or safety_checks layer. No free-form output is consumed downstream; all classification is enum-bound.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "trace",
    "content_hash",
    "hypothesis_id",
    "candidate_id",
    "stage",
    "failure_class",
    "severity",
    "evidence",
    "detected_at",
    "blocks_promotion"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^hop_failure_[a-z0-9_-]+$"
    },
    "artifact_type": {
      "const": "hop_harness_failure_hypothesis"
    },
    "schema_ref": {
      "const": "hop/harness_failure_hypothesis.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace": {
      "$ref": "#/$defs/trace"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "hypothesis_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "run_id": {
      "type": ["string", "null"],
      "pattern": "^[a-z0-9_-]+$"
    },
    "stage": {
      "type": "string",
      "enum": [
        "validation",
        "safety_check",
        "evaluation",
        "store_admission",
        "proposer",
        "mutation_policy",
        "causal_analysis",
        "frontier"
      ]
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "schema_violation",
        "import_error",
        "missing_method",
        "runtime_error",
        "malformed_artifact",
        "missing_trace",
        "incomplete_trace",
        "hardcoded_answer",
        "eval_dataset_leakage",
        "schema_weakening",
        "eval_bypass_attempt",
        "duplicate_artifact",
        "unknown_eval_case",
        "mutation_policy_violation",
        "regression",
        "improvement",
        "neutral_change",
        "trace_falsification",
        "frontier_invalid_member",
        "concurrent_write_conflict",
        "store_lock_timeout",
        "proposer_quota_exceeded"
      ]
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warn", "reject"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "detail"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "schema_path",
              "code_path",
              "trace_id",
              "eval_case_id",
              "snippet",
              "exception",
              "comparison"
            ]
          },
          "detail": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "detected_at": {
      "type": "string",
      "format": "date-time"
    },
    "blocks_promotion": {
      "type": "boolean"
    },
    "baseline_candidate_id": {
      "type": ["string", "null"],
      "pattern": "^[a-z0-9_-]+$"
    },
    "observed_change": {
      "type": ["string", "null"],
      "enum": ["regression", "improvement", "neutral", null]
    },
    "diff_summary": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["changed_fields", "added_lines", "removed_lines"],
      "properties": {
        "changed_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "added_lines": {
          "type": "integer",
          "minimum": 0
        },
        "removed_lines": {
          "type": "integer",
          "minimum": 0
        },
        "summary": {
          "type": ["string", "null"],
          "maxLength": 4096
        }
      }
    },
    "suspected_cause": {
      "type": ["string", "null"],
      "maxLength": 1024
    },
    "eval_deltas": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["eval_case_id", "baseline_passed", "candidate_passed"],
        "properties": {
          "eval_case_id": {
            "type": "string",
            "minLength": 1
          },
          "baseline_passed": {
            "type": "boolean"
          },
          "candidate_passed": {
            "type": "boolean"
          },
          "baseline_failure_reason": {
            "type": ["string", "null"]
          },
          "candidate_failure_reason": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "trace_excerpts": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["trace_artifact_id", "eval_case_id", "summary"],
        "properties": {
          "trace_artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "eval_case_id": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          }
        }
      }
    },
    "confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    }
  },
  "$defs": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "related": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
