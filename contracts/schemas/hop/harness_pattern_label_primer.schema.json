{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_pattern_label_primer.schema.json",
  "title": "HOP Label Primer Pattern",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "artifact_type", "schema_ref", "schema_version", "trace", "content_hash", "pattern_id", "workflow_id", "labels", "coverage_examples", "contrastive_pairs"],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^hop_pattern_[a-z0-9_-]+$"},
    "artifact_type": {"const": "hop_harness_pattern_label_primer"},
    "schema_ref": {"const": "hop/harness_pattern_label_primer.schema.json"},
    "schema_version": {"const": "1.0.0"},
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {"type": "string", "minLength": 1},
        "related": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "pattern_id": {"type": "string", "minLength": 1},
    "workflow_id": {"type": "string", "minLength": 1},
    "labels": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "coverage_examples": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["label", "input", "rationale"], "properties": {"label": {"type": "string"}, "input": {"type": "string"}, "rationale": {"type": "string"}}}},
    "contrastive_pairs": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["left_label", "right_label", "left_input", "right_input"], "properties": {"left_label": {"type": "string"}, "right_label": {"type": "string"}, "left_input": {"type": "string"}, "right_input": {"type": "string"}}}}
  }
}
