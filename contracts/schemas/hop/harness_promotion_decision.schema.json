{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_promotion_decision.schema.json",
  "title": "HOP Promotion Decision",
  "description": "Advisory promotion decision emitted by the HOP promotion gate. HOP NEVER promotes — final authority is the external control plane. The decision artifact is fail-closed: any required check missing produces decision=block.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "trace",
    "content_hash",
    "decision_id",
    "candidate_id",
    "search_score_artifact_id",
    "heldout_score_artifact_id",
    "search_score",
    "heldout_score",
    "search_eval_set_id",
    "heldout_eval_set_id",
    "trace_completeness",
    "blocking_failure_count",
    "decision",
    "rationale",
    "advisory_only",
    "evaluated_at"
  ],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^hop_promo_[a-z0-9_-]+$"},
    "artifact_type": {"const": "hop_harness_promotion_decision"},
    "schema_ref": {"const": "hop/harness_promotion_decision.schema.json"},
    "schema_version": {"const": "1.0.0"},
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "trace": {"$ref": "#/$defs/trace"},
    "decision_id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
    "candidate_id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
    "search_score_artifact_id": {"type": "string", "minLength": 1},
    "heldout_score_artifact_id": {"type": "string", "minLength": 1},
    "search_score": {"type": "number", "minimum": 0, "maximum": 1},
    "heldout_score": {"type": "number", "minimum": 0, "maximum": 1},
    "search_eval_set_id": {"type": "string", "minLength": 1},
    "heldout_eval_set_id": {"type": "string", "minLength": 1},
    "trace_completeness": {"type": "number", "minimum": 0, "maximum": 1},
    "blocking_failure_count": {"type": "integer", "minimum": 0},
    "decision": {"type": "string", "enum": ["allow", "warn", "block"]},
    "rationale": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check", "passed", "detail"],
        "properties": {
          "check": {
            "type": "string",
            "enum": [
              "search_score_threshold",
              "heldout_score_threshold",
              "trace_completeness",
              "no_blocking_failures",
              "candidate_admitted",
              "search_set_disjoint_from_heldout",
              "candidate_not_quarantined",
              "scores_admitted"
            ]
          },
          "passed": {"type": "boolean"},
          "detail": {"type": "string", "minLength": 1, "maxLength": 1024}
        }
      }
    },
    "advisory_only": {"const": true},
    "evaluated_at": {"type": "string", "format": "date-time"}
  },
  "allOf": [
    {
      "if": {"properties": {"decision": {"const": "allow"}}},
      "then": {
        "properties": {
          "rationale": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "passed": {"const": true}
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {"type": "string", "minLength": 1},
        "related": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
