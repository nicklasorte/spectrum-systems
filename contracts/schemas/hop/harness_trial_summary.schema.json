{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_trial_summary.schema.json",
  "title": "HOP Controlled Trial Summary",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "artifact_type", "schema_ref", "schema_version", "trace", "content_hash", "summary_id", "workflow_id", "iterations", "baseline_candidate_id", "baseline_score", "best_candidate_id", "best_score", "frontier_evolution", "failure_modes", "advisory_only"],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^hop_trial_[a-z0-9_-]+$"},
    "artifact_type": {"const": "hop_harness_trial_summary"},
    "schema_ref": {"const": "hop/harness_trial_summary.schema.json"},
    "schema_version": {"const": "1.0.0"},
    "content_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {"type": "string", "minLength": 1},
        "related": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "summary_id": {"type": "string"},
    "workflow_id": {"const": "transcript_to_faq"},
    "iterations": {"type": "integer", "minimum": 5, "maximum": 10},
    "baseline_candidate_id": {"type": "string"},
    "baseline_score": {"type": "number", "minimum": 0, "maximum": 1},
    "best_candidate_id": {"type": "string"},
    "best_score": {"type": "number", "minimum": 0, "maximum": 1},
    "frontier_evolution": {"type": "array", "minItems": 1, "items": {"type": "number", "minimum": 0, "maximum": 1}},
    "failure_modes": {"type": "array", "items": {"type": "string"}},
    "advisory_only": {"const": true}
  }
}
