{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_extraction_signal.schema.json",
  "title": "HOP Harness Extraction Signal",
  "description": "Advisory-only extraction signal produced by the transcript -> issue/risk/action/open_question/assumption harness. Every item is content-bound to source turns. The harness does not own or claim any governing authority; canonical owners (JSX, EVL) decide how to consume this artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "trace",
    "content_hash",
    "advisory_only",
    "delegates_to",
    "transcript_id",
    "candidate_id",
    "items",
    "generated_at"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^hop_extract_[a-z0-9_-]+$"
    },
    "artifact_type": {
      "const": "hop_harness_extraction_signal"
    },
    "schema_ref": {
      "const": "hop/harness_extraction_signal.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace": {
      "$ref": "#/$defs/trace"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "advisory_only": {
      "const": true
    },
    "delegates_to": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["JSX", "EVL"]
      }
    },
    "transcript_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/extraction_item"
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "related": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["turn_index", "char_start", "char_end"],
      "properties": {
        "turn_index": {
          "type": "integer",
          "minimum": 0
        },
        "char_start": {
          "type": "integer",
          "minimum": 0
        },
        "char_end": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "extraction_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "category",
        "description",
        "evidence_refs",
        "source_turn_indices",
        "owner_text",
        "due_date_text",
        "confidence_signal",
        "ambiguity_signal"
      ],
      "properties": {
        "item_id": {
          "type": "string",
          "pattern": "^hop_extract_[a-z0-9_-]+$"
        },
        "category": {
          "type": "string",
          "enum": ["issue", "risk", "action", "open_question", "assumption"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_ref"
          }
        },
        "source_turn_indices": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 0
          }
        },
        "owner_text": {
          "type": ["string", "null"]
        },
        "due_date_text": {
          "type": ["string", "null"]
        },
        "confidence_signal": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "ambiguity_signal": {
          "type": "string",
          "enum": ["none", "attribution", "commitment", "temporal", "negation", "multi"]
        }
      }
    }
  }
}
