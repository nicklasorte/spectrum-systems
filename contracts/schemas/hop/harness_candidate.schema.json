{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_candidate.schema.json",
  "title": "HOP Harness Candidate",
  "description": "A registered harness candidate for the Harness Optimization Pipeline. Code, declared interface, and provenance are immutably bound to a content hash so identical candidate code always resolves to the same candidate_id.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "trace",
    "content_hash",
    "candidate_id",
    "harness_type",
    "code_module",
    "code_entrypoint",
    "code_source",
    "declared_methods",
    "created_at"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^hop_candidate_[a-z0-9_-]+$"
    },
    "artifact_type": {
      "const": "hop_harness_candidate"
    },
    "schema_ref": {
      "const": "hop/harness_candidate.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace": {
      "$ref": "#/$defs/trace"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "minLength": 4,
      "maxLength": 96
    },
    "harness_type": {
      "type": "string",
      "enum": ["transcript_to_faq"]
    },
    "code_module": {
      "type": "string",
      "minLength": 1
    },
    "code_entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "code_source": {
      "type": "string",
      "minLength": 1
    },
    "declared_methods": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z_][a-z0-9_]*$"
      }
    },
    "parent_candidate_id": {
      "type": ["string", "null"],
      "pattern": "^[a-z0-9_-]+$"
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "related": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
