{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hop/harness_faq_output.schema.json",
  "title": "HOP Harness FAQ Output",
  "description": "Structured FAQ output of the transcript -> FAQ harness. No free-form fields are consumed downstream; questions and answers are individually content-bound to source turns when possible.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_ref",
    "schema_version",
    "trace",
    "content_hash",
    "transcript_id",
    "candidate_id",
    "items",
    "generated_at"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^hop_faq_[a-z0-9_-]+$"
    },
    "artifact_type": {
      "const": "hop_harness_faq_output"
    },
    "schema_ref": {
      "const": "hop/harness_faq_output.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace": {
      "$ref": "#/$defs/trace"
    },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "transcript_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "answer"],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1
          },
          "answer": {
            "type": "string",
            "minLength": 1
          },
          "source_turn_indices": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "related": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
