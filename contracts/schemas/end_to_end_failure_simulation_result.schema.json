{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/end_to_end_failure_simulation_result.schema.json",
  "title": "End-to-End Failure Simulation Result",
  "description": "VAL-08 governed result artifact proving deterministic fail-closed end-to-end behavior under multi-layer injected faults.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "simulation_run_id",
    "timestamp",
    "input_refs",
    "simulation_cases",
    "summary",
    "final_status",
    "trace_ids"
  ],
  "properties": {
    "simulation_run_id": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "input_refs": {
      "type": "object",
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "simulation_cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/simulation_case"}
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_cases",
        "passed_cases",
        "failed_cases",
        "silent_propagation_detected",
        "missing_failure_artifact_detected",
        "end_to_end_block_failure_detected"
      ],
      "properties": {
        "total_cases": {"type": "integer", "minimum": 1},
        "passed_cases": {"type": "integer", "minimum": 0},
        "failed_cases": {"type": "integer", "minimum": 0},
        "silent_propagation_detected": {"type": "boolean"},
        "missing_failure_artifact_detected": {"type": "boolean"},
        "end_to_end_block_failure_detected": {"type": "boolean"}
      }
    },
    "final_status": {"type": "string", "enum": ["PASSED", "FAILED"]},
    "trace_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  },
  "$defs": {
    "simulation_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "case_type",
        "injected_faults",
        "expected_outcome",
        "actual_outcome",
        "blocked",
        "failure_artifact_refs",
        "control_decision_ref",
        "enforcement_action_ref",
        "passed",
        "divergence_reason"
      ],
      "properties": {
        "case_id": {"type": "string", "minLength": 1},
        "case_type": {"type": "string", "minLength": 1},
        "injected_faults": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "expected_outcome": {"type": "string", "minLength": 1},
        "actual_outcome": {"type": "string", "minLength": 1},
        "blocked": {"type": "boolean"},
        "failure_artifact_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "control_decision_ref": {"type": "string"},
        "enforcement_action_ref": {"type": "string"},
        "passed": {"type": "boolean"},
        "divergence_reason": {"type": "string"}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"summary": {"properties": {"failed_cases": {"minimum": 1}}}},
        "required": ["summary"]
      },
      "then": {"properties": {"final_status": {"const": "FAILED"}}}
    },
    {
      "if": {
        "properties": {"summary": {"properties": {"silent_propagation_detected": {"const": true}}}},
        "required": ["summary"]
      },
      "then": {"properties": {"final_status": {"const": "FAILED"}}}
    },
    {
      "if": {
        "properties": {"summary": {"properties": {"missing_failure_artifact_detected": {"const": true}}}},
        "required": ["summary"]
      },
      "then": {"properties": {"final_status": {"const": "FAILED"}}}
    }
  ]
}
