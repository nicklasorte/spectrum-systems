{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/next24_serial_execution_record.schema.json",
  "title": "next24_serial_execution_record",
  "description": "Deterministic serial governance execution record for the 24-step foundation build.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "schema_version",
    "trace_id",
    "created_at",
    "primary_artifact_family",
    "executed_steps",
    "guarantees_enforced"
  ],
  "properties": {
    "record_id": {"type": "string", "pattern": "^N24-[A-F0-9]{12}$"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "trace_id": {"type": "string", "pattern": "^trace-[A-Za-z0-9._:-]+$"},
    "created_at": {"type": "string", "format": "date-time"},
    "primary_artifact_family": {"type": "string", "minLength": 1},
    "executed_steps": {
      "type": "array",
      "minItems": 24,
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "title", "status", "gate_evidence_refs"],
        "properties": {
          "step_id": {"type": "string", "pattern": "^(JUD|CL|GOV|OBS|INT|SUB)-[0-9]{2,3}[A-Z]?$"},
          "title": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["completed"]},
          "gate_evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
        }
      }
    },
    "guarantees_enforced": {
      "type": "array",
      "minItems": 4,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
