{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/ril_pra_slh_bypass_red_team_report.schema.json",
  "title": "ril_pra_slh_bypass_red_team_report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "status",
    "deterministic",
    "bypass_scenarios"
  ],
  "properties": {
    "artifact_type": {
      "const": "ril_pra_slh_bypass_red_team_report"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "RIL"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "deterministic": {
      "type": "boolean"
    },
    "bypass_scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "round",
          "exploit",
          "detected"
        ],
        "properties": {
          "round": {
            "type": "string"
          },
          "exploit": {
            "type": "string"
          },
          "detected": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
