{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/review_request.schema.json",
  "title": "Review Request",
  "description": "Typed governed request describing required Claude review execution at deterministic checkpoints.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "review_type",
    "scope_refs",
    "triggering_event",
    "required",
    "blocking",
    "related_batch_id",
    "slice_id",
    "program_id",
    "created_at",
    "trace_id",
    "source_refs"
  ],
  "properties": {
    "review_id": {"type": "string", "minLength": 1},
    "review_type": {
      "type": "string",
      "enum": ["surgical", "failure", "batch_architecture", "hard_gate", "strategic"]
    },
    "scope_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "triggering_event": {"type": "string", "minLength": 1},
    "required": {"type": "boolean"},
    "blocking": {"type": "boolean"},
    "related_batch_id": {"type": "string", "minLength": 1},
    "slice_id": {"type": "string", "minLength": 1},
    "program_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "trace_id": {"type": "string", "minLength": 1},
    "source_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
