{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/faq_source_artifact.schema.json",
  "title": "Faq Source Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "schema_version",
    "run_id",
    "trace_id",
    "lineage_refs",
    "source_refs",
    "questions",
    "evidence_coverage_rate"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "faq_source_artifact"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 3
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "const": "1.9.5"
    },
    "run_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "lineage_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_coverage_rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
