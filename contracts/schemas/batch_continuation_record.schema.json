{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/batch_continuation_record.schema.json",
  "title": "Batch Continuation Record",
  "description": "Deterministic governed artifact recording the explicit continuation gate decision before each roadmap batch attempt.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "continuation_id",
    "current_batch_id",
    "next_candidate_batch_id",
    "decision",
    "reason_codes",
    "signals_used",
    "program_state_snapshot",
    "risk_level",
    "created_at",
    "trace_id"
  ],
  "properties": {
    "continuation_id": {"type": "string", "pattern": "^BCR-[A-F0-9]{12}$"},
    "current_batch_id": {"type": ["string", "null"], "pattern": "^BATCH-[A-Z]$"},
    "next_candidate_batch_id": {"type": ["string", "null"], "pattern": "^BATCH-[A-Z]$"},
    "decision": {"type": "string", "enum": ["continue", "stop", "escalate"]},
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 3},
      "uniqueItems": true
    },
    "signals_used": {"type": "object", "additionalProperties": true},
    "program_state_snapshot": {"type": "object", "additionalProperties": true},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
    "created_at": {"type": "string", "format": "date-time"},
    "trace_id": {"type": "string", "pattern": "^trace-[A-Za-z0-9._:-]+$"}
  }
}
