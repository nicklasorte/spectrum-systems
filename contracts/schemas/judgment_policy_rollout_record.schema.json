{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/judgment_policy_rollout_record.schema.json",
  "title": "Judgment Policy Rollout Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "rollout_id",
    "policy_id",
    "policy_version",
    "rollout_type",
    "cohort",
    "expected_gates",
    "rollout_status",
    "trace",
    "created_at"
  ],
  "properties": {
    "artifact_type": {"const": "judgment_policy_rollout_record"},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "standards_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "rollout_id": {"type": "string", "minLength": 1},
    "policy_id": {"type": "string", "minLength": 1},
    "policy_version": {"type": "string", "minLength": 1},
    "rollout_type": {"type": "string", "enum": ["canary", "staged", "full"]},
    "cohort": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"type": "string", "enum": ["environment", "trace_bucket", "explicit_trace_ids"]},
        "values": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "modulo": {"type": "integer", "minimum": 1},
        "buckets": {"type": "array", "items": {"type": "integer", "minimum": 0}}
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"const": "trace_bucket"}}, "required": ["kind"]},
          "then": {"required": ["modulo", "buckets"]}
        },
        {
          "if": {"properties": {"kind": {"const": "environment"}}, "required": ["kind"]},
          "then": {"required": ["values"]}
        },
        {
          "if": {"properties": {"kind": {"const": "explicit_trace_ids"}}, "required": ["kind"]},
          "then": {"required": ["values"]}
        }
      ]
    },
    "expected_gates": {"type": "object", "minProperties": 1},
    "rollout_status": {"type": "string", "enum": ["planned", "active", "completed", "aborted"]},
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "run_id", "source_lifecycle_id"],
      "properties": {
        "trace_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "source_lifecycle_id": {"type": "string", "minLength": 1}
      }
    },
    "created_at": {"type": "string", "format": "date-time"}
  }
}
