{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/roadmap_review_view_artifact.schema.json",
  "title": "Roadmap Review View Artifact",
  "description": "RIL-005 deterministic read-only roadmap consumer view derived only from roadmap_review_projection_artifact. Non-authoritative intake surface only; not an enforcement or policy-mutation decision artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_class",
    "schema_version",
    "roadmap_review_view_id",
    "source_roadmap_projection_ref",
    "source_review_projection_bundle_ref",
    "source_review_path",
    "review_date",
    "system_scope",
    "roadmap_view_items",
    "highest_priority",
    "item_count",
    "blocker_present",
    "emitted_at",
    "non_authoritative_notice",
    "provenance"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "roadmap_review_view_artifact"},
    "artifact_class": {"type": "string", "const": "coordination"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "roadmap_review_view_id": {"type": "string", "pattern": "^rrv-[a-f0-9]{16}$"},
    "source_roadmap_projection_ref": {"type": "string", "pattern": "^rrp-[a-f0-9]{16}$"},
    "source_review_projection_bundle_ref": {"type": "string", "pattern": "^rpb-[a-f0-9]{16}$"},
    "source_review_path": {"type": "string", "minLength": 1},
    "review_date": {"type": "string", "pattern": "^20\\d{2}-\\d{2}-\\d{2}$"},
    "system_scope": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
    "roadmap_view_items": {
      "type": "array",
      "items": {"$ref": "#/$defs/roadmapViewItem"}
    },
    "highest_priority": {"type": "string", "enum": ["P0", "P1", "P2", "monitor"]},
    "item_count": {"type": "integer", "minimum": 0},
    "blocker_present": {"type": "boolean"},
    "emitted_at": {"type": "string", "format": "date-time"},
    "non_authoritative_notice": {
      "type": "string",
      "const": "Read-only consumer intake/view artifact only; signals such as enforcement_block or control_escalation are non-authoritative and require independent governed decisions."
    },
    "provenance": {"$ref": "#/$defs/provenance"}
  },
  "$defs": {
    "traceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_path", "line_number", "source_excerpt"],
      "properties": {
        "source_path": {"type": "string", "minLength": 1},
        "line_number": {"type": "integer", "minimum": 1},
        "source_excerpt": {"type": "string", "minLength": 1}
      }
    },
    "roadmapViewItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "view_item_id",
        "source_projection_item_id",
        "priority",
        "severity",
        "affected_systems",
        "rationale",
        "trace_refs"
      ],
      "properties": {
        "view_item_id": {"type": "string", "pattern": "^rvi-[a-f0-9]{16}$"},
        "source_projection_item_id": {"type": "string", "pattern": "^rpi-[a-f0-9]{16}$"},
        "priority": {"type": "string", "enum": ["P0", "P1", "P2", "monitor"]},
        "severity": {"type": "string", "enum": ["critical", "high", "medium"]},
        "affected_systems": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z0-9_-]+$"}
        },
        "rationale": {"type": "string", "minLength": 1},
        "trace_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/traceRef"}
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter",
        "consumer_surface",
        "consumption_mode",
        "source_review_projection_bundle_ref",
        "source_roadmap_projection_ref"
      ],
      "properties": {
        "adapter": {"type": "string", "const": "review_consumer_wiring"},
        "consumer_surface": {"type": "string", "const": "roadmap_prioritization_view"},
        "consumption_mode": {"type": "string", "const": "projection_only_read_only"},
        "source_review_projection_bundle_ref": {"type": "string", "pattern": "^rpb-[a-f0-9]{16}$"},
        "source_roadmap_projection_ref": {"type": "string", "pattern": "^rrp-[a-f0-9]{16}$"}
      }
    }
  }
}
