{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/program_artifact.schema.json",
  "title": "Program Artifact",
  "description": "Governed program direction artifact that constrains roadmap generation and execution prioritization without overriding control decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "program_id",
    "schema_version",
    "title",
    "goal",
    "batches",
    "success_criteria",
    "blocking_conditions",
    "allowed_targets",
    "disallowed_targets",
    "priority_rules",
    "status",
    "created_at",
    "trace_id",
    "source_refs"
  ],
  "properties": {
    "program_id": {
      "type": "string",
      "pattern": "^PRG-[A-Z0-9-]+$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "batches": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^BATCH-[A-M]$"
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blocking_conditions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_targets": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "disallowed_targets": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "priority_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "category",
          "target",
          "priority"
        ],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "hardening",
              "consolidation",
              "build",
              "defer"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "blocked",
        "completed"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
