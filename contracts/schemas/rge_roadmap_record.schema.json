{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/rge_roadmap_record.schema.json",
  "title": "rge_roadmap_record",
  "description": "Emitted by the RGE Roadmap Generator. Content-addressed roadmap candidate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "record_id",
    "run_id",
    "trace_id",
    "created_at",
    "analysis_record_id",
    "admitted_phases",
    "blocked_proposals",
    "candidate_count",
    "admitted_count",
    "blocked_count",
    "content_hash",
    "stop_reason_catalog",
    "diminishing_returns_sentinel",
    "invalid_state_sentinel"
  ],
  "properties": {
    "artifact_type": { "type": "string", "const": "rge_roadmap_record" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "record_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "trace_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "analysis_record_id": { "type": "string" },
    "admitted_phases": { "type": "array" },
    "blocked_proposals": { "type": "array" },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "admitted_count": { "type": "integer", "minimum": 0 },
    "blocked_count": { "type": "integer", "minimum": 0 },
    "content_hash": { "type": "string", "minLength": 64, "maxLength": 64 },
    "stop_reason_catalog": { "type": "array", "items": { "type": "string" } },
    "diminishing_returns_sentinel": { "type": "string" },
    "invalid_state_sentinel": { "type": "string" }
  }
}
