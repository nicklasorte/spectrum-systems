{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/dag_dependency_bundle.schema.json",
  "title": "dag_dependency_bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "graph_ref",
    "cycle_report_ref",
    "critical_path_ref"
  ],
  "properties": {
    "artifact_type": {
      "const": "dag_dependency_bundle"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "graph_ref": {
      "type": "string"
    },
    "cycle_report_ref": {
      "type": "string"
    },
    "critical_path_ref": {
      "type": "string"
    }
  }
}
