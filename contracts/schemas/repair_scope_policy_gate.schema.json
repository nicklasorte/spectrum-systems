{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/repair_scope_policy_gate.schema.json",
  "title": "Repair Scope Policy Gate",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "schema_version", "gate_id", "repair_candidate_ref", "repair_class", "decision", "reason_code", "non_authority_assertions"],
  "properties": {
    "artifact_type": {"const": "repair_scope_policy_gate"},
    "schema_version": {"const": "1.0.0"},
    "gate_id": {"type": "string", "pattern": "^fre-gate-[a-f0-9]{16}$"},
    "repair_candidate_ref": {"type": "string", "pattern": "^repair_candidate:.+"},
    "repair_class": {"type": "string", "enum": ["artifact_only", "schema_adjustment", "test_only", "runtime_code"]},
    "decision": {"type": "string", "enum": ["allowed", "blocked", "review_required"]},
    "reason_code": {"type": "string", "minLength": 1},
    "non_authority_assertions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
