{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/contract_impact_artifact.schema.json",
  "title": "Contract Impact Artifact",
  "description": "Deterministic contract compatibility impact analysis used as a fail-closed pre-execution PQX gate.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "impact_id",
    "generated_at",
    "analyzer_version",
    "standards_manifest_path",
    "changed_contract_paths",
    "changed_example_paths",
    "impacted_consumer_paths",
    "impacted_test_paths",
    "impacted_runtime_paths",
    "impacted_script_paths",
    "compatibility_class",
    "blocking",
    "blocking_reasons",
    "required_remediations",
    "safe_to_execute",
    "evidence_refs",
    "summary"
  ],
  "properties": {
    "artifact_type": {
      "const": "contract_impact_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "impact_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "analyzer_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "standards_manifest_path": {
      "type": "string",
      "const": "contracts/standards-manifest.json"
    },
    "changed_contract_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^contracts/schemas/.+\\.schema\\.json$"
      }
    },
    "changed_example_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^contracts/examples/.+\\.json$"
      }
    },
    "impacted_consumer_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "impacted_test_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^tests/.+"
      }
    },
    "impacted_runtime_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^spectrum_systems/.+"
      }
    },
    "impacted_script_paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^scripts/.+"
      }
    },
    "compatibility_class": {
      "type": "string",
      "enum": [
        "compatible",
        "caution",
        "breaking",
        "indeterminate"
      ]
    },
    "blocking": {
      "type": "boolean"
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_remediations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "safe_to_execute": {
      "type": "boolean"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
