{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/stakeholder_critique_artifact.schema.json",
  "title": "stakeholder_critique_artifact",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "artifact_type": {
      "const": "stakeholder_critique_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace_id": {
      "type": "string"
    },
    "outputs": {
      "type": "object",
      "required": [
        "findings",
        "high_severity_count"
      ]
    },
    "evaluation_refs": {
      "type": "object",
      "required": [
        "control_decision"
      ]
    }
  },
  "required": [
    "artifact_type",
    "schema_version",
    "trace_id",
    "outputs",
    "evaluation_refs"
  ]
}
