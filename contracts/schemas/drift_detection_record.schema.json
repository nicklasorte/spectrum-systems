{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/drift_detection_record.schema.json",
  "title": "drift_detection_record",
  "description": "Deterministic architectural drift classification record used for fail-closed governance and roadmap steering.",
  "type": "object",
  "additionalProperties": false,
  "required": ["drift_detection_id", "schema_version", "findings", "severity_summary", "created_at", "trace_id"],
  "properties": {
    "drift_detection_id": {"type": "string", "pattern": "^DDR-[A-F0-9]{12}$"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["drift_type", "severity", "affected_component", "violated_invariant", "reason_codes", "required_action", "created_at", "trace_id"],
        "properties": {
          "drift_type": {"type": "string", "enum": ["artifact_drift", "eval_drift", "control_drift", "replay_trace_drift", "judgment_drift", "governance_drift", "roadmap_drift"]},
          "severity": {"type": "string", "enum": ["none", "warning", "freeze_candidate", "block"]},
          "affected_component": {"type": "string", "minLength": 1},
          "violated_invariant": {"type": "string", "minLength": 1},
          "reason_codes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 3}},
          "required_action": {"type": "string", "minLength": 1},
          "created_at": {"type": "string", "format": "date-time"},
          "trace_id": {"type": "string", "pattern": "^trace-[A-Za-z0-9._:-]+$"}
        }
      }
    },
    "severity_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["none", "warning", "freeze_candidate", "block"],
      "properties": {
        "none": {"type": "integer", "minimum": 0},
        "warning": {"type": "integer", "minimum": 0},
        "freeze_candidate": {"type": "integer", "minimum": 0},
        "block": {"type": "integer", "minimum": 0}
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "trace_id": {"type": "string", "pattern": "^trace-[A-Za-z0-9._:-]+$"}
  }
}
