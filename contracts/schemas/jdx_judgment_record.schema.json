{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/jdx_judgment_record.schema.json",
  "title": "jdx_judgment_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "evidence_refs",
    "policy_ref",
    "rationale",
    "uncertainty_flags",
    "contradiction_refs",
    "lineage_ref"
  ],
  "properties": {
    "artifact_type": {
      "const": "jdx_judgment_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "uncertainty_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contradiction_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lineage_ref": {
      "type": "string",
      "minLength": 1
    },
    "non_authoritative": {
      "const": true
    }
  }
}
