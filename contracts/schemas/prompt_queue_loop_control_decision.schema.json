{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prompt_queue_loop_control_decision.schema.json",
  "title": "Prompt Queue Loop Control Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "loop_control_decision_artifact_id",
    "work_item_id",
    "parent_work_item_id",
    "generation_count",
    "max_generation_allowed",
    "loop_control_status",
    "enforcement_action",
    "reason_code",
    "generated_at",
    "generator_version"
  ],
  "properties": {
    "loop_control_decision_artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "work_item_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_work_item_id": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "generation_count": {
      "type": "integer",
      "minimum": 0
    },
    "max_generation_allowed": {
      "type": "integer",
      "minimum": 0
    },
    "loop_control_status": {
      "type": "string",
      "enum": ["within_budget", "limit_reached", "limit_exceeded"]
    },
    "enforcement_action": {
      "type": "string",
      "enum": ["allow_reentry", "require_review", "block_reentry"]
    },
    "reason_code": {
      "type": "string",
      "enum": [
        "within_budget_allow_reentry",
        "limit_reached_require_review",
        "limit_exceeded_block_reentry"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generator_version": {
      "type": "string",
      "minLength": 1
    },
    "source_queue_state_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "oneOf": [
    {
      "properties": {
        "loop_control_status": {"const": "within_budget"},
        "enforcement_action": {"const": "allow_reentry"},
        "reason_code": {"const": "within_budget_allow_reentry"}
      }
    },
    {
      "properties": {
        "loop_control_status": {"const": "limit_reached"},
        "enforcement_action": {"const": "require_review"},
        "reason_code": {"const": "limit_reached_require_review"}
      }
    },
    {
      "properties": {
        "loop_control_status": {"const": "limit_exceeded"},
        "enforcement_action": {"const": "block_reentry"},
        "reason_code": {"const": "limit_exceeded_block_reentry"}
      }
    }
  ]
}
