{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spectrum-systems.org/contracts/structured_issue_set.json",
  "title": "Structured Issue Set",
  "description": "Issues with resolved dependency graph and validation status.",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "artifact_type", "issues", "dependency_graph"],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^SIS-[0-9a-f]{8}$"},
    "artifact_type": {"type": "string", "const": "structured_issue_set"},
    "issues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["issue_id", "title"],
        "additionalProperties": true,
        "properties": {
          "issue_id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "assignee": {"type": "string"},
          "priority": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "dependency_graph": {
      "type": "object",
      "description": "Adjacency map: issue_id -> list of blocking issue_ids",
      "additionalProperties": {"type": "array", "items": {"type": "string"}}
    },
    "validation_status": {
      "type": "string",
      "enum": ["valid", "has_cycles", "incomplete"]
    },
    "cycle_report": {
      "type": "array",
      "description": "List of detected dependency cycles, empty if none",
      "items": {"type": "array", "items": {"type": "string"}}
    },
    "provenance": {
      "type": "object",
      "properties": {
        "trace_id": {"type": "string"},
        "upstream_artifact_id": {"type": "string"},
        "created_at": {"type": "string"}
      }
    }
  }
}
