{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/eval_candidate_artifact.schema.json",
  "title": "Eval Candidate Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "candidate_id",
    "failure_class",
    "source_failure_ref",
    "minimal_repro_case",
    "expected_behavior",
    "proposed_eval_type",
    "trace_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "eval_candidate_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "candidate_id": {
      "type": "string",
      "pattern": "^EVC-[a-f0-9]{20}$"
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "schema_mismatch",
        "contract_registration_missing",
        "branch_policy_violation",
        "dependency_graph_violation",
        "test_expectation_drift",
        "unknown_failure"
      ]
    },
    "source_failure_ref": {
      "type": "string",
      "minLength": 1
    },
    "minimal_repro_case": {
      "type": "string",
      "minLength": 1
    },
    "expected_behavior": {
      "type": "string",
      "minLength": 1
    },
    "proposed_eval_type": {
      "type": "string",
      "enum": [
        "schema",
        "contract",
        "integration",
        "policy",
        "regression"
      ]
    },
    "trace_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
