{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pqx_block_record.schema.json",
  "title": "PQX Block Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "step_id",
    "blocked_at",
    "block_type",
    "reason",
    "blocking_dependencies"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "step_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "blocked_at": {
      "type": "string",
      "format": "date-time"
    },
    "block_type": {
      "type": "string",
      "enum": [
        "MISSING_ROW",
        "DEPENDENCY_UNSATISFIED",
        "MISSING_INPUT",
        "SCHEMA_INVALID",
        "UNKNOWN"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "blocking_dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
