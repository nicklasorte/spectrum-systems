{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/artifact_lineage.schema.json",
  "title": "Artifact Lineage",
  "description": "Governed artifact lineage record connecting pipeline stages BR → BD → BE → BF → BG → BH → SLO with full traceability.",
  "type": "object",
  "required": [
    "artifact_id",
    "run_id",
    "trace_id",
    "artifact_type",
    "parent_artifact_ids",
    "created_at",
    "created_by",
    "version",
    "lineage_depth",
    "root_artifact_ids",
    "lineage_valid",
    "lineage_errors",
    "lineage_nodes",
    "lineage_edges"
  ],
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "type": "string",
      "description": "Unique identifier for this artifact.",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string",
      "description": "Governed artifact type.",
      "enum": [
        "simulation_input",
        "simulation_output",
        "evidence_pack",
        "reasoning_trace",
        "adversarial_result",
        "synthesis",
        "decision",
        "slo_evaluation"
      ]
    },
    "parent_artifact_ids": {
      "type": "array",
      "description": "IDs of direct parent artifacts. Empty for root (simulation_input) artifacts.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 date-time when this artifact was created.",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "description": "Module or agent that created this artifact.",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "description": "Version of this artifact.",
      "minLength": 1
    },
    "lineage_depth": {
      "type": "integer",
      "description": "Depth in the lineage graph. Root artifacts have depth 0.",
      "minimum": 0
    },
    "root_artifact_ids": {
      "type": "array",
      "description": "IDs of all root (simulation_input) ancestors reachable from this artifact. Must be non-empty for every artifact.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "lineage_valid": {
      "type": "boolean",
      "description": "Whether this artifact's lineage chain has been validated without errors."
    },
    "lineage_errors": {
      "type": "array",
      "description": "List of lineage validation error messages, empty when lineage_valid is true.",
      "items": {
        "type": "string"
      }
    },
    "lineage_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_key", "artifact_id", "artifact_type", "run_id", "trace_id"],
        "properties": {
          "artifact_key": {"type": "string", "minLength": 1},
          "artifact_id": {"type": "string", "minLength": 1},
          "artifact_type": {"type": "string", "minLength": 1},
          "run_id": {"type": "string", "minLength": 1},
          "trace_id": {"type": "string", "minLength": 1}
        }
      }
    },
    "lineage_edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["parent_artifact_id", "child_artifact_id"],
        "properties": {
          "parent_artifact_id": {"type": "string", "minLength": 1},
          "child_artifact_id": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "if": {
    "properties": {
      "artifact_type": { "const": "simulation_input" }
    },
    "required": ["artifact_type"]
  },
  "then": {
    "properties": {
      "root_artifact_ids": {
        "minItems": 1
      }
    },
    "description": "simulation_input artifacts must include themselves in root_artifact_ids (enforced at runtime by validate_against_schema)."
  },
  "else": {
    "properties": {
      "root_artifact_ids": {
        "minItems": 1
      }
    }
  }
}
