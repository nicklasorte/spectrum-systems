{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/obs_required_observability_producer_audit_result.schema.json",
  "title": "obs_required_observability_producer_audit_result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "status",
    "required_families_checked",
    "missing_emission_paths"
  ],
  "properties": {
    "artifact_type": {
      "const": "obs_required_observability_producer_audit_result"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "OBS"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "required_families_checked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_emission_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
