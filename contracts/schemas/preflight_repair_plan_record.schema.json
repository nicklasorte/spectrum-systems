{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "preflight_repair_plan_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "plan_id",
    "failure_class",
    "eligibility_decision",
    "allowed_paths",
    "apply_automatically",
    "escalation_required",
    "max_retry_attempts",
    "rerun_prerequisites"
  ],
  "properties": {
    "artifact_type": {
      "const": "preflight_repair_plan_record"
    },
    "artifact_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "failure_class": {
      "type": "string"
    },
    "eligibility_decision": {
      "type": "string",
      "enum": [
        "auto_repair_allowed",
        "auto_repair_forbidden",
        "escalation_required"
      ]
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "apply_automatically": {
      "type": "boolean"
    },
    "escalation_required": {
      "type": "boolean"
    },
    "max_retry_attempts": {
      "type": "integer",
      "minimum": 0
    },
    "rerun_prerequisites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
