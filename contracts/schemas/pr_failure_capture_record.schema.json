{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prl/pr_failure_capture_record.schema.json",
  "title": "PR Failure Capture Record",
  "description": "PRL-01: raw and normalized capture of a single PR/CI failure. Owned by PRL.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "id",
    "timestamp",
    "run_id",
    "trace_id",
    "trace_refs",
    "source",
    "raw_log_excerpt",
    "normalized_message",
    "failure_class",
    "owning_system",
    "file_refs"
  ],
  "properties": {
    "artifact_type": {
      "const": "pr_failure_capture_record"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "pattern": "^prl-cap-[a-f0-9]{16}$"
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "related"],
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "related": { "type": "array", "items": { "type": "string" } }
      }
    },
    "source": {
      "type": "string",
      "enum": ["ci_log", "local_run", "pre_pr_gate"]
    },
    "raw_log_excerpt": {
      "type": "string",
      "maxLength": 5000
    },
    "normalized_message": {
      "type": "string",
      "minLength": 1
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "pytest_selection_missing",
        "authority_shape_violation",
        "system_registry_mismatch",
        "contract_schema_violation",
        "missing_required_artifact",
        "trace_missing",
        "replay_mismatch",
        "policy_mismatch",
        "timeout",
        "rate_limited",
        "unknown_failure"
      ]
    },
    "owning_system": {
      "type": "string",
      "minLength": 1
    },
    "file_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "line_number": {
      "type": "integer",
      "minimum": 1
    },
    "exit_code": {
      "type": "integer"
    }
  }
}
