{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/schema_compatibility_result.schema.json",
  "title": "schema_compatibility_result",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "schema_compatibility_result"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner_system": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,8}$"
    },
    "artifact_type_target": {
      "type": "string"
    },
    "from_version": {
      "type": "string"
    },
    "to_version": {
      "type": "string"
    },
    "compatible": {
      "type": "boolean"
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "trace_id",
    "created_at",
    "owner_system",
    "artifact_type_target",
    "from_version",
    "to_version",
    "compatible"
  ]
}
