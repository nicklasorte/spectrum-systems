{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/reviewer_comment_set.schema.json",
  "title": "Reviewer Comment Set",
  "description": "Normalized collection of reviewer comments tied to a working paper revision.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "record_id",
    "run_id",
    "created_at",
    "created_by",
    "source_repo",
    "source_repo_version",
    "working_paper_id",
    "working_paper_revision",
    "comment_set_id",
    "comments"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "reviewer_comment_set",
      "description": "Canonical artifact type identifier."
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[A-Z0-9._-]+$",
      "description": "Stable identifier for this comment set artifact."
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version of this artifact instance for diffing and rollback."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the reviewer_comment_set schema."
    },
    "standards_version": {
      "type": "string",
      "const": "2026.03.0",
      "description": "Standards release version from contracts/standards-manifest.json."
    },
    "record_id": {
      "type": "string",
      "pattern": "^REC-[A-Z0-9._-]+$",
      "description": "Record identifier used for provenance and diffing."
    },
    "run_id": {
      "type": "string",
      "pattern": "^run-[A-Za-z0-9._-]+$",
      "description": "Deterministic run identifier for the workflow that produced this record."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this comment set was generated."
    },
    "created_by": {
      "$ref": "#/$defs/created_by"
    },
    "source_repo": {
      "type": "string",
      "description": "Repository slug that produced this comment set."
    },
    "source_repo_version": {
      "type": "string",
      "description": "Tag or commit hash of the source repository."
    },
    "working_paper_id": {
      "type": "string",
      "pattern": "^WKP-[A-Z0-9._-]+$",
      "description": "Identifier of the working paper being reviewed."
    },
    "working_paper_revision": {
      "type": "string",
      "pattern": "^rev[0-9]+$",
      "description": "Revision marker for the working paper the comments reference."
    },
    "comment_set_id": {
      "type": "string",
      "pattern": "^CSET-[A-Z0-9._-]+$",
      "description": "Identifier for this batch of comments."
    },
    "input_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_artifact"
      },
      "description": "Upstream artifacts used to build this comment set (e.g., source PDFs, prior datasets)."
    },
    "comments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/comment"
      },
      "description": "List of normalized reviewer comments."
    }
  },
  "$defs": {
    "created_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "agent_type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "agent_type": {
          "type": "string",
          "enum": [
            "human",
            "ai_model",
            "workflow",
            "script"
          ]
        },
        "organization": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "input_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "artifact_version",
        "role"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^[A-Z0-9._-]+$"
        },
        "artifact_type": {
          "type": "string"
        },
        "artifact_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "role": {
          "type": "string"
        },
        "source_repo": {
          "type": "string"
        },
        "source_repo_version": {
          "type": "string"
        }
      }
    },
    "comment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "comment_id",
        "text",
        "severity",
        "priority",
        "location",
        "status",
        "proposed_disposition",
        "provenance_id"
      ],
      "properties": {
        "comment_id": {
          "type": "string",
          "pattern": "^CMT-[A-Z0-9._-]+$"
        },
        "text": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "minor",
            "major",
            "critical"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "section_id",
            "reference"
          ],
          "properties": {
            "section_id": {
              "type": "string",
              "pattern": "^SEC-[A-Za-z0-9._-]+$"
            },
            "page": {
              "type": "integer",
              "minimum": 1
            },
            "reference": {
              "type": "string"
            }
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "new",
            "triaged",
            "in_review",
            "resolved",
            "deferred"
          ]
        },
        "proposed_disposition": {
          "type": "string"
        },
        "provenance_id": {
          "type": "string",
          "pattern": "^PRV-[A-Z0-9._-]+$"
        },
        "proposed_change": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "linked_issue_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attachments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
