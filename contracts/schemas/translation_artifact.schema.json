{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/translation_artifact.schema.json",
  "title": "translation_artifact",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "translation_artifact"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner_system": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,8}$"
    },
    "source_format": {
      "type": "string"
    },
    "target_artifact_type": {
      "type": "string"
    },
    "translation_status": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ]
    },
    "translated_payload": {
      "type": "object"
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "trace_id",
    "created_at",
    "owner_system",
    "source_format",
    "target_artifact_type",
    "translation_status",
    "translated_payload"
  ]
}
