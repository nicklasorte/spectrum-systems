{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/m3l/gate_shard_parity_record.schema.json",
  "title": "Gate Shard Parity Record",
  "description": "M3L-03 measurement-only artifact emitted by scripts/build_gate_shard_parity_record.py. Records whether APR, CLP, and the GitHub-driven shard runner reference compatible EVL shard artifacts, and surfaces shard-status mismatch findings between those systems. The record is observation-only; it never recomputes shard results, never reruns tests, never invokes the shard runner, and never claims admission, execution, eval, policy, control, or final-gate authority. Canonical authority remains with AEX (admission), PQX (bounded execution closure), EVL (eval evidence), TPA (policy/scope), CDE (continuation/closure), SEL (final gate signal), LIN (lineage), REP (replay), and GOV per docs/architecture/system_registry.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "record_id",
    "created_at",
    "work_item_id",
    "base_ref",
    "head_ref",
    "apr_result_ref",
    "clp_result_ref",
    "m3l_result_ref",
    "shard_summary_ref",
    "shard_artifact_refs",
    "apr_shard_refs",
    "clp_shard_refs",
    "github_shard_refs",
    "apr_status",
    "clp_status",
    "github_shard_status",
    "parity_status",
    "github_escape",
    "apr_clp_mismatch",
    "clp_github_mismatch",
    "missing_artifact_refs",
    "mismatch_findings",
    "reason_codes",
    "authority_scope"
  ],
  "properties": {
    "artifact_type": {
      "const": "gate_shard_parity_record"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "work_item_id": {
      "type": "string",
      "minLength": 1
    },
    "base_ref": {
      "type": "string",
      "minLength": 1
    },
    "head_ref": {
      "type": "string",
      "minLength": 1
    },
    "apr_result_ref": {
      "type": ["string", "null"]
    },
    "clp_result_ref": {
      "type": ["string", "null"]
    },
    "m3l_result_ref": {
      "type": ["string", "null"]
    },
    "shard_summary_ref": {
      "type": ["string", "null"]
    },
    "shard_artifact_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "apr_shard_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "clp_shard_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "github_shard_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "apr_status": {
      "enum": ["pass", "warn", "block", "missing", "unknown", "human_review_required"]
    },
    "clp_status": {
      "enum": ["pass", "warn", "block", "missing", "unknown"]
    },
    "github_shard_status": {
      "enum": ["pass", "block", "fail", "missing", "unknown"]
    },
    "parity_status": {
      "enum": ["aligned", "drift", "partial", "unknown"]
    },
    "github_escape": {
      "type": "boolean"
    },
    "apr_clp_mismatch": {
      "type": "boolean"
    },
    "clp_github_mismatch": {
      "type": "boolean"
    },
    "missing_artifact_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "mismatch_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/mismatch_finding" }
    },
    "reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "authority_scope": {
      "const": "observation_only"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "parity_status": { "const": "aligned" } }
      },
      "then": {
        "properties": {
          "github_escape": { "const": false },
          "apr_clp_mismatch": { "const": false },
          "clp_github_mismatch": { "const": false },
          "missing_artifact_refs": { "maxItems": 0 },
          "mismatch_findings": { "maxItems": 0 },
          "shard_summary_ref": { "type": "string", "minLength": 1 },
          "apr_result_ref": { "type": "string", "minLength": 1 },
          "clp_result_ref": { "type": "string", "minLength": 1 },
          "shard_artifact_refs": { "minItems": 1 },
          "apr_shard_refs": { "minItems": 1 },
          "clp_shard_refs": { "minItems": 1 },
          "github_shard_refs": { "minItems": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "parity_status": { "enum": ["drift", "partial", "unknown"] }
        }
      },
      "then": {
        "properties": {
          "reason_codes": { "minItems": 1 }
        }
      }
    }
  ],
  "$defs": {
    "mismatch_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "artifact_refs"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "artifact_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "shard_name": {
          "type": ["string", "null"]
        },
        "details": {
          "type": "object"
        }
      }
    }
  }
}
