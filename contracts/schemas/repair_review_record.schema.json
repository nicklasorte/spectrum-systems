{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/repair_review_record.schema.json",
  "title": "Repair Review Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "schema_version", "review_id", "repair_candidate_ref", "reviewer_id", "disposition", "review_notes", "reviewed_at", "non_authority_assertions"],
  "properties": {
    "artifact_type": {"const": "repair_review_record"},
    "schema_version": {"const": "1.0.0"},
    "review_id": {"type": "string", "pattern": "^fre-rvw-[a-f0-9]{16}$"},
    "repair_candidate_ref": {"type": "string", "pattern": "^repair_candidate:.+"},
    "reviewer_id": {"type": "string", "minLength": 1},
    "disposition": {"type": "string", "enum": ["approved", "rejected", "needs_more_evidence"]},
    "review_notes": {"type": "string", "minLength": 1},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "non_authority_assertions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
