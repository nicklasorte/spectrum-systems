{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/ai_programming_work_item_record.schema.json",
  "title": "AI Programming Work Item Record",
  "description": "Per-work-item evidence record for an AI programming contribution (Codex, Claude, or unknown_ai_agent). Observation only; MET owns this record and does not claim AEX, PQX, EVL, TPA, CDE, or SEL authority. Fail-closed: repo_mutating=true requires AEX and PQX legs. present status requires non-empty artifact_refs. partial/missing/unknown requires reason_codes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "record_id",
    "created_at",
    "owner_system",
    "work_item_id",
    "tool_source",
    "repo_mutating",
    "legs",
    "compliance_status",
    "source_artifacts_used"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "ai_programming_work_item_record"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner_system": {
      "type": "string",
      "const": "MET"
    },
    "work_item_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_source": {
      "type": "string",
      "enum": ["codex", "claude", "unknown"]
    },
    "repo_mutating": {
      "oneOf": [
        {"type": "boolean"},
        {"type": "string", "const": "unknown"}
      ]
    },
    "pr_ref": {
      "type": ["string", "null"]
    },
    "branch_ref": {
      "type": ["string", "null"]
    },
    "legs": {
      "type": "object",
      "description": "Per-leg evidence for the AEX→PQX→EVL→TPA→CDE→SEL canonical loop.",
      "additionalProperties": false,
      "required": ["AEX", "PQX", "EVL", "TPA", "CDE", "SEL"],
      "properties": {
        "AEX": {"$ref": "#/$defs/leg_evidence"},
        "PQX": {"$ref": "#/$defs/leg_evidence"},
        "EVL": {"$ref": "#/$defs/leg_evidence"},
        "TPA": {"$ref": "#/$defs/leg_evidence"},
        "CDE": {"$ref": "#/$defs/leg_evidence"},
        "SEL": {"$ref": "#/$defs/leg_evidence"}
      }
    },
    "lineage_status": {
      "type": "string",
      "enum": ["present", "partial", "missing", "unknown", "not_required"]
    },
    "lineage_artifact_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "lineage_reason_codes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "compliance_status": {
      "type": "string",
      "enum": ["PASS", "WARN", "BLOCK"]
    },
    "bypass_risk": {
      "type": "string",
      "enum": ["none", "aex_missing", "pqx_missing", "eval_missing", "lineage_missing", "unknown"]
    },
    "backfill_allowed": {
      "type": ["boolean", "string"]
    },
    "human_review_required": {
      "type": "boolean"
    },
    "next_recommended_input": {
      "type": "string"
    },
    "source_artifacts_used": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "reason_codes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "warnings": {
      "type": "array",
      "items": {"type": "string"}
    },
    "sma_loop_run_ref": {
      "type": ["string", "null"],
      "description": "Reference to 3ls_loop_run_record for this work item."
    }
  },
  "$defs": {
    "leg_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["present", "partial", "missing", "unknown", "not_required"]
        },
        "artifact_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "reason_codes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "source_artifacts_used": {
          "type": "array",
          "items": {"type": "string"}
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "present"}}, "required": ["status"]},
          "then": {
            "properties": {
              "artifact_refs": {"type": "array", "minItems": 1}
            },
            "required": ["artifact_refs"]
          }
        },
        {
          "if": {
            "properties": {
              "status": {"enum": ["partial", "missing", "unknown"]}
            },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "reason_codes": {"type": "array", "minItems": 1}
            },
            "required": ["reason_codes"]
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "description": "repo_mutating=true requires AEX and PQX at minimum. If either is missing or unknown, compliance_status must be BLOCK.",
      "if": {
        "properties": {"repo_mutating": {"const": true}},
        "required": ["repo_mutating"]
      },
      "then": {
        "if": {
          "anyOf": [
            {"properties": {"legs": {"properties": {"AEX": {"properties": {"status": {"enum": ["missing", "unknown"]}}, "required": ["status"]}}},"required": ["legs"]}},
            {"properties": {"legs": {"properties": {"PQX": {"properties": {"status": {"enum": ["missing", "unknown"]}}, "required": ["status"]}}},"required": ["legs"]}}
          ]
        },
        "then": {
          "properties": {"compliance_status": {"const": "BLOCK"}},
          "required": ["compliance_status"]
        }
      }
    }
  ]
}
