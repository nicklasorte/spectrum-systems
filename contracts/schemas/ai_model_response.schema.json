{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/ai_model_response.schema.json",
  "title": "AI Model Response",
  "description": "Canonical governed model response artifact at the AG runtime/provider boundary.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "response_id",
    "created_at",
    "request_id",
    "provider_name",
    "provider_model_name",
    "normalized_output_text",
    "finish_reason",
    "response_status",
    "structured_output",
    "trace"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "ai_model_response"
    },
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "response_id": {
      "type": "string",
      "pattern": "^amres-[a-f0-9]{16}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "request_id": {
      "type": "string",
      "pattern": "^amr-[a-f0-9]{16}$"
    },
    "provider_name": {
      "type": "string",
      "minLength": 1
    },
    "provider_model_name": {
      "type": "string",
      "minLength": 1
    },
    "normalized_output_text": {
      "type": "string",
      "minLength": 1
    },
    "finish_reason": {
      "type": "string",
      "enum": [
        "stop",
        "length",
        "content_filter",
        "error"
      ]
    },
    "response_status": {
      "type": "string",
      "enum": [
        "completed",
        "failed"
      ]
    },
    "structured_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested",
        "target_schema_ref",
        "generation_mode",
        "enforcement_path",
        "status",
        "failure_reason"
      ],
      "properties": {
        "requested": {
          "type": "boolean"
        },
        "target_schema_ref": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "generation_mode": {
          "type": "string",
          "enum": [
            "unstructured",
            "provider_native_strict",
            "adapter_json_schema_strict"
          ]
        },
        "enforcement_path": {
          "type": "string",
          "enum": [
            "none",
            "provider_native",
            "adapter_json_schema"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "not_requested",
            "succeeded",
            "failed"
          ]
        },
        "failure_reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "agent_run_id",
        "step_id"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "agent_run_id": {
          "type": "string",
          "minLength": 1
        },
        "step_id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
