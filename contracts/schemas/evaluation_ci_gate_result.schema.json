{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/evaluation_ci_gate_result.schema.json",
  "title": "Evaluation CI Gate Result",
  "description": "Machine-readable fail-closed CI gate result for governed eval execution and promotion blocking.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "gate_run_id",
    "timestamp",
    "status",
    "blocking_reasons",
    "required_artifacts_checked",
    "missing_artifacts",
    "invalid_artifacts",
    "eval_summary_refs",
    "threshold_results",
    "control_decision_ref",
    "repo_state"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "evaluation_ci_gate_result"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "gate_run_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked"
      ]
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_artifacts_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "missing_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "invalid_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "eval_summary_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "threshold_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "threshold",
          "passed"
        ],
        "properties": {
          "threshold": {
            "type": "string",
            "minLength": 1
          },
          "passed": {
            "type": "boolean"
          }
        }
      }
    },
    "control_decision_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "repo_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commit_sha",
        "branch",
        "workflow_run_id"
      ],
      "properties": {
        "commit_sha": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "workflow_run_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
