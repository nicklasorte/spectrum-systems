{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "preflight_block_diagnosis_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "diagnosis_id",
    "strategy_gate_decision",
    "failure_class",
    "reason_codes",
    "root_cause_summary",
    "normalized_failure"
  ],
  "properties": {
    "artifact_type": {
      "const": "preflight_block_diagnosis_record"
    },
    "artifact_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "diagnosis_id": {
      "type": "string"
    },
    "strategy_gate_decision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "WARN",
        "FREEZE",
        "BLOCK"
      ]
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "missing_required_artifact",
        "contract_mismatch",
        "schema_violation",
        "lineage_missing",
        "authority_evidence_missing",
        "invalid_wrapper",
        "pytest_config_missing",
        "pytest_config_mismatch",
        "testpaths_missing",
        "no_tests_discovered",
        "unexpected_test_inventory_regression",
        "import_resolution_failure",
        "collection_failure",
        "working_directory_mismatch",
        "accidental_filtering_detected",
        "non_repairable_policy_violation",
        "internal_preflight_error",
        "test_inventory_regression",
        "control_surface_gap",
        "downstream_test_failure",
        "pytest_selection_missing",
        "pytest_selection_mismatch",
        "pytest_selection_filtering",
        "pytest_selection_threshold"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "root_cause_summary": {
      "type": "string",
      "minLength": 1
    },
    "normalized_failure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failure_class",
        "repairable"
      ],
      "properties": {
        "failure_class": {
          "type": "string",
          "minLength": 1
        },
        "repairable": {
          "type": "boolean"
        }
      }
    },
    "pytest_selection_diagnostic": {
      "type": "object",
      "description": "Optional diagnostic populated for pytest_selection_* failure classes. Names the changed files that did not map to a pytest selection, the surface rules that were attempted, and the registry locations to update.",
      "additionalProperties": false,
      "required": [
        "unmatched_changed_paths",
        "attempted_surface_rules",
        "recommended_mapping_locations"
      ],
      "properties": {
        "unmatched_changed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attempted_surface_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path_prefix",
              "required_test_targets"
            ],
            "properties": {
              "path_prefix": {
                "type": "string"
              },
              "required_test_targets": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "recommended_mapping_locations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
