{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/system_roadmap.schema.json",
  "title": "System Roadmap",
  "description": "Governed deterministic roadmap source-of-truth for bounded batch activation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "roadmap_id",
    "version",
    "batches",
    "created_at",
    "trace_id"
  ],
  "properties": {
    "roadmap_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "batches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "batch_id",
          "title",
          "status",
          "dependencies",
          "priority",
          "description"
        ],
        "properties": {
          "batch_id": {
            "type": "string",
            "pattern": "^BATCH-[A-Z0-9-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "not_started",
              "in_progress",
              "completed",
              "blocked"
            ]
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^BATCH-[A-Z0-9-]+$"
            },
            "uniqueItems": true
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace-[A-Za-z0-9._:-]+$"
    }
  }
}
