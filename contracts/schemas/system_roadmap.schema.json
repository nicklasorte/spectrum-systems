{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/system_roadmap.schema.json",
  "title": "System Roadmap",
  "description": "Canonical governed roadmap artifact used as the machine execution source of truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "roadmap_id",
    "version",
    "created_at",
    "trace_id",
    "batches"
  ],
  "properties": {
    "roadmap_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace-[A-Za-z0-9._:-]+$"
    },
    "batches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "batch_id",
          "acronym",
          "title",
          "goal",
          "depends_on",
          "hard_gate",
          "priority",
          "status",
          "allowed_when",
          "stop_conditions",
          "artifacts_expected",
          "tests_required",
          "description"
        ],
        "properties": {
          "batch_id": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9-]*$"
          },
          "acronym": {
            "type": "string",
            "pattern": "^[A-Z]{1,6}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9-]*$"
            },
            "uniqueItems": true
          },
          "hard_gate": {
            "type": "boolean"
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "not_started",
              "in_progress",
              "completed",
              "blocked"
            ]
          },
          "allowed_when": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "stop_conditions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "artifacts_expected": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "tests_required": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
