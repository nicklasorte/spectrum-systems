{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/provenance_record.schema.json",
  "title": "Contract Provenance Record",
  "description": "Reusable provenance schema for artifact contracts and run chains.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "record_id",
    "run_id",
    "created_at",
    "created_by",
    "source_repo",
    "source_repo_version",
    "record_type",
    "entity_id",
    "activity",
    "agents",
    "derived_from",
    "lineage"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "provenance_record",
      "description": "Canonical artifact type identifier."
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^PRV-[A-Z0-9._-]+$",
      "description": "Identifier for this provenance artifact."
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version of this provenance record."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the provenance_record schema."
    },
    "standards_version": {
      "type": "string",
      "const": "2026.03.0",
      "description": "Standards release version from contracts/standards-manifest.json."
    },
    "record_id": {
      "type": "string",
      "pattern": "^REC-[A-Z0-9._-]+$",
      "description": "Record identifier used for provenance and diffing."
    },
    "run_id": {
      "type": "string",
      "pattern": "^run-[A-Za-z0-9._-]+$",
      "description": "Deterministic run identifier for the workflow that produced this record."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this provenance record was generated."
    },
    "created_by": {
      "$ref": "#/$defs/created_by"
    },
    "source_repo": {
      "type": "string",
      "description": "Repository slug that produced this record."
    },
    "source_repo_version": {
      "type": "string",
      "description": "Tag or commit hash of the source repository."
    },
    "record_type": {
      "type": "string",
      "enum": [
        "artifact",
        "transformation",
        "validation",
        "review"
      ]
    },
    "entity_id": {
      "type": "string",
      "description": "Identifier of the entity this provenance refers to."
    },
    "activity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_name",
        "workflow_step",
        "timestamp",
        "status"
      ],
      "properties": {
        "workflow_name": {
          "type": "string"
        },
        "workflow_step": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": [
            "started",
            "completed",
            "failed"
          ]
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/agent"
      },
      "description": "Agents responsible for creation, transformation, or review."
    },
    "derived_from": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parent_reference"
      },
      "description": "Parent entities that informed this record."
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version_id",
        "version_number",
        "lineage_type"
      ],
      "properties": {
        "version_id": {
          "type": "string"
        },
        "version_number": {
          "type": "string"
        },
        "lineage_type": {
          "type": "string",
          "enum": [
            "original",
            "derived",
            "merged",
            "corrected",
            "superseded"
          ]
        }
      }
    },
    "review_status": {
      "type": "string",
      "enum": [
        "unreviewed",
        "pending_review",
        "approved",
        "rejected"
      ]
    },
    "reviewed_by": {
      "type": "string"
    },
    "review_notes": {
      "type": "string"
    },
    "quality_status": {
      "type": "string",
      "enum": [
        "raw",
        "normalized",
        "validated",
        "superseded"
      ]
    },
    "working_paper_revision": {
      "type": "string",
      "pattern": "^rev[0-9]+$",
      "description": "Optional working paper revision anchor for contracts tied to a paper."
    },
    "input_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_artifact"
      },
      "description": "Referenced artifacts used to generate or validate this provenance record."
    }
  },
  "$defs": {
    "created_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "agent_type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "agent_type": {
          "type": "string",
          "enum": [
            "human",
            "ai_model",
            "workflow",
            "script"
          ]
        },
        "organization": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "input_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "artifact_version",
        "role"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^[A-Z0-9._-]+$"
        },
        "artifact_type": {
          "type": "string"
        },
        "artifact_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "role": {
          "type": "string"
        },
        "source_repo": {
          "type": "string"
        },
        "source_repo_version": {
          "type": "string"
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_id",
        "agent_type",
        "role"
      ],
      "properties": {
        "agent_id": {
          "type": "string"
        },
        "agent_type": {
          "type": "string",
          "enum": [
            "human",
            "ai_model",
            "workflow",
            "script",
            "team"
          ]
        },
        "role": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "parent_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "relationship": {
          "type": "string"
        }
      }
    }
  }
}
