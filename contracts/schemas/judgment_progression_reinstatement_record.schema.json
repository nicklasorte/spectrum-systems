{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/judgment_progression_reinstatement_record.schema.json",
  "title": "Judgment Progression Reinstatement Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "reinstatement_id",
    "source_closure_id",
    "affected_scope",
    "reinstatement_type",
    "required_gates_satisfied",
    "approved_by_role",
    "approved_at",
    "resulting_next_allowed_state",
    "trace"
  ],
  "properties": {
    "artifact_type": {"const": "judgment_progression_reinstatement_record"},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "const": "1.0.0"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "standards_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "reinstatement_id": {"type": "string", "minLength": 1},
    "source_closure_id": {"type": "string", "minLength": 1},
    "affected_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "trace_id", "scope"],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "trace_id": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1},
        "artifact_id": {"type": "string", "minLength": 1}
      }
    },
    "reinstatement_type": {
      "type": "string",
      "enum": ["unblock", "unfreeze", "warning_acknowledged_continue"]
    },
    "required_gates_satisfied": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "approved_by_role": {"type": "string", "minLength": 1},
    "approved_at": {"type": "string", "format": "date-time"},
    "resulting_next_allowed_state": {"type": "string", "enum": ["allowed", "allowed_with_warning"]},
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "run_id", "closure_id", "remediation_id"],
      "properties": {
        "trace_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "closure_id": {"type": "string", "minLength": 1},
        "remediation_id": {"type": "string", "minLength": 1}
      }
    }
  }
}
