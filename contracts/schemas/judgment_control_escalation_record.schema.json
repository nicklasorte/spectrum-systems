{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/judgment_control_escalation_record.schema.json",
  "title": "Judgment Control Escalation Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "decision",
    "triggering_signals",
    "thresholds_used",
    "rationale",
    "trace",
    "created_at"
  ],
  "properties": {
    "artifact_type": {"const": "judgment_control_escalation_record"},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "schema_version": {"type": "string", "const": "1.1.0"},
    "standards_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "decision": {"type": "string", "enum": ["allow", "warn", "freeze", "block"]},
    "triggering_signals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drift", "calibration", "error_budget"],
      "properties": {
        "drift": {"type": "string", "enum": ["no_drift", "warning_drift", "critical_drift"]},
        "calibration": {"type": "string", "minLength": 1},
        "error_budget": {"type": "string", "enum": ["healthy", "warning", "exhausted", "invalid"]}
      }
    },
    "thresholds_used": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drift", "calibration", "error_budget"],
      "properties": {
        "drift": {"type": "object"},
        "calibration": {"type": "object"},
        "error_budget": {"type": "object"}
      }
    },
    "rationale": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "run_id",
        "judgment_eval_result_id",
        "judgment_calibration_result_id",
        "judgment_drift_signal_id",
        "judgment_error_budget_status_id",
        "judgment_policy_id",
        "judgment_policy_version",
        "policy_lifecycle_status",
        "policy_rollout_id"
      ],
      "properties": {
        "trace_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "judgment_eval_result_id": {"type": "string", "minLength": 1},
        "judgment_calibration_result_id": {"type": "string", "minLength": 1},
        "judgment_drift_signal_id": {"type": "string", "minLength": 1},
        "judgment_error_budget_status_id": {"type": "string", "minLength": 1},
        "judgment_policy_id": {"type": "string", "minLength": 1},
        "judgment_policy_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "policy_lifecycle_status": {"type": "string", "enum": ["draft", "canary", "active", "deprecated", "revoked"]},
        "policy_rollout_id": {"type": "string", "minLength": 1}
      }
    },
    "created_at": {"type": "string", "format": "date-time"}
  }
}
