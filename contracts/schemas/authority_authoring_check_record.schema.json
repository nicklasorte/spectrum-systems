{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/authority_authoring_check_record.schema.json",
  "title": "authority_authoring_check_record",
  "description": "Observation-only record produced by run_authority_authoring_check.py. Surfaces authoring-time signals about reserved authority terminology and protected owner-acronym usage in non-owner files. Does not claim admission, control, enforcement, or eval authority. Existing authority_shape_preflight, authority_leak_guard, and system_registry_guard remain canonical and run independently.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "record_id",
    "created_at",
    "base_ref",
    "head_ref",
    "changed_files",
    "scanned_files",
    "skipped_files",
    "unsafe_findings",
    "protected_owner_findings",
    "status",
    "reason_codes",
    "output_artifact_refs"
  ],
  "properties": {
    "artifact_type": {
      "const": "authority_authoring_check_record"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "base_ref": {
      "type": "string",
      "minLength": 1
    },
    "head_ref": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scanned_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skipped_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "skip_reason"],
        "properties": {
          "file": {
            "type": "string"
          },
          "skip_reason": {
            "type": "string",
            "enum": [
              "non_text",
              "outside_authored_surface",
              "generated_artifact",
              "owner_path",
              "missing_on_disk",
              "unreadable"
            ]
          }
        }
      }
    },
    "unsafe_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "line", "term", "category", "snippet", "reason_code"],
        "properties": {
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "term": {
            "type": "string"
          },
          "category": {
            "type": "string",
            "enum": [
              "reserved_authority_term",
              "negated_authority_term"
            ]
          },
          "snippet": {
            "type": "string"
          },
          "reason_code": {
            "type": "string"
          },
          "canonical_owner_hint": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "protected_owner_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "line", "owner_acronym", "snippet", "reason_code"],
        "properties": {
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "owner_acronym": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          },
          "reason_code": {
            "type": "string"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["pass", "warn", "block", "unknown"]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authority_scope": {
      "type": "string",
      "const": "observation_only"
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "unsafe_finding_count": {
          "type": "integer",
          "minimum": 0
        },
        "protected_owner_finding_count": {
          "type": "integer",
          "minimum": 0
        },
        "scanned_file_count": {
          "type": "integer",
          "minimum": 0
        },
        "skipped_file_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "pass"
          }
        }
      },
      "then": {
        "properties": {
          "output_artifact_refs": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": ["warn", "block", "unknown"]
          }
        }
      },
      "then": {
        "properties": {
          "reason_codes": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  ]
}
