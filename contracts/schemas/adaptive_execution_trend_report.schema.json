{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/adaptive_execution_trend_report.schema.json",
  "title": "Adaptive Execution Trend Report",
  "description": "Deterministic bounded adaptive execution trend and guardrail report artifact for operator tuning decisions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trend_report_id",
    "schema_version",
    "created_at",
    "trace_id",
    "observability_ref",
    "runs_observed",
    "autonomy_effectiveness",
    "safety_trend",
    "guardrail_status",
    "guardrail_checks",
    "trend_signals",
    "tuning_warranted",
    "watch_next",
    "source_refs"
  ],
  "properties": {
    "trend_report_id": {
      "type": "string",
      "pattern": "^AET-[A-F0-9]{12}$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace-[A-Za-z0-9._:-]+$"
    },
    "observability_ref": {
      "type": "string",
      "pattern": "^adaptive_execution_observability:AEO-[A-F0-9]{12}$"
    },
    "runs_observed": {
      "type": "integer",
      "minimum": 0
    },
    "autonomy_effectiveness": {
      "type": "string",
      "enum": [
        "improving",
        "stable",
        "needs_tuning"
      ]
    },
    "safety_trend": {
      "type": "string",
      "enum": [
        "safer",
        "watch",
        "riskier"
      ]
    },
    "guardrail_status": {
      "type": "string",
      "enum": [
        "within_guardrails",
        "alert"
      ]
    },
    "guardrail_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "check_id",
          "status",
          "threshold",
          "observed",
          "direction",
          "message"
        ],
        "properties": {
          "check_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "triggered"
            ]
          },
          "threshold": {
            "type": "number"
          },
          "observed": {
            "type": "number"
          },
          "direction": {
            "type": "string",
            "enum": [
              "lower_is_better",
              "higher_is_better"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "trend_signals": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "early_stop_rate_trend",
        "useful_batches_per_run_trend",
        "risk_stop_share",
        "resolved_cap_efficiency_gap"
      ],
      "properties": {
        "early_stop_rate_trend": {
          "type": "string",
          "enum": [
            "improving",
            "stable",
            "degrading"
          ]
        },
        "useful_batches_per_run_trend": {
          "type": "string",
          "enum": [
            "improving",
            "stable",
            "degrading"
          ]
        },
        "risk_stop_share": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "resolved_cap_efficiency_gap": {
          "type": "number"
        }
      }
    },
    "tuning_warranted": {
      "type": "boolean"
    },
    "watch_next": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
