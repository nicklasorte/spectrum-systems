{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems/contracts/core_loop_contract.schema.json",
  "title": "Core Loop Contract",
  "description": "CL-01: Machine-checkable meta-contract that pins the canonical core loop AEX → PQX → EVL → TPA → CDE → SEL. Defines the fixed stage order, required handoff fields between adjacent stages, the required artifact references each stage must surface for downstream consumers, the terminal statuses, and the deterministic precedence used to elect a single primary reason on block/freeze. The contract itself is non-authoritative: it does not decide, gate, orchestrate, or enforce. Authority remains with AEX (admission), PQX (execution), EVL (required-eval registry), TPA (trust/policy), CDE (closure/decision), and SEL (enforcement). Other modules are support seams that emit signals, observations, or recommendations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "contract_id",
    "stage_order",
    "transitions",
    "terminal_statuses",
    "reason_precedence",
    "non_authority_assertions"
  ],
  "properties": {
    "artifact_type": { "const": "core_loop_contract" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "contract_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "stage_order": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "string",
        "enum": ["AEX", "PQX", "EVL", "TPA", "CDE", "SEL"]
      }
    },
    "stage_required_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      }
    },
    "transitions": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "from_stage",
          "to_stage",
          "required_handoff_fields",
          "required_input_refs",
          "required_output_refs"
        ],
        "properties": {
          "from_stage": {
            "type": "string",
            "enum": ["AEX", "PQX", "EVL", "TPA", "CDE", "SEL"]
          },
          "to_stage": {
            "type": "string",
            "enum": ["AEX", "PQX", "EVL", "TPA", "CDE", "SEL"]
          },
          "required_handoff_fields": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "required_input_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "required_output_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "terminal_statuses": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "string",
        "enum": ["pass", "block", "freeze"]
      }
    },
    "reason_precedence": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "string",
        "enum": ["admission", "execution", "eval", "policy", "decision", "action"]
      }
    },
    "stage_owners": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "AEX": { "const": "AEX" },
        "PQX": { "const": "PQX" },
        "EVL": { "const": "EVL" },
        "TPA": { "const": "TPA" },
        "CDE": { "const": "CDE" },
        "SEL": { "const": "SEL" }
      }
    },
    "non_authority_assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "preparatory_only",
          "not_admission_authority",
          "not_execution_authority",
          "not_eval_authority",
          "not_policy_authority",
          "not_control_authority",
          "not_enforcement_authority",
          "not_promotion_authority",
          "not_certification_authority"
        ]
      }
    }
  }
}
