{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/build_summary.schema.json",
  "title": "build_summary",
  "description": "Deterministic operator summary artifact for one bounded system cycle execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary_id",
    "schema_version",
    "run_id",
    "next_batch_candidate",
    "stop_reason",
    "continuation_decision",
    "what_ran",
    "what_changed",
    "what_failed",
    "run_outcome",
    "watch_next",
    "artifact_index",
    "failure_surface",
    "trace_navigation",
    "replay_entry_points",
    "quick_links",
    "trace_id",
    "created_at",
    "source_refs",
    "execution_path_type",
    "program_alignment_status",
    "program_stop_cause",
    "program_drift_severity",
    "next_cycle_decision",
    "next_cycle_decision_reason_codes",
    "next_cycle_inputs_ref"
  ],
  "properties": {
    "summary_id": {
      "type": "string",
      "pattern": "^BSR-[A-F0-9]{12}$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.5.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "what_ran": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "what_changed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "what_failed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "run_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "stop_reason",
        "has_blockers"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "blocked"
          ]
        },
        "stop_reason": {
          "type": "string",
          "enum": [
            "max_batches_reached",
            "hard_gate_stop",
            "authorization_block",
            "authorization_freeze",
            "missing_required_signal",
            "execution_blocked",
            "execution_failed",
            "loop_validation_failed",
            "replay_not_ready",
            "invalid_roadmap_state",
            "invalid_progress_state",
            "contract_precondition_failed",
            "no_eligible_batch",
            "diminishing_returns_detected",
            "repeated_failure_pattern",
            "unresolved_blocker_persists",
            "risk_accumulation_threshold_exceeded",
            "control_block",
            "control_freeze",
            "program_blocking_condition",
            "program_priority_violation",
            "program_alignment_invalid",
            "program_drift_detected",
            "eval_health_degraded",
            "manual_review_required"
          ]
        },
        "has_blockers": {
          "type": "boolean"
        }
      }
    },
    "watch_next": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "artifact_index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roadmap_multi_batch_run_result",
        "core_system_integration_validation",
        "next_step_recommendation",
        "trace_id",
        "replay_refs",
        "upstream_refs",
        "downstream_refs",
        "related_artifacts",
        "next_cycle_decision",
        "next_cycle_input_bundle"
      ],
      "properties": {
        "roadmap_multi_batch_run_result": {
          "type": "string",
          "minLength": 3
        },
        "core_system_integration_validation": {
          "type": "string",
          "minLength": 3
        },
        "next_step_recommendation": {
          "type": "string",
          "minLength": 3
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trace-[A-Za-z0-9._:-]+$"
        },
        "replay_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "upstream_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "downstream_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "related_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "next_cycle_decision": {
          "type": "string",
          "pattern": "^next_cycle_decision:NCD-[A-F0-9]{12}$"
        },
        "next_cycle_input_bundle": {
          "type": "string",
          "pattern": "^next_cycle_input_bundle:NCB-[A-F0-9]{12}$"
        }
      }
    },
    "failure_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stop_reason",
        "root_cause",
        "root_cause_chain",
        "next_action",
        "blocker_refs",
        "source_refs"
      ],
      "properties": {
        "stop_reason": {
          "type": "string",
          "enum": [
            "max_batches_reached",
            "hard_gate_stop",
            "authorization_block",
            "authorization_freeze",
            "missing_required_signal",
            "execution_blocked",
            "execution_failed",
            "loop_validation_failed",
            "replay_not_ready",
            "invalid_roadmap_state",
            "invalid_progress_state",
            "contract_precondition_failed",
            "no_eligible_batch",
            "diminishing_returns_detected",
            "repeated_failure_pattern",
            "unresolved_blocker_persists",
            "risk_accumulation_threshold_exceeded",
            "control_block",
            "control_freeze",
            "program_blocking_condition",
            "program_priority_violation",
            "program_alignment_invalid",
            "program_drift_detected",
            "eval_health_degraded",
            "manual_review_required"
          ]
        },
        "root_cause": {
          "type": "string",
          "minLength": 3
        },
        "root_cause_chain": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "step",
              "reason"
            ],
            "properties": {
              "step": {
                "type": "string",
                "minLength": 3
              },
              "reason": {
                "type": "string",
                "minLength": 3
              }
            }
          }
        },
        "next_action": {
          "type": "string",
          "minLength": 3
        },
        "blocker_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        }
      }
    },
    "trace_navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "execution_path",
        "decision_points",
        "influencing_artifacts",
        "layer_transitions",
        "replay_entry_points",
        "replay_ready"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "execution_path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "decision_points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "influencing_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "layer_transitions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Z]+->[A-Z]+$"
          },
          "uniqueItems": true
        },
        "replay_entry_points": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "replay_from_context",
            "replay_from_plan",
            "replay_from_execution",
            "replay_from_failure"
          ],
          "properties": {
            "replay_from_context": {
              "$ref": "#/$defs/replay_entry_point"
            },
            "replay_from_plan": {
              "$ref": "#/$defs/replay_entry_point"
            },
            "replay_from_execution": {
              "$ref": "#/$defs/replay_entry_point"
            },
            "replay_from_failure": {
              "$ref": "#/$defs/replay_entry_point"
            }
          }
        },
        "replay_ready": {
          "type": "boolean"
        }
      }
    },
    "replay_entry_points": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replay_from_context",
        "replay_from_plan",
        "replay_from_execution",
        "replay_from_failure"
      ],
      "properties": {
        "replay_from_context": {
          "$ref": "#/$defs/replay_entry_point"
        },
        "replay_from_plan": {
          "$ref": "#/$defs/replay_entry_point"
        },
        "replay_from_execution": {
          "$ref": "#/$defs/replay_entry_point"
        },
        "replay_from_failure": {
          "$ref": "#/$defs/replay_entry_point"
        }
      }
    },
    "quick_links": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace-[A-Za-z0-9._:-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "continuation_decision": {
      "type": "string",
      "enum": [
        "continue",
        "stop",
        "escalate"
      ]
    },
    "stop_reason": {
      "type": "string",
      "enum": [
        "max_batches_reached",
        "hard_gate_stop",
        "authorization_block",
        "authorization_freeze",
        "missing_required_signal",
        "execution_blocked",
        "execution_failed",
        "loop_validation_failed",
        "replay_not_ready",
        "invalid_roadmap_state",
        "invalid_progress_state",
        "contract_precondition_failed",
        "no_eligible_batch",
        "diminishing_returns_detected",
        "repeated_failure_pattern",
        "unresolved_blocker_persists",
        "risk_accumulation_threshold_exceeded",
        "control_block",
        "control_freeze",
        "program_blocking_condition",
        "program_priority_violation",
        "program_alignment_invalid",
        "program_drift_detected",
        "eval_health_degraded",
        "manual_review_required"
      ]
    },
    "next_batch_candidate": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^BATCH-[A-Z]$"
    },
    "execution_path_type": {
      "type": "string",
      "enum": [
        "positive_path",
        "negative_path"
      ]
    },
    "program_alignment_status": {
      "type": "string",
      "enum": [
        "aligned",
        "misaligned"
      ]
    },
    "program_stop_cause": {
      "type": "string",
      "enum": [
        "none",
        "program_alignment_invalid",
        "program_priority_violation",
        "program_blocking_condition",
        "program_drift_detected"
      ]
    },
    "program_drift_severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "next_cycle_decision": {
      "type": "string",
      "enum": [
        "run_next_cycle",
        "stop",
        "escalate"
      ]
    },
    "next_cycle_decision_reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "healthy_aligned_progress",
          "block_or_freeze_state",
          "program_misalignment",
          "program_drift_high",
          "missing_required_artifacts",
          "repeated_failure_threshold_exceeded",
          "eval_health_degraded",
          "manual_review_required",
          "roadmap_not_ready",
          "no_remaining_batch"
        ]
      },
      "uniqueItems": true
    },
    "next_cycle_inputs_ref": {
      "type": "string",
      "pattern": "^next_cycle_input_bundle:NCB-[A-F0-9]{12}$"
    }
  },
  "$defs": {
    "replay_entry_point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_artifacts",
        "trace_refs"
      ],
      "properties": {
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "trace_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        }
      }
    }
  }
}
