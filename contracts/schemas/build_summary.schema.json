{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/build_summary.schema.json",
  "title": "build_summary",
  "description": "Deterministic operator summary artifact for one bounded system cycle execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary_id",
    "schema_version",
    "run_id",
    "what_ran",
    "what_changed",
    "what_failed",
    "run_outcome",
    "watch_next",
    "artifact_index",
    "failure_surface",
    "trace_id",
    "created_at",
    "source_refs"
  ],
  "properties": {
    "summary_id": {"type": "string", "pattern": "^BSR-[A-F0-9]{12}$"},
    "schema_version": {"type": "string", "const": "1.1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "what_ran": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 3},
      "uniqueItems": true
    },
    "what_changed": {
      "type": "array",
      "items": {"type": "string", "minLength": 3},
      "uniqueItems": true
    },
    "what_failed": {
      "type": "array",
      "items": {"type": "string", "minLength": 3},
      "uniqueItems": true
    },
    "run_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "stop_reason", "has_blockers"],
      "properties": {
        "status": {"type": "string", "enum": ["success", "blocked"]},
        "stop_reason": {"type": "string", "minLength": 3},
        "has_blockers": {"type": "boolean"}
      }
    },
    "watch_next": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 3},
      "uniqueItems": true
    },
    "artifact_index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roadmap_multi_batch_run_result",
        "core_system_integration_validation",
        "next_step_recommendation",
        "trace_id",
        "replay_refs"
      ],
      "properties": {
        "roadmap_multi_batch_run_result": {"type": "string", "minLength": 3},
        "core_system_integration_validation": {"type": "string", "minLength": 3},
        "next_step_recommendation": {"type": "string", "minLength": 3},
        "trace_id": {"type": "string", "pattern": "^trace-[A-Za-z0-9._:-]+$"},
        "replay_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        }
      }
    },
    "failure_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stop_reason", "root_cause", "next_action", "blocker_refs", "source_refs"],
      "properties": {
        "stop_reason": {"type": "string", "minLength": 3},
        "root_cause": {"type": "string", "minLength": 3},
        "next_action": {"type": "string", "minLength": 3},
        "blocker_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        }
      }
    },
    "trace_id": {"type": "string", "pattern": "^trace-[A-Za-z0-9._:-]+$"},
    "created_at": {"type": "string", "format": "date-time"},
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
