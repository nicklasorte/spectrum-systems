{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/build_summary.schema.json",
  "title": "build_summary",
  "description": "Deterministic operator summary artifact for one bounded system cycle execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary_id",
    "schema_version",
    "run_id",
    "next_batch_candidate",
    "stop_reason",
    "continuation_decision",
    "what_ran",
    "what_changed",
    "what_failed",
    "run_outcome",
    "watch_next",
    "artifact_index",
    "failure_surface",
    "trace_navigation",
    "replay_entry_points",
    "quick_links",
    "trace_id",
    "created_at",
    "source_refs",
    "execution_path_type",
    "program_alignment_status",
    "program_stop_cause",
    "program_drift_severity",
    "next_cycle_decision",
    "next_cycle_decision_reason_codes",
    "autonomy_decision",
    "autonomy_reason_codes",
    "autonomy_decision_ref",
    "next_cycle_inputs_ref",
    "exception_class",
    "recommended_exception_action",
    "exception_action_type",
    "exception_requires_human_review",
    "exception_requires_freeze",
    "capability_readiness_state",
    "capability_readiness_ref",
    "decision_proof_ref",
    "allow_decision_proof_ref",
    "unknown_state_signal_refs",
    "unknown_state_blockers",
    "failure_taxonomy_ref",
    "correction_pattern_ref",
    "rollback_plan_ref",
    "promotion_consistency_ref",
    "decision_quality_budget_ref",
    "calibration_assessment_ref",
    "judgment_promotion_gate_ref",
    "system_budget_status_ref",
    "canary_rollout_ref",
    "continuous_eval_run_refs",
    "trust_posture_snapshot_ref",
    "artifact_family_health_report_ref",
    "evidence_gap_hotspot_report_ref",
    "override_hotspot_report_ref",
    "judgment_lifecycle_refs",
    "precedent_selection_refs",
    "precedent_conflict_refs",
    "override_governance_refs"
  ],
  "properties": {
    "summary_id": {
      "type": "string",
      "pattern": "^BSR-[A-F0-9]{12}$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.13.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "what_ran": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "what_changed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "what_failed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "run_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "stop_reason",
        "has_blockers"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "blocked"
          ]
        },
        "stop_reason": {
          "type": "string",
          "enum": [
            "max_batches_reached",
            "hard_gate_stop",
            "authorization_block",
            "authorization_freeze",
            "missing_required_signal",
            "execution_blocked",
            "execution_failed",
            "loop_validation_failed",
            "replay_not_ready",
            "invalid_roadmap_state",
            "invalid_progress_state",
            "contract_precondition_failed",
            "no_eligible_batch",
            "diminishing_returns_detected",
            "repeated_failure_pattern",
            "unresolved_blocker_persists",
            "risk_accumulation_threshold_exceeded",
            "control_block",
            "control_freeze",
            "program_blocking_condition",
            "program_priority_violation",
            "program_alignment_invalid",
            "program_drift_detected",
            "eval_health_degraded",
            "manual_review_required"
          ]
        },
        "has_blockers": {
          "type": "boolean"
        }
      }
    },
    "watch_next": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "artifact_index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "roadmap_multi_batch_run_result",
        "core_system_integration_validation",
        "next_step_recommendation",
        "trace_id",
        "replay_refs",
        "upstream_refs",
        "downstream_refs",
        "related_artifacts",
        "next_cycle_decision",
        "next_cycle_input_bundle"
      ],
      "properties": {
        "roadmap_multi_batch_run_result": {
          "type": "string",
          "minLength": 3
        },
        "core_system_integration_validation": {
          "type": "string",
          "minLength": 3
        },
        "next_step_recommendation": {
          "type": "string",
          "minLength": 3
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trace-[A-Za-z0-9._:-]+$"
        },
        "replay_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "upstream_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "downstream_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "related_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "next_cycle_decision": {
          "type": "string",
          "pattern": "^next_cycle_decision:NCD-[A-F0-9]{12}$"
        },
        "next_cycle_input_bundle": {
          "type": "string",
          "pattern": "^next_cycle_input_bundle:NCB-[A-F0-9]{12}$"
        }
      }
    },
    "failure_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stop_reason",
        "root_cause",
        "root_cause_chain",
        "next_action",
        "blocker_refs",
        "source_refs"
      ],
      "properties": {
        "stop_reason": {
          "type": "string",
          "enum": [
            "max_batches_reached",
            "hard_gate_stop",
            "authorization_block",
            "authorization_freeze",
            "missing_required_signal",
            "execution_blocked",
            "execution_failed",
            "loop_validation_failed",
            "replay_not_ready",
            "invalid_roadmap_state",
            "invalid_progress_state",
            "contract_precondition_failed",
            "no_eligible_batch",
            "diminishing_returns_detected",
            "repeated_failure_pattern",
            "unresolved_blocker_persists",
            "risk_accumulation_threshold_exceeded",
            "control_block",
            "control_freeze",
            "program_blocking_condition",
            "program_priority_violation",
            "program_alignment_invalid",
            "program_drift_detected",
            "eval_health_degraded",
            "manual_review_required"
          ]
        },
        "root_cause": {
          "type": "string",
          "minLength": 3
        },
        "root_cause_chain": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "step",
              "reason"
            ],
            "properties": {
              "step": {
                "type": "string",
                "minLength": 3
              },
              "reason": {
                "type": "string",
                "minLength": 3
              }
            }
          }
        },
        "next_action": {
          "type": "string",
          "minLength": 3
        },
        "blocker_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        }
      }
    },
    "trace_navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "execution_path",
        "decision_points",
        "influencing_artifacts",
        "layer_transitions",
        "replay_entry_points",
        "replay_ready"
      ],
      "properties": {
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "execution_path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "decision_points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "influencing_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "layer_transitions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[A-Z]+->[A-Z]+$"
          },
          "uniqueItems": true
        },
        "replay_entry_points": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "replay_from_context",
            "replay_from_plan",
            "replay_from_execution",
            "replay_from_failure"
          ],
          "properties": {
            "replay_from_context": {
              "$ref": "#/$defs/replay_entry_point"
            },
            "replay_from_plan": {
              "$ref": "#/$defs/replay_entry_point"
            },
            "replay_from_execution": {
              "$ref": "#/$defs/replay_entry_point"
            },
            "replay_from_failure": {
              "$ref": "#/$defs/replay_entry_point"
            }
          }
        },
        "replay_ready": {
          "type": "boolean"
        }
      }
    },
    "replay_entry_points": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replay_from_context",
        "replay_from_plan",
        "replay_from_execution",
        "replay_from_failure"
      ],
      "properties": {
        "replay_from_context": {
          "$ref": "#/$defs/replay_entry_point"
        },
        "replay_from_plan": {
          "$ref": "#/$defs/replay_entry_point"
        },
        "replay_from_execution": {
          "$ref": "#/$defs/replay_entry_point"
        },
        "replay_from_failure": {
          "$ref": "#/$defs/replay_entry_point"
        }
      }
    },
    "quick_links": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace-[A-Za-z0-9._:-]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "continuation_decision": {
      "type": "string",
      "enum": [
        "continue",
        "stop",
        "escalate"
      ]
    },
    "stop_reason": {
      "type": "string",
      "enum": [
        "max_batches_reached",
        "hard_gate_stop",
        "authorization_block",
        "authorization_freeze",
        "missing_required_signal",
        "execution_blocked",
        "execution_failed",
        "loop_validation_failed",
        "replay_not_ready",
        "invalid_roadmap_state",
        "invalid_progress_state",
        "contract_precondition_failed",
        "no_eligible_batch",
        "diminishing_returns_detected",
        "repeated_failure_pattern",
        "unresolved_blocker_persists",
        "risk_accumulation_threshold_exceeded",
        "control_block",
        "control_freeze",
        "program_blocking_condition",
        "program_priority_violation",
        "program_alignment_invalid",
        "program_drift_detected",
        "eval_health_degraded",
        "manual_review_required"
      ]
    },
    "next_batch_candidate": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^BATCH-[A-Z]$"
    },
    "execution_path_type": {
      "type": "string",
      "enum": [
        "positive_path",
        "negative_path"
      ]
    },
    "program_alignment_status": {
      "type": "string",
      "enum": [
        "aligned",
        "misaligned"
      ]
    },
    "program_stop_cause": {
      "type": "string",
      "enum": [
        "none",
        "program_alignment_invalid",
        "program_priority_violation",
        "program_blocking_condition",
        "program_drift_detected"
      ]
    },
    "program_drift_severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "next_cycle_decision": {
      "type": "string",
      "enum": [
        "run_next_cycle",
        "stop",
        "escalate"
      ]
    },
    "next_cycle_decision_reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "healthy_aligned_progress",
          "block_or_freeze_state",
          "program_misalignment",
          "program_drift_high",
          "missing_required_artifacts",
          "repeated_failure_threshold_exceeded",
          "eval_health_degraded",
          "manual_review_required",
          "roadmap_not_ready",
          "no_remaining_batch"
        ]
      },
      "uniqueItems": true
    },
    "autonomy_decision": {
      "type": "string",
      "enum": [
        "continue",
        "stop",
        "require_human_review",
        "escalate"
      ]
    },
    "autonomy_reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "autonomy_decision_ref": {
      "type": "string",
      "pattern": "^autonomy_decision_record:ADR-[A-F0-9]{12}$"
    },
    "next_cycle_inputs_ref": {
      "type": "string",
      "pattern": "^next_cycle_input_bundle:NCB-[A-F0-9]{12}$"
    },
    "exception_class": {
      "type": "string",
      "enum": [
        "missing_eval_coverage",
        "missing_required_eval_result",
        "indeterminate_required_eval",
        "replay_mismatch",
        "review_required",
        "autonomy_blocked",
        "program_misalignment",
        "drift_detected",
        "unresolved_critical_risk",
        "policy_violation",
        "execution_failure",
        "unknown_blocker"
      ]
    },
    "recommended_exception_action": {
      "type": "string",
      "enum": [
        "create_eval_coverage_work",
        "re_run_or_remediate_eval_path",
        "freeze_and_investigate",
        "freeze_and_replay_investigation",
        "queue_review",
        "require_human_review",
        "roadmap_adjustment",
        "remediation_batch",
        "escalate"
      ]
    },
    "exception_action_type": {
      "type": "string",
      "enum": [
        "create_remediation_batch",
        "create_eval_batch",
        "queue_review",
        "freeze_and_investigate",
        "escalate",
        "adjust_roadmap",
        "stop_without_auto_action"
      ]
    },
    "exception_requires_human_review": {
      "type": "boolean"
    },
    "exception_requires_freeze": {
      "type": "boolean"
    },
    "capability_readiness_state": {
      "type": "string",
      "enum": [
        "unsafe",
        "constrained",
        "supervised",
        "autonomous"
      ]
    },
    "capability_readiness_ref": {
      "type": "string",
      "pattern": "^capability_readiness_record:CRD-[A-F0-9]{12}$"
    },
    "decision_proof_ref": {
      "type": "string",
      "pattern": "^decision_proof_record:DPR-[A-F0-9]{12}$"
    },
    "allow_decision_proof_ref": {
      "type": "string",
      "pattern": "^allow_decision_proof:ADP-[A-F0-9]{12}$"
    },
    "unknown_state_signal_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^unknown_state_signal:USS-[A-F0-9]{12}$"
      },
      "uniqueItems": true
    },
    "unknown_state_blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "failure_taxonomy_ref": {
      "type": "string",
      "pattern": "^failure_taxonomy_record:FTX-[A-F0-9]{12}$"
    },
    "correction_pattern_ref": {
      "type": "string",
      "pattern": "^correction_pattern_record:CPR-[A-F0-9]{12}$"
    },
    "rollback_plan_ref": {
      "type": "string",
      "pattern": "^rollback_plan_record:RBP-[A-F0-9]{12}$"
    },
    "promotion_consistency_ref": {
      "type": "string",
      "pattern": "^promotion_consistency_record:PCR-[A-F0-9]{12}$"
    },
    "system_budget_status_ref": {
      "type": "string",
      "pattern": "^system_budget_status:SBS-[A-F0-9]{12}$"
    },
    "canary_rollout_ref": {
      "type": "string",
      "pattern": "^canary_rollout_record:CNR-[A-F0-9]{12}$"
    },
    "continuous_eval_run_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^continuous_eval_run_record:CER-[A-F0-9]{12}$"
      },
      "minItems": 4,
      "uniqueItems": true
    },
    "trust_posture_snapshot_ref": {
      "type": "string",
      "pattern": "^trust_posture_snapshot:TPS-[A-F0-9]{12}$"
    },
    "artifact_family_health_report_ref": {
      "type": "string",
      "pattern": "^artifact_family_health_report:AFH-[A-F0-9]{12}$"
    },
    "evidence_gap_hotspot_report_ref": {
      "type": "string",
      "pattern": "^evidence_gap_hotspot_report:EGH-[A-F0-9]{12}$"
    },
    "override_hotspot_report_ref": {
      "type": "string",
      "pattern": "^override_hotspot_report:OVH-[A-F0-9]{12}$"
    },
    "judgment_lifecycle_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^judgment_lifecycle_record:JLC-[A-F0-9]{12}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "precedent_selection_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^precedent_selection_record:PSL-[A-F0-9]{12}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "precedent_conflict_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^precedent_conflict_record:PCF-[A-F0-9]{12}$"
      },
      "uniqueItems": true
    },
    "override_governance_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^override_governance_record:OVG-[A-F0-9]{12}$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "decision_quality_budget_ref": {
      "type": "string",
      "pattern": "^decision_quality_budget_status:DQB-[A-F0-9]{12}$"
    },
    "calibration_assessment_ref": {
      "type": "string",
      "pattern": "^calibration_assessment_record:CAL-[A-F0-9]{12}$"
    },
    "judgment_promotion_gate_ref": {
      "type": "string",
      "pattern": "^judgment_promotion_gate_record:JPG-[A-F0-9]{12}$"
    }
  },
  "$defs": {
    "replay_entry_point": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_artifacts",
        "trace_refs"
      ],
      "properties": {
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        },
        "trace_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          },
          "uniqueItems": true
        }
      }
    }
  }
}
