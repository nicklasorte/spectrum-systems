      "type": "string"
    },
    "artifact_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "recipe_id": {
      "type": "string"
    },
    "artifact_family": {
      "type": "string"
    },
    "strict_mode": {
      "type": "boolean"
    },
    "required_sources": {
