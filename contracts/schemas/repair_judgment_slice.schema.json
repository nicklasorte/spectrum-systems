{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/repair_judgment_slice.schema.json",
  "title": "Repair Judgment Slice",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "schema_version", "judgment_id", "trace_id", "selected_candidate_ref", "selected_eval_ref", "bounded_outcome", "rationale_codes", "non_authority_assertions"],
  "properties": {
    "artifact_type": {"const": "repair_judgment_slice"},
    "schema_version": {"const": "1.0.0"},
    "judgment_id": {"type": "string", "pattern": "^fre-judge-[a-f0-9]{16}$"},
    "trace_id": {"type": "string", "minLength": 1},
    "selected_candidate_ref": {"type": "string", "pattern": "^repair_candidate:.+"},
    "selected_eval_ref": {"type": "string", "pattern": "^repair_eval_result:.+"},
    "bounded_outcome": {"type": "string", "enum": ["candidate_selected", "candidate_rejected"]},
    "rationale_codes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "non_authority_assertions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
