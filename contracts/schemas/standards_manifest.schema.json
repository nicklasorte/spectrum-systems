{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/standards_manifest.schema.json",
  "title": "Standards Manifest",
  "description": "Registry of contract schemas, versions, and stability state published by Spectrum Systems.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "record_id",
    "run_id",
    "created_at",
    "created_by",
    "source_repo",
    "source_repo_version",
    "contracts"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "standards_manifest",
      "description": "Canonical artifact type identifier."
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^STD-[A-Z0-9._-]+$",
      "description": "Stable identifier for this manifest instance."
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version of this manifest instance."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the standards_manifest schema."
    },
    "standards_version": {
      "type": "string",
      "const": "2026.03.0",
      "description": "Published standards release represented by this manifest."
    },
    "record_id": {
      "type": "string",
      "pattern": "^REC-[A-Z0-9._-]+$",
      "description": "Record identifier used for provenance and diffing."
    },
    "run_id": {
      "type": "string",
      "pattern": "^run-[A-Za-z0-9._-]+$",
      "description": "Deterministic run identifier for the workflow that produced this record."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this manifest was generated."
    },
    "created_by": {
      "$ref": "#/$defs/created_by"
    },
    "source_repo": {
      "type": "string",
      "description": "Repository slug that produced this manifest."
    },
    "source_repo_version": {
      "type": "string",
      "description": "Tag or commit hash of the source repository."
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/contract_entry"
      },
      "description": "Published contract schemas and their stability state."
    },
    "input_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input_artifact"
      },
      "description": "Upstream manifests or artifacts used to generate this manifest."
    }
  },
  "$defs": {
    "created_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "agent_type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "agent_type": {
          "type": "string",
          "enum": [
            "human",
            "ai_model",
            "workflow",
            "script"
          ]
        },
        "organization": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "input_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "artifact_version",
        "role"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^[A-Z0-9._-]+$"
        },
        "artifact_type": {
          "type": "string"
        },
        "artifact_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "role": {
          "type": "string"
        },
        "source_repo": {
          "type": "string"
        },
        "source_repo_version": {
          "type": "string"
        }
      }
    },
    "contract_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "artifact_class",
        "schema_version",
        "status",
        "intended_consumers",
        "introduced_in"
      ],
      "properties": {
        "artifact_type": {
          "type": "string"
        },
        "artifact_class": {
          "type": "string",
          "enum": [
            "coordination",
            "work",
            "review",
            "governance"
          ],
          "description": "Canonical artifact class for this contract."
        },
        "schema_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "stable",
            "deprecated"
          ]
        },
        "intended_consumers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "introduced_in": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "Manifest version when this contract was first published."
        },
        "last_updated_in": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
          "description": "Manifest version that last changed this contract."
        },
        "notes": {
          "type": "string"
        },
        "example_path": {
          "type": "string"
        }
      }
    }
  }
}
