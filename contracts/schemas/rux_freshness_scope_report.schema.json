{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/rux_freshness_scope_report.schema.json",
  "title": "rux_freshness_scope_report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "reuse_ref",
    "freshness_ok",
    "scope_ok",
    "active_set_ok",
    "reason_codes"
  ],
  "properties": {
    "artifact_type": {
      "const": "rux_freshness_scope_report"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "reuse_ref": {
      "type": "string"
    },
    "freshness_ok": {
      "type": "boolean"
    },
    "scope_ok": {
      "type": "boolean"
    },
    "active_set_ok": {
      "type": "boolean"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
