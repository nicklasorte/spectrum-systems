{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/rep_replayability_gap_explainer_result.schema.json",
  "title": "rep_replayability_gap_explainer_result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "status",
    "missing_prerequisites",
    "gap_explanation"
  ],
  "properties": {
    "artifact_type": {
      "const": "rep_replayability_gap_explainer_result"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "REP"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "missing_prerequisites": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gap_explanation": {
      "type": "string"
    }
  }
}
