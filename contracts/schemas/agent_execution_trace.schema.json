{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/agent_execution_trace.schema.json",
  "title": "Agent Execution Trace",
  "description": "Governed bounded-execution trace artifact for agent step execution with replay-compatible tool and step logging.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_run_id",
    "context_bundle_id",
    "context_source_summary",
    "trace_id",
    "routing_decision",
    "prompt_resolution",
    "step_sequence",
    "tool_calls",
    "model_invocations",
    "intermediate_artifacts",
    "multi_pass_generation",
    "final_output_artifact_id",
    "execution_status",
    "failure_reason",
    "started_at",
    "completed_at"
  ],
  "properties": {
    "agent_run_id": {
      "type": "string",
      "minLength": 1
    },
    "context_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "step_sequence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "step_type",
          "status"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "step_type": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "completed",
              "failed",
              "blocked"
            ]
          },
          "input_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "output_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "error": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "tool_name",
          "input_ref",
          "output_ref",
          "status"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "tool_name": {
            "type": "string",
            "minLength": 1
          },
          "input_ref": {
            "type": "string",
            "minLength": 1
          },
          "output_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "completed",
              "failed",
              "blocked"
            ]
          },
          "error": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "intermediate_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "artifact_type",
          "schema_name"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "artifact_type": {
            "type": "string",
            "minLength": 1
          },
          "schema_name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "final_output_artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_status": {
      "type": "string",
      "enum": [
        "completed",
        "failed",
        "blocked"
      ]
    },
    "failure_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "prompt_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_id",
        "prompt_version",
        "requested_alias",
        "resolution_source",
        "status"
      ],
      "properties": {
        "prompt_id": {
          "type": "string",
          "minLength": 1
        },
        "prompt_version": {
          "type": "string",
          "minLength": 1
        },
        "requested_alias": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "resolution_source": {
          "type": "string",
          "enum": [
            "prompt_alias_map"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "resolved"
          ]
        }
      }
    },
    "model_invocations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "request_id",
          "response_id",
          "requested_model_id",
          "provider_name",
          "provider_model_name",
          "response_status",
          "finish_reason",
          "structured_generation_mode",
          "structured_target_schema_ref",
          "structured_enforcement_path",
          "structured_output_status"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "request_id": {
            "type": "string",
            "pattern": "^amr-[a-f0-9]{16}$"
          },
          "response_id": {
            "type": "string",
            "pattern": "^amres-[a-f0-9]{16}$"
          },
          "requested_model_id": {
            "type": "string",
            "minLength": 1
          },
          "provider_name": {
            "type": "string",
            "minLength": 1
          },
          "provider_model_name": {
            "type": "string",
            "minLength": 1
          },
          "response_status": {
            "type": "string",
            "enum": [
              "completed",
              "failed"
            ]
          },
          "finish_reason": {
            "type": "string",
            "enum": [
              "stop",
              "length",
              "content_filter",
              "error"
            ]
          },
          "structured_generation_mode": {
            "type": "string",
            "enum": [
              "unstructured",
              "provider_native_strict",
              "adapter_json_schema_strict"
            ]
          },
          "structured_target_schema_ref": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
          },
          "structured_enforcement_path": {
            "type": "string",
            "enum": [
              "none",
              "provider_native",
              "adapter_json_schema"
            ]
          },
          "structured_output_status": {
            "type": "string",
            "enum": [
              "not_requested",
              "succeeded",
              "failed"
            ]
          }
        }
      }
    },
    "routing_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "routing_decision_id",
        "policy_id",
        "route_key",
        "task_class",
        "selected_model_id"
      ],
      "properties": {
        "routing_decision_id": {
          "type": "string",
          "pattern": "^rd-[a-f0-9]{16}$"
        },
        "policy_id": {
          "type": "string",
          "pattern": "^rp-[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "route_key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "task_class": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "selected_model_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9:_./-]{2,127}$"
        }
      }
    },
    "context_source_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classification_counts",
        "item_refs_by_class",
        "inferred_item_refs",
        "glossary_entry_refs",
        "glossary_definition_item_refs",
        "glossary_injection_enabled",
        "glossary_unresolved_terms",
        "glossary_fail_on_missing_required",
        "prompt_injection"
      ],
      "properties": {
        "classification_counts": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "internal",
            "external",
            "inferred",
            "user_provided"
          ],
          "properties": {
            "internal": {
              "type": "integer",
              "minimum": 0
            },
            "external": {
              "type": "integer",
              "minimum": 0
            },
            "inferred": {
              "type": "integer",
              "minimum": 0
            },
            "user_provided": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "item_refs_by_class": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "internal",
            "external",
            "inferred",
            "user_provided"
          ],
          "properties": {
            "internal": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^ctxi-[a-f0-9]{16}$"
              }
            },
            "external": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^ctxi-[a-f0-9]{16}$"
              }
            },
            "inferred": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^ctxi-[a-f0-9]{16}$"
              }
            },
            "user_provided": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^ctxi-[a-f0-9]{16}$"
              }
            }
          }
        },
        "inferred_item_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ctxi-[a-f0-9]{16}$"
          }
        },
        "glossary_entry_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^gle-[a-f0-9]{16}$"
          }
        },
        "glossary_definition_item_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ctxi-[a-f0-9]{16}$"
          }
        },
        "glossary_injection_enabled": {
          "type": "boolean"
        },
        "glossary_unresolved_terms": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "glossary_fail_on_missing_required": {
          "type": "boolean"
        },
        "prompt_injection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "assessment_id",
            "detection_status",
            "enforcement_action",
            "policy_id",
            "flagged_item_refs",
            "detected_pattern_refs"
          ],
          "properties": {
            "assessment_id": {
              "type": "string",
              "pattern": "^pia-[a-f0-9]{16}$"
            },
            "detection_status": {
              "type": "string",
              "enum": [
                "clean",
                "suspicious"
              ]
            },
            "enforcement_action": {
              "type": "string",
              "enum": [
                "allow_as_data",
                "quarantine",
                "block_bundle"
              ]
            },
            "policy_id": {
              "type": "string",
              "minLength": 1
            },
            "flagged_item_refs": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^ctxi-[a-f0-9]{16}$"
              }
            },
            "detected_pattern_refs": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^pi-[a-z0-9-]+:ctxi-[a-f0-9]{16}$"
              }
            }
          }
        }
      }
    },
    "multi_pass_generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "pass_ids",
        "pass_output_refs",
        "evidence_binding_record_id",
        "evidence_binding_claim_ids",
        "evidence_binding_policy_mode",
        "grounding_factcheck_eval_id",
        "grounding_factcheck_overall_status",
        "grounding_factcheck_failure_classes",
        "grounding_control_decision"
      ],
      "properties": {
        "record_id": {
          "type": "string"
        },
        "pass_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "pass_1",
              "pass_2",
              "pass_3",
              "final"
            ]
          }
        },
        "pass_output_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_binding_record_id": {
          "type": "string"
        },
        "evidence_binding_claim_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ebc-[a-f0-9]{16}$"
          }
        },
        "evidence_binding_policy_mode": {
          "type": "string"
        },
        "grounding_factcheck_eval_id": {
          "type": "string"
        },
        "grounding_factcheck_overall_status": {
          "type": "string",
          "enum": [
            "",
            "pass",
            "warn",
            "fail"
          ]
        },
        "grounding_factcheck_failure_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "fact_check_fail",
              "semantic_error",
              "evidence_mismatch",
              "unsupported_grounded_claim",
              "incomplete_grounding"
            ]
          },
          "uniqueItems": true
        },
        "grounding_control_decision": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "decision_id",
            "status",
            "enforcement_action",
            "triggered_rules"
          ],
          "properties": {
            "decision_id": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "",
                "pass",
                "warn",
                "block"
              ]
            },
            "enforcement_action": {
              "type": "string",
              "enum": [
                "",
                "allow",
                "flag",
                "block_execution"
              ]
            },
            "triggered_rules": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "execution_status": {
            "enum": [
              "failed",
              "blocked"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "failure_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
