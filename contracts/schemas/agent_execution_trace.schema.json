{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/agent_execution_trace.schema.json",
  "title": "Agent Execution Trace",
  "description": "Governed bounded-execution trace artifact for agent step execution with replay-compatible tool and step logging.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_run_id",
    "context_bundle_id",
    "trace_id",
    "routing_decision",
    "prompt_resolution",
    "step_sequence",
    "tool_calls",
    "model_invocations",
    "intermediate_artifacts",
    "final_output_artifact_id",
    "execution_status",
    "failure_reason",
    "started_at",
    "completed_at"
  ],
  "properties": {
    "agent_run_id": {
      "type": "string",
      "minLength": 1
    },
    "context_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "step_sequence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "step_type",
          "status"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "step_type": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "completed",
              "failed",
              "blocked"
            ]
          },
          "input_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "output_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "error": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "tool_name",
          "input_ref",
          "output_ref",
          "status"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "tool_name": {
            "type": "string",
            "minLength": 1
          },
          "input_ref": {
            "type": "string",
            "minLength": 1
          },
          "output_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "completed",
              "failed",
              "blocked"
            ]
          },
          "error": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "intermediate_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_id",
          "artifact_type",
          "schema_name"
        ],
        "properties": {
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "artifact_type": {
            "type": "string",
            "minLength": 1
          },
          "schema_name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "final_output_artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_status": {
      "type": "string",
      "enum": [
        "completed",
        "failed",
        "blocked"
      ]
    },
    "failure_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "prompt_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_id",
        "prompt_version",
        "requested_alias",
        "resolution_source",
        "status"
      ],
      "properties": {
        "prompt_id": {
          "type": "string",
          "minLength": 1
        },
        "prompt_version": {
          "type": "string",
          "minLength": 1
        },
        "requested_alias": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "resolution_source": {
          "type": "string",
          "enum": [
            "prompt_alias_map"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "resolved"
          ]
        }
      }
    },
    "model_invocations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "request_id",
          "response_id",
          "requested_model_id",
          "provider_name",
          "provider_model_name",
          "response_status",
          "finish_reason",
          "structured_generation_mode",
          "structured_target_schema_ref",
          "structured_enforcement_path",
          "structured_output_status"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "request_id": {
            "type": "string",
            "pattern": "^amr-[a-f0-9]{16}$"
          },
          "response_id": {
            "type": "string",
            "pattern": "^amres-[a-f0-9]{16}$"
          },
          "requested_model_id": {
            "type": "string",
            "minLength": 1
          },
          "provider_name": {
            "type": "string",
            "minLength": 1
          },
          "provider_model_name": {
            "type": "string",
            "minLength": 1
          },
          "response_status": {
            "type": "string",
            "enum": [
              "completed",
              "failed"
            ]
          },
          "finish_reason": {
            "type": "string",
            "enum": [
              "stop",
              "length",
              "content_filter",
              "error"
            ]
          },
          "structured_generation_mode": {
            "type": "string",
            "enum": [
              "unstructured",
              "provider_native_strict",
              "adapter_json_schema_strict"
            ]
          },
          "structured_target_schema_ref": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
          },
          "structured_enforcement_path": {
            "type": "string",
            "enum": [
              "none",
              "provider_native",
              "adapter_json_schema"
            ]
          },
          "structured_output_status": {
            "type": "string",
            "enum": [
              "not_requested",
              "succeeded",
              "failed"
            ]
          }
        }
      }
    },
    "routing_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "routing_decision_id",
        "policy_id",
        "route_key",
        "task_class",
        "selected_model_id"
      ],
      "properties": {
        "routing_decision_id": {
          "type": "string",
          "pattern": "^rd-[a-f0-9]{16}$"
        },
        "policy_id": {
          "type": "string",
          "pattern": "^rp-[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "route_key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "task_class": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
        },
        "selected_model_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9:_./-]{2,127}$"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "execution_status": {
            "enum": [
              "failed",
              "blocked"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "failure_reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
