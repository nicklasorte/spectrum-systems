{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum.systems/contracts/schemas/evidence_map.schema.json",
  "title": "Evidence Map",
  "allOf": [
    {"$ref": "strategic_knowledge_artifact_ref.schema.json"},
    {
      "type": "object",
      "unevaluatedProperties": false,
      "required": ["artifact_type", "claim_id", "claim_text", "evidence_anchors"],
      "properties": {
        "artifact_type": {"const": "evidence_map"},
        "claim_id": {"type": "string", "minLength": 1},
        "claim_text": {"type": "string", "minLength": 1},
        "evidence_anchors": {
          "type": "array",
          "items": {"$ref": "strategic_knowledge_artifact_ref.schema.json#/$defs/evidence_anchor"},
          "minItems": 1
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      }
    }
  ]
}
