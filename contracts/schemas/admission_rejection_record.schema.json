{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/admission_rejection_record.schema.json",
  "title": "Admission Rejection Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "rejection_id",
    "request_id",
    "trace_id",
    "created_at",
    "rejection_reason_codes",
    "rejection_summary",
    "produced_by"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "admission_rejection_record"},
    "rejection_id": {"type": "string", "minLength": 1},
    "request_id": {"type": "string", "minLength": 1},
    "trace_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "rejection_reason_codes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "rejection_summary": {"type": "string", "minLength": 1},
    "produced_by": {"type": "string", "minLength": 1}
  }
}
