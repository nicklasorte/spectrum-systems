{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/dag_cycle_deadlock_report.schema.json",
  "title": "dag_cycle_deadlock_report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "graph_ref",
    "has_cycle",
    "deadlock_nodes",
    "status"
  ],
  "properties": {
    "artifact_type": {
      "const": "dag_cycle_deadlock_report"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "graph_ref": {
      "type": "string"
    },
    "has_cycle": {
      "type": "boolean"
    },
    "deadlock_nodes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    }
  }
}
