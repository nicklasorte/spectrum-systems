{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pra_system_impact_mapping_record.schema.json",
  "title": "pra_system_impact_mapping_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "pr_number",
    "impacted_systems",
    "mapping_basis",
    "review_risk_tags"
  ],
  "properties": {
    "artifact_type": {
      "const": "pra_system_impact_mapping_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "PRA"
    },
    "pr_number": {
      "type": "integer"
    },
    "impacted_systems": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mapping_basis": {
      "type": "string"
    },
    "review_risk_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
