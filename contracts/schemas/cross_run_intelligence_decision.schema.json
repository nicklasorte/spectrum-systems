{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum.systems/contracts/cross_run_intelligence_decision.schema.json",
  "title": "Cross-Run Intelligence Decision",
  "description": "Governed decision artifact produced by BF. Summarises overall comparison status, failure classification, and actionable findings for decision support.",
  "type": "object",
  "required": [
    "artifact_type",
    "schema_version",
    "decision_id",
    "comparison_id",
    "overall_status",
    "failure_type",
    "findings",
    "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "artifact_type": {
      "type": "string",
      "description": "Must equal cross_run_intelligence_decision.",
      "const": "cross_run_intelligence_decision"
    },
    "schema_version": {
      "type": "string",
      "description": "Semantic version of this schema.",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "decision_id": {
      "type": "string",
      "description": "Unique identifier for this decision artifact.",
      "pattern": "^CRI-[A-Z0-9][A-Z0-9._-]*$"
    },
    "comparison_id": {
      "type": "string",
      "description": "The comparison_id of the cross_run_comparison this decision is based on.",
      "pattern": "^CMP-[A-Z0-9][A-Z0-9._-]*$"
    },
    "overall_status": {
      "type": "string",
      "description": "Overall comparison status.",
      "enum": ["pass", "warning", "fail"]
    },
    "failure_type": {
      "type": "string",
      "description": "Governing failure classification. none when overall_status is pass.",
      "enum": [
        "none",
        "no_inputs",
        "malformed_input",
        "schema_invalid",
        "mixed_study_types",
        "no_comparable_metrics",
        "comparison_error",
        "anomaly_detection_error"
      ]
    },
    "findings": {
      "type": "array",
      "description": "Ordered list of findings surfaced during comparison.",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message", "artifact_path"],
        "additionalProperties": false,
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "error"]
          },
          "message": { "type": "string" },
          "artifact_path": { "type": "string" }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 date-time when this artifact was generated.",
      "format": "date-time"
    }
  }
}
