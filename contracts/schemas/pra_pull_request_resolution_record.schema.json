{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pra_pull_request_resolution_record.schema.json",
  "title": "pra_pull_request_resolution_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "repo_name",
    "selection_mode",
    "override_used",
    "selected_pr_reason",
    "pr_number",
    "pr_url",
    "base_sha",
    "head_sha",
    "state"
  ],
  "properties": {
    "artifact_type": {
      "const": "pra_pull_request_resolution_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "PRA"
    },
    "repo_name": {
      "type": "string"
    },
    "selection_mode": {
      "type": "string",
      "enum": [
        "default_latest",
        "override"
      ]
    },
    "override_used": {
      "type": "boolean"
    },
    "selected_pr_reason": {
      "type": "string"
    },
    "pr_number": {
      "type": "integer",
      "minimum": 0
    },
    "pr_url": {
      "type": "string"
    },
    "base_sha": {
      "type": "string"
    },
    "head_sha": {
      "type": "string"
    },
    "state": {
      "type": "string"
    }
  }
}
