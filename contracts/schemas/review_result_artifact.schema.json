{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/review_result_artifact.schema.json",
  "title": "Review Result Artifact",
  "description": "Structured bounded RQX review result used to generate repo-native markdown review artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "standards_version",
    "review_id",
    "review_name",
    "review_type",
    "scope",
    "files_inspected",
    "findings",
    "verdict",
    "rationale",
    "required_follow_up",
    "source_review_request_ref",
    "generated_at",
    "bounded_review",
    "automatic_fix_execution"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "review_result_artifact"},
    "artifact_version": {"type": "string", "const": "1.0.0"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "standards_version": {"type": "string", "const": "1.0.0"},
    "review_id": {"type": "string", "minLength": 1},
    "review_name": {"type": "string", "pattern": "^[a-z0-9._-]+$"},
    "review_type": {
      "type": "string",
      "enum": [
        "code_path_review",
        "architecture_boundary_review",
        "contract_surface_review",
        "trust_boundary_review"
      ]
    },
    "scope": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "batch_id": {"type": "string", "minLength": 1},
    "files_inspected": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "title",
          "severity",
          "evidence",
          "why_it_matters"
        ],
        "properties": {
          "finding_id": {"type": "string", "pattern": "^F-[0-9]+$"},
          "title": {"type": "string", "minLength": 1},
          "severity": {"type": "string", "enum": ["blocker", "high", "medium", "low"]},
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "why_it_matters": {"type": "string", "minLength": 1}
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["safe_to_merge", "fix_required", "not_safe_to_merge"]
    },
    "rationale": {"type": "string", "minLength": 1},
    "required_follow_up": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "source_review_request_ref": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "bounded_review": {"type": "boolean", "const": true},
    "automatic_fix_execution": {"type": "string", "const": "disabled"}
  },
  "anyOf": [
    {"required": ["run_id"]},
    {"required": ["batch_id"]}
  ]
}
