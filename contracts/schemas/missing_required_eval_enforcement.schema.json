{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/missing_required_eval_enforcement.schema.json",
  "title": "missing_required_eval_enforcement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "enforcement_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "artifact_family",
    "decision",
    "reason_code",
    "blocking_reasons",
    "coverage_signal_ref",
    "trace",
    "created_at"
  ],
  "properties": {
    "artifact_type": {"const": "missing_required_eval_enforcement"},
    "enforcement_id": {"type": "string", "pattern": "^MRE-[A-Z0-9-]+$"},
    "artifact_version": {"type": "string", "pattern": "^1\\.0\\.0$"},
    "schema_version": {"type": "string", "pattern": "^1\\.0\\.0$"},
    "standards_version": {"type": "string", "minLength": 1},
    "artifact_family": {"type": "string", "minLength": 1},
    "decision": {"type": "string", "enum": ["allow", "block", "freeze"]},
    "reason_code": {
      "type": "string",
      "enum": ["none", "missing_required_eval_mapping", "missing_required_eval_definition", "missing_required_eval_result", "indeterminate_required_eval", "required_eval_failed"]
    },
    "blocking_reasons": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "coverage_signal_ref": {"type": "string", "minLength": 1},
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "run_id"],
      "properties": {
        "trace_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1}
      }
    },
    "created_at": {"type": "string", "format": "date-time"}
  }
}
