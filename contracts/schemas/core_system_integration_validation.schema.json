{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/core_system_integration_validation.schema.json",
  "title": "core_system_integration_validation",
  "description": "Governed cross-layer integration validation artifact proving PRG/RVW/CTX/TPA/MAP/RDX/control-certification coherence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "validation_id",
    "schema_version",
    "exercised_layers",
    "validation_scope",
    "determinism_status",
    "replay_status",
    "authority_boundary_status",
    "cross_layer_findings",
    "blocking_conditions",
    "deterministic_outcome",
    "replayability_fingerprint",
    "trace_navigation",
    "upstream_refs",
    "downstream_refs",
    "related_artifacts",
    "created_at",
    "trace_id",
    "source_refs"
  ],
  "properties": {
    "validation_id": {
      "type": "string",
      "minLength": 8
    },
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "exercised_layers": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["PRG", "RVW", "RPT", "CTX", "TPA", "MAP", "RDX", "CONTROL", "CERT"]
      }
    },
    "validation_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batch_id", "run_id", "mode"],
      "properties": {
        "batch_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "determinism_status": {
      "type": "string",
      "enum": ["deterministic", "non_deterministic"]
    },
    "replay_status": {
      "type": "string",
      "enum": ["replayable", "not_replayable"]
    },
    "authority_boundary_status": {
      "type": "string",
      "enum": ["bounded", "violated"]
    },
    "cross_layer_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message", "layer", "severity"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 3
          },
          "message": {
            "type": "string",
            "minLength": 3
          },
          "layer": {
            "type": "string",
            "enum": ["PRG", "RVW", "RPT", "CTX", "TPA", "MAP", "RDX", "CONTROL", "CERT"]
          },
          "severity": {
            "type": "string",
            "enum": ["warning", "error"]
          }
        }
      }
    },
    "blocking_conditions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "deterministic_outcome": {
      "type": "string",
      "enum": ["deterministic", "failed_closed"]
    },
    "replayability_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "trace_navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_id",
        "execution_path",
        "decision_points",
        "influencing_artifacts",
        "layer_transitions",
        "replay_entry_points",
        "replay_ready"
      ],
      "properties": {
        "trace_id": {"type": "string", "minLength": 1},
        "execution_path": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3}
        },
        "decision_points": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        },
        "influencing_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        },
        "layer_transitions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^[A-Z]+->[A-Z]+$"},
          "uniqueItems": true
        },
        "replay_entry_points": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "replay_from_context",
            "replay_from_plan",
            "replay_from_execution",
            "replay_from_failure"
          ],
          "properties": {
            "replay_from_context": {"$ref": "#/$defs/replay_entry_point"},
            "replay_from_plan": {"$ref": "#/$defs/replay_entry_point"},
            "replay_from_execution": {"$ref": "#/$defs/replay_entry_point"},
            "replay_from_failure": {"$ref": "#/$defs/replay_entry_point"}
          }
        },
        "replay_ready": {"type": "boolean"}
      }
    },
    "upstream_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 3},
      "uniqueItems": true
    },
    "downstream_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 3},
      "uniqueItems": true
    },
    "related_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 3},
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "required": [
        "program_artifact",
        "review_control_signal",
        "eval_result",
        "context_bundle_v2",
        "tpa_gate",
        "roadmap_execution_loop_validation",
        "roadmap_multi_batch_run_result",
        "control_decision",
        "certification_pack"
      ]
    }
  },
  "$defs": {
    "replay_entry_point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_artifacts", "trace_refs"],
      "properties": {
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        },
        "trace_refs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3},
          "uniqueItems": true
        }
      }
    }
  }
}
