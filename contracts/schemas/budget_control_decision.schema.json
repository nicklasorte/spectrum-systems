{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "budget_control_decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "decision_id",
    "run_id",
    "trace_id",
    "decision",
    "reason_codes",
    "status_ref"
  ],
  "properties": {
    "artifact_type": {
      "const": "budget_control_decision"
    },
    "artifact_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "decision_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "warn",
        "freeze",
        "block"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "status_ref": {
      "type": "string"
    }
  }
}
