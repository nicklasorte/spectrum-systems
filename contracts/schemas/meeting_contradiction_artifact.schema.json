{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/meeting_contradiction_artifact.schema.json",
  "title": "meeting_contradiction_artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "schema_version",
    "artifact_version",
    "standards_version",
    "run_id",
    "trace_id",
    "lineage_refs",
    "evidence_refs",
    "timestamp",
    "confidence",
    "ambiguity_flags",
    "contradiction",
    "severity"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 3
    },
    "schema_version": {
      "const": "1.1.0"
    },
    "artifact_version": {
      "const": "1.1.0"
    },
    "standards_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "lineage_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifact_type": {
      "const": "meeting_contradiction_artifact"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "ambiguity_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contradiction": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string"
    }
  }
}
