    },
    "schema_version": {
      "type": "string"
    },
    "standards_version": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "current_recommendation": {
      "type": "string"
    },
    "prior_recommendation": {
      "type": "string"
    },
    "what_changed": {
