{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/override_governance_record.schema.json",
  "title": "override_governance_record",
  "description": "Deterministic governed override lifecycle artifact enforcing ownership, expiry, review cadence, and escalation visibility.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "override_governance_id",
    "override_record_ref",
    "owner",
    "justification",
    "scope",
    "issued_at",
    "expires_at",
    "review_due_at",
    "outcome_tracking_status",
    "linked_decision_refs",
    "linked_artifact_refs",
    "escalation_state",
    "active",
    "created_at",
    "trace_id",
    "reason",
    "duration",
    "affected_artifacts",
    "override_type"
  ],
  "properties": {
    "override_governance_id": {
      "type": "string",
      "pattern": "^OVG-[A-F0-9]{12}$"
    },
    "override_record_ref": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "justification": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "review_due_at": {
      "type": "string",
      "format": "date-time"
    },
    "outcome_tracking_status": {
      "type": "string",
      "enum": [
        "pending",
        "observed",
        "resolved",
        "expired"
      ]
    },
    "linked_decision_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "linked_artifact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "escalation_state": {
      "type": "string",
      "enum": [
        "none",
        "warning",
        "freeze_candidate",
        "block"
      ]
    },
    "active": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "duration": {
      "type": "string",
      "minLength": 3
    },
    "affected_artifacts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "override_type": {
      "type": "string",
      "enum": [
        "bounded_bypass",
        "emergency_stop_release",
        "temporary_unblock"
      ]
    }
  }
}
