{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pqx_execution_eval_result.schema.json",
  "title": "Pqx Execution Eval Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "eval_id",
    "run_id",
    "trace_id",
    "slice_id",
    "status",
    "checks",
    "fail_reasons",
    "generated_at"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "pqx_execution_eval_result"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "eval_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "slice_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "checks": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "fail_reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
