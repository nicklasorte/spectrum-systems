{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/judgment_operator_remediation_record.schema.json",
  "title": "Judgment Operator Remediation Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "remediation_id",
    "source_escalation_record_id",
    "source_action_id",
    "source_outcome_id",
    "remediation_reason",
    "required_human_role",
    "required_evidence_artifacts",
    "status",
    "status_history",
    "trace",
    "created_at"
  ],
  "properties": {
    "artifact_type": {"const": "judgment_operator_remediation_record"},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "schema_version": {"type": "string", "const": "1.1.0"},
    "standards_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "remediation_id": {"type": "string", "minLength": 1},
    "source_escalation_record_id": {"type": "string", "minLength": 1},
    "source_action_id": {"type": "string", "minLength": 1},
    "source_outcome_id": {"type": "string", "minLength": 1},
    "remediation_reason": {"type": "string", "minLength": 1},
    "required_human_role": {"type": "string", "minLength": 1},
    "required_evidence_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "in_progress",
        "evidence_submitted",
        "pending_review",
        "approved_for_closure",
        "closed",
        "rejected"
      ]
    },
    "status_history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from_status", "to_status", "changed_at", "changed_by_role", "rationale"],
        "properties": {
          "from_status": {
            "type": "string",
            "enum": [
              "open",
              "in_progress",
              "evidence_submitted",
              "pending_review",
              "approved_for_closure",
              "closed",
              "rejected"
            ]
          },
          "to_status": {
            "type": "string",
            "enum": [
              "open",
              "in_progress",
              "evidence_submitted",
              "pending_review",
              "approved_for_closure",
              "closed",
              "rejected"
            ]
          },
          "changed_at": {"type": "string", "format": "date-time"},
          "changed_by_role": {"type": "string", "minLength": 1},
          "rationale": {"type": "string", "minLength": 1}
        }
      }
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "run_id", "source_escalation_record_id", "action_id", "outcome_id"],
      "properties": {
        "trace_id": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "source_escalation_record_id": {"type": "string", "minLength": 1},
        "action_id": {"type": "string", "minLength": 1},
        "outcome_id": {"type": "string", "minLength": 1}
      }
    },
    "created_at": {"type": "string", "format": "date-time"}
  }
}
