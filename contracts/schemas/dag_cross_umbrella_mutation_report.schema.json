{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "dag_cross_umbrella_mutation_report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "artifact_type",
    "schema_version",
    "artifact_id",
    "created_at",
    "owner",
    "status",
    "summary",
    "inputs"
  ],
  "properties": {
    "artifact_type": {
      "const": "dag_cross_umbrella_mutation_report"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 3
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "metrics": {
      "type": "object"
    },
    "authority_boundary": {
      "type": "string"
    }
  }
}
