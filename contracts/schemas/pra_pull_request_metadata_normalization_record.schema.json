{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pra_pull_request_metadata_normalization_record.schema.json",
  "title": "pra_pull_request_metadata_normalization_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "pr_number",
    "pr_url",
    "title",
    "body",
    "changed_files",
    "additions",
    "deletions",
    "mergeable",
    "ci_status",
    "failed_checks",
    "review_summaries",
    "created_at_pr",
    "updated_at_pr"
  ],
  "properties": {
    "artifact_type": {
      "const": "pra_pull_request_metadata_normalization_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "PRA"
    },
    "pr_number": {
      "type": "integer"
    },
    "pr_url": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "additions": {
      "type": "integer"
    },
    "deletions": {
      "type": "integer"
    },
    "mergeable": {
      "type": "boolean"
    },
    "ci_status": {
      "type": "string"
    },
    "failed_checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "author",
          "state",
          "summary"
        ],
        "properties": {
          "author": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "created_at_pr": {
      "type": "string"
    },
    "updated_at_pr": {
      "type": "string"
    }
  }
}
