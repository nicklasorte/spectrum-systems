{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/meeting_minutes_record.schema.json",
  "title": "Meeting Minutes Record",
  "description": "Canonical machine-validated meeting minutes artifact produced by meeting-minutes-engine and consumed by downstream engines.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_class",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "record_id",
    "run_id",
    "trace_id",
    "created_at",
    "created_by",
    "source_repo",
    "source_repo_version",
    "meeting_id",
    "meeting_title",
    "date",
    "source_transcript",
    "attendees",
    "agenda_items",
    "decisions",
    "action_items",
    "open_questions",
    "provenance"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "meeting_minutes_record",
      "description": "Canonical artifact type identifier."
    },
    "artifact_class": {
      "type": "string",
      "const": "coordination",
      "description": "Canonical artifact class identifier."
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^MMR-[A-Z0-9._-]+$",
      "description": "Stable identifier for this meeting minutes record instance."
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version of this artifact instance for diffing and rollback."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the meeting_minutes_record schema."
    },
    "standards_version": {
      "type": "string",
      "const": "2026.03.0",
      "description": "Standards release version from contracts/standards-manifest.json."
    },
    "record_id": {
      "type": "string",
      "pattern": "^REC-[A-Z0-9._-]+$",
      "description": "Record identifier used for provenance and diffing."
    },
    "run_id": {
      "type": "string",
      "pattern": "^run-[A-Za-z0-9._-]+$",
      "description": "Deterministic run identifier for the workflow that produced this record."
    },
    "trace_id": {
      "type": "string",
      "minLength": 1,
      "description": "Deterministic trace identifier for the workflow that produced this record."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this record was generated."
    },
    "created_by": {
      "$ref": "#/$defs/created_by"
    },
    "source_repo": {
      "type": "string",
      "description": "Repository slug that produced this record."
    },
    "source_repo_version": {
      "type": "string",
      "description": "Tag or commit hash of the source repository."
    },
    "meeting_id": {
      "type": "string",
      "description": "Stable meeting identifier or series instance ID."
    },
    "meeting_title": {
      "type": "string",
      "description": "Human-readable meeting title."
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date the meeting occurred."
    },
    "source_transcript": {
      "type": "string",
      "description": "Reference to the transcript text or path used to generate the record."
    },
    "attendees": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "List of attendees present for the meeting."
    },
    "agenda_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/agenda_item"
      },
      "description": "Agenda items discussed with context from the transcript."
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/decision"
      },
      "description": "Decisions made during the meeting."
    },
    "action_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action_item"
      },
      "description": "Action items derived from the meeting."
    },
    "open_questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/open_question"
      },
      "description": "Open questions that remain unresolved."
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated_by",
        "generation_timestamp",
        "source_file"
      ],
      "properties": {
        "generated_by": {
          "type": "string",
          "description": "Workflow, engine, or agent that generated this record."
        },
        "generation_timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the record was generated."
        },
        "source_file": {
          "type": "string",
          "description": "Path or URI to the transcript input used for generation."
        }
      }
    },
    "slides_present": {
      "type": "boolean",
      "description": "Whether slide artifacts were provided and processed by the slide intelligence layer."
    },
    "slide_alignment": {
      "type": "object",
      "description": "Slide-to-transcript alignment map produced by the slide intelligence layer. Keys are slide_ids; values contain matched_segments and confidence.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "matched_segments": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        }
      }
    },
    "slide_signals": {
      "type": "object",
      "description": "Structured signals extracted from slide content (claims, assumptions, proposals, metrics, open questions).",
      "properties": {
        "claims": { "type": "array", "items": { "type": "object" } },
        "assumptions": { "type": "array", "items": { "type": "object" } },
        "proposals": { "type": "array", "items": { "type": "string" } },
        "metrics": { "type": "array", "items": { "type": "string" } },
        "open_questions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "gap_analysis": {
      "type": "object",
      "description": "Gap analysis between slide content and meeting discussion. Uses the canonical gap object shape shared with slide_intelligence_packet.",
      "properties": {
        "unpresented_discussions": { "type": "array", "items": { "type": "string" } },
        "undiscussed_slides": { "type": "array", "items": { "type": "string" } },
        "weak_alignment_areas": { "type": "array", "items": { "type": "string" } },
        "recommended_followups": {
          "type": "array",
          "description": "Structured follow-up recommendations. Each item is a canonical follow-up object.",
          "items": { "$ref": "#/$defs/followup" }
        },
        "reconciliation_status": {
          "type": "string",
          "enum": ["ok", "inert_review_required"],
          "description": "Status of the reconciliation pass."
        },
        "canonical_gaps": {
          "type": "array",
          "description": "Optional canonical gap objects for machine-readable downstream consumption. Uses the same shape as slide_intelligence_packet analysis_gaps.",
          "items": { "$ref": "#/$defs/gap" }
        }
      }
    }
  },
  "$defs": {
    "followup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["followup_id", "type", "text", "source_type", "source_id"],
      "properties": {
        "followup_id": { "type": "string", "pattern": "^FUP-[A-Z0-9][A-Z0-9._-]*$" },
        "type": {
          "type": "string",
          "enum": ["discuss", "add_evidence", "clarify_alignment"]
        },
        "text": { "type": "string" },
        "source_type": {
          "type": "string",
          "enum": ["slide", "transcript", "gap"]
        },
        "source_id": { "type": "string" },
        "target_section": { "type": ["string", "null"] },
        "severity": { "type": ["string", "null"] }
      }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gap_id", "gap_type", "description", "severity", "source_slide_id", "related_claim_ids"],
      "properties": {
        "gap_id": { "type": "string", "pattern": "^GAP-[A-Z0-9][A-Z0-9._-]*$" },
        "gap_type": {
          "type": "string",
          "enum": [
            "missing_propagation_model",
            "missing_assumption",
            "missing_criteria",
            "missing_method",
            "missing_basis",
            "contradiction",
            "reconciliation_gap"
          ]
        },
        "description": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "related_claim_ids": { "type": "array", "items": { "type": "string" } },
        "source_slide_id": { "type": ["string", "null"] },
        "evidence": { "type": ["string", "null"] }
      }
    },
    "created_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "agent_type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "agent_type": {
          "type": "string",
          "enum": [
            "human",
            "ai_model",
            "workflow",
            "script",
            "automated_system",
            "ai_assistant"
          ]
        },
        "organization": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "agenda_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "description",
        "rationale",
        "decided_by"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "pattern": "^DEC-[A-Z0-9][A-Z0-9._-]*$"
        },
        "description": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "decided_by": {
          "type": "string",
          "description": "Person or group responsible for the decision."
        }
      }
    },
    "action_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "description",
        "owner",
        "due_date",
        "status"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "pattern": "^ACT-[A-Z0-9][A-Z0-9._-]*$"
        },
        "description": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "in_progress",
            "done",
            "blocked"
          ]
        }
      }
    },
    "open_question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question_id",
        "description",
        "raised_by"
      ],
      "properties": {
        "question_id": {
          "type": "string",
          "pattern": "^QST-[A-Z0-9][A-Z0-9._-]*$"
        },
        "description": {
          "type": "string"
        },
        "raised_by": {
          "type": "string"
        }
      }
    }
  }
}
