{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/evaluation_control_decision.schema.json",
  "title": "Evaluation Control Decision",
  "description": "Governed control-loop decision artifact derived from eval_summary signals.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "decision_id",
    "eval_run_id",
    "system_status",
    "system_response",
    "triggered_signals",
    "threshold_snapshot",
    "trace_id",
    "created_at",
    "decision",
    "rationale_code",
    "input_signal_reference",
    "run_id"
  ],
  "properties": {
    "artifact_type": { "type": "string", "const": "evaluation_control_decision" },
    "schema_version": { "type": "string", "const": "1.1.0" },
    "decision_id": { "type": "string", "minLength": 1 },
    "eval_run_id": { "type": "string", "minLength": 1 },
    "system_status": {
      "type": "string",
      "enum": ["healthy", "warning", "exhausted", "blocked"]
    },
    "system_response": {
      "type": "string",
      "enum": ["allow", "warn", "freeze", "block"]
    },
    "triggered_signals": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "reliability_breach",
          "stability_breach",
          "trust_breach",
          "indeterminate_failure",
          "budget_warning",
          "budget_exhausted",
          "budget_invalid",
          "malformed_eval_summary",
          "missing_required_signal"
        ]
      },
      "uniqueItems": true
    },
    "threshold_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reliability_threshold",
        "drift_threshold",
        "trust_threshold"
      ],
      "properties": {
        "reliability_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "drift_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "trust_threshold": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "trace_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "decision": {
      "type": "string",
      "enum": ["allow", "deny", "require_review"]
    },
    "rationale_code": {
      "type": "string",
      "enum": [
        "allow_healthy_eval_summary",
        "deny_reliability_breach",
        "deny_stability_breach",
        "deny_trust_breach",
        "deny_indeterminate_failure",
        "require_review_warning_signal",
        "require_review_budget_warning",
        "deny_budget_exhausted",
        "deny_budget_invalid",
        "deny_failure_eval_case",
        "deny_malformed_signal",
        "deny_missing_required_signal"
      ]
    },
    "input_signal_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal_type", "source_artifact_id"],
      "properties": {
        "signal_type": {
          "type": "string",
          "enum": ["eval_summary", "failure_eval_case"]
        },
        "source_artifact_id": { "type": "string", "minLength": 1 }
      }
    },
    "run_id": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "system_status": {
            "enum": ["warning", "exhausted", "blocked"]
          }
        },
        "required": ["system_status"]
      },
      "then": {
        "properties": {
          "system_response": { "not": { "const": "allow" } }
        }
      }
    },
    {
      "if": {
        "properties": {
          "system_response": { "enum": ["warn", "freeze", "block"] }
        },
        "required": ["system_response"]
      },
      "then": {
        "properties": {
          "triggered_signals": {
            "minItems": 1
          }
        },
        "required": ["triggered_signals"]
      }
    }
  ]
}
