{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/transcript_artifact.schema.json",
  "title": "Transcript Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "schema_version", "trace_id", "outputs"],
  "properties": {
    "artifact_type": {"type": "string", "const": "transcript_artifact"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "trace_id": {"type": "string", "minLength": 1},
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["segments"],
      "properties": {
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["segment_id", "speaker", "agency", "text"],
            "properties": {
              "segment_id": {"type": "string", "minLength": 1},
              "speaker": {"type": "string", "minLength": 1},
              "agency": {"type": "string", "minLength": 1},
              "text": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  }
}
