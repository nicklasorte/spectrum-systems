{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "$id": "https://spectrum-systems.org/contracts/nx_fused_signal_record.schema.json",
  "title": "nx_fused_signal_record",
  "required": [
    "artifact_type",
    "schema_version",
    "authority_scope",
    "signals",
    "prepared_for",
    "trace_id",
    "lineage"
  ],
  "properties": {
    "artifact_type": {
      "const": "fused_signal_record"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "authority_scope": {
      "const": "preparatory_non_authoritative"
    },
    "signals": {
      "type": "object"
    },
    "prepared_for": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "lineage": {
      "type": "object"
    }
  }
}
