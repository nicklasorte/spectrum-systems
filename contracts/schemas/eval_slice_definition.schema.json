{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/eval_slice_definition.schema.json",
  "title": "Eval Slice Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "slice_id",
    "artifact_family",
    "match_rules"
  ],
  "properties": {
    "artifact_type": {
      "const": "eval_slice_definition"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "slice_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_family": {
      "type": "string",
      "minLength": 1
    },
    "match_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "field",
          "equals"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "equals": {}
        }
      }
    }
  }
}
