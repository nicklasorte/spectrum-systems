{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum.systems/contracts/working_paper_evidence_pack.schema.json",
  "title": "Working Paper Evidence Pack",
  "description": "Governed artifact produced by BG. Assembles traceable evidence blocks from BE normalized run results and optional BF cross-run comparison outputs for working-paper drafting, review, and agency follow-up.",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "evidence_pack_id",
    "study_type",
    "source_artifacts",
    "section_evidence",
    "ranked_findings",
    "caveats",
    "followup_questions",
    "generated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "type": "string",
      "description": "Unique identifier for this working_paper_evidence_pack artifact.",
      "pattern": "^WPE-[A-Z0-9][A-Z0-9._-]*$"
    },
    "artifact_type": {
      "type": "string",
      "description": "Must equal working_paper_evidence_pack.",
      "const": "working_paper_evidence_pack"
    },
    "schema_version": {
      "type": "string",
      "description": "Semantic version of this schema.",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "evidence_pack_id": {
      "type": "string",
      "description": "Unique identifier for this evidence pack.",
      "pattern": "^EPK-[A-Z0-9][A-Z0-9._-]*$"
    },
    "study_type": {
      "type": "string",
      "description": "The type of spectrum study this evidence pack covers.",
      "enum": ["p2p_interference", "adjacency_analysis", "retuning_analysis", "sharing_study", "generic"]
    },
    "source_artifacts": {
      "type": "array",
      "description": "References to the BE and BF source artifacts consumed by this synthesis.",
      "items": {
        "type": "object",
        "required": ["artifact_type", "artifact_id", "source_bundle_id", "path_or_reference"],
        "additionalProperties": false,
        "properties": {
          "artifact_type": { "type": "string", "minLength": 1 },
          "artifact_id": { "type": "string", "minLength": 1 },
          "source_bundle_id": { "type": "string", "minLength": 1 },
          "path_or_reference": { "type": "string" }
        }
      }
    },
    "section_evidence": {
      "type": "array",
      "description": "Evidence organized by working-paper-relevant sections.",
      "items": {
        "type": "object",
        "required": ["section_key", "section_title", "evidence_items", "synthesis_status"],
        "additionalProperties": false,
        "properties": {
          "section_key": {
            "type": "string",
            "enum": [
              "executive_summary",
              "study_objective",
              "technical_findings",
              "comparative_results",
              "operational_implications",
              "limitations_and_caveats",
              "agency_questions",
              "recommended_next_steps"
            ]
          },
          "section_title": { "type": "string", "minLength": 1 },
          "evidence_items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "evidence_id",
                "evidence_type",
                "statement",
                "support",
                "confidence",
                "traceability"
              ],
              "additionalProperties": false,
              "properties": {
                "evidence_id": {
                  "type": "string",
                  "pattern": "^EVI-[A-Z0-9][A-Z0-9._-]*$"
                },
                "evidence_type": {
                  "type": "string",
                  "enum": [
                    "metric_observation",
                    "ranked_result",
                    "anomaly",
                    "caveat",
                    "threshold_result",
                    "completeness_gap",
                    "scenario_summary"
                  ]
                },
                "statement": { "type": "string", "minLength": 1 },
                "support": {
                  "type": "object",
                  "required": ["metric_name", "value", "unit", "comparison_context"],
                  "additionalProperties": false,
                  "properties": {
                    "metric_name": { "type": "string" },
                    "value": { "type": "string" },
                    "unit": { "type": "string" },
                    "comparison_context": { "type": "string" }
                  }
                },
                "confidence": {
                  "type": "string",
                  "enum": ["high", "medium", "low"]
                },
                "traceability": {
                  "type": "object",
                  "required": ["source_artifact_id", "source_bundle_id", "source_path"],
                  "additionalProperties": false,
                  "properties": {
                    "source_artifact_id": { "type": "string", "minLength": 1 },
                    "source_bundle_id": { "type": "string", "minLength": 1 },
                    "source_path": { "type": "string" }
                  }
                }
              }
            }
          },
          "synthesis_status": {
            "type": "string",
            "enum": ["populated", "partial", "empty"]
          }
        }
      }
    },
    "ranked_findings": {
      "type": "array",
      "description": "Sparse ranked findings ordered by priority.",
      "items": {
        "type": "object",
        "required": ["finding_id", "priority", "headline", "rationale", "supporting_evidence_ids"],
        "additionalProperties": false,
        "properties": {
          "finding_id": {
            "type": "string",
            "pattern": "^FND-[A-Z0-9][A-Z0-9._-]*$"
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "headline": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "supporting_evidence_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "caveats": {
      "type": "array",
      "description": "Explicit caveats that must be carried forward into any downstream drafting.",
      "items": {
        "type": "object",
        "required": ["caveat_id", "category", "statement", "severity", "supporting_evidence_ids"],
        "additionalProperties": false,
        "properties": {
          "caveat_id": {
            "type": "string",
            "pattern": "^CAV-[A-Z0-9][A-Z0-9._-]*$"
          },
          "category": {
            "type": "string",
            "enum": [
              "data_gap",
              "comparability_limit",
              "anomaly",
              "threshold_uncertainty",
              "provenance_limit",
              "modeling_limit"
            ]
          },
          "statement": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "error"]
          },
          "supporting_evidence_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "followup_questions": {
      "type": "array",
      "description": "Evidence-triggered follow-up questions for agencies or reviewers.",
      "items": {
        "type": "object",
        "required": ["question_id", "target_section", "question", "reason", "supporting_evidence_ids"],
        "additionalProperties": false,
        "properties": {
          "question_id": {
            "type": "string",
            "pattern": "^QST-[A-Z0-9][A-Z0-9._-]*$"
          },
          "target_section": {
            "type": "string",
            "enum": [
              "executive_summary",
              "study_objective",
              "technical_findings",
              "comparative_results",
              "operational_implications",
              "limitations_and_caveats",
              "agency_questions",
              "recommended_next_steps"
            ]
          },
          "question": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "supporting_evidence_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 date-time when this artifact was generated.",
      "format": "date-time"
    }
  }
}
