{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prompt_queue_sequence_run.schema.json",
  "title": "Prompt Queue Sequence Run",
  "description": "Canonical deterministic persisted state for sequential PQX prompt-queue execution batches.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "queue_run_id",
    "run_id",
    "trace_id",
    "status",
    "created_at",
    "updated_at",
    "requested_slice_ids",
    "completed_slice_ids",
    "failed_slice_ids",
    "current_slice_id",
    "prior_slice_ref",
    "next_slice_ref",
    "execution_history",
    "blocked_reason",
    "resume_token",
    "continuation_records",
    "lineage",
    "certification_complete_by_slice",
    "audit_complete_by_slice",
    "blocked_continuation_context",
    "replay_verification",
    "review_checkpoint_status",
    "review_artifact_refs",
    "sequence_budget_status",
    "sequence_budget_ref",
    "chain_certification_status",
    "chain_certification_refs",
    "bundle_readiness_decision",
    "bundle_certification_status",
    "bundle_certification_ref",
    "bundle_audit_status",
    "bundle_audit_ref",
    "unresolved_fix_ids",
    "control_surface_gap_visibility",
    "termination_reason",
    "admission_preflight_artifact",
    "admitted_input_snapshot",
    "admitted_input_hash",
    "run_fingerprint",
    "replayable_run_snapshot"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.5.0"
    },
    "queue_run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "running",
        "blocked",
        "failed",
        "completed"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "requested_slice_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty"
      },
      "uniqueItems": true
    },
    "completed_slice_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty"
      },
      "uniqueItems": true
    },
    "failed_slice_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty"
      },
      "uniqueItems": true
    },
    "current_slice_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "prior_slice_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "next_slice_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "execution_history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/execution_entry"
      }
    },
    "blocked_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "resume_token": {
      "type": "string",
      "pattern": "^resume:[A-Za-z0-9._:-]+:[0-9]+$"
    },
    "continuation_records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/continuation_record"
      },
      "uniqueItems": true
    },
    "lineage": {
      "$ref": "#/$defs/lineage"
    },
    "certification_complete_by_slice": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[A-Za-z0-9._:-]+$": {
          "type": "boolean"
        }
      }
    },
    "audit_complete_by_slice": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[A-Za-z0-9._:-]+$": {
          "type": "boolean"
        }
      }
    },
    "blocked_continuation_context": {
      "$ref": "#/$defs/blocked_continuation_context"
    },
    "replay_verification": {
      "$ref": "#/$defs/replay_verification"
    },
    "review_checkpoint_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slice_1_optional_review",
        "slice_2_required_review",
        "slice_3_strict_review"
      ],
      "properties": {
        "slice_1_optional_review": {
          "type": "string",
          "enum": [
            "not_required",
            "satisfied",
            "missing",
            "blocked"
          ]
        },
        "slice_2_required_review": {
          "type": "string",
          "enum": [
            "required_pending",
            "satisfied",
            "missing",
            "blocked"
          ]
        },
        "slice_3_strict_review": {
          "type": "string",
          "enum": [
            "required_pending",
            "satisfied",
            "missing",
            "blocked"
          ]
        }
      }
    },
    "review_artifact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sequence_budget_status": {
      "type": "string",
      "enum": [
        "not_started",
        "within_budget",
        "exceeded_budget"
      ]
    },
    "sequence_budget_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "chain_certification_status": {
      "type": "string",
      "enum": [
        "pending",
        "certified",
        "blocked"
      ]
    },
    "chain_certification_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "bundle_readiness_decision": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "ready",
        "reason"
      ],
      "properties": {
        "ready": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "bundle_certification_status": {
      "type": "string",
      "enum": [
        "pending",
        "certified",
        "failed"
      ]
    },
    "bundle_certification_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "bundle_audit_status": {
      "type": "string",
      "enum": [
        "pending",
        "synthesized",
        "missing"
      ]
    },
    "bundle_audit_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "unresolved_fix_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "control_surface_gap_visibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "by_slice",
        "summary"
      ],
      "properties": {
        "by_slice": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/control_surface_gap_visibility"
          }
        },
        "summary": {
          "$ref": "#/$defs/control_surface_gap_visibility"
        }
      }
    },
    "termination_reason": {
      "type": "string",
      "minLength": 1
    },
    "admission_preflight_artifact": {
      "type": [
        "object",
        "null"
      ]
    },
    "admitted_input_snapshot": {
      "type": [
        "object",
        "null"
      ]
    },
    "admitted_input_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "run_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fingerprint_hash",
        "decision_sequence",
        "stopping_slice_id"
      ],
      "properties": {
        "fingerprint_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "decision_sequence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "slice_id",
              "status",
              "error"
            ],
            "properties": {
              "slice_id": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "status": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "error": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        },
        "stopping_slice_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "replayable_run_snapshot": {
      "type": [
        "object",
        "null"
      ]
    }
  },
  "$defs": {
    "non_empty": {
      "type": "string",
      "minLength": 1
    },
    "execution_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_ref",
        "queue_run_id",
        "run_id",
        "trace_id",
        "slice_id",
        "status",
        "parent_execution_ref",
        "started_at",
        "completed_at",
        "error",
        "slice_execution_record_ref",
        "certification_ref",
        "audit_bundle_ref",
        "certification_complete",
        "audit_complete",
        "continuation_record_id",
        "control_surface_gap_visibility"
      ],
      "properties": {
        "execution_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "queue_run_id": {
          "$ref": "#/$defs/non_empty"
        },
        "run_id": {
          "$ref": "#/$defs/non_empty"
        },
        "trace_id": {
          "$ref": "#/$defs/non_empty"
        },
        "slice_id": {
          "$ref": "#/$defs/non_empty"
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "failed"
          ]
        },
        "parent_execution_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "slice_execution_record_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "certification_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "audit_bundle_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "certification_complete": {
          "type": "boolean"
        },
        "audit_complete": {
          "type": "boolean"
        },
        "continuation_record_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "control_surface_gap_visibility": {
          "$ref": "#/$defs/control_surface_gap_visibility"
        }
      }
    },
    "control_surface_gap_visibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_surface_gap_packet_ref",
        "control_surface_gap_packet_consumed",
        "prioritized_control_surface_gaps",
        "pqx_gap_work_items",
        "control_surface_gap_influence"
      ],
      "properties": {
        "control_surface_gap_packet_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "control_surface_gap_packet_consumed": {
          "type": "boolean"
        },
        "prioritized_control_surface_gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "gap_id",
              "surface_name",
              "severity",
              "blocking",
              "source_artifact_ref"
            ],
            "properties": {
              "gap_id": {
                "type": "string",
                "minLength": 1
              },
              "surface_name": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "minLength": 1
              },
              "blocking": {
                "type": "boolean"
              },
              "source_artifact_ref": {
                "type": "string"
              }
            }
          }
        },
        "pqx_gap_work_items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "work_item_id",
              "gap_id",
              "surface_name",
              "required_action_type",
              "blocking"
            ],
            "properties": {
              "work_item_id": {
                "type": "string",
                "minLength": 1
              },
              "gap_id": {
                "type": "string",
                "minLength": 1
              },
              "surface_name": {
                "type": "string",
                "minLength": 1
              },
              "required_action_type": {
                "type": "string",
                "minLength": 1
              },
              "blocking": {
                "type": "boolean"
              }
            }
          }
        },
        "control_surface_gap_influence": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "influenced_execution_block",
            "influenced_next_step_selection",
            "influenced_priority_ordering",
            "influenced_transition_decision",
            "reason_codes",
            "control_surface_blocking_reason_refs"
          ],
          "properties": {
            "influenced_execution_block": {
              "type": "boolean"
            },
            "influenced_next_step_selection": {
              "type": "boolean"
            },
            "influenced_priority_ordering": {
              "type": "boolean"
            },
            "influenced_transition_decision": {
              "type": "boolean"
            },
            "reason_codes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "control_surface_blocking_reason_refs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "continuation_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "prior_step_id",
        "next_step_id",
        "prior_run_id",
        "prior_trace_id",
        "prior_slice_execution_record_ref",
        "prior_certification_ref",
        "prior_audit_bundle_ref",
        "continuation_status",
        "continuation_decision",
        "continuation_reasons",
        "created_at"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/non_empty"
        },
        "prior_step_id": {
          "$ref": "#/$defs/non_empty"
        },
        "next_step_id": {
          "$ref": "#/$defs/non_empty"
        },
        "prior_run_id": {
          "$ref": "#/$defs/non_empty"
        },
        "prior_trace_id": {
          "$ref": "#/$defs/non_empty"
        },
        "prior_slice_execution_record_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "prior_certification_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "prior_audit_bundle_ref": {
          "$ref": "#/$defs/non_empty"
        },
        "continuation_status": {
          "type": "string",
          "enum": [
            "ready",
            "blocked"
          ]
        },
        "continuation_decision": {
          "type": "string",
          "enum": [
            "allow",
            "block"
          ]
        },
        "continuation_reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/non_empty"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "artifact_type": {
          "type": "string",
          "const": "pqx_slice_continuation_record"
        },
        "schema_version": {
          "type": "string",
          "const": "1.0.0"
        }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prior_run_id",
        "prior_trace_id"
      ],
      "properties": {
        "prior_run_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "prior_trace_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "blocked_continuation_context": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "block_type",
        "reason",
        "next_slice_id"
      ],
      "properties": {
        "block_type": {
          "type": "string",
          "enum": [
            "INVALID_SLICE_CONTINUATION",
            "PRIOR_SLICE_NOT_GOVERNED",
            "CONTINUATION_STATE_MISMATCH",
            "CANARY_FROZEN"
          ]
        },
        "reason": {
          "$ref": "#/$defs/non_empty"
        },
        "next_slice_id": {
          "$ref": "#/$defs/non_empty"
        }
      }
    },
    "replay_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "replay_record_ref"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_run",
            "pass",
            "fail"
          ]
        },
        "replay_record_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    }
  }
}
