{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/ai_programming_loop_violation_record.schema.json",
  "title": "AI Programming Loop Violation Record",
  "description": "Records a specific governance loop violation for an AI programming work item. Emitted when a required leg (AEX, PQX, EVL, TPA, CDE, SEL) is missing or unknown for a repo_mutating work item. MET observation only; does not claim enforcement authority (SEL) or decision authority (CDE).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "record_id",
    "created_at",
    "owner_system",
    "violation_id",
    "work_item_id",
    "tool_source",
    "violation_type",
    "missing_leg",
    "repo_mutating",
    "reason_codes",
    "source_artifacts_used"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "ai_programming_loop_violation_record"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "record_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "owner_system": {"type": "string", "const": "MET"},
    "violation_id": {"type": "string", "minLength": 1},
    "work_item_id": {"type": "string", "minLength": 1},
    "tool_source": {
      "type": "string",
      "enum": ["codex", "claude", "unknown"]
    },
    "violation_type": {
      "type": "string",
      "enum": [
        "aex_missing",
        "pqx_missing",
        "evl_missing",
        "tpa_missing",
        "cde_missing",
        "sel_missing",
        "lineage_missing",
        "aex_unknown",
        "pqx_unknown"
      ]
    },
    "missing_leg": {
      "type": "string",
      "enum": ["AEX", "PQX", "EVL", "TPA", "CDE", "SEL", "lineage"]
    },
    "repo_mutating": {
      "oneOf": [
        {"type": "boolean"},
        {"type": "string", "const": "unknown"}
      ]
    },
    "why_it_matters": {"type": "string"},
    "next_recommended_input": {"type": "string"},
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "source_artifacts_used": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "backfill_allowed": {
      "oneOf": [
        {"type": "boolean"},
        {"type": "string", "enum": ["partial"]}
      ]
    },
    "human_review_required": {"type": "boolean"}
  }
}
