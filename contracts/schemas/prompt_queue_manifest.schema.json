{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prompt_queue_manifest.schema.json",
  "title": "Prompt Queue Manifest",
  "description": "Canonical deterministic queue run manifest with fail-closed step declarations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "queue_id",
    "created_at",
    "version",
    "steps",
    "execution_policy"
  ],
  "properties": {
    "queue_id": {
      "type": "string",
      "pattern": "^queue-[a-z0-9][a-z0-9-]*$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "execution_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stop_on_block",
        "allow_warn",
        "trace_id"
      ],
      "properties": {
        "stop_on_block": {
          "type": "boolean"
        },
        "allow_warn": {
          "type": "boolean"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "step_type",
        "input_refs",
        "expected_outputs",
        "metadata"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "pattern": "^step-[0-9]{3}$"
        },
        "step_type": {
          "type": "string",
          "minLength": 1
        },
        "input_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "null"
            ]
          }
        }
      }
    }
  }
}
