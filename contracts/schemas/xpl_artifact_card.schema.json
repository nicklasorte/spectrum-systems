{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/xpl_artifact_card.schema.json",
  "title": "xpl_artifact_card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "artifact_family",
    "generator",
    "intended_use",
    "limitations",
    "evaluation_status",
    "known_risks",
    "non_authoritative"
  ],
  "properties": {
    "artifact_type": {
      "const": "xpl_artifact_card"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_family": {
      "type": "string"
    },
    "generator": {
      "type": "string"
    },
    "intended_use": {
      "type": "string"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "evaluation_status": {
      "type": "string",
      "enum": [
        "passing",
        "degraded",
        "unknown"
      ]
    },
    "known_risks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "non_authoritative": {
      "const": true
    }
  }
}
