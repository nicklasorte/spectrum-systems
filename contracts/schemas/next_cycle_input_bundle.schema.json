{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/next_cycle_input_bundle.schema.json",
  "title": "next_cycle_input_bundle",
  "description": "Deterministic machine-readable handoff bundle required to start the next bounded governed cycle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "schema_version",
    "source_cycle_id",
    "required_artifacts",
    "active_program_constraints",
    "active_risks",
    "unresolved_blockers",
    "required_reviews",
    "autonomy_decision_ref",
    "autonomy_blockers",
    "recommended_start_batch",
    "context_refs",
    "source_cycle_runner_result_ref",
    "continuation_depth",
    "created_at",
    "trace_id",
    "latest_exception_class",
    "latest_exception_resolution_action",
    "latest_exception_action_type",
    "latest_exception_requires_human_review",
    "latest_exception_requires_freeze",
    "required_next_actions"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "pattern": "^NCB-[A-F0-9]{12}$"
    },
    "schema_version": {
      "type": "string",
      "const": "1.2.0"
    },
    "source_cycle_id": {
      "type": "string",
      "minLength": 3
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "active_program_constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "active_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "unresolved_blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "recommended_start_batch": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^BATCH-[A-Z]$"
    },
    "context_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^trace-[A-Za-z0-9._:-]+$"
    },
    "required_reviews": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "autonomy_decision_ref": {
      "type": "string",
      "pattern": "^autonomy_decision_record:ADR-[A-F0-9]{12}$"
    },
    "autonomy_blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    },
    "continuation_depth": {
      "type": "integer",
      "minimum": 0
    },
    "source_cycle_runner_result_ref": {
      "type": "string",
      "pattern": "^cycle_runner_result:CRR-[A-F0-9]{12}$"
    },
    "latest_exception_class": {
      "type": "string",
      "enum": [
        "missing_eval_coverage",
        "missing_required_eval_result",
        "indeterminate_required_eval",
        "replay_mismatch",
        "review_required",
        "autonomy_blocked",
        "program_misalignment",
        "drift_detected",
        "unresolved_critical_risk",
        "policy_violation",
        "execution_failure",
        "unknown_blocker"
      ]
    },
    "latest_exception_resolution_action": {
      "type": "string",
      "enum": [
        "create_eval_coverage_work",
        "re_run_or_remediate_eval_path",
        "freeze_and_investigate",
        "freeze_and_replay_investigation",
        "queue_review",
        "require_human_review",
        "roadmap_adjustment",
        "remediation_batch",
        "escalate"
      ]
    },
    "latest_exception_action_type": {
      "type": "string",
      "enum": [
        "create_remediation_batch",
        "create_eval_batch",
        "queue_review",
        "freeze_and_investigate",
        "escalate",
        "adjust_roadmap",
        "stop_without_auto_action"
      ]
    },
    "latest_exception_requires_human_review": {
      "type": "boolean"
    },
    "latest_exception_requires_freeze": {
      "type": "boolean"
    },
    "required_next_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      },
      "uniqueItems": true
    }
  }
}
