{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "lineage_completeness_report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "standards_version",
    "record_id",
    "owner",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "lineage_completeness_report"
    },
    "artifact_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "standards_version": {
      "type": "string"
    },
    "record_id": {
      "type": "string",
      "minLength": 3
    },
    "owner": {
      "type": "string",
      "minLength": 2
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "artifact_family": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "lineage_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
