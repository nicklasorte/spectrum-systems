{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pqx_fix_gate_record.schema.json",
  "title": "PQX Fix Gate Record",
  "description": "Deterministic governed adjudication record that decides whether executed PQX fixes allow bundle progression to resume.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fix_gate_id",
    "created_at",
    "run_id",
    "trace_id",
    "bundle_id",
    "fix_id",
    "originating_pending_fix_id",
    "originating_review_artifact_id",
    "originating_finding_id",
    "fix_execution_record_ref",
    "adjudication_inputs",
    "gate_status",
    "allows_resume",
    "blocking_reason",
    "comparison_summary",
    "producer"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.1.0"},
    "fix_gate_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "run_id": {"type": "string", "minLength": 1},
    "trace_id": {"type": "string", "minLength": 1},
    "bundle_id": {"type": "string", "minLength": 1},
    "fix_id": {"type": "string", "minLength": 1},
    "originating_pending_fix_id": {"type": "string", "minLength": 1},
    "originating_review_artifact_id": {"type": ["string", "null"], "minLength": 1},
    "originating_finding_id": {"type": ["string", "null"], "minLength": 1},
    "fix_execution_record_ref": {"type": "string", "minLength": 1},
    "adjudication_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_status",
        "validation_result",
        "accepted_target_step_ids",
        "insertion_point",
        "artifact_refs"
      ],
      "properties": {
        "execution_status": {"type": "string", "enum": ["complete", "blocked", "failed"]},
        "validation_result": {"type": "string", "minLength": 1},
        "accepted_target_step_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1,
          "uniqueItems": true
        },
        "insertion_point": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "anchor_step_id", "insert_before_step_id", "ordered_index"],
          "properties": {
            "mode": {"type": "string", "enum": ["before_source", "patch_after_source"]},
            "anchor_step_id": {"type": "string", "minLength": 1},
            "insert_before_step_id": {"type": ["string", "null"], "minLength": 1},
            "ordered_index": {"type": "integer", "minimum": 0}
          }
        },
        "artifact_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "gate_status": {"type": "string", "enum": ["passed", "blocked"]},
    "allows_resume": {"type": "boolean"},
    "blocking_reason": {"type": ["string", "null"], "minLength": 1},
    "comparison_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapping_status", "resolution_status", "reason_codes", "replay_safe"],
      "properties": {
        "mapping_status": {"type": "string", "enum": ["matched", "mismatched"]},
        "resolution_status": {"type": "string", "enum": ["resolved", "unresolved"]},
        "reason_codes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1,
          "uniqueItems": true
        },
        "replay_safe": {"type": "boolean", "const": true}
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["module", "function"],
      "properties": {
        "module": {"type": "string", "const": "spectrum_systems.modules.runtime.pqx_fix_gate"},
        "function": {"type": "string", "const": "evaluate_fix_completion"}
      }
    }
  }
}
