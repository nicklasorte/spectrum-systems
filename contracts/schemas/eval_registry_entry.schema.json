{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/eval_registry_entry.schema.json",
  "title": "Eval Registry Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "entry_id",
    "artifact_family",
    "required_eval_ids",
    "judge_policy_id",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "eval_registry_entry"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "entry_id": {
      "type": "string",
      "pattern": "^ere-[a-f0-9]{16}$"
    },
    "artifact_family": {
      "type": "string",
      "minLength": 1
    },
    "required_eval_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "judge_policy_id": {
      "type": "string",
      "minLength": 1
    },
    "slice_definition_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
