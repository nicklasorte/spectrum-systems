{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/governed_roadmap_artifact.schema.json",
  "title": "Governed Roadmap Artifact",
  "description": "Deterministic roadmap planning artifact with explicit eligibility metadata. Planning does not grant execution permission.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "roadmap_ref",
    "generated_at",
    "steps",
    "available_artifact_refs",
    "satisfied_trust_requirements",
    "satisfied_review_requirements",
    "satisfied_eval_requirements"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "governed_roadmap_artifact"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "roadmap_ref": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "available_artifact_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "satisfied_trust_requirements": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "satisfied_review_requirements": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "satisfied_eval_requirements": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "order_index",
          "title",
          "status",
          "dependency_step_ids",
          "dependency_artifact_refs",
          "trust_requirements",
          "review_requirements",
          "eval_requirements"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "pattern": "^[A-Z0-9][A-Z0-9_.-]*$"
          },
          "order_index": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "ready",
              "in_progress",
              "completed",
              "blocked"
            ]
          },
          "dependency_step_ids": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[A-Z0-9][A-Z0-9_.-]*$"
            }
          },
          "dependency_artifact_refs": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "trust_requirements": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "review_requirements": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "eval_requirements": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
