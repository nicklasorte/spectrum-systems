{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/admission_policy_observation.schema.json",
  "title": "Admission Policy Observation",
  "description": "AEX-emitted admission observation that downstream authorities (notably SEL/ENF for enforcement input and POL for policy review) consume. AEX is observer-only — it does not own enforcement, control, or promotion authority. The presence of this artifact signals that AEX's admission decision can be read as enforcement input by SEL.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "observation_id",
    "request_id",
    "trace_id",
    "run_id",
    "created_at",
    "produced_by",
    "producer_authority",
    "admission_outcome",
    "reason_codes",
    "input_refs",
    "output_refs",
    "downstream_refs",
    "evidence_refs",
    "replay_refs",
    "policy_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "admission_policy_observation"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "observation_id": {
      "type": "string",
      "pattern": "^apo-[0-9a-f]{16}$"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "produced_by": {
      "type": "string",
      "minLength": 1
    },
    "producer_authority": {
      "type": "string",
      "const": "AEX"
    },
    "admission_outcome": {
      "type": "string",
      "enum": [
        "admitted",
        "rejected",
        "indeterminate"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "input_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Refs to upstream inputs the admission decision read (codex_build_request id, normalized_execution_request ref)."
    },
    "output_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Refs to AEX-owned outputs (build_admission_record, normalized_execution_request, admission_rejection_record)."
    },
    "downstream_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumer_systems",
        "handoff_refs"
      ],
      "properties": {
        "consumer_systems": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "SEL",
              "ENF",
              "POL",
              "PQX",
              "TPA",
              "CDE",
              "GOV",
              "OBS"
            ]
          }
        },
        "handoff_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "replay_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_hash",
        "output_hash",
        "replay_command_ref"
      ],
      "properties": {
        "input_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "output_hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "replay_command_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policy_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_authority_assertions": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "enum": [
          "aex_does_not_own_enforcement_authority",
          "aex_does_not_own_promotion_authority",
          "aex_does_not_own_certification_authority",
          "aex_does_not_own_control_decision_authority",
          "aex_does_not_own_governance_readiness_authority",
          "aex_does_not_own_replay_authority",
          "aex_does_not_own_lineage_issuance_authority",
          "aex_does_not_own_observability_authority",
          "aex_does_not_own_evaluation_authority"
        ]
      }
    }
  }
}
