{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "judgment_status_record",
  "type": "object",
  "properties": {
    "artifact_type": {
      "type": "string"
    },
    "artifact_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "judgment_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "revoked"
      ]
    },
    "status_reason": {
      "type": "string"
    }
  },
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "judgment_id",
    "status",
    "status_reason"
  ],
  "additionalProperties": false
}
