{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/error_budget_policy.schema.json",
  "title": "Error Budget Policy",
  "description": "Governed deterministic policy for error budget status computation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "policy_id",
    "measurement_window",
    "supported_metrics",
    "warning_consumption_ratio",
    "exhausted_consumption_ratio",
    "unknown_metric_handling",
    "missing_metric_handling",
    "generated_by_version"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "error_budget_policy"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1
    },
    "measurement_window": {
      "type": "string",
      "enum": [
        "single_run",
        "rolling_batch"
      ]
    },
    "supported_metrics": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "replay_success_rate",
          "grounding_block_rate",
          "unsupported_claim_rate",
          "invalid_evidence_ref_rate",
          "drift_exceed_threshold_rate",
          "baseline_gate_block_rate",
          "regression_failure_rate"
        ]
      }
    },
    "warning_consumption_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "exhausted_consumption_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "unknown_metric_handling": {
      "type": "string",
      "enum": [
        "fail_closed"
      ]
    },
    "missing_metric_handling": {
      "type": "string",
      "enum": [
        "fail_closed"
      ]
    },
    "generated_by_version": {
      "type": "string",
      "minLength": 1
    }
  }
}
