{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pqx_execution_conflict_record.schema.json",
  "title": "Pqx Execution Conflict Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "conflict_id",
    "eval_result_ref",
    "conflict_type",
    "reason_codes",
    "materiality",
    "generated_at"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "pqx_execution_conflict_record"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "conflict_id": {
      "type": "string",
      "minLength": 1
    },
    "eval_result_ref": {
      "type": "string",
      "minLength": 1
    },
    "conflict_type": {
      "type": "string",
      "const": "execution_integrity_violation"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "materiality": {
      "type": "string",
      "enum": [
        "minor",
        "material"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
