{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/prg_prompt_size_governor_result.schema.json",
  "title": "prg_prompt_size_governor_result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "owner",
    "status",
    "max_tokens",
    "observed_tokens",
    "action"
  ],
  "properties": {
    "artifact_type": {
      "const": "prg_prompt_size_governor_result"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "const": "PRG"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "max_tokens": {
      "type": "integer"
    },
    "observed_tokens": {
      "type": "integer"
    },
    "action": {
      "type": "string"
    }
  }
}
