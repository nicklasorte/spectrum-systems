{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/authority_language_violation_record.schema.json",
  "title": "authority_language_violation_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "file",
    "line",
    "symbol",
    "authority_cluster",
    "canonical_owners",
    "suggested_replacements"
  ],
  "properties": {
    "artifact_type": { "type": "string", "const": "authority_language_violation_record" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "file": { "type": "string", "minLength": 1 },
    "line": { "type": "integer", "minimum": 1 },
    "symbol": { "type": "string", "enum": ["compliance_observation", "signal", "review_request", "policy_observation", "readiness_observation", "readiness_evidence"] },
    "authority_cluster": { "type": "string", "minLength": 1 },
    "canonical_owners": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "suggested_replacements": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
