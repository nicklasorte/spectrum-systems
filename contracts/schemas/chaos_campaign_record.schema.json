{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems/contracts/chaos_campaign_record.schema.json",
  "title": "chaos_campaign_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "campaigns"
  ],
  "properties": {
    "artifact_type": {
      "const": "chaos_campaign_record"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "campaigns": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "target_systems",
          "failure_injection",
          "expected_detection",
          "control_response"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "target_systems": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Z0-9]{3}$"
            }
          },
          "failure_injection": {
            "type": "string"
          },
          "expected_detection": {
            "type": "string"
          },
          "control_response": {
            "type": "string"
          }
        }
      }
    }
  }
}
