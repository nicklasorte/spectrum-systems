{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/review_artifact.schema.json",
  "title": "Review Artifact",
  "description": "Canonical machine-readable review artifact contract for governed Codex/Claude review outputs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "module",
    "review_type",
    "review_date",
    "reviewer",
    "decision",
    "trust_assessment",
    "status",
    "scope",
    "related_plan",
    "critical_findings",
    "required_fixes",
    "watch_items",
    "failure_mode_summary"
  ],
  "properties": {
    "review_id": {
      "type": "string",
      "pattern": "^REV-[A-Z0-9._-]+$",
      "minLength": 8
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "review_type": {
      "type": "string",
      "minLength": 1
    },
    "review_date": {
      "type": "string",
      "format": "date"
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "trust_assessment": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "status": {
      "type": "string",
      "enum": ["final"]
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "related_plan": {
      "type": "string",
      "pattern": "^docs/review-actions/PLAN-[A-Za-z0-9._-]+\\.md$"
    },
    "critical_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/critical_finding"
      }
    },
    "required_fixes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/required_fix"
      }
    },
    "watch_items": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "failure_mode_summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "decision": {
            "const": "FAIL"
          }
        },
        "required": ["decision"]
      },
      "then": {
        "properties": {
          "critical_findings": {
            "minItems": 1
          },
          "required_fixes": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "critical_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "file",
        "function",
        "failure_mode",
        "impact",
        "minimal_fix"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^F-[0-9]{3}$"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "function": {
          "type": "string",
          "minLength": 1
        },
        "failure_mode": {
          "type": "string",
          "minLength": 1
        },
        "impact": {
          "type": "string",
          "minLength": 1
        },
        "minimal_fix": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "required_fix": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fix_id",
        "description",
        "priority"
      ],
      "properties": {
        "fix_id": {
          "type": "string",
          "pattern": "^FIX-[0-9]{3}$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2"]
        }
      }
    }
  }
}
