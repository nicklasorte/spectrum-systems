{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/authority_language_mismatch_packet.schema.json",
  "title": "authority_language_mismatch_packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "mismatch_count",
    "violations",
    "allowed_replacement_policy",
    "repair_constraints",
    "symbols_seen"
  ],
  "properties": {
    "artifact_type": { "type": "string", "const": "authority_language_mismatch_packet" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "mismatch_count": { "type": "integer", "minimum": 0 },
    "violations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_type",
          "schema_version",
          "file",
          "line",
          "symbol",
          "authority_cluster",
          "canonical_owners",
          "suggested_replacements"
        ],
        "properties": {
          "artifact_type": { "type": "string", "const": "authority_language_violation_record" },
          "schema_version": { "type": "string", "const": "1.0.0" },
          "file": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "symbol": { "type": "string", "enum": ["compliance_observation", "signal", "review_request", "policy_observation", "readiness_observation", "readiness_evidence"] },
          "authority_cluster": { "type": "string", "minLength": 1 },
          "canonical_owners": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "suggested_replacements": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    },
    "allowed_replacement_policy": { "type": "string", "const": "replacement_only_no_semantic_expansion_no_authority_reassignment" },
    "repair_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allow_only_suggested_replacements",
        "forbid_semantic_expansion",
        "forbid_authority_reassignment"
      ],
      "properties": {
        "allow_only_suggested_replacements": { "type": "boolean", "const": true },
        "forbid_semantic_expansion": { "type": "boolean", "const": true },
        "forbid_authority_reassignment": { "type": "boolean", "const": true }
      }
    },
    "symbols_seen": {
      "type": "array",
      "items": { "type": "string", "enum": ["compliance_observation", "signal", "review_request", "policy_observation", "readiness_observation", "readiness_evidence"] },
      "uniqueItems": true
    }
  }
}
