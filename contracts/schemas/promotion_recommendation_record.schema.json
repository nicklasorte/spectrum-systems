{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/promotion_recommendation_record.schema.json",
  "title": "promotion_recommendation_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "generated_eval_artifact_id",
    "reason_code",
    "occurrence_count",
    "recommendation",
    "justification",
    "created_at"
  ],
  "properties": {
    "artifact_type": { "type": "string", "const": "promotion_recommendation_record" },
    "artifact_id": { "type": "string", "minLength": 1 },
    "generated_eval_artifact_id": { "type": "string", "minLength": 1 },
    "reason_code": { "type": "string", "minLength": 1 },
    "occurrence_count": { "type": "integer", "minimum": 1 },
    "recommendation": { "type": "string", "enum": ["promote", "monitor"] },
    "justification": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
