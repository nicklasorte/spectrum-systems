{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hnx_control_signal_record.schema.json",
  "title": "HNX Control Signal Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "signal_id",
    "structural_health",
    "continuity_status",
    "replay_status",
    "unresolved_feedback_count",
    "trace_id",
    "created_at",
    "non_authority_note"
  ],
  "properties": {
    "artifact_type": {
      "const": "hnx_control_signal_record"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "signal_id": {
      "type": "string",
      "minLength": 1
    },
    "structural_health": {
      "enum": [
        "stable",
        "degraded"
      ]
    },
    "continuity_status": {
      "enum": [
        "healthy",
        "at_risk"
      ]
    },
    "replay_status": {
      "enum": [
        "consistent",
        "mismatch_risk"
      ]
    },
    "unresolved_feedback_count": {
      "type": "integer",
      "minimum": 0
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "non_authority_note": {
      "type": "string",
      "minLength": 1
    }
  }
}
