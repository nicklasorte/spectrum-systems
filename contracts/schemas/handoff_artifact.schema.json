{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/handoff_artifact.schema.json",
  "title": "Handoff Artifact",
  "description": "Canonical HNX governed state-transfer artifact for reset-with-handoff continuation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "handoff_id",
    "from_stage",
    "to_stage",
    "stage_contract_id",
    "required_state",
    "state_snapshot_ref",
    "validation_rules",
    "created_at",
    "trace"
  ],
  "properties": {
    "artifact_type": {"const": "handoff_artifact"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "handoff_id": {"type": "string", "minLength": 1},
    "from_stage": {"type": "string", "minLength": 1},
    "to_stage": {"type": "string", "minLength": 1},
    "stage_contract_id": {"type": "string", "minLength": 1},
    "required_state": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "state_snapshot_ref": {"type": "string", "minLength": 1},
    "validation_rules": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "created_at": {"type": "string", "format": "date-time"},
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trace_id", "agent_run_id"],
      "properties": {
        "trace_id": {"type": "string", "minLength": 1},
        "agent_run_id": {"type": "string", "minLength": 1},
        "span_id": {"type": "string", "minLength": 1}
      }
    },
    "parent_checkpoint_id": {"type": "string", "minLength": 1}
  }
}
