{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/replay_result.schema.json",
  "title": "Replay Result",
  "description": "Deterministic BAG replay artifact for canonical control-loop + enforcement re-execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "replay_id",
    "original_run_id",
    "replay_run_id",
    "timestamp",
    "trace_id",
    "input_artifact_reference",
    "original_decision_reference",
    "original_enforcement_reference",
    "replay_decision_reference",
    "replay_enforcement_reference",
    "replay_decision",
    "replay_enforcement_action",
    "replay_final_status",
    "original_enforcement_action",
    "original_final_status",
    "consistency_status",
    "drift_detected",
    "failure_reason",
    "replay_path",
    "provenance"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifact_type": {
      "type": "string",
      "const": "replay_result"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1,
      "const": "1.2.0"
    },
    "replay_id": {
      "type": "string",
      "minLength": 1
    },
    "original_run_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!unknown(?:-|$))[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "replay_run_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!unknown(?:-|$))[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^(?!unknown(?:-|$))[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "input_artifact_reference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!unknown(?:-|$))[a-z_]+:[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "original_decision_reference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!unknown(?:-|$))[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "original_enforcement_reference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!unknown(?:-|$))[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "replay_decision_reference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!unknown(?:-|$))[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "replay_enforcement_reference": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!unknown(?:-|$))[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "replay_decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "require_review"
      ]
    },
    "replay_enforcement_action": {
      "type": "string",
      "enum": [
        "allow_execution",
        "deny_execution",
        "require_manual_review"
      ]
    },
    "replay_final_status": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "require_review"
      ]
    },
    "original_enforcement_action": {
      "type": "string",
      "enum": [
        "allow_execution",
        "deny_execution",
        "require_manual_review"
      ]
    },
    "original_final_status": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "require_review"
      ]
    },
    "consistency_status": {
      "type": "string",
      "enum": [
        "match",
        "mismatch",
        "indeterminate"
      ]
    },
    "drift_detected": {
      "type": "boolean"
    },
    "failure_reason": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "replay_path": {
      "type": "string",
      "const": "bag_replay_engine"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_artifact_type",
        "source_artifact_id",
        "trace_id"
      ],
      "properties": {
        "source_artifact_type": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!unknown(?:-|$))[a-z_][a-z0-9_]*$"
        },
        "source_artifact_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!unknown(?:-|$))[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "trace_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 128,
          "pattern": "^(?!unknown(?:-|$))[A-Za-z0-9][A-Za-z0-9._:-]*$"
        }
      }
    },
    "drift_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drift_result_id",
        "source_run_id",
        "replay_run_id",
        "drift_detected",
        "drift_type",
        "comparison_fields",
        "original_values",
        "replay_values",
        "drift_severity",
        "detection_timestamp",
        "provenance"
      ],
      "properties": {
        "drift_result_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "source_run_id": {
          "type": "string",
          "minLength": 1
        },
        "replay_run_id": {
          "type": "string",
          "minLength": 1
        },
        "drift_detected": {
          "type": "boolean"
        },
        "drift_type": {
          "type": "string",
          "enum": [
            "none",
            "status_mismatch",
            "action_mismatch",
            "missing_original",
            "missing_replay",
            "indeterminate"
          ]
        },
        "comparison_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "final_status",
              "enforcement_action"
            ]
          },
          "minItems": 2,
          "maxItems": 2
        },
        "original_values": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "final_status",
            "enforcement_action"
          ],
          "properties": {
            "final_status": {
              "type": [
                "string",
                "null"
              ]
            },
            "enforcement_action": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "replay_values": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "final_status",
            "enforcement_action"
          ],
          "properties": {
            "final_status": {
              "type": [
                "string",
                "null"
              ]
            },
            "enforcement_action": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "drift_severity": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "detection_timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "trace_id",
            "run_id"
          ],
          "properties": {
            "trace_id": {
              "type": "string",
              "minLength": 1
            },
            "run_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "description": "Optional deterministic drift classification attached to replay_result."
    },
    "drift_detection_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "schema_version",
        "timestamp",
        "trace_refs",
        "run_id",
        "policy_id",
        "baseline_id",
        "baseline_source",
        "comparison_target_id",
        "comparison_target_type",
        "drift_status",
        "compared_dimensions",
        "metrics",
        "triggered_thresholds",
        "reasons",
        "generated_by_version"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "artifact_type": {
          "type": "string",
          "const": "drift_detection_result"
        },
        "schema_version": {
          "type": "string",
          "const": "1.1.0"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "trace_refs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "trace_id"
          ],
          "properties": {
            "trace_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "baseline_id": {
          "type": "string",
          "minLength": 1
        },
        "baseline_source": {
          "type": "string",
          "enum": [
            "approved_replay_baseline",
            "approved_release_baseline"
          ]
        },
        "comparison_target_id": {
          "type": "string",
          "minLength": 1
        },
        "comparison_target_type": {
          "type": "string",
          "enum": [
            "replay_result"
          ]
        },
        "drift_status": {
          "type": "string",
          "enum": [
            "no_drift",
            "within_threshold",
            "exceeds_threshold",
            "invalid_comparison"
          ]
        },
        "compared_dimensions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "type": "string",
            "enum": [
              "final_status_delta",
              "enforcement_action_delta",
              "consistency_mismatch_delta",
              "drift_detected_delta",
              "failure_reason_present_delta"
            ]
          },
          "uniqueItems": true
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "final_status_delta",
            "enforcement_action_delta",
            "consistency_mismatch_delta",
            "drift_detected_delta",
            "failure_reason_present_delta"
          ],
          "properties": {
            "final_status_delta": {
              "type": "number",
              "minimum": 0
            },
            "enforcement_action_delta": {
              "type": "number",
              "minimum": 0
            },
            "consistency_mismatch_delta": {
              "type": "number",
              "minimum": 0
            },
            "drift_detected_delta": {
              "type": "number",
              "minimum": 0
            },
            "failure_reason_present_delta": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "triggered_thresholds": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "dimension",
              "severity",
              "value",
              "threshold"
            ],
            "properties": {
              "dimension": {
                "type": "string",
                "enum": [
                  "final_status_delta",
                  "enforcement_action_delta",
                  "consistency_mismatch_delta",
                  "drift_detected_delta",
                  "failure_reason_present_delta"
                ]
              },
              "severity": {
                "type": "string",
                "enum": [
                  "warn",
                  "block"
                ]
              },
              "value": {
                "type": "number",
                "minimum": 0
              },
              "threshold": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "generated_by_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "baseline_gate_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "timestamp",
        "trace_id",
        "run_id",
        "drift_result_id",
        "policy_id",
        "baseline_id",
        "status",
        "enforcement_action",
        "triggered_thresholds",
        "reasons",
        "generated_by_version"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "trace_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "drift_result_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "baseline_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "warn",
            "block"
          ]
        },
        "enforcement_action": {
          "type": "string",
          "enum": [
            "allow",
            "flag",
            "block_promotion"
          ]
        },
        "triggered_thresholds": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "dimension",
              "severity",
              "value",
              "threshold"
            ],
            "properties": {
              "dimension": {
                "type": "string",
                "enum": [
                  "final_status_delta",
                  "enforcement_action_delta",
                  "consistency_mismatch_delta",
                  "drift_detected_delta",
                  "failure_reason_present_delta"
                ]
              },
              "severity": {
                "type": "string",
                "enum": [
                  "warn",
                  "block"
                ]
              },
              "value": {
                "type": "number",
                "minimum": 0
              },
              "threshold": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "generated_by_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "observability_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "schema_version",
        "timestamp",
        "trace_refs",
        "measurement_scope",
        "run_ids",
        "source_artifact_ids",
        "metric_window",
        "metrics",
        "slo_id",
        "policy_id",
        "breach_summary",
        "generated_by_version"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "artifact_type": {
          "type": "string",
          "const": "observability_metrics"
        },
        "schema_version": {
          "type": "string",
          "const": "1.0.0"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "trace_refs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "trace_id"
          ],
          "properties": {
            "trace_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "measurement_scope": {
          "type": "string",
          "enum": [
            "single_replay_run",
            "batch_runtime_replay"
          ]
        },
        "run_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "source_artifact_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "metric_window": {
          "type": "string",
          "enum": [
            "single_run",
            "rolling_batch"
          ]
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "total_runs",
            "replay_success_rate"
          ],
          "properties": {
            "total_runs": {
              "type": "integer",
              "minimum": 1
            },
            "replay_success_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "grounding_block_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "unsupported_claim_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "invalid_evidence_ref_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "drift_exceed_threshold_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "baseline_gate_block_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "regression_failure_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "slo_id": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        },
        "policy_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "breach_summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "breached_metrics",
            "highest_severity",
            "reasons"
          ],
          "properties": {
            "breached_metrics": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "replay_success_rate",
                  "grounding_block_rate",
                  "unsupported_claim_rate",
                  "invalid_evidence_ref_rate",
                  "drift_exceed_threshold_rate",
                  "baseline_gate_block_rate",
                  "regression_failure_rate"
                ]
              },
              "uniqueItems": true
            },
            "highest_severity": {
              "type": "string",
              "enum": [
                "none",
                "warn",
                "block"
              ]
            },
            "reasons": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "generated_by_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "error_budget_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "schema_version",
        "timestamp",
        "trace_refs",
        "slo_id",
        "observability_metrics_id",
        "policy_id",
        "budget_window",
        "budget_status",
        "objectives",
        "highest_severity",
        "triggered_conditions",
        "reasons",
        "generated_by_version"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "artifact_type": {
          "type": "string",
          "const": "error_budget_status"
        },
        "schema_version": {
          "type": "string",
          "const": "1.0.0"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "trace_refs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "trace_id"
          ],
          "properties": {
            "trace_id": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "slo_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "observability_metrics_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "policy_id": {
          "type": "string",
          "minLength": 1
        },
        "budget_window": {
          "type": "string",
          "enum": [
            "single_run",
            "rolling_batch"
          ]
        },
        "budget_status": {
          "type": "string",
          "enum": [
            "healthy",
            "warning",
            "exhausted",
            "invalid"
          ]
        },
        "objectives": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "metric_name",
              "target_value",
              "observed_value",
              "allowed_error",
              "consumed_error",
              "remaining_error",
              "consumption_ratio",
              "status"
            ],
            "properties": {
              "metric_name": {
                "type": "string",
                "enum": [
                  "replay_success_rate",
                  "grounding_block_rate",
                  "unsupported_claim_rate",
                  "invalid_evidence_ref_rate",
                  "drift_exceed_threshold_rate",
                  "baseline_gate_block_rate",
                  "regression_failure_rate"
                ]
              },
              "target_value": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "observed_value": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "allowed_error": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "consumed_error": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "remaining_error": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "consumption_ratio": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "healthy",
                  "warning",
                  "exhausted",
                  "invalid"
                ]
              }
            }
          }
        },
        "highest_severity": {
          "type": "string",
          "enum": [
            "healthy",
            "warning",
            "exhausted",
            "invalid"
          ]
        },
        "triggered_conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "metric_name",
              "status",
              "consumption_ratio"
            ],
            "properties": {
              "metric_name": {
                "type": "string",
                "enum": [
                  "replay_success_rate",
                  "grounding_block_rate",
                  "unsupported_claim_rate",
                  "invalid_evidence_ref_rate",
                  "drift_exceed_threshold_rate",
                  "baseline_gate_block_rate",
                  "regression_failure_rate"
                ]
              },
              "status": {
                "type": "string",
                "enum": [
                  "warning",
                  "exhausted",
                  "invalid"
