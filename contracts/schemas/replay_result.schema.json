{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/replay_result.schema.json",
  "title": "Replay Result",
  "description": "Deterministic BAG replay artifact for canonical control-loop + enforcement re-execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "replay_id",
    "original_run_id",
    "replay_run_id",
    "timestamp",
    "trace_id",
    "input_artifact_reference",
    "original_decision_reference",
    "original_enforcement_reference",
    "replay_decision_reference",
    "replay_enforcement_reference",
    "replay_decision",
    "replay_enforcement_action",
    "replay_final_status",
    "original_enforcement_action",
    "original_final_status",
    "consistency_status",
    "drift_detected",
    "failure_reason",
    "replay_path",
    "provenance"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "replay_result"
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "replay_id": {
      "type": "string",
      "minLength": 1
    },
    "original_run_id": {
      "type": "string",
      "minLength": 1
    },
    "replay_run_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "input_artifact_reference": {
      "type": "string",
      "minLength": 1
    },
    "original_decision_reference": {
      "type": "string",
      "minLength": 1
    },
    "original_enforcement_reference": {
      "type": "string",
      "minLength": 1
    },
    "replay_decision_reference": {
      "type": "string",
      "minLength": 1
    },
    "replay_enforcement_reference": {
      "type": "string",
      "minLength": 1
    },
    "replay_decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "require_review"
      ]
    },
    "replay_enforcement_action": {
      "type": "string",
      "enum": [
        "allow_execution",
        "deny_execution",
        "require_manual_review"
      ]
    },
    "replay_final_status": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "require_review"
      ]
    },
    "original_enforcement_action": {
      "type": "string",
      "enum": [
        "allow_execution",
        "deny_execution",
        "require_manual_review"
      ]
    },
    "original_final_status": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "require_review"
      ]
    },
    "consistency_status": {
      "type": "string",
      "enum": [
        "match",
        "mismatch",
        "indeterminate"
      ]
    },
    "drift_detected": {
      "type": "boolean"
    },
    "failure_reason": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "replay_path": {
      "type": "string",
      "const": "bag_replay_engine"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_artifact_type",
        "source_artifact_id"
      ],
      "properties": {
        "source_artifact_type": {
          "type": "string",
          "minLength": 1
        },
        "source_artifact_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "drift_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "drift_result_id",
        "source_run_id",
        "replay_run_id",
        "drift_detected",
        "drift_type",
        "comparison_fields",
        "original_values",
        "replay_values",
        "drift_severity",
        "detection_timestamp",
        "provenance"
      ],
      "properties": {
        "drift_result_id": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "source_run_id": {
          "type": "string",
          "minLength": 1
        },
        "replay_run_id": {
          "type": "string",
          "minLength": 1
        },
        "drift_detected": {
          "type": "boolean"
        },
        "drift_type": {
          "type": "string",
          "enum": [
            "none",
            "status_mismatch",
            "action_mismatch",
            "missing_original",
            "missing_replay",
            "indeterminate"
          ]
        },
        "comparison_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "final_status",
              "enforcement_action"
            ]
          },
          "minItems": 2,
          "maxItems": 2
        },
        "original_values": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "final_status",
            "enforcement_action"
          ],
          "properties": {
            "final_status": {
              "type": [
                "string",
                "null"
              ]
            },
            "enforcement_action": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "replay_values": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "final_status",
            "enforcement_action"
          ],
          "properties": {
            "final_status": {
              "type": [
                "string",
                "null"
              ]
            },
            "enforcement_action": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "drift_severity": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "detection_timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "trace_id",
            "run_id"
          ],
          "properties": {
            "trace_id": {
              "type": "string",
              "minLength": 1
            },
            "run_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "description": "Optional deterministic drift classification attached to replay_result."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "consistency_status": {
            "const": "match"
          }
        },
        "required": [
          "consistency_status"
        ]
      },
      "then": {
        "properties": {
          "drift_detected": {
            "const": false
          },
          "failure_reason": {
            "const": null
          }
        },
        "required": [
          "drift_detected",
          "failure_reason"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "consistency_status": {
            "const": "mismatch"
          }
        },
        "required": [
          "consistency_status"
        ]
      },
      "then": {
        "properties": {
          "drift_detected": {
            "const": true
          },
          "failure_reason": {
            "const": null
          }
        },
        "required": [
          "drift_detected",
          "failure_reason"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "consistency_status": {
            "const": "indeterminate"
          }
        },
        "required": [
          "consistency_status"
        ]
      },
      "then": {
        "properties": {
          "drift_detected": {
            "const": false
          },
          "failure_reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "drift_detected",
          "failure_reason"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "consistency_status": {
            "const": "match"
          },
          "original_final_status": {
            "const": "allow"
          }
        },
        "required": [
          "consistency_status",
          "original_final_status"
        ]
      },
      "then": {
        "properties": {
          "replay_final_status": {
            "const": "allow"
          },
          "original_enforcement_action": {
            "const": "allow_execution"
          },
          "replay_enforcement_action": {
            "const": "allow_execution"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "consistency_status": {
            "const": "match"
          },
          "original_final_status": {
            "const": "deny"
          }
        },
        "required": [
          "consistency_status",
          "original_final_status"
        ]
      },
      "then": {
        "properties": {
          "replay_final_status": {
            "const": "deny"
          },
          "original_enforcement_action": {
            "const": "deny_execution"
          },
          "replay_enforcement_action": {
            "const": "deny_execution"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "consistency_status": {
            "const": "match"
          },
          "original_final_status": {
            "const": "require_review"
          }
        },
        "required": [
          "consistency_status",
          "original_final_status"
        ]
      },
      "then": {
        "properties": {
          "replay_final_status": {
            "const": "require_review"
          },
          "original_enforcement_action": {
            "const": "require_manual_review"
          },
          "replay_enforcement_action": {
            "const": "require_manual_review"
          }
        }
      }
    }
  ]
}
