{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems/contracts/global_invariant_check_record.schema.json",
  "title": "Global Invariant Check Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "trace_id",
    "run_id",
    "gate",
    "gate_status",
    "blocking_reasons",
    "requirements_satisfied",
    "authority_required"
  ],
  "properties": {
    "artifact_type": { "const": "global_invariant_check_record" },
    "schema_version": { "type": "string", "const": "1.0.0" },
    "trace_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "gate": { "type": "string", "enum": ["pipeline_exit", "phase_transition", "promotion_precheck", "promotion_gate"] },
    "gate_status": { "type": "string", "enum": ["pass", "fail", "indeterminate"] },
    "blocking_reasons": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "requirements_satisfied": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eval_present", "control_signal_present", "lineage_present", "schema_valid", "critical_eval_determinate"],
      "properties": {
        "eval_present": { "type": "boolean" },
        "control_signal_present": { "type": "boolean" },
        "lineage_present": { "type": "boolean" },
        "schema_valid": { "type": "boolean" },
        "critical_eval_determinate": { "type": "boolean" }
      }
    },
    "authority_required": { "type": "boolean", "const": true }
  }
}
