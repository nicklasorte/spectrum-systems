{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum.systems/contracts/schemas/strategic_knowledge_artifact_ref.schema.json",
  "title": "Strategic Knowledge Artifact Reference",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "source",
    "provenance",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": [
        "book_intelligence_pack",
        "transcript_intelligence_pack",
        "story_bank_entry",
        "tactic_register",
        "viewpoint_pack",
        "evidence_map"
      ]
    },
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "minLength": 1},
    "schema_version": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_type", "source_path"],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "source_type": {"type": "string", "enum": ["book_pdf", "transcript", "slide_deck"]},
        "source_path": {"type": "string", "minLength": 1}
      }
    },
    "provenance": {"$ref": "#/$defs/provenance"},
    "evidence_anchors": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence_anchor"},
      "minItems": 1
    }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extraction_run_id", "extractor_version"],
      "properties": {
        "extraction_run_id": {"type": "string", "minLength": 1},
        "extractor_version": {"type": "string", "minLength": 1},
        "notes": {"type": "string"}
      }
    },
    "evidence_anchor": {
      "type": "object",
      "oneOf": [
        {"$ref": "#/$defs/pdf_anchor"},
        {"$ref": "#/$defs/transcript_anchor"}
      ]
    },
    "pdf_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchor_type", "page_number"],
      "properties": {
        "anchor_type": {"const": "pdf"},
        "page_number": {"type": "integer", "minimum": 1},
        "text_span": {"type": "string"},
        "quote_snippet": {"type": "string"}
      }
    },
    "transcript_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchor_type", "timestamp_start", "timestamp_end"],
      "properties": {
        "anchor_type": {"const": "transcript"},
        "timestamp_start": {"type": "string", "pattern": "^[0-9]{2}:[0-9]{2}:[0-9]{2}$"},
        "timestamp_end": {"type": "string", "pattern": "^[0-9]{2}:[0-9]{2}:[0-9]{2}$"},
        "speaker": {"type": "string"},
        "quote_snippet": {"type": "string"}
      }
    }
  }
}
