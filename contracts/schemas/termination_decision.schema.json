{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "termination_decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "decision_id",
    "run_id",
    "trace_id",
    "decision",
    "reason_codes",
    "policy_version",
    "input_refs"
  ],
  "properties": {
    "artifact_type": {
      "const": "termination_decision"
    },
    "artifact_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "decision_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "complete",
        "continue",
        "repair_required",
        "freeze_required",
        "block_required",
        "await_async_signal"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "policy_version": {
      "type": "string"
    },
    "input_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "termination_signal_record_ref",
        "termination_policy_ref"
      ],
      "properties": {
        "termination_signal_record_ref": {
          "type": "string"
        },
        "termination_policy_ref": {
          "type": "string"
        },
        "bax_status_ref": {
          "type": "string"
        }
      }
    }
  }
}
