{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/normalized_execution_request.schema.json",
  "title": "Normalized Execution Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "request_id",
    "prompt_text",
    "execution_type",
    "repo_mutation_requested",
    "target_paths",
    "requested_outputs",
    "source_prompt_kind",
    "trace_id",
    "created_at",
    "produced_by"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "normalized_execution_request"},
    "request_id": {"type": "string", "minLength": 1},
    "prompt_text": {"type": "string", "minLength": 1},
    "execution_type": {"type": "string", "enum": ["repo_write", "read_only", "analysis_only", "unknown"]},
    "repo_mutation_requested": {"type": "boolean"},
    "target_paths": {"type": "array", "items": {"type": "string"}},
    "requested_outputs": {"type": "array", "items": {"type": "string"}},
    "source_prompt_kind": {"type": "string", "minLength": 1},
    "trace_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "produced_by": {"type": "string", "minLength": 1}
  }
}
