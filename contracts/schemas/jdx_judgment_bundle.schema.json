{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/jdx_judgment_bundle.schema.json",
  "title": "jdx_judgment_bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "created_at",
    "judgment_record_ref",
    "judgment_policy_ref",
    "judgment_eval_ref",
    "judgment_application_ref"
  ],
  "properties": {
    "artifact_type": {
      "const": "jdx_judgment_bundle"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "judgment_record_ref": {
      "type": "string"
    },
    "judgment_policy_ref": {
      "type": "string"
    },
    "judgment_eval_ref": {
      "type": "string"
    },
    "judgment_application_ref": {
      "type": "string"
    }
  }
}
