{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://spectrum-systems.org/contracts/formatted_paper_artifact.json",
  "title": "Formatted Paper Artifact",
  "description": "Final formatted publication-ready paper with rendering metadata.",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_id", "artifact_type", "content", "metadata"],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^FMT-[0-9a-f]{8}$"},
    "artifact_type": {"type": "string", "const": "formatted_paper_artifact"},
    "content": {
      "type": "string",
      "minLength": 100,
      "description": "Full formatted paper content (markdown or structured text)"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["title", "format_version"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "format_version": {"type": "string"},
        "word_count": {"type": "integer", "minimum": 0},
        "sections": {"type": "array", "items": {"type": "string"}},
        "created_at": {"type": "string"},
        "source_draft_id": {"type": "string"}
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "trace_id": {"type": "string"},
        "upstream_artifact_id": {"type": "string"},
        "created_at": {"type": "string"}
      }
    }
  }
}
