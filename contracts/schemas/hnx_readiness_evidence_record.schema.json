{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/hnx_readiness_evidence_record.schema.json",
  "title": "HNX Readiness Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "evidence_id",
    "run_id",
    "trace_id",
    "stage_contract_completeness",
    "replay_integrity_status",
    "readiness_findings",
    "recommended_control_posture",
    "non_authority_proof_refs",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "hnx_readiness_evidence_record"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "stage_contract_completeness": {
      "type": "boolean"
    },
    "replay_integrity_status": {
      "enum": [
        "consistent",
        "mismatch_detected"
      ]
    },
    "readiness_findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "recommended_control_posture": {
      "enum": [
        "normal_monitoring",
        "escalated_review_required"
      ]
    },
    "non_authority_proof_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
