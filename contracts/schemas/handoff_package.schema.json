{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/handoff_package.schema.json",
  "title": "Handoff Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "trace_id",
    "provenance",
    "created_at"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "handoff_package"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_system",
        "inputs"
      ],
      "properties": {
        "source_system": {
          "type": "string",
          "pattern": "^[A-Z0-9]{2,8}$"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "simulated": {
          "type": "boolean"
        }
      }
    },
    "record_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
