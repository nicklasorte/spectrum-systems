{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/interpretation_record.schema.json",
  "title": "interpretation_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "interpretation_id",
    "trace_id",
    "failure_packet_ref",
    "conflict_record_ref",
    "normalized_failure_class",
    "reason_code",
    "interpretation_notes",
    "ambiguity_score",
    "contains_material_conflict",
    "non_authority_assertions"
  ],
  "properties": {
    "artifact_type": {
      "const": "interpretation_record"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "interpretation_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "failure_packet_ref": {
      "type": "string",
      "pattern": "^failure_packet:.+"
    },
    "conflict_record_ref": {
      "type": "string",
      "pattern": "^interpretation_conflict_record:.+"
    },
    "normalized_failure_class": {
      "type": "string"
    },
    "reason_code": {
      "type": "string"
    },
    "interpretation_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "ambiguity_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "contains_material_conflict": {
      "type": "boolean"
    },
    "non_authority_assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
