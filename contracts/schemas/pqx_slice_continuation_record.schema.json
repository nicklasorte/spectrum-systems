{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pqx_slice_continuation_record.schema.json",
  "title": "PQX Slice Continuation Record",
  "description": "Canonical governed continuation artifact binding a completed prior PQX slice to the only admissible next slice in deterministic two-slice continuation flows.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "prior_step_id",
    "next_step_id",
    "prior_run_id",
    "prior_trace_id",
    "prior_slice_execution_record_ref",
    "prior_certification_ref",
    "prior_audit_bundle_ref",
    "continuation_status",
    "continuation_decision",
    "continuation_reasons",
    "created_at"
  ],
  "properties": {
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_type": {"type": "string", "const": "pqx_slice_continuation_record"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "prior_step_id": {"type": "string", "minLength": 1},
    "next_step_id": {"type": "string", "minLength": 1},
    "prior_run_id": {"type": "string", "minLength": 1},
    "prior_trace_id": {"type": "string", "minLength": 1},
    "prior_slice_execution_record_ref": {"type": "string", "minLength": 1},
    "prior_certification_ref": {"type": "string", "minLength": 1},
    "prior_audit_bundle_ref": {"type": "string", "minLength": 1},
    "continuation_status": {"type": "string", "enum": ["ready", "blocked"]},
    "continuation_decision": {"type": "string", "enum": ["allow", "block"]},
    "continuation_reasons": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "created_at": {"type": "string", "format": "date-time"}
  }
}
