{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "control_arbitration_reason_bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "schema_version",
    "bundle_id",
    "run_id",
    "trace_id",
    "reason_codes",
    "source_signals"
  ],
  "properties": {
    "artifact_type": {
      "const": "control_arbitration_reason_bundle"
    },
    "artifact_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "source_signals": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
