{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/test_asset_governance_record.schema.json",
  "title": "test_asset_governance_record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "test_asset_governance_record"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "standards_version": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner_system": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,8}$"
    },
    "asset_id": {
      "type": "string"
    },
    "freshness_status": {
      "type": "string",
      "enum": [
        "fresh",
        "stale"
      ]
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    },
    "required_path": {
      "type": "boolean"
    }
  },
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "trace_id",
    "created_at",
    "owner_system",
    "asset_id",
    "freshness_status",
    "last_verified_at",
    "required_path"
  ]
}
