{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "pr_number",
    "repo",
    "head_sha",
    "attempt_number",
    "max_attempts",
    "source_artifacts_used",
    "trace_refs",
    "reason_codes",
    "authority_scope",
    "failure_class",
    "affected_files",
    "next_action",
    "human_review_required"
  ],
  "properties": {
    "artifact_type": {
      "const": "pr_failure_normalization_packet"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "pr_number": {
      "type": "integer",
      "minimum": 1
    },
    "repo": {
      "type": "string"
    },
    "head_sha": {
      "type": "string"
    },
    "attempt_number": {
      "type": "integer",
      "enum": [
        1,
        2
      ]
    },
    "max_attempts": {
      "const": 2
    },
    "source_artifacts_used": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trace_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authority_scope": {
      "const": "observation_only"
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "authority_shape_violation",
        "authority_leak_guard_failure",
        "pytest_selection_missing",
        "schema_validation_failure",
        "contract_enforcement_failure",
        "missing_shard_artifact",
        "invalid_shard_artifact",
        "pr_gate_block",
        "dashboard_test_failure",
        "unknown_failure"
      ]
    },
    "affected_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_action": {
      "type": "string"
    },
    "human_review_required": {
      "type": "boolean"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/pr_failure_normalization_packet.schema.json",
  "title": "pr_failure_normalization_packet"
}
