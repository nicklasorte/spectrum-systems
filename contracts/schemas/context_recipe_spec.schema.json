{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/context_recipe_spec.schema.json",
  "title": "Context Recipe Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "recipe_id",
    "recipe_version",
    "required_sources"
  ],
  "properties": {
    "artifact_type": {
      "const": "context_recipe_spec"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "recipe_id": {
      "type": "string"
    },
    "recipe_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "required_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "optional_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
