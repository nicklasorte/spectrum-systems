{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/implementation_review_artifact.schema.json",
  "title": "Implementation Review Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "artifact_type",
    "schema_version",
    "cycle_id",
    "reviewer",
    "scope",
    "findings",
    "reviewed_at"
  ],
  "properties": {
    "artifact_id": {"type": "string"},
    "artifact_type": {"const": "implementation_review_artifact"},
    "schema_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "cycle_id": {"type": "string"},
    "reviewer": {"type": "string", "enum": ["claude", "codex"]},
    "scope": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["finding_id", "title", "severity", "category", "affected_paths"],
        "properties": {
          "finding_id": {"type": "string"},
          "title": {"type": "string"},
          "severity": {"type": "string", "enum": ["critical", "high", "medium", "low", "info"]},
          "category": {"type": "string", "enum": ["contract", "logic", "test", "docs", "security", "performance"]},
          "summary": {"type": "string"},
          "affected_paths": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "depends_on": {"type": "array", "items": {"type": "string"}},
          "fingerprint": {"type": "string"}
        }
      }
    },
    "reviewed_at": {"type": "string", "format": "date-time"}
  }
}
