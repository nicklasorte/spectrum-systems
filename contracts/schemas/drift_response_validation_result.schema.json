{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/drift_response_validation_result.schema.json",
  "title": "Drift Response Validation Result",
  "description": "VAL-09 deterministic validation artifact proving drift detection and control-response threshold behavior under progressive degradation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "validation_run_id",
    "drift_sequence",
    "detection_points",
    "control_responses",
    "threshold_crossings",
    "missed_detection",
    "delayed_response",
    "incorrect_response",
    "final_status"
  ],
  "properties": {
    "validation_run_id": { "type": "string", "pattern": "^VAL09-[A-F0-9]{12}$" },
    "drift_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "case_type", "run_index", "drift_detected", "drift_status"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "case_type": {
            "type": "string",
            "enum": ["gradual_drift_increase", "flat_no_drift_baseline"]
          },
          "run_index": { "type": "integer", "minimum": 0 },
          "drift_detected": { "type": "boolean" },
          "drift_status": {
            "type": "string",
            "enum": ["no_drift", "within_threshold", "exceeds_threshold", "invalid_comparison"]
          }
        }
      }
    },
    "detection_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "run_index", "signal_strength", "drift_status"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "run_index": { "type": "integer", "minimum": 0 },
          "signal_strength": { "type": "number", "minimum": 0 },
          "drift_status": {
            "type": "string",
            "enum": ["no_drift", "within_threshold", "exceeds_threshold", "invalid_comparison"]
          }
        }
      }
    },
    "control_responses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "run_index", "system_status", "system_response", "decision"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "run_index": { "type": "integer", "minimum": 0 },
          "system_status": {
            "type": "string",
            "enum": ["healthy", "warning", "exhausted", "blocked"]
          },
          "system_response": {
            "type": "string",
            "enum": ["allow", "warn", "freeze", "block", "fail_closed", "unexpected_allow"]
          },
          "decision": {
            "type": "string",
            "enum": ["allow", "deny", "require_review", "fail_closed"]
          }
        }
      }
    },
    "threshold_crossings": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "case_id",
          "threshold_type",
          "crossed",
          "expected_response",
          "actual_response",
          "response_on_time"
        ],
        "properties": {
          "case_id": { "type": "string", "enum": ["VAL09-B", "VAL09-C", "VAL09-E"] },
          "threshold_type": {
            "type": "string",
            "enum": ["warning_or_freeze", "severe", "insufficient_input_fail_closed"]
          },
          "crossed": { "type": "boolean" },
          "expected_response": {
            "type": "string",
            "enum": ["warn", "freeze", "block", "fail_closed"]
          },
          "actual_response": {
            "type": "string",
            "enum": ["warn", "freeze", "block", "fail_closed", "unexpected_allow"]
          },
          "response_on_time": { "type": "boolean" }
        }
      }
    },
    "missed_detection": { "type": "boolean" },
    "delayed_response": { "type": "boolean" },
    "incorrect_response": { "type": "boolean" },
    "final_status": { "type": "string", "enum": ["PASSED", "FAILED"] }
  }
}
