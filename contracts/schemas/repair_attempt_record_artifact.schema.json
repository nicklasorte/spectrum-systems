{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/repair_attempt_record_artifact.schema.json",
  "title": "Repair Attempt Record Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "attempt_id",
    "failure_id",
    "run_id",
    "attempt_number",
    "files_touched",
    "commands_run",
    "result_status",
    "trace_refs"
  ],
  "properties": {
    "artifact_type": {"type": "string", "const": "repair_attempt_record_artifact"},
    "schema_version": {"type": "string", "const": "1.0.0"},
    "attempt_id": {"type": "string", "minLength": 1},
    "failure_id": {"type": "string", "minLength": 1},
    "roadmap_id": {"type": ["string", "null"]},
    "run_id": {"type": "string", "minLength": 1},
    "attempt_number": {"type": "integer", "minimum": 1},
    "files_touched": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "commands_run": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "result_status": {"type": "string", "enum": ["tests_green", "tests_failed", "blocked", "escalated"]},
    "trace_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
