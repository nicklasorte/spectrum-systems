{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems/contracts/pqx_canary_evaluation_record.schema.json",
  "title": "PQX Canary Evaluation Record",
  "type": "object",
  "required": ["schema_version", "canary_id", "decision_ref", "evaluation_outcome", "observed_metrics", "failed_criteria", "scheduling_freeze", "frozen_paths", "created_at"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0.0"},
    "canary_id": {"type": "string", "minLength": 1},
    "decision_ref": {"type": "string", "minLength": 1},
    "evaluation_outcome": {"type": "string", "enum": ["pass", "fail"]},
    "observed_metrics": {"type": "object", "additionalProperties": {"type": "boolean"}},
    "failed_criteria": {"type": "array", "items": {"type": "string"}},
    "scheduling_freeze": {"type": "boolean"},
    "frozen_paths": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": false
}
