{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/roadmap_signal_artifact.schema.json",
  "title": "Roadmap Signal Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "signal_id",
    "failure_class",
    "recurrence_count",
    "recommended_hardening_action",
    "source_refs"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "roadmap_signal_artifact"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "signal_id": {
      "type": "string",
      "pattern": "^RMS-[a-f0-9]{20}$"
    },
    "failure_class": {
      "type": "string",
      "enum": [
        "schema_mismatch",
        "contract_registration_missing",
        "branch_policy_violation",
        "dependency_graph_violation",
        "test_expectation_drift",
        "unknown_failure"
      ]
    },
    "recurrence_count": {
      "type": "integer",
      "minimum": 1
    },
    "recommended_hardening_action": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
