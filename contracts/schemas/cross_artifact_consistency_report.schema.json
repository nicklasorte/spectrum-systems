{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/cross_artifact_consistency_report.schema.json",
  "title": "Cross Artifact Consistency Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "trace_id",
    "provenance",
    "created_at",
    "consistent",
    "checks"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "cross_artifact_consistency_report"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_system",
        "inputs"
      ],
      "properties": {
        "source_system": {
          "type": "string",
          "pattern": "^[A-Z0-9]{2,8}$"
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "simulated": {
          "type": "boolean"
        }
      }
    },
    "record_id": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "consistent": {
      "type": "boolean"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "ok",
          "reason_code"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          },
          "reason_code": {
            "type": "string"
          }
        }
      }
    }
  }
}
