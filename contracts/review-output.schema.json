{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/contracts/review-output.schema.json",
  "title": "Review Output",
  "description": "Canonical output format for review engines (e.g., working-paper-review-engine) to exchange findings and dispositions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_id",
    "artifact_version",
    "schema_version",
    "standards_version",
    "record_id",
    "run_id",
    "created_at",
    "created_by",
    "source_repo",
    "source_repo_version",
    "review_id",
    "review_type",
    "review_scope",
    "source_artifacts",
    "summary",
    "findings",
    "actions"
  ],
  "properties": {
    "artifact_type": {
      "type": "string",
      "const": "review_output",
      "description": "Canonical artifact type identifier."
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[A-Z0-9._-]+$",
      "description": "Stable identifier for this review artifact."
    },
    "artifact_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Version of this review instance for diffing and rollback."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the review-output schema."
    },
    "standards_version": {
      "type": "string",
      "const": "2026.03.0",
      "description": "Standards release version from contracts/standards-manifest.json."
    },
    "record_id": {
      "type": "string",
      "pattern": "^REC-[A-Z0-9._-]+$",
      "description": "Record identifier used for provenance and diffing."
    },
    "run_id": {
      "type": "string",
      "pattern": "^run-[A-Za-z0-9._-]+$",
      "description": "Deterministic run identifier for the workflow that produced this review."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when this review output was generated."
    },
    "created_by": {
      "$ref": "#/$defs/created_by"
    },
    "source_repo": {
      "type": "string",
      "description": "Repository slug that produced this review output."
    },
    "source_repo_version": {
      "type": "string",
      "description": "Tag or commit hash of the source repository."
    },
    "review_id": {
      "type": "string",
      "pattern": "^REV-[A-Z0-9._-]+$",
      "description": "Identifier for the review run."
    },
    "review_type": {
      "type": "string",
      "description": "Type of review (e.g., working paper, safety, policy)."
    },
    "review_scope": {
      "type": "string",
      "description": "Scope statement describing what was in bounds for this review."
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/input_artifact"
      },
      "description": "Artifacts inspected during the review."
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_status",
        "key_findings",
        "key_risks",
        "strengths"
      ],
      "properties": {
        "overall_status": {
          "type": "string",
          "enum": [
            "in_review",
            "changes_requested",
            "approved",
            "blocked"
          ]
        },
        "key_findings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "key_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "strengths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action_item"
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/attachment"
      }
    }
  },
  "$defs": {
    "created_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "agent_type"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "agent_type": {
          "type": "string",
          "enum": [
            "human",
            "ai_model",
            "workflow",
            "script"
          ]
        },
        "organization": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "input_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "artifact_type",
        "artifact_version",
        "role"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^[A-Z0-9._-]+$"
        },
        "artifact_type": {
          "type": "string"
        },
        "artifact_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "role": {
          "type": "string"
        },
        "source_repo": {
          "type": "string"
        },
        "source_repo_version": {
          "type": "string"
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "title",
        "description",
        "severity",
        "status",
        "location",
        "recommendation"
      ],
      "properties": {
        "finding_id": {
          "type": "string",
          "pattern": "^FND-[A-Z0-9._-]+$"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": [
            "critical",
            "major",
            "minor",
            "info"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "in_discussion",
            "accepted",
            "rejected",
            "resolved"
          ]
        },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifact_type",
            "reference"
          ],
          "properties": {
            "artifact_type": {
              "type": "string"
            },
            "reference": {
              "type": "string",
              "description": "Section, page, or anchor within the reviewed artifact."
            },
            "line_number": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "recommendation": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "evidence_links": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "related_comments": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "Related comment_id or matrix entry id."
          }
        }
      }
    },
    "action_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "description",
        "owner",
        "status"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "pattern": "^ACT-[A-Z0-9._-]+$"
        },
        "description": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "due_date": {
          "type": "string",
          "format": "date"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "in_progress",
            "complete",
            "blocked"
          ]
        },
        "related_finding": {
          "type": "string"
        }
      }
    },
    "attachment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "uri"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
