    "signal",
    "observation",
    "input",
    "recommendation",
    "finding",
    "evidence",
    "advisory",
    "request",
    "candidate",
    "hint",
    "summary",
    "report"
  ],
  "remediation_policy": {
    "modes": ["suggest-only", "apply-safe-renames"],
    "default_mode": "suggest-only",
    "unsafe_actions": [
      "modifying guard scripts",
      "adding exceptions",
      "renaming canonical owner artifacts",
      "suppressing diagnostics",
      "weakening fail-closed policy"
    ],
    "rename_targets": {
      "include_suffixes": [".py", ".json", ".md", ".yml", ".yaml", ".rst", ".txt"],
      "exclude_path_prefixes": [
        "spectrum_systems/modules/governance/",
        "scripts/run_authority_leak_guard.py",
        "scripts/authority_leak_rules.py",
        "scripts/authority_shape_detector.py",
