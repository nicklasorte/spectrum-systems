{
  "version": "1.0",
  "description": "Policy defining automated responses to governance violations detected by the cross-repo scanner.",
  "violation_classes": [
    {
      "class_name": "boundary_violation",
      "severity": "high",
      "auto_response": "notify",
      "notification_targets": [
        "governance-team",
        "repo-owner"
      ],
      "sla_hours": 48,
      "description": "Implementation code found in a governance-only repo boundary."
    },
    {
      "class_name": "schema_owner_mismatch",
      "severity": "medium",
      "auto_response": "notify",
      "notification_targets": [
        "governance-team"
      ],
      "sla_hours": 72,
      "description": "A schema file is claimed or modified by a system other than its declared owner."
    },
    {
      "class_name": "protected_authority_seam_write",
      "severity": "critical",
      "auto_response": "block",
      "notification_targets": [
        "governance-team",
        "repo-owner",
        "on-call"
      ],
      "sla_hours": 4,
      "description": "A PR modifies a protected authority seam file without governance approval."
    },
    {
      "class_name": "shadow_ownership_overlap",
      "severity": "high",
      "auto_response": "freeze",
      "notification_targets": [
        "governance-team",
        "repo-owner"
      ],
      "sla_hours": 24,
      "description": "A PR touches files with overlapping ownership, creating ambiguous authority."
    },
    {
      "class_name": "missing_done_certification",
      "severity": "high",
      "auto_response": "block",
      "notification_targets": [
        "governance-team",
        "pr-author"
      ],
      "sla_hours": 24,
      "description": "A PR is missing a required done_certification_record artifact."
    },
    {
      "class_name": "unsafe_vocabulary_in_guarded_path",
      "severity": "medium",
      "auto_response": "notify",
      "notification_targets": [
        "governance-team"
      ],
      "sla_hours": 72,
      "description": "A file in a guarded path (scripts/, src/) contains reserved vocabulary that may conflict with authority seam scanning."
    }
  ]
}
