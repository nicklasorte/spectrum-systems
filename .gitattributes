# .gitattributes — generated artifact merge policy
#
# Run-specific generated artifacts must NEVER be hand-merged across branches.
# Each match below is bound to the `generated-artifact` merge driver, which is
# documented in docs/generated-artifact-merge-policy.md and configured locally
# by `scripts/install_hooks.sh`.
#
# The driver keeps the current branch's version (`merge.generated-artifact.driver = true`),
# so Git stops emitting conflict markers in JSON outputs whose timestamps and
# trace IDs would otherwise diverge between parallel branches.
#
# After a merge that touches these paths, the operator MUST regenerate the
# artifacts via the script declared in `config/generated_artifact_policy.json`,
# or the CI guard (scripts/run_generated_artifact_git_guard.py) will fail.
#
# DO NOT broaden these globs to all JSON. Source-controlled schemas, contracts,
# canonical examples, review records, and roadmap manifests must continue to
# merge normally.

# Certification judgment 40-step explicit run state
artifacts/certification_judgment_40_explicit/*.json merge=generated-artifact

# Review fix loop 36-step explicit run state
artifacts/review_fix_loop_36_explicit/*.json merge=generated-artifact

# Baseline failure fix run state
artifacts/blf_01_baseline_failure_fix/*.json merge=generated-artifact

# Authenticity hardgate run state
artifacts/authenticity_hardgate_24_01/*.json merge=generated-artifact

# PQX execution slice records
artifacts/pqx_runs/**/*.json merge=generated-artifact

# RDX run traces
artifacts/rdx_runs/**/*.json merge=generated-artifact

# Dashboard metrics regenerated by build pipeline
artifacts/dashboard_metrics/*.json merge=generated-artifact
artifacts/dashboard_seed/*.json merge=generated-artifact

# Runtime execution outputs
artifacts/runtime/**/*.json merge=generated-artifact

# Transient test outputs
artifacts/test_tmp/**/*.json merge=generated-artifact
