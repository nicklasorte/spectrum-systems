{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectrum-systems.org/design-reviews/claude-review.schema.json",
  "title": "Claude Design Review Actions",
  "description": "Machine-readable action file produced with every Claude design review. Maps review findings to recommendations and concrete follow-up actions that automation can turn into GitHub issues, labels, and follow-up triggers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_metadata",
    "findings",
    "summary",
    "recommendations",
    "actions"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional self-describing schema reference."
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Version of the claude review actions schema."
    },
    "review_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_id",
        "review_date",
        "repository",
        "scope",
        "reviewer",
        "source_artifact"
      ],
      "properties": {
        "review_id": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+$",
          "description": "Deterministic slug matching the markdown filename."
        },
        "review_date": {
          "type": "string",
          "format": "date",
          "description": "Date the review was performed."
        },
        "repository": {
          "type": "string",
          "description": "Repository reviewed (owner/name)."
        },
        "scope": {
          "type": "string",
          "description": "Short description of the review focus."
        },
        "reviewer": {
          "type": "string",
          "description": "Reviewer or agent handle."
        },
        "source_artifact": {
          "type": "string",
          "description": "Relative path to the human-readable markdown review."
        },
        "actions_artifact": {
          "type": "string",
          "description": "Relative path to this actions file."
        },
        "source_commit": {
          "type": "string",
          "description": "Commit SHA or reference reviewed."
        },
        "inputs": {
          "type": "array",
          "description": "List of inputs consulted during the review.",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "category",
          "title",
          "description",
          "recommended_action",
          "files_affected",
          "create_issue"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F-[0-9]+$",
            "description": "Stable finding identifier referenced across artifacts."
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ],
            "description": "Impact classification for the finding."
          },
          "category": {
            "type": "string",
            "minLength": 1,
            "description": "Thematic grouping for the finding (e.g., governance, automation, process)."
          },
          "title": {
            "type": "string",
            "description": "Short label for the finding."
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the finding."
          },
          "recommended_action": {
            "description": "Remediation guidance for the finding.",
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            ]
          },
          "files_affected": {
            "description": "Paths or components impacted by this finding.",
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            ]
          },
          "create_issue": {
            "type": "boolean",
            "default": true,
            "description": "Whether automation should open a GitHub issue for this finding."
          },
          "suggested_issue_title": {
            "type": "string",
            "description": "Preferred GitHub issue title."
          },
          "suggested_labels": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Labels to apply when creating an issue."
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "Deprecated alias for suggested_labels."
          },
          "target_repo": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
            "description": "Optional override for the repository where the issue should be created."
          },
          "trigger": {
            "type": "string",
            "description": "Optional trigger or condition associated with this finding."
          },
          "follow_up_trigger": {
            "type": "string",
            "minLength": 1,
            "description": "Primary event or checkpoint that should prompt follow-up for this finding and can be mirrored into the review registry (e.g., after merge of related PR, next architecture review)."
          },
          "due_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Optional due date (YYYY-MM-DD) when this finding should be re-evaluated or closed; use this value for registry follow-up scheduling."
          }
        }
      },
      "description": "Automation-ready findings that can be turned into GitHub issues."
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executive_summary",
        "gaps",
        "risks"
      ],
      "properties": {
        "executive_summary": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "Key bullets summarizing the review."
        },
        "strengths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Validated positives that should be preserved."
        },
        "gaps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "statement"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^G[0-9]+$",
                "description": "Stable gap identifier referenced in markdown and actions."
              },
              "statement": {
                "type": "string",
                "description": "Gap statement."
              },
              "evidence": {
                "type": "string",
                "description": "Evidence or references supporting the gap."
              },
              "links": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uri"
                },
                "description": "Optional links that provide context."
              }
            }
          },
          "description": "Structural gaps identified in the review."
        },
        "risks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "statement",
              "severity",
              "likelihood"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^R[0-9]+$",
                "description": "Stable risk identifier referenced in markdown and actions."
              },
              "statement": {
                "type": "string",
                "description": "Risk statement."
              },
              "severity": {
                "type": "string",
                "enum": [
                  "critical",
                  "high",
                  "medium",
                  "low"
                ],
                "description": "Severity classification."
              },
              "likelihood": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ],
                "description": "Likelihood classification."
              },
              "rationale": {
                "type": "string",
                "description": "Reasoning for the severity and likelihood."
              },
              "related_gaps": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^G[0-9]+$"
                },
                "description": "Referenced gaps tied to this risk."
              }
            }
          },
          "description": "Risks highlighted during the review."
        }
      }
    },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "statement",
          "priority"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^REC-[0-9]+$",
            "description": "Recommendation identifier linked to the markdown review."
          },
          "statement": {
            "type": "string",
            "description": "Recommendation text."
          },
          "priority": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ],
            "description": "Priority classification per design-review-standard."
          },
          "expected_outcome": {
            "type": "string",
            "description": "Intended outcome when the recommendation is implemented."
          },
          "related_gaps": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^G[0-9]+$"
            },
            "description": "Gaps addressed by this recommendation."
          },
          "related_risks": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^R[0-9]+$"
            },
            "description": "Risks mitigated by this recommendation."
          }
        }
      },
      "description": "Recommendations mapped to identified gaps and risks."
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "description",
          "priority",
          "status",
          "source_recommendations",
          "target_repos",
          "acceptance_criteria"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^A-[0-9]+$",
            "description": "Action identifier matching the markdown review."
          },
          "title": {
            "type": "string",
            "description": "Short action label."
          },
          "description": {
            "type": "string",
            "description": "Detailed description of the action."
          },
          "priority": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ],
            "description": "Priority classification."
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "in_progress",
              "blocked",
              "done"
            ],
            "description": "Lifecycle state for automation."
          },
          "owners": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Suggested owners responsible for delivery."
          },
          "source_recommendations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^REC-[0-9]+$"
            },
            "description": "Recommendation IDs that produced this action."
          },
          "related_gaps": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^G[0-9]+$"
            },
            "description": "Gap IDs linked to this action."
          },
          "related_risks": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^R[0-9]+$"
            },
            "description": "Risk IDs linked to this action."
          },
          "target_repos": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
            },
            "description": "Repos where automation should file or update issues."
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Labels automation should apply when creating issues."
          },
          "expected_artifact": {
            "type": "string",
            "description": "Expected output (issue, PR, doc, tracker update)."
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "description": "Conditions that define completion."
          },
          "follow_up_trigger": {
            "type": "string",
            "minLength": 1,
            "description": "Primary event or checkpoint that should prompt a revisit of this action and should be mirrored into the review registry."
          },
          "due_date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "Due date for the action in YYYY-MM-DD format when a checkpoint is scheduled; use this for registry follow-up entries."
          },
          "blocking_dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "IDs of actions or work items that must complete first."
          },
          "follow_up_triggers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Secondary events that should trigger review or escalation, in addition to the primary follow_up_trigger."
          }
        }
      },
      "description": "Concrete, automation-ready actions derived from the review."
    },
    "follow_up": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "next_review_due": {
          "type": "string",
          "format": "date",
          "description": "Scheduled next review date."
        },
        "triggers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Events that should trigger the next review."
        }
      },
      "description": "Follow-up scheduling guidance."
    }
  }
}
